{
  "endpoints": {
    "FI.SYKE.Hydrology.Kafka": {
      "usage": [
        "producer"
      ],
      "protocol": "KAFKA",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "structured",
        "format": "application/cloudevents+json"
      },
      "protocoloptions": {
        "deployed": false,
        "options": {
          "topic": "syke-hydro",
          "key": "{station_id}"
        }
      },
      "messagegroups": [
        "#/messagegroups/FI.SYKE.Hydrology"
      ],
      "description": "Kafka producer endpoint for SYKE Hydrology CloudEvents on the `syke-hydro` topic keyed by `{station_id}`."
    },
    "FI.SYKE.Hydrology.Mqtt": {
      "usage": [
        "producer"
      ],
      "protocol": "MQTT/5.0",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "binary"
      },
      "protocoloptions": {
        "deployed": false,
        "endpoints": [
          {
            "uri": "mqtt://localhost:1883"
          }
        ]
      },
      "messagegroups": [
        "#/messagegroups/FI.SYKE.Hydrology.mqtt"
      ],
      "description": "MQTT 5 producer endpoint for syke-hydro CloudEvents using the documented UNS topic hierarchy."
    },
    "FI.SYKE.Hydrology.Amqp": {
      "usage": [
        "producer"
      ],
      "protocol": "AMQP/1.0",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "binary"
      },
      "protocoloptions": {
        "deployed": false,
        "endpoints": [
          {
            "uri": "amqps://localhost:5671/syke-hydro"
          }
        ]
      },
      "messagegroups": [
        "#/messagegroups/FI.SYKE.Hydrology.amqp"
      ],
      "description": "AMQP 1.0 producer endpoint for syke-hydro CloudEvents on the configured broker address."
    }
  },
  "messagegroups": {
    "FI.SYKE.Hydrology": {
      "messages": {
        "FI.SYKE.Hydrology.Station": {
          "name": "Station",
          "envelope": "CloudEvents/1.0",
          "envelopemetadata": {
            "type": {
              "value": "FI.SYKE.Hydrology.Station"
            },
            "source": {
              "value": "https://rajapinnat.ymparisto.fi"
            },
            "subject": {
              "value": "{station_id}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/FI.SYKE.Hydrology.jstruct/schemas/FI.SYKE.Hydrology.Station",
          "description": "A reference record for one Finnish hydrological monitoring station published by the Finnish Environment Institute (SYKE). It fires when the bridge publishes or refreshes the station catalog so consumers can interpret measurement events."
        },
        "FI.SYKE.Hydrology.WaterLevelObservation": {
          "name": "WaterLevelObservation",
          "envelope": "CloudEvents/1.0",
          "envelopemetadata": {
            "type": {
              "value": "FI.SYKE.Hydrology.WaterLevelObservation"
            },
            "source": {
              "value": "https://rajapinnat.ymparisto.fi"
            },
            "subject": {
              "value": "{station_id}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/FI.SYKE.Hydrology.jstruct/schemas/FI.SYKE.Hydrology.WaterLevelObservation",
          "description": "A current measurement from the Finnish Environment Institute (SYKE) for one monitoring site. It carries water level and discharge observations when the upstream feed reports a new or refreshed value."
        }
      },
      "description": "Events from SYKE Hydrology covering Finnish hydrological monitoring stations and their current measurements. Use the reference records to identify stations and the measurement records for the latest observations."
    },
    "FI.SYKE.Hydrology.mqtt": {
      "description": "MQTT 5 variant of syke-hydro events with UNS topics for wildcard subscribers.",
      "messages": {
        "FI.SYKE.Hydrology.mqtt.Station": {
          "name": "Station",
          "basemessageurl": "/messagegroups/FI.SYKE.Hydrology/messages/FI.SYKE.Hydrology.Station",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "topic_name": "hydro/fi/syke/syke-hydro/{basin}/{station_id}/info",
            "qos": 1,
            "retain": true
          }
        },
        "FI.SYKE.Hydrology.mqtt.WaterLevelObservation": {
          "name": "WaterLevelObservation",
          "basemessageurl": "/messagegroups/FI.SYKE.Hydrology/messages/FI.SYKE.Hydrology.WaterLevelObservation",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "topic_name": "hydro/fi/syke/syke-hydro/{basin}/{station_id}/water-level",
            "qos": 1,
            "retain": true
          }
        }
      }
    },
    "FI.SYKE.Hydrology.amqp": {
      "description": "AMQP 1.0 variant of syke-hydro events for queue-oriented consumers and Azure Service Bus.",
      "messages": {
        "FI.SYKE.Hydrology.amqp.Station": {
          "name": "Station",
          "basemessageurl": "/messagegroups/FI.SYKE.Hydrology/messages/FI.SYKE.Hydrology.Station",
          "protocol": "AMQP/1.0",
          "protocoloptions": {
            "properties": {
              "subject": {
                "type": "uritemplate",
                "value": "{station_id}",
                "description": "AMQP message subject matching the CloudEvent subject and Kafka key identity."
              }
            },
            "application-properties": {
              "basin": {
                "type": "uritemplate",
                "value": "{basin}",
                "description": "Routing property for AMQP subscription filters (basin)."
              }
            },
            "message-annotations": {
              "x-opt-partition-key": {
                "type": "uritemplate",
                "value": "{station_id}",
                "description": "Service Bus/Event Hubs partition key matching the stable CloudEvent subject."
              }
            }
          }
        },
        "FI.SYKE.Hydrology.amqp.WaterLevelObservation": {
          "name": "WaterLevelObservation",
          "basemessageurl": "/messagegroups/FI.SYKE.Hydrology/messages/FI.SYKE.Hydrology.WaterLevelObservation",
          "protocol": "AMQP/1.0",
          "protocoloptions": {
            "properties": {
              "subject": {
                "type": "uritemplate",
                "value": "{station_id}",
                "description": "AMQP message subject matching the CloudEvent subject and Kafka key identity."
              }
            },
            "application-properties": {
              "basin": {
                "type": "uritemplate",
                "value": "{basin}",
                "description": "Routing property for AMQP subscription filters (basin)."
              }
            },
            "message-annotations": {
              "x-opt-partition-key": {
                "type": "uritemplate",
                "value": "{station_id}",
                "description": "Service Bus/Event Hubs partition key matching the stable CloudEvent subject."
              }
            }
          }
        }
      }
    }
  },
  "schemagroups": {
    "FI.SYKE.Hydrology.jstruct": {
      "schemas": {
        "FI.SYKE.Hydrology.Station": {
          "name": "Station",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/extended/v0/#",
                "type": "object",
                "required": [
                  "station_id",
                  "name",
                  "latitude",
                  "longitude"
                ],
                "name": "Station",
                "properties": {
                  "station_id": {
                    "type": "string",
                    "altnames": {
                      "lang:fi": "Paikka_Id"
                    },
                    "description": "Stable identifier assigned by the upstream provider for the monitoring station or site."
                  },
                  "name": {
                    "type": "string",
                    "altnames": {
                      "lang:fi": "Nimi"
                    },
                    "description": "Human-readable name of the station, site, or location."
                  },
                  "river_name": {
                    "type": "string",
                    "altnames": {
                      "lang:fi": "PaaVesalNimi"
                    },
                    "description": "Name of the river or watercourse observed at the station."
                  },
                  "water_area_name": {
                    "type": "string",
                    "altnames": {
                      "lang:fi": "VesalNimi"
                    },
                    "description": "Human-readable name of the water area."
                  },
                  "municipality": {
                    "type": "string",
                    "altnames": {
                      "lang:fi": "KuntaNimi"
                    },
                    "description": "Provider-supplied municipality value for this record."
                  },
                  "latitude": {
                    "type": "double",
                    "description": "Latitude of the station in WGS 84 coordinates."
                  },
                  "longitude": {
                    "type": "double",
                    "description": "Longitude of the station in WGS 84 coordinates."
                  },
                  "basin": {
                    "type": "string",
                    "description": "Stable routing axis used by MQTT and AMQP transport templates for syke-hydro."
                  }
                },
                "$id": "https://example.com/schemas/FI/SYKE/Hydrology/Station",
                "description": "Reference details for one monitoring station or site in the SYKE Hydrology source."
              }
            }
          }
        },
        "FI.SYKE.Hydrology.WaterLevelObservation": {
          "name": "WaterLevelObservation",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/extended/v0/#",
                "type": "object",
                "required": [
                  "station_id"
                ],
                "name": "WaterLevelObservation",
                "properties": {
                  "station_id": {
                    "type": "string",
                    "altnames": {
                      "lang:fi": "Paikka_Id"
                    },
                    "description": "Stable identifier assigned by the upstream provider for the monitoring station or site."
                  },
                  "water_level": {
                    "type": [
                      "double",
                      "null"
                    ],
                    "description": "Water level reading value in centimetres. Null when the station does not report a water level in the current polling window.",
                    "altnames": {
                      "lang:fi": "Arvo"
                    }
                  },
                  "water_level_unit": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Unit of measurement for water_level. Constant 'cm' when present, null when water_level is null."
                  },
                  "water_level_timestamp": {
                    "type": [
                      "datetime",
                      "null"
                    ],
                    "description": "RFC3339 UTC timestamp (with 'Z' suffix) of the water level observation, derived from the SYKE 'Aika' field. Null when no water level is available.",
                    "altnames": {
                      "lang:fi": "Aika"
                    }
                  },
                  "discharge": {
                    "type": [
                      "double",
                      "null"
                    ],
                    "description": "Discharge (flow) reading value in cubic metres per second. Null for stations that do not measure discharge.",
                    "altnames": {
                      "lang:fi": "Arvo"
                    }
                  },
                  "discharge_unit": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Unit of measurement for discharge. Constant 'm3/s' when present, null when discharge is null."
                  },
                  "discharge_timestamp": {
                    "type": [
                      "datetime",
                      "null"
                    ],
                    "description": "RFC3339 UTC timestamp (with 'Z' suffix) of the discharge observation, derived from the SYKE 'Aika' field. Null when no discharge is available.",
                    "altnames": {
                      "lang:fi": "Aika"
                    }
                  },
                  "basin": {
                    "type": "string",
                    "description": "Stable routing axis used by MQTT and AMQP transport templates for syke-hydro."
                  }
                },
                "$id": "https://example.com/schemas/FI/SYKE/Hydrology/WaterLevelObservation",
                "description": "Measurement payload for water level and discharge observations in the SYKE Hydrology source."
              }
            }
          }
        }
      }
    },
    "FI.SYKE.Hydrology.avro": {
      "schemas": {
        "FI.SYKE.Hydrology.Station": {
          "name": "Station",
          "format": "Avro/1.11.3",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "Avro/1.11.3",
              "schema": {
                "type": "record",
                "name": "Station",
                "doc": "Reference details for one monitoring station or site in the SYKE Hydrology source.",
                "fields": [
                  {
                    "name": "station_id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "river_name",
                    "type": [
                      "null",
                      "string"
                    ],
                    "default": null
                  },
                  {
                    "name": "water_area_name",
                    "type": [
                      "null",
                      "string"
                    ],
                    "default": null
                  },
                  {
                    "name": "municipality",
                    "type": [
                      "null",
                      "string"
                    ],
                    "default": null
                  },
                  {
                    "name": "latitude",
                    "type": "double"
                  },
                  {
                    "name": "longitude",
                    "type": "double"
                  }
                ],
                "namespace": "FI.SYKE.Hydrology",
                "description": "Reference details for one monitoring station or site in the SYKE Hydrology source."
              }
            }
          }
        },
        "FI.SYKE.Hydrology.WaterLevelObservation": {
          "name": "WaterLevelObservation",
          "format": "Avro/1.11.3",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "Avro/1.11.3",
              "schema": {
                "type": "record",
                "name": "WaterLevelObservation",
                "doc": "Measurement payload for observations in the SYKE Hydrology source.",
                "fields": [
                  {
                    "name": "station_id",
                    "type": "string"
                  },
                  {
                    "name": "water_level",
                    "type": [
                      "null",
                      "double"
                    ],
                    "default": null
                  },
                  {
                    "name": "water_level_unit",
                    "type": [
                      "null",
                      "string"
                    ],
                    "default": null
                  },
                  {
                    "name": "water_level_timestamp",
                    "type": [
                      "null",
                      {
                        "type": "string",
                        "logicalType": "timestamp-millis"
                      }
                    ],
                    "default": null
                  },
                  {
                    "name": "discharge",
                    "type": [
                      "null",
                      "double"
                    ],
                    "default": null
                  },
                  {
                    "name": "discharge_unit",
                    "type": [
                      "null",
                      "string"
                    ],
                    "default": null
                  },
                  {
                    "name": "discharge_timestamp",
                    "type": [
                      "null",
                      {
                        "type": "string",
                        "logicalType": "timestamp-millis"
                      }
                    ],
                    "default": null
                  }
                ],
                "namespace": "FI.SYKE.Hydrology",
                "description": "Measurement payload for observations in the SYKE Hydrology source."
              }
            }
          }
        }
      }
    }
  },
  "description": "SYKE Hydrology publishes water level and discharge observations from the Finnish Environment Institute (SYKE) for Finnish hydrological monitoring stations. These events let consumers build real-time monitoring, alerting, and operational dashboards without polling the upstream API directly.",
  "documentation": {
    "description": "Source documentation for SYKE Hydrology, including upstream API context and bridge deployment notes.",
    "url": "README.md"
  }
}
