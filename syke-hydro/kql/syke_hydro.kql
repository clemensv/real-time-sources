.create-merge table [_cloudevents_dispatch] (
    [specversion]: string,
    [type]: string,
    [source]: string,
    [id]: string,
    [time]: datetime,
    [subject]: string,
    [datacontenttype]: string,
    [dataschema]: string,
    [data]: dynamic
);

.create-or-alter table [_cloudevents_dispatch] ingestion json mapping "_cloudevents_dispatch_json"
```
[
  {"column": "specversion", "path": "$.specversion"},
  {"column": "type", "path": "$.type"},
  {"column": "source", "path": "$.source"},
  {"column": "id", "path": "$.id"},
  {"column": "time", "path": "$.time"},
  {"column": "subject", "path": "$.subject"},
  {"column": "datacontenttype", "path": "$.datacontenttype"},
  {"column": "dataschema", "path": "$.dataschema"},
  {"column": "data", "path": "$.data"}
]
```

.create-merge table ['fi.syke.hydrology.Station'] (
   [station_id]: string,
   [name]: string,
   [river_name]: string,
   [water_area_name]: string,
   [municipality]: string,
   [latitude]: real,
   [longitude]: real,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table ['fi.syke.hydrology.Station'] docstring "{\"description\": \"Station\"}";

.create-or-alter table ['fi.syke.hydrology.Station'] ingestion json mapping "fi.syke.hydrology.Station_json_flat"
```
[
  {"column": "___type", "path": "$.type"},
  {"column": "___source", "path": "$.source"},
  {"column": "___id", "path": "$.id"},
  {"column": "___time", "path": "$.time"},
  {"column": "___subject", "path": "$.subject"},
  {"column": "station_id", "path": "$.station_id"},
  {"column": "name", "path": "$.name"},
  {"column": "river_name", "path": "$.river_name"},
  {"column": "water_area_name", "path": "$.water_area_name"},
  {"column": "municipality", "path": "$.municipality"},
  {"column": "latitude", "path": "$.latitude"},
  {"column": "longitude", "path": "$.longitude"},
]
```

.create-or-alter table ['fi.syke.hydrology.Station'] ingestion json mapping "fi.syke.hydrology.Station_json_ce_structured"
```
[
  {"column": "___type", "path": "$.type"},
  {"column": "___source", "path": "$.source"},
  {"column": "___id", "path": "$.id"},
  {"column": "___time", "path": "$.time"},
  {"column": "___subject", "path": "$.subject"},
  {"column": "station_id", "path": "$.data.station_id"},
  {"column": "name", "path": "$.data.name"},
  {"column": "river_name", "path": "$.data.river_name"},
  {"column": "water_area_name", "path": "$.data.water_area_name"},
  {"column": "municipality", "path": "$.data.municipality"},
  {"column": "latitude", "path": "$.data.latitude"},
  {"column": "longitude", "path": "$.data.longitude"},
]
```

.drop materialized-view ['fi.syke.hydrology.StationLatest'] ifexists;

.create materialized-view with (backfill=true) ['fi.syke.hydrology.StationLatest'] on table ['fi.syke.hydrology.Station'] {
    ['fi.syke.hydrology.Station'] | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table ['fi.syke.hydrology.Station'] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'FI.SYKE.Hydrology.Station') | project['station_id'] = tostring(data.['station_id']),['name'] = tostring(data.['name']),['river_name'] = tostring(data.['river_name']),['water_area_name'] = tostring(data.['water_area_name']),['municipality'] = tostring(data.['municipality']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

