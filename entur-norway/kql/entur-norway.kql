  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'no.entur.DatedServiceJourney') | project['service_journey_id'] = tostring(data.['service_journey_id']),['operating_day'] = tostring(data.['operating_day']),['line_ref'] = tostring(data.['line_ref']),['operator_ref'] = tostring(data.['operator_ref']),['direction_ref'] = tostring(data.['direction_ref']),['vehicle_mode'] = tostring(data.['vehicle_mode']),['route_ref'] = tostring(data.['route_ref']),['published_line_name'] = tostring(data.['published_line_name']),['external_line_ref'] = tostring(data.['external_line_ref']),['origin_name'] = tostring(data.['origin_name']),['destination_name'] = tostring(data.['destination_name']),['data_source'] = tostring(data.['data_source']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

