   [validity_periods]: dynamic,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [PtSituationElement] docstring "{\"description\": \"Real-time transit disruption or service alert from the Entur SIRI-SX feed. Describes a published situation element such as a service disruption, delay cause, planned engineering work, or passenger information notice. Includes affected network elements, severity, textual descriptions, and validity periods. Sourced from GET /realtime/v1/rest/sx.\"}";

.alter table [PtSituationElement] column-docstrings (
   [situation_number]: "{\"description\": \"Unique situation identifier from the SIRI SituationNumber element. Used as the Kafka key. Example: RUT:SituationNumber:12345.\"}",
   [version]: "{\"description\": \"Version number of this situation record, from the SIRI Version element. Increments with each update to the same situation.\"}",
   [creation_time]: "{\"description\": \"ISO 8601 UTC timestamp when this situation was first created, from the SIRI CreationTime element.\"}",
   [source_type]: "{\"description\": \"Type of the originating source system from the SIRI Source/SourceType element.\"}",
   [source_name]: "{\"description\": \"Name of the originating source organisation from the SIRI Source/Name element.\"}",
   [progress]: "{\"description\": \"Publication progress state of this situation from the SIRI Progress element.\"}",
   [severity]: "{\"description\": \"SIRI Severity classification of the impact of this situation on passenger services.\"}",
   [keywords]: "{\"description\": \"Space-separated list of classification keywords from the SIRI Keywords element, used to categorise the situation type.\"}",
   [summary]: "{\"description\": \"Short public-facing summary text in Norwegian or English describing the situation, from the SIRI Summary element.\"}",
   [description]: "{\"description\": \"Full public-facing descriptive text in Norwegian or English providing details about the situation, from the SIRI Description element.\"}",
   [affects_line_refs]: "{\"description\": \"List of NeTEx LineRef values identifying the lines affected by this situation, extracted from Affects/Networks/AffectedNetwork/AffectedLine/LineRef elements.\", \"schema\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}, \"description\": \"List of NeTEx LineRef values identifying the lines affected by this situation, extracted from Affects/Networks/AffectedNetwork/AffectedLine/LineRef elements.\"}}",
   [affects_stop_point_refs]: "{\"description\": \"List of NSR StopPointRef values identifying the stop points affected by this situation, extracted from Affects/StopPoints/AffectedStopPoint/StopPointRef elements.\", \"schema\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}, \"description\": \"List of NSR StopPointRef values identifying the stop points affected by this situation, extracted from Affects/StopPoints/AffectedStopPoint/StopPointRef elements.\"}}",
   [validity_periods]: "{\"description\": \"One or more time windows during which this situation is active, from the SIRI ValidityPeriod elements.\", \"schema\": {\"type\": \"array\", \"items\": {\"$ref\": \"#/definitions/no/entur/ValidityPeriod\"}, \"description\": \"One or more time windows during which this situation is active, from the SIRI ValidityPeriod elements.\"}}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

