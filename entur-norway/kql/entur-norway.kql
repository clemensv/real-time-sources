.alter table [PtSituationElement] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'no.entur.PtSituationElement') | project['situation_number'] = tostring(data.['situation_number']),['version'] = tostring(data.['version']),['creation_time'] = todatetime(data.['creation_time']),['source_type'] = tostring(data.['source_type']),['source_name'] = tostring(data.['source_name']),['progress'] = tostring(data.['progress']),['severity'] = tostring(data.['severity']),['keywords'] = tostring(data.['keywords']),['summary'] = tostring(data.['summary']),['description'] = tostring(data.['description']),['affects_line_refs'] = todynamic(data.['affects_line_refs']),['affects_stop_point_refs'] = todynamic(data.['affects_stop_point_refs']),['validity_periods'] = todynamic(data.['validity_periods']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

