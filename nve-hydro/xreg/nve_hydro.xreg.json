{
  "endpoints": {
    "NO.NVE.Hydrology.Kafka": {
      "usage": [
        "producer"
      ],
      "protocol": "KAFKA",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "structured",
        "format": "application/cloudevents+json"
      },
      "protocoloptions": {
        "deployed": false,
        "options": {
          "topic": "nve-hydro",
          "key": "{station_id}"
        }
      },
      "messagegroups": [
        "#/messagegroups/NO.NVE.Hydrology"
      ]
    },
    "NO.NVE.Hydrology.Mqtt": {
      "usage": [
        "producer"
      ],
      "protocol": "MQTT/5.0",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "binary"
      },
      "protocoloptions": {
        "deployed": false,
        "endpoints": [
          {
            "uri": "mqtt://localhost:1883"
          }
        ]
      },
      "messagegroups": [
        "#/messagegroups/NO.NVE.Hydrology.mqtt"
      ]
    }
  },
  "messagegroups": {
    "NO.NVE.Hydrology": {
      "messages": {
        "NO.NVE.Hydrology.Station": {
          "name": "Station",
          "envelope": "CloudEvents/1.0",
          "envelopemetadata": {
            "type": {
              "value": "NO.NVE.Hydrology.Station"
            },
            "source": {
              "value": "https://hydapi.nve.no"
            },
            "subject": {
              "value": "{station_id}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/NO.NVE.Hydrology.jstruct/schemas/NO.NVE.Hydrology.Station"
        },
        "NO.NVE.Hydrology.WaterLevelObservation": {
          "name": "WaterLevelObservation",
          "envelope": "CloudEvents/1.0",
          "envelopemetadata": {
            "type": {
              "value": "NO.NVE.Hydrology.WaterLevelObservation"
            },
            "source": {
              "value": "https://hydapi.nve.no"
            },
            "subject": {
              "value": "{station_id}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/NO.NVE.Hydrology.jstruct/schemas/NO.NVE.Hydrology.WaterLevelObservation"
        }
      }
    },
    "NO.NVE.Hydrology.mqtt": {
      "description": "MQTT/5.0 transport variants of the NVE Hydrology CloudEvents, mapping each message to a retained, QoS-1 Unified Namespace topic under hydro/no/nve/nve-hydro/{river_name}/{station_id}/... The {river_name} placeholder is sourced from the NVE HydAPI station catalog field 'riverName' (Norwegian: 'Vassdrag', e.g. 'Glomma', 'Drammenselva') and normalized by the bridge to lowercase kebab-case before publishing so subscribers can wildcard whole rivers (e.g. hydro/no/nve/nve-hydro/glomma/+/water-level).",
      "messages": {
        "NO.NVE.Hydrology.mqtt.Station": {
          "name": "Station",
          "basemessageurl": "/messagegroups/NO.NVE.Hydrology/messages/NO.NVE.Hydrology.Station",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "topic_name": "hydro/no/nve/nve-hydro/{river_name}/{station_id}/info",
            "qos": 1,
            "retain": true
          }
        },
        "NO.NVE.Hydrology.mqtt.WaterLevelObservation": {
          "name": "WaterLevelObservation",
          "basemessageurl": "/messagegroups/NO.NVE.Hydrology/messages/NO.NVE.Hydrology.WaterLevelObservation",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "topic_name": "hydro/no/nve/nve-hydro/{river_name}/{station_id}/water-level",
            "qos": 1,
            "retain": true
          }
        }
      }
    }
  },
  "schemagroups": {
    "NO.NVE.Hydrology.jstruct": {
      "schemas": {
        "NO.NVE.Hydrology.Station": {
          "name": "Station",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/extended/v0/#",
                "type": "object",
                "required": [
                  "station_id",
                  "station_name",
                  "latitude",
                  "longitude"
                ],
                "name": "Station",
                "properties": {
                  "station_id": {
                    "type": "string"
                  },
                  "station_name": {
                    "type": "string"
                  },
                  "river_name": {
                    "type": "string"
                  },
                  "latitude": {
                    "type": "double"
                  },
                  "longitude": {
                    "type": "double"
                  },
                  "masl": {
                    "type": "double"
                  },
                  "council_name": {
                    "type": "string"
                  },
                  "county_name": {
                    "type": "string"
                  },
                  "drainage_basin_area": {
                    "type": "double"
                  }
                },
                "$id": "https://example.com/schemas/NO/NVE/Hydrology/Station",
                "description": "Station"
              }
            }
          }
        },
        "NO.NVE.Hydrology.WaterLevelObservation": {
          "name": "WaterLevelObservation",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/extended/v0/#",
                "type": "object",
                "required": [
                  "station_id",
                  "river_name"
                ],
                "name": "WaterLevelObservation",
                "properties": {
                  "station_id": {
                    "type": "string"
                  },
                  "river_name": {
                    "type": "string",
                    "description": "Name of the river the station observes (NVE HydAPI 'riverName' field, in Norwegian 'Vassdrag', e.g. 'Glomma', 'Drammenselva'). Sourced by the bridge from the station catalog (https://hydapi.nve.no/api/v1/Stations) and propagated onto every observation so subscribers do not need an out-of-band catalog join to route by river. Used as the {river_name} segment of the MQTT/UNS topic and normalized to lowercase kebab-case before publishing."
                  },
                  "water_level": {
                    "type": "double"
                  },
                  "water_level_unit": {
                    "type": "string"
                  },
                  "water_level_timestamp": {
                    "type": "datetime"
                  },
                  "discharge": {
                    "type": "double"
                  },
                  "discharge_unit": {
                    "type": "string"
                  },
                  "discharge_timestamp": {
                    "type": "datetime"
                  }
                },
                "$id": "https://example.com/schemas/NO/NVE/Hydrology/WaterLevelObservation",
                "description": "WaterLevelObservation"
              }
            }
          }
        }
      }
    },
    "NO.NVE.Hydrology.avro": {
      "schemas": {
        "NO.NVE.Hydrology.Station": {
          "name": "Station",
          "format": "Avro/1.11.3",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "Avro/1.11.3",
              "schema": {
                "type": "record",
                "name": "Station",
                "doc": "Station",
                "fields": [
                  {
                    "name": "station_id",
                    "type": "string"
                  },
                  {
                    "name": "station_name",
                    "type": "string"
                  },
                  {
                    "name": "river_name",
                    "type": [
                      "null",
                      "string"
                    ],
                    "default": null
                  },
                  {
                    "name": "latitude",
                    "type": "double"
                  },
                  {
                    "name": "longitude",
                    "type": "double"
                  },
                  {
                    "name": "masl",
                    "type": [
                      "null",
                      "double"
                    ],
                    "default": null
                  },
                  {
                    "name": "council_name",
                    "type": [
                      "null",
                      "string"
                    ],
                    "default": null
                  },
                  {
                    "name": "county_name",
                    "type": [
                      "null",
                      "string"
                    ],
                    "default": null
                  },
                  {
                    "name": "drainage_basin_area",
                    "type": [
                      "null",
                      "double"
                    ],
                    "default": null
                  }
                ],
                "namespace": "NO.NVE.Hydrology"
              }
            }
          }
        },
        "NO.NVE.Hydrology.WaterLevelObservation": {
          "name": "WaterLevelObservation",
          "format": "Avro/1.11.3",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "Avro/1.11.3",
              "schema": {
                "type": "record",
                "name": "WaterLevelObservation",
                "doc": "WaterLevelObservation",
                "fields": [
                  {
                    "name": "station_id",
                    "type": "string"
                  },
                  {
                    "name": "river_name",
                    "type": "string",
                    "doc": "Name of the river the station observes (NVE HydAPI 'riverName' / Norwegian 'Vassdrag'). Sourced from the station catalog and propagated to telemetry so consumers can route by river without a separate catalog join."
                  },
                  {
                    "name": "water_level",
                    "type": [
                      "null",
                      "double"
                    ],
                    "default": null
                  },
                  {
                    "name": "water_level_unit",
                    "type": [
                      "null",
                      "string"
                    ],
                    "default": null
                  },
                  {
                    "name": "water_level_timestamp",
                    "type": [
                      "null",
                      {
                        "type": "string",
                        "logicalType": "timestamp-millis"
                      }
                    ],
                    "default": null
                  },
                  {
                    "name": "discharge",
                    "type": [
                      "null",
                      "double"
                    ],
                    "default": null
                  },
                  {
                    "name": "discharge_unit",
                    "type": [
                      "null",
                      "string"
                    ],
                    "default": null
                  },
                  {
                    "name": "discharge_timestamp",
                    "type": [
                      "null",
                      {
                        "type": "string",
                        "logicalType": "timestamp-millis"
                      }
                    ],
                    "default": null
                  }
                ],
                "namespace": "NO.NVE.Hydrology"
              }
            }
          }
        }
      }
    }
  }
}
