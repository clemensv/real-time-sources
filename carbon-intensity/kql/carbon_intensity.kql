.create-merge table [_cloudevents_dispatch] (
    [specversion]: string,
    [type]: string,
    [source]: string,
    [id]: string,
    [time]: datetime,
    [subject]: string,
    [datacontenttype]: string,
    [dataschema]: string,
    [data]: dynamic
);

.create-or-alter table [_cloudevents_dispatch] ingestion json mapping "_cloudevents_dispatch_json"
```
[
  {"column": "specversion", "path": "$.specversion"},
  {"column": "type", "path": "$.type"},
  {"column": "source", "path": "$.source"},
  {"column": "id", "path": "$.id"},
  {"column": "time", "path": "$.time"},
  {"column": "subject", "path": "$.subject"},
  {"column": "datacontenttype", "path": "$.datacontenttype"},
  {"column": "dataschema", "path": "$.dataschema"},
  {"column": "data", "path": "$.data"}
]
```

.create-merge table [Intensity] (
   [period_from]: datetime,
   [period_to]: datetime,
   [forecast]: int,
   [actual]: int,
   [index]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [Intensity] docstring "{\"description\": \"National half-hourly carbon intensity for the Great Britain electricity grid, published by National Grid ESO. Contains the forecast and actual carbon dioxide emission intensity in grams of CO2 per kilowatt-hour, along with a qualitative index band.\"}";

.alter table [Intensity] column-docstrings (
   [period_from]: "{\"description\": \"ISO 8601 UTC timestamp marking the start of the half-hour settlement period (e.g. 2026-04-06T09:30Z).\"}",
   [period_to]: "{\"description\": \"ISO 8601 UTC timestamp marking the end of the half-hour settlement period (e.g. 2026-04-06T10:00Z).\"}",
   [forecast]: "{\"description\": \"Forecast carbon intensity for this settlement period in grams of CO2 per kilowatt-hour (gCO2/kWh), computed ahead of real-time by National Grid ESO.\"}",
   [actual]: "{\"description\": \"Actual (metered) carbon intensity for this settlement period in grams of CO2 per kilowatt-hour (gCO2/kWh). May be null when the period has not yet completed.\"}",
   [index]: "{\"description\": \"Qualitative index band for the carbon intensity: one of 'very low', 'low', 'moderate', 'high', or 'very high'.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

.create-or-alter table [Intensity] ingestion json mapping "Intensity_json_flat"
```
[
  {"column": "___type", "path": "$.type"},
  {"column": "___source", "path": "$.source"},
  {"column": "___id", "path": "$.id"},
  {"column": "___time", "path": "$.time"},
  {"column": "___subject", "path": "$.subject"},
  {"column": "period_from", "path": "$.period_from"},
  {"column": "period_to", "path": "$.period_to"},
  {"column": "forecast", "path": "$.forecast"},
  {"column": "actual", "path": "$.actual"},
  {"column": "index", "path": "$.index"},
]
```

.create-or-alter table [Intensity] ingestion json mapping "Intensity_json_ce_structured"
```
[
  {"column": "___type", "path": "$.type"},
  {"column": "___source", "path": "$.source"},
  {"column": "___id", "path": "$.id"},
  {"column": "___time", "path": "$.time"},
  {"column": "___subject", "path": "$.subject"},
  {"column": "period_from", "path": "$.data.period_from"},
  {"column": "period_to", "path": "$.data.period_to"},
  {"column": "forecast", "path": "$.data.forecast"},
  {"column": "actual", "path": "$.data.actual"},
  {"column": "index", "path": "$.data.index"},
]
```

.drop materialized-view IntensityLatest ifexists;

.create materialized-view with (backfill=true) IntensityLatest on table Intensity {
    Intensity | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [Intensity] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'uk.org.carbonintensity.Intensity') | project['period_from'] = todatetime(data.['period_from']),['period_to'] = todatetime(data.['period_to']),['forecast'] = toint(data.['forecast']),['actual'] = toint(data.['actual']),['index'] = tostring(data.['index']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

.create-merge table [GenerationMix] (
   [period_from]: datetime,
   [period_to]: datetime,
   [biomass_pct]: real,
   [coal_pct]: real,
   [gas_pct]: real,
   [hydro_pct]: real,
   [imports_pct]: real,
   [nuclear_pct]: real,
   [oil_pct]: real,
   [other_pct]: real,
   [solar_pct]: real,
   [wind_pct]: real,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [GenerationMix] docstring "{\"description\": \"National half-hourly electricity generation fuel mix for Great Britain, published by National Grid ESO. Each field represents the percentage contribution of a specific fuel type to total generation during the settlement period.\"}";

.alter table [GenerationMix] column-docstrings (
   [period_from]: "{\"description\": \"ISO 8601 UTC timestamp marking the start of the half-hour settlement period.\"}",
   [period_to]: "{\"description\": \"ISO 8601 UTC timestamp marking the end of the half-hour settlement period.\"}",
   [biomass_pct]: "{\"description\": \"Percentage of electricity generated from biomass (wood pellets, energy crops, and other organic matter) during this settlement period.\"}",
   [coal_pct]: "{\"description\": \"Percentage of electricity generated from coal-fired power stations during this settlement period.\"}",
   [gas_pct]: "{\"description\": \"Percentage of electricity generated from natural gas (CCGT and OCGT) during this settlement period.\"}",
   [hydro_pct]: "{\"description\": \"Percentage of electricity generated from hydroelectric power stations during this settlement period.\"}",
   [imports_pct]: "{\"description\": \"Percentage of electricity supplied via interconnector imports from continental Europe and Ireland during this settlement period.\"}",
   [nuclear_pct]: "{\"description\": \"Percentage of electricity generated from nuclear power stations during this settlement period.\"}",
   [oil_pct]: "{\"description\": \"Percentage of electricity generated from oil-fired power stations during this settlement period.\"}",
   [other_pct]: "{\"description\": \"Percentage of electricity generated from other or unclassified fuel sources during this settlement period.\"}",
   [solar_pct]: "{\"description\": \"Percentage of electricity generated from solar photovoltaic installations during this settlement period.\"}",
   [wind_pct]: "{\"description\": \"Percentage of electricity generated from onshore and offshore wind turbines during this settlement period.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

