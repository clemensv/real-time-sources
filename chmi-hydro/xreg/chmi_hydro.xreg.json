                            "schema": {
                                "$schema": "http://json-schema.org/draft-07/schema#",
                                "type": "object",
                                "title": "WaterLevelObservation",
                                "namespace": "CZ.Gov.CHMI.Hydro",
                                "properties": {
                                    "station_id": { "type": "string", "description": "Station identifier" },
                                    "station_name": { "type": "string", "description": "Station name" },
                                    "stream_name": { "type": "string", "description": "River or stream name" },
                                    "water_level": { "type": "number", "description": "Water level in cm" },
                                    "water_level_timestamp": { "type": "string", "format": "date-time", "description": "Water level measurement timestamp" },
                                    "discharge": { "type": "number", "description": "Discharge (flow rate) in m³/s" },
                                    "discharge_timestamp": { "type": "string", "format": "date-time", "description": "Discharge measurement timestamp" },
                                    "water_temperature": { "type": "number", "description": "Water temperature in °C" },
                                    "water_temperature_timestamp": { "type": "string", "format": "date-time", "description": "Water temperature measurement timestamp" }
