.drop materialized-view StationLatest ifexists;

.create materialized-view with (backfill=true) StationLatest on table Station {
    Station | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [Station] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'CZ.Gov.CHMI.Hydro.Station') | project['station_id'] = tostring(data.['station_id']),['dbc'] = tostring(data.['dbc']),['station_name'] = tostring(data.['station_name']),['stream_name'] = tostring(data.['stream_name']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),['flood_level_1'] = toreal(data.['flood_level_1']),['flood_level_2'] = toreal(data.['flood_level_2']),['flood_level_3'] = toreal(data.['flood_level_3']),['flood_level_4'] = toreal(data.['flood_level_4']),['has_forecast'] = tobool(data.['has_forecast']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

