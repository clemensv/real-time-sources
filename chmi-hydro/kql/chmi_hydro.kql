.create-merge table [Station] (
   [station_id]: string,
   [dbc]: string,
   [station_name]: string,
   [stream_name]: string,
   [latitude]: real,
   [longitude]: real,
   [flood_level_1]: real,
   [flood_level_2]: real,
   [flood_level_3]: real,
   [flood_level_4]: real,
   [has_forecast]: bool,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [Station] docstring "{\"description\": \"Station\"}";

.create-or-alter table [Station] ingestion json mapping "Station_json_flat"
