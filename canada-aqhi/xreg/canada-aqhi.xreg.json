  "messagegroups": {
    "ca.gc.weather.aqhi": {
      "messages": {
        "ca.gc.weather.aqhi.Community": {
          "name": "Community",
          "envelope": "CloudEvents/1.0",
          "description": "Reference data for a Canadian Air Quality Health Index reporting community, including its stable CGNDB identifier and current upstream feed URLs.",
          "envelopemetadata": {
            "type": {
              "value": "ca.gc.weather.aqhi.Community"
            },
            "source": {
              "value": "https://dd.weather.gc.ca/today/air_quality/aqhi/",
              "type": "uritemplate"
            },
            "subject": {
              "value": "{province}/{community_name}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/ca.gc.weather.aqhi.jstruct/schemas/ca.gc.weather.aqhi.Community"
        },
        "ca.gc.weather.aqhi.Observation": {
          "name": "Observation",
          "envelope": "CloudEvents/1.0",
          "description": "Latest AQHI observation for a reporting community. Observations are published hourly and may include decimal AQHI values.",
          "envelopemetadata": {
            "type": {
              "value": "ca.gc.weather.aqhi.Observation"
            },
            "source": {
              "value": "https://dd.weather.gc.ca/today/air_quality/aqhi/",
              "type": "uritemplate"
            },
            "subject": {
              "value": "{province}/{community_name}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/ca.gc.weather.aqhi.jstruct/schemas/ca.gc.weather.aqhi.Observation"
        },
        "ca.gc.weather.aqhi.Forecast": {
          "name": "Forecast",
          "envelope": "CloudEvents/1.0",
          "description": "Public AQHI forecast for one of the four standard Canadian forecast periods published for an AQHI community.",
          "envelopemetadata": {
            "type": {
              "value": "ca.gc.weather.aqhi.Forecast"
            },
            "source": {
              "value": "https://dd.weather.gc.ca/today/air_quality/aqhi/",
              "type": "uritemplate"
            },
            "subject": {
              "value": "{province}/{community_name}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
