  "schemagroups": {
    "ca.gc.weather.aqhi.jstruct": {
      "schemas": {
        "ca.gc.weather.aqhi.Community": {
          "name": "Community",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/core/v0/#",
                "$id": "https://github.com/clemensv/real-time-sources/canada-aqhi/schemas/ca.gc.weather.aqhi.Community",
                "name": "Community",
                "$root": "#/definitions/ca/gc/weather/aqhi/Community",
                "definitions": {
                  "ca": {
                    "gc": {
                      "weather": {
                        "aqhi": {
                          "Community": {
                            "name": "Community",
                            "type": "object",
                            "description": "Reference record for an AQHI community from the official ECCC AQHI city lists. It links the public community name and province code to the CGNDB key and current XML feeds used by the bridge.",
                            "properties": {
                              "province": {
                                "type": "string",
                                "description": "Two-letter Canadian province or territory abbreviation resolved for the AQHI community.",
                                "pattern": "^[A-Z]{2}$"
                              },
                              "community_name": {
                                "type": "string",
                                "description": "English AQHI community name as published by Environment and Climate Change Canada."
                              },
                              "cgndb_code": {
                                "type": "string",
                                "description": "Five-character CGNDB community identifier published by Natural Resources Canada and referenced by ECCC AQHI feeds.",
                                "pattern": "^[A-Z0-9]{5}$"
                              },
                              "latitude": {
                                "type": "double",
                                "description": "Latitude of the AQHI community reference point in WGS84 decimal degrees.",
                                "minimum": -90,
                                "maximum": 90
                              },
                              "longitude": {
                                "type": "double",
                                "description": "Longitude of the AQHI community reference point in WGS84 decimal degrees.",
                                "minimum": -180,
                                "maximum": 180
                              },
                              "observation_url": {
                                "type": [
                                  "string",
                                  "null"
                                ],
                                "description": "Current XML observation feed URL for the AQHI community, or null when observations are not distributed for that community."
                              },
                              "forecast_url": {
                                "type": [
                                  "string",
                                  "null"
                                ],
                                "description": "Current XML forecast feed URL for the AQHI community, or null when a public forecast feed is not available."
                              }
                            },
                            "required": [
                              "province",
                              "community_name",
                              "cgndb_code",
                              "latitude",
                              "longitude"
                            ]
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "ca.gc.weather.aqhi.Observation": {
          "name": "Observation",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/core/v0/#",
                "$id": "https://github.com/clemensv/real-time-sources/canada-aqhi/schemas/ca.gc.weather.aqhi.Observation",
                "name": "Observation",
                "$root": "#/definitions/ca/gc/weather/aqhi/Observation",
                "definitions": {
                  "ca": {
                    "gc": {
                      "weather": {
                        "aqhi": {
                          "Observation": {
                            "name": "Observation",
                            "type": "object",
                            "description": "Latest AQHI observation for a reporting community. The value reflects short-term health risk from air pollution and may be null when the upstream feed has not published a value yet.",
                            "properties": {
                              "province": {
                                "type": "string",
                                "description": "Two-letter Canadian province or territory abbreviation resolved for the AQHI community.",
                                "pattern": "^[A-Z]{2}$"
                              },
                              "community_name": {
                                "type": "string",
                                "description": "English AQHI community name as published by Environment and Climate Change Canada."
                              },
                              "cgndb_code": {
                                "type": "string",
                                "description": "Five-character CGNDB community identifier published by Natural Resources Canada and referenced by ECCC AQHI feeds.",
                                "pattern": "^[A-Z0-9]{5}$"
                              },
                              "observation_datetime": {
                                "type": "string",
                                "description": "UTC timestamp of the AQHI observation in ISO 8601 format."
                              },
                              "aqhi": {
                                "type": [
                                  "double",
                                  "null"
                                ],
                                "description": "Observed AQHI value for the community. Observation feeds publish AQHI with decimal precision."
                              },
                              "aqhi_category": {
                                "type": "string",
                                "description": "Public AQHI health-risk category derived from the AQHI value.",
                                "enum": [
                                  "Low",
                                  "Moderate",
                                  "High",
                                  "Very High",
                                  "Unknown"
                                ]
                              }
                            },
                            "required": [
                              "province",
                              "community_name",
                              "cgndb_code",
                              "observation_datetime",
                              "aqhi_category"
                            ]
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "ca.gc.weather.aqhi.Forecast": {
          "name": "Forecast",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/core/v0/#",
                "$id": "https://github.com/clemensv/real-time-sources/canada-aqhi/schemas/ca.gc.weather.aqhi.Forecast",
                "name": "Forecast",
                "$root": "#/definitions/ca/gc/weather/aqhi/Forecast",
                "definitions": {
                  "ca": {
                    "gc": {
                      "weather": {
                        "aqhi": {
                          "Forecast": {
                            "name": "Forecast",
                            "type": "object",
                            "description": "Public AQHI forecast for a community and one of the four standard forecast periods published by ECCC.",
                            "properties": {
                              "province": {
                                "type": "string",
                                "description": "Two-letter Canadian province or territory abbreviation resolved for the AQHI community.",
                                "pattern": "^[A-Z]{2}$"
                              },
                              "community_name": {
                                "type": "string",
                                "description": "English AQHI community name as published by Environment and Climate Change Canada."
                              },
                              "cgndb_code": {
                                "type": "string",
                                "description": "Five-character CGNDB community identifier published by Natural Resources Canada and referenced by ECCC AQHI feeds.",
                                "pattern": "^[A-Z0-9]{5}$"
                              },
                              "publication_datetime": {
                                "type": "string",
                                "description": "UTC timestamp at which the public AQHI forecast bulletin was issued."
                              },
                              "forecast_date": {
                                "type": "string",
                                "description": "Forecast target date expressed as YYYYMMDD. Periods 1 and 2 use the bulletin issue date; periods 3 and 4 use the following day.",
                                "pattern": "^[0-9]{8}$"
                              },
                              "forecast_period": {
                                "type": "integer",
                                "description": "AQHI public forecast period number: 1 Today, 2 Tonight, 3 Tomorrow, 4 Tomorrow Night.",
                                "enum": [
                                  1,
                                  2,
                                  3,
                                  4
                                ]
                              },
                              "forecast_period_label": {
                                "type": "string",
                                "description": "English public label for the AQHI forecast period.",
                                "enum": [
                                  "Today",
                                  "Tonight",
                                  "Tomorrow",
                                  "Tomorrow Night"
                                ]
                              },
                              "aqhi": {
                                "type": [
                                  "integer",
                                  "null"
                                ],
                                "description": "Forecast AQHI value for the forecast period. Public forecasts are published as whole numbers."
                              },
                              "aqhi_category": {
                                "type": "string",
                                "description": "Public AQHI health-risk category derived from the forecast AQHI value.",
                                "enum": [
                                  "Low",
                                  "Moderate",
                                  "High",
                                  "Very High",
                                  "Unknown"
                                ]
                              }
                            },
                            "required": [
                              "province",
                              "community_name",
                              "cgndb_code",
                              "publication_datetime",
                              "forecast_date",
                              "forecast_period",
                              "forecast_period_label",
                              "aqhi_category"
                            ]
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
