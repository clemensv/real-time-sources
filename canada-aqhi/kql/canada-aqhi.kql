.drop materialized-view CommunityLatest ifexists;

.create materialized-view with (backfill=true) CommunityLatest on table Community {
    Community | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [Community] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'ca.gc.weather.aqhi.Community') | project['province'] = tostring(data.['province']),['community_name'] = tostring(data.['community_name']),['cgndb_code'] = tostring(data.['cgndb_code']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),['observation_url'] = tostring(data.['observation_url']),['forecast_url'] = tostring(data.['forecast_url']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

.create-merge table [Observation] (
   [province]: string,
   [community_name]: string,
   [cgndb_code]: string,
   [observation_datetime]: string,
   [aqhi]: real,
   [aqhi_category]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [Observation] docstring "{\"description\": \"Latest AQHI observation for a reporting community. The value reflects short-term health risk from air pollution and may be null when the upstream feed has not published a value yet.\"}";

.alter table [Observation] column-docstrings (
   [province]: "{\"description\": \"Two-letter Canadian province or territory abbreviation resolved for the AQHI community.\"}",
   [community_name]: "{\"description\": \"English AQHI community name as published by Environment and Climate Change Canada.\"}",
   [cgndb_code]: "{\"description\": \"Five-character CGNDB community identifier published by Natural Resources Canada and referenced by ECCC AQHI feeds.\"}",
   [observation_datetime]: "{\"description\": \"UTC timestamp of the AQHI observation in ISO 8601 format.\"}",
   [aqhi]: "{\"description\": \"Observed AQHI value for the community. Observation feeds publish AQHI with decimal precision.\"}",
   [aqhi_category]: "{\"description\": \"Public AQHI health-risk category derived from the AQHI value.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

