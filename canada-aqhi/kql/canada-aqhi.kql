.create-merge table [_cloudevents_dispatch] (
    [specversion]: string,
    [type]: string,
    [source]: string,
    [id]: string,
    [time]: datetime,
    [subject]: string,
    [datacontenttype]: string,
    [dataschema]: string,
    [data]: dynamic
);

.create-or-alter table [_cloudevents_dispatch] ingestion json mapping "_cloudevents_dispatch_json"
```
[
  {"column": "specversion", "path": "$.specversion"},
  {"column": "type", "path": "$.type"},
  {"column": "source", "path": "$.source"},
  {"column": "id", "path": "$.id"},
  {"column": "time", "path": "$.time"},
  {"column": "subject", "path": "$.subject"},
  {"column": "datacontenttype", "path": "$.datacontenttype"},
  {"column": "dataschema", "path": "$.dataschema"},
  {"column": "data", "path": "$.data"}
]
```

.create-merge table [Community] (
   [province]: string,
   [community_name]: string,
   [cgndb_code]: string,
   [latitude]: real,
   [longitude]: real,
   [observation_url]: string,
   [forecast_url]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [Community] docstring "{\"description\": \"Reference record for an AQHI community from the official ECCC AQHI city lists. It links the public community name and province code to the CGNDB key and current XML feeds used by the bridge.\"}";

.alter table [Community] column-docstrings (
   [province]: "{\"description\": \"Two-letter Canadian province or territory abbreviation resolved for the AQHI community.\"}",
   [community_name]: "{\"description\": \"English AQHI community name as published by Environment and Climate Change Canada.\"}",
   [cgndb_code]: "{\"description\": \"Five-character CGNDB community identifier published by Natural Resources Canada and referenced by ECCC AQHI feeds.\"}",
   [latitude]: "{\"description\": \"Latitude of the AQHI community reference point in WGS84 decimal degrees.\"}",
   [longitude]: "{\"description\": \"Longitude of the AQHI community reference point in WGS84 decimal degrees.\"}",
   [observation_url]: "{\"description\": \"Current XML observation feed URL for the AQHI community, or null when observations are not distributed for that community.\"}",
   [forecast_url]: "{\"description\": \"Current XML forecast feed URL for the AQHI community, or null when a public forecast feed is not available.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

.create-or-alter table [Community] ingestion json mapping "Community_json_flat"
```
[
  {"column": "___type", "path": "$.type"},
  {"column": "___source", "path": "$.source"},
  {"column": "___id", "path": "$.id"},
  {"column": "___time", "path": "$.time"},
  {"column": "___subject", "path": "$.subject"},
  {"column": "province", "path": "$.province"},
  {"column": "community_name", "path": "$.community_name"},
  {"column": "cgndb_code", "path": "$.cgndb_code"},
  {"column": "latitude", "path": "$.latitude"},
  {"column": "longitude", "path": "$.longitude"},
  {"column": "observation_url", "path": "$.observation_url"},
  {"column": "forecast_url", "path": "$.forecast_url"},
]
```

.create-or-alter table [Community] ingestion json mapping "Community_json_ce_structured"
```
[
  {"column": "___type", "path": "$.type"},
  {"column": "___source", "path": "$.source"},
  {"column": "___id", "path": "$.id"},
  {"column": "___time", "path": "$.time"},
  {"column": "___subject", "path": "$.subject"},
  {"column": "province", "path": "$.data.province"},
  {"column": "community_name", "path": "$.data.community_name"},
  {"column": "cgndb_code", "path": "$.data.cgndb_code"},
  {"column": "latitude", "path": "$.data.latitude"},
  {"column": "longitude", "path": "$.data.longitude"},
  {"column": "observation_url", "path": "$.data.observation_url"},
  {"column": "forecast_url", "path": "$.data.forecast_url"},
]
