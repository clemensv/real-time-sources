.create-merge table [NetworkStatus] (
   [callsign]: string,
   [update_timestamp]: datetime,
   [connected_clients]: int,
   [unique_users]: int,
   [pilot_count]: int,
   [controller_count]: int,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [NetworkStatus] docstring "{\"description\": \"Aggregate VATSIM network status snapshot emitted once per poll cycle, summarising connected client counts.\"}";

.alter table [NetworkStatus] column-docstrings (
   [callsign]: "{\"description\": \"Constant key value 'status' used to identify this network status record.\"}",
   [update_timestamp]: "{\"description\": \"UTC timestamp of the VATSIM data snapshot as reported by the data feed.\"}",
   [connected_clients]: "{\"description\": \"Total number of clients (pilots, controllers, observers) currently connected to the network.\"}",
   [unique_users]: "{\"description\": \"Number of unique VATSIM user IDs currently connected.\"}",
   [pilot_count]: "{\"description\": \"Number of pilots currently connected and flying.\"}",
   [controller_count]: "{\"description\": \"Number of controllers (including observers) currently connected and providing ATC services.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

