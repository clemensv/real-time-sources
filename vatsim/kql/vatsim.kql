.alter table [PilotPosition] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'net.vatsim.PilotPosition') | project['cid'] = toint(data.['cid']),['callsign'] = tostring(data.['callsign']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),['altitude'] = toint(data.['altitude']),['groundspeed'] = toint(data.['groundspeed']),['heading'] = toint(data.['heading']),['transponder'] = tostring(data.['transponder']),['qnh_mb'] = toint(data.['qnh_mb']),['flight_rules'] = tostring(data.['flight_rules']),['aircraft_short'] = tostring(data.['aircraft_short']),['departure'] = tostring(data.['departure']),['arrival'] = tostring(data.['arrival']),['route'] = tostring(data.['route']),['cruise_altitude'] = tostring(data.['cruise_altitude']),['pilot_rating'] = toint(data.['pilot_rating']),['last_updated'] = todatetime(data.['last_updated']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

.create-merge table [ControllerPosition] (
   [cid]: int,
   [callsign]: string,
   [frequency]: string,
   [facility]: int,
   [rating]: int,
   [text_atis]: string,
   [last_updated]: datetime,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [ControllerPosition] docstring "{\"description\": \"Current state and frequency of an air traffic controller or observer connected to the VATSIM virtual aviation network.\"}";

.alter table [ControllerPosition] column-docstrings (
   [cid]: "{\"description\": \"VATSIM Certificate Identifier (CID) \\u2014 unique numeric member ID.\"}",
   [callsign]: "{\"description\": \"Controller position callsign (e.g. 'EGLL_TWR', 'KJFK_APP').\"}",
   [frequency]: "{\"description\": \"Radio frequency the controller is operating on, in MHz with three decimal places (e.g. '118.500').\"}",
   [facility]: "{\"description\": \"VATSIM facility type code. 0 = Observer, 1 = Flight Service Station, 2 = Delivery, 3 = Ground, 4 = Tower, 5 = Approach/Departure, 6 = Center/Enroute.\"}",
   [rating]: "{\"description\": \"VATSIM ATC rating. 1 = OBS, 2 = S1, 3 = S2, 4 = S3, 5 = C1, 6 = C2, 7 = C3, 8 = I1, 9 = I2, 10 = I3, 11 = SUP, 12 = ADM.\"}",
   [text_atis]: "{\"description\": \"Controller information or ATIS text, with individual lines joined by newline characters. Null when the controller has not set any ATIS text.\"}",
   [last_updated]: "{\"description\": \"UTC timestamp of the last update received by the VATSIM data servers.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

.create-or-alter table [ControllerPosition] ingestion json mapping "ControllerPosition_json_flat"
