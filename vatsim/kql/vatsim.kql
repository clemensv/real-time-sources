.create-merge table [PilotPosition] (
   [cid]: int,
   [callsign]: string,
   [latitude]: real,
   [longitude]: real,
   [altitude]: int,
   [groundspeed]: int,
   [heading]: int,
   [transponder]: string,
   [qnh_mb]: int,
   [flight_rules]: string,
   [aircraft_short]: string,
   [departure]: string,
   [arrival]: string,
   [route]: string,
   [cruise_altitude]: string,
   [pilot_rating]: int,
   [last_updated]: datetime,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [PilotPosition] docstring "{\"description\": \"Current position, flight plan summary, and state of a pilot connected to the VATSIM virtual aviation network. Updated every 15 seconds at the source.\"}";

.alter table [PilotPosition] column-docstrings (
   [cid]: "{\"description\": \"VATSIM Certificate Identifier (CID) \\u2014 unique numeric member ID.\"}",
   [callsign]: "{\"description\": \"ATC-style callsign chosen by the pilot for this session (e.g. 'BAW123', 'N12345').\"}",
   [latitude]: "{\"description\": \"Aircraft latitude in decimal degrees (WGS-84). Positive is north.\"}",
   [longitude]: "{\"description\": \"Aircraft longitude in decimal degrees (WGS-84). Positive is east.\"}",
   [altitude]: "{\"description\": \"Indicated altitude of the aircraft in feet above mean sea level.\"}",
   [groundspeed]: "{\"description\": \"Ground speed of the aircraft in knots.\"}",
   [heading]: "{\"description\": \"Magnetic heading of the aircraft in degrees (0-359).\"}",
   [transponder]: "{\"description\": \"Four-digit transponder (squawk) code currently set by the pilot.\"}",
   [qnh_mb]: "{\"description\": \"Altimeter setting (QNH) in millibars / hectopascals as reported by the pilot client.\"}",
   [flight_rules]: "{\"description\": \"Flight rules filed in the flight plan: 'I' for Instrument Flight Rules, 'V' for Visual Flight Rules. Null if no flight plan is filed.\"}",
   [aircraft_short]: "{\"description\": \"ICAO aircraft type designator from the filed flight plan (e.g. 'B738', 'A320'). Null if no flight plan is filed.\"}",
   [departure]: "{\"description\": \"ICAO code of the departure airport from the filed flight plan. Null if no flight plan is filed.\"}",
   [arrival]: "{\"description\": \"ICAO code of the arrival airport from the filed flight plan. Null if no flight plan is filed.\"}",
   [route]: "{\"description\": \"Route string from the filed flight plan. Null if no flight plan is filed.\"}",
   [cruise_altitude]: "{\"description\": \"Planned cruise altitude or flight level from the filed flight plan (e.g. '36000' or 'FL350'). Null if no flight plan is filed.\"}",
   [pilot_rating]: "{\"description\": \"VATSIM pilot rating bitmask. 0 = New Member (P0), 1 = PPL, 3 = IR, 7 = CMEL, 15 = ATPL.\"}",
   [last_updated]: "{\"description\": \"UTC timestamp of the last position update received by the VATSIM data servers.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

