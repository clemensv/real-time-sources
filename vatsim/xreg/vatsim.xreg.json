      ]
    },
    "net.vatsim.Mqtt": {
      "usage": [
        "producer"
      ],
      "protocol": "MQTT/5.0",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "binary"
      },
      "deployed": false,
      "endpoints": [
        {
          "uri": "mqtt://localhost:1883"
        }
      ],
      "messagegroups": [
        "#/messagegroups/net.vatsim.mqtt"
      ]
    },
    "net.vatsim.Amqp": {
      "usage": [
        "producer"
      ],
      "protocol": "AMQP/1.0",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "binary"
      },
      "protocoloptions": {
        "deployed": false,
        "endpoints": [
          {
            "uri": "amqps://localhost:5671/vatsim"
          }
        ]
      },
      "messagegroups": [
        "#/messagegroups/net.vatsim.amqp"
      ],
      "description": "AMQP 1.0 producer endpoint for vatsim CloudEvents on the configured broker address."
    }
