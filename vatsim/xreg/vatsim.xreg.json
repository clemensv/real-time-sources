        }
      }
    },
    "net.vatsim.mqtt": {
      "description": "MQTT/5.0 transport variant for VATSIM live network data. Non-retained QoS-1 streams split pilots, controllers, and network facility status into distinct UNS topic branches under aviation-network/intl/vatsim/vatsim/...",
      "messages": {
        "net.vatsim.mqtt.PilotPosition": {
          "name": "PilotPosition",
          "basemessageurl": "/messagegroups/net.vatsim.pilots/messages/net.vatsim.PilotPosition",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "topic_name": "aviation-network/intl/vatsim/vatsim/pilots/{callsign}/pilot-position",
            "qos": 1,
            "retain": false
          }
        },
        "net.vatsim.mqtt.ControllerPosition": {
          "name": "ControllerPosition",
          "basemessageurl": "/messagegroups/net.vatsim.controllers/messages/net.vatsim.ControllerPosition",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "topic_name": "aviation-network/intl/vatsim/vatsim/controllers/{callsign}/controller-position",
            "qos": 1,
            "retain": false
          }
        },
        "net.vatsim.mqtt.FacilityStatus": {
          "name": "FacilityStatus",
          "basemessageurl": "/messagegroups/net.vatsim.status/messages/net.vatsim.NetworkStatus",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "topic_name": "aviation-network/intl/vatsim/vatsim/facilities/{facility}/facility-status",
            "qos": 1,
            "retain": false
          }
        }
      }
    },
    "net.vatsim.amqp": {
      "description": "AMQP 1.0 variant of the vatsim events. It carries the same source event semantics for brokers and services that consume AMQP messages.",
      "messages": {
        "net.vatsim.amqp.PilotPosition": {
          "name": "PilotPosition",
          "basemessageurl": "/messagegroups/net.vatsim.pilots/messages/net.vatsim.PilotPosition",
          "protocol": "AMQP/1.0",
          "protocoloptions": {
            "properties": {
              "subject": {
                "type": "uritemplate",
                "value": "{callsign}",
                "description": "AMQP message subject matching the CloudEvent subject and Kafka key identity for this event family."
              }
            },
            "application_properties": {}
          }
        },
        "net.vatsim.amqp.ControllerPosition": {
          "name": "ControllerPosition",
          "basemessageurl": "/messagegroups/net.vatsim.controllers/messages/net.vatsim.ControllerPosition",
          "protocol": "AMQP/1.0",
          "protocoloptions": {
            "properties": {
              "subject": {
                "type": "uritemplate",
                "value": "{callsign}",
                "description": "AMQP message subject matching the CloudEvent subject and Kafka key identity for this event family."
              }
            },
            "application_properties": {}
          }
        },
        "net.vatsim.amqp.FacilityStatus": {
          "name": "FacilityStatus",
          "basemessageurl": "/messagegroups/net.vatsim.status/messages/net.vatsim.NetworkStatus",
          "protocol": "AMQP/1.0",
          "protocoloptions": {
            "properties": {
              "subject": {
                "type": "uritemplate",
                "value": "{callsign}",
                "description": "AMQP message subject matching the CloudEvent subject and Kafka key identity for this event family."
              }
            },
            "application_properties": {
              "facility": {
                "type": "uritemplate",
                "value": "{facility}",
                "description": "Routing axis 'facility' copied from the source event so AMQP brokers and Service Bus subscriptions can filter without decoding the payload."
              }
            }
          }
        }
      }
    }
  },
  "schemagroups": {
    "net.vatsim.jstruct": {
      "schemas": {
        "net.vatsim.PilotPosition": {
          "name": "PilotPosition",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/core/v0/#",
                "$id": "https://example.com/schemas/net/vatsim/PilotPosition",
                "name": "PilotPosition",
                "$root": "#/definitions/net/vatsim/PilotPosition",
                "definitions": {
                  "net": {
                    "vatsim": {
                      "PilotPosition": {
                        "name": "PilotPosition",
                        "type": "object",
                        "description": "Current position, flight plan summary, and state of a pilot connected to the VATSIM virtual aviation network. Updated every 15 seconds at the source.",
                        "properties": {
                          "cid": {
                            "type": "int32",
                            "description": "VATSIM Certificate Identifier (CID) — unique numeric member ID."
                          },
                          "callsign": {
                            "type": "string",
                            "description": "ATC-style callsign chosen by the pilot for this session (e.g. 'BAW123', 'N12345')."
                          },
                          "latitude": {
                            "type": "double",
                            "description": "Aircraft latitude in decimal degrees (WGS-84). Positive is north.",
                            "unit": "degree",
                            "symbol": "°"
                          },
                          "longitude": {
                            "type": "double",
                            "description": "Aircraft longitude in decimal degrees (WGS-84). Positive is east.",
                            "unit": "degree",
                            "symbol": "°"
                          },
                          "altitude": {
                            "type": "int32",
                            "description": "Indicated altitude of the aircraft in feet above mean sea level.",
                            "unit": "foot",
                            "symbol": "ft"
                          },
                          "groundspeed": {
                            "type": "int32",
                            "description": "Ground speed of the aircraft in knots.",
                            "unit": "knot",
                            "symbol": "kn"
                          },
                          "heading": {
                            "type": "int32",
                            "description": "Magnetic heading of the aircraft in degrees (0-359).",
                            "unit": "degree",
                            "symbol": "°"
                          },
                          "transponder": {
                            "type": "string",
                            "description": "Four-digit transponder (squawk) code currently set by the pilot."
                          },
                          "qnh_mb": {
                            "type": "int32",
                            "description": "Altimeter setting (QNH) in millibars / hectopascals as reported by the pilot client.",
                            "unit": "millibar",
                            "symbol": "mb"
                          },
                          "flight_rules": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "description": "Flight rules filed in the flight plan: 'I' for Instrument Flight Rules, 'V' for Visual Flight Rules. Null if no flight plan is filed."
                          },
                          "aircraft_short": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "description": "ICAO aircraft type designator from the filed flight plan (e.g. 'B738', 'A320'). Null if no flight plan is filed."
                          },
                          "departure": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "description": "ICAO code of the departure airport from the filed flight plan. Null if no flight plan is filed."
                          },
                          "arrival": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "description": "ICAO code of the arrival airport from the filed flight plan. Null if no flight plan is filed."
                          },
                          "route": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "description": "Route string from the filed flight plan. Null if no flight plan is filed."
                          },
                          "cruise_altitude": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "description": "Planned cruise altitude or flight level from the filed flight plan (e.g. '36000' or 'FL350'). Null if no flight plan is filed."
                          },
                          "pilot_rating": {
                            "type": "int32",
                            "description": "VATSIM pilot rating bitmask. 0 = New Member (P0), 1 = PPL, 3 = IR, 7 = CMEL, 15 = ATPL."
                          },
                          "last_updated": {
                            "type": "string",
                            "description": "UTC timestamp of the last position update received by the VATSIM data servers (RFC3339 string)."
                          }
                        },
                        "required": [
                          "cid",
                          "callsign",
                          "latitude",
                          "longitude",
                          "altitude",
                          "groundspeed",
                          "heading",
                          "transponder",
                          "qnh_mb",
                          "pilot_rating",
                          "last_updated"
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "net.vatsim.ControllerPosition": {
          "name": "ControllerPosition",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/core/v0/#",
                "$id": "https://example.com/schemas/net/vatsim/ControllerPosition",
                "name": "ControllerPosition",
                "$root": "#/definitions/net/vatsim/ControllerPosition",
                "definitions": {
                  "net": {
                    "vatsim": {
                      "ControllerPosition": {
                        "name": "ControllerPosition",
                        "type": "object",
                        "description": "Current state and frequency of an air traffic controller or observer connected to the VATSIM virtual aviation network.",
                        "properties": {
                          "cid": {
                            "type": "int32",
                            "description": "VATSIM Certificate Identifier (CID) — unique numeric member ID."
                          },
                          "callsign": {
                            "type": "string",
                            "description": "Controller position callsign (e.g. 'EGLL_TWR', 'KJFK_APP')."
                          },
                          "frequency": {
                            "type": "string",
                            "description": "Radio frequency the controller is operating on, in MHz with three decimal places (e.g. '118.500')."
                          },
                          "facility": {
                            "type": "int32",
                            "description": "VATSIM facility type code. 0 = Observer, 1 = Flight Service Station, 2 = Delivery, 3 = Ground, 4 = Tower, 5 = Approach/Departure, 6 = Center/Enroute."
                          },
                          "rating": {
                            "type": "int32",
                            "description": "VATSIM ATC rating. 1 = OBS, 2 = S1, 3 = S2, 4 = S3, 5 = C1, 6 = C2, 7 = C3, 8 = I1, 9 = I2, 10 = I3, 11 = SUP, 12 = ADM."
                          },
                          "text_atis": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "description": "Controller information or ATIS text, with individual lines joined by newline characters. Null when the controller has not set any ATIS text."
                          },
                          "last_updated": {
                            "type": "string",
                            "description": "UTC timestamp of the last update received by the VATSIM data servers (RFC3339 string)."
                          }
                        },
                        "required": [
                          "cid",
                          "callsign",
                          "frequency",
                          "facility",
                          "rating",
                          "last_updated"
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "net.vatsim.NetworkStatus": {
          "name": "NetworkStatus",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/core/v0/#",
                "$id": "https://example.com/schemas/net/vatsim/NetworkStatus",
                "name": "NetworkStatus",
                "$root": "#/definitions/net/vatsim/NetworkStatus",
                "definitions": {
                  "net": {
                    "vatsim": {
                      "NetworkStatus": {
                        "name": "NetworkStatus",
                        "type": "object",
                        "description": "Aggregate VATSIM network status snapshot emitted once per poll cycle, summarising connected client counts.",
                        "properties": {
                          "callsign": {
                            "type": "string",
                            "description": "Constant key value 'status' used to identify this network status record."
                          },
                          "update_timestamp": {
                            "type": "string",
                            "description": "UTC timestamp of the VATSIM data snapshot as reported by the data feed (RFC3339 string)."
                          },
                          "connected_clients": {
                            "type": "int32",
                            "description": "Total number of clients (pilots, controllers, observers) currently connected to the network."
                          },
                          "unique_users": {
                            "type": "int32",
                            "description": "Number of unique VATSIM user IDs currently connected."
                          },
                          "pilot_count": {
                            "type": "int32",
                            "description": "Number of pilots currently connected and flying."
                          },
                          "controller_count": {
                            "type": "int32",
                            "description": "Number of controllers (including observers) currently connected and providing ATC services."
                          },
                          "facility": {
                            "type": "string",
                            "description": "UNS facility identifier for this aggregate VATSIM network status snapshot. The bridge emits 'network'."
                          }
                        },
                        "required": [
                          "callsign",
                          "facility",
                          "update_timestamp",
                          "connected_clients",
                          "unique_users",
                          "pilot_count",
                          "controller_count"
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
