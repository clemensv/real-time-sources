{
  "endpoints": {
    "net.vatsim.Kafka": {
      "usage": [
        "producer"
      ],
      "protocol": "KAFKA",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "structured",
        "format": "application/cloudevents+json"
      },
      "protocoloptions": {
        "deployed": false,
        "options": {
          "topic": "vatsim",
          "key": "{callsign}"
        }
      },
      "messagegroups": [
        "#/messagegroups/net.vatsim.pilots"
      ]
    },
    "net.vatsim.controllers.Kafka": {
      "usage": [
        "producer"
      ],
      "protocol": "KAFKA",
      "envelope": "CloudEvents/1.0",
