  "messagegroups": {
    "net.vatsim.pilots": {
      "messages": {
        "net.vatsim.PilotPosition": {
          "name": "PilotPosition",
          "envelope": "CloudEvents/1.0",
          "description": "Current position, flight plan summary, and state of a pilot connected to the VATSIM virtual aviation network.",
          "envelopemetadata": {
            "type": {
              "value": "net.vatsim.PilotPosition"
            },
            "source": {
              "value": "https://data.vatsim.net/v3/vatsim-data.json"
            },
            "subject": {
              "value": "{callsign}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/net.vatsim.jstruct/schemas/net.vatsim.PilotPosition"
        }
      }
    },
    "net.vatsim.controllers": {
