                "name": "OceanObservation",
                "type": "object",
                "description": "A single oceanographic measurement. parameter_id is one of: sealev_dvr (sea level vs DVR90 datum, cm; preferred since 1997), sealev_ln (sea level vs local zero, cm; preferred before 1997), sea_reg (sea-level registration by Kystdirektoratet, cm), tw (water temperature, deg C; indicative).",
                "required": ["station_id", "parameter_id", "observed", "value"],
                "properties": {
                  "observation_id": {
                    "type": ["string", "null"],
                    "description": "DMI-assigned row identifier (not stable across re-ingestions).",
                    "altnames": {"json": "id"}
                  },
                  "station_id": {
                    "type": "string",
                    "altnames": {"json": "stationId"}
                  },
                  "parameter_id": {
                    "type": "string",
                    "description": "One of sealev_dvr, sealev_ln, sea_reg, tw.",
                    "altnames": {"json": "parameterId"},
                    "altenums": {
                      "descriptions": {
                        "sealev_dvr": "Sea level relative to DVR90 datum (cm)",
                        "sealev_ln": "Sea level relative to local zero (cm)",
                        "sea_reg": "Sea level registration by Kystdirektoratet (cm)",
                        "tw": "Water temperature (deg C)"
                      }
                    }
                  },
                  "observed": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "value": {
                    "type": "double",
