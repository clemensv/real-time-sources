{
  "$schema": "https://xregistry.io/schema/xregistry_messaging_catalog.json",
  "specversion": "1.0-rc1",
  "documentation": "Danmarks Meteorologiske Institut (DMI) open-data triad: meteorological observations (metObs), oceanographic observations + tidewater predictions (oceanObs), and triangulated lightning strikes (lightningData). All payloads ride a single Kafka topic 'dmi' multiplexed by ce_type. The MQTT endpoint carries metObs + oceanObs only as retained QoS-1 last-known-value (LKV) topics; lightning is excluded from MQTT because per-strike events do not fit LKV semantics.",
  "endpoints": {
    "dk.dmi.Kafka": {
      "usage": ["producer"],
      "protocol": "KAFKA",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "binary"
      },
      "protocoloptions": {
        "deployed": false,
        "options": {
          "topic": "dmi"
        }
      },
      "messagegroups": [
        "#/messagegroups/dk.dmi.metObs.kafka",
        "#/messagegroups/dk.dmi.oceanObs.kafka",
        "#/messagegroups/dk.dmi.lightning.kafka"
      ]
    },
    "dk.dmi.Mqtt": {
      "usage": ["producer"],
      "protocol": "MQTT/5.0",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "binary"
      },
      "protocoloptions": {
        "deployed": false,
        "endpoints": [
          {
            "uri": "mqtt://localhost:1883"
          }
        ]
      },
      "messagegroups": [
        "#/messagegroups/dk.dmi.metObs.mqtt",
        "#/messagegroups/dk.dmi.oceanObs.mqtt"
      ]
    }
  },
  "messagegroups": {
    "dk.dmi.metObs": {
      "messages": {
        "dk.dmi.metObs.Station": {
          "name": "Station",
          "envelope": "CloudEvents/1.0",
          "description": "Reference data for a DMI meteorological observation station. Emitted at feeder startup and refreshed daily. Stations cover Denmark, Greenland (DNK/GRL) and the Faroe Islands (FRO).",
          "envelopemetadata": {
            "type": {"value": "dk.dmi.metObs.Station"},
            "source": {"value": "{feedurl}", "type": "uritemplate"},
            "subject": {"value": "{station_id}", "type": "uritemplate"}
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/dk.dmi.jstruct/schemas/dk.dmi.metObs.Station"
        },
        "dk.dmi.metObs.Observation": {
          "name": "Observation",
          "envelope": "CloudEvents/1.0",
          "description": "A single meteorological observation value reported by a station for one parameter at a specific observed time. Cadence depends on parameter (10-minute or hourly).",
          "envelopemetadata": {
            "type": {"value": "dk.dmi.metObs.Observation"},
            "source": {"value": "{feedurl}", "type": "uritemplate"},
            "subject": {"value": "{station_id}/{parameter_id}", "type": "uritemplate"}
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/dk.dmi.jstruct/schemas/dk.dmi.metObs.Observation"
        }
      }
    },
    "dk.dmi.oceanObs": {
      "messages": {
        "dk.dmi.oceanObs.Station": {
          "name": "OceanStation",
          "envelope": "CloudEvents/1.0",
          "description": "Reference data for an oceanographic observation station (tide gauge or other coastal sensor). Owners include DMI and Kystdirektoratet (Danish Coastal Authority).",
          "envelopemetadata": {
            "type": {"value": "dk.dmi.oceanObs.Station"},
            "source": {"value": "{feedurl}", "type": "uritemplate"},
            "subject": {"value": "{station_id}", "type": "uritemplate"}
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/dk.dmi.jstruct/schemas/dk.dmi.oceanObs.Station"
        },
        "dk.dmi.oceanObs.TidewaterStation": {
          "name": "TidewaterStation",
          "envelope": "CloudEvents/1.0",
          "description": "Reference data for a station/grid-point at which DMI publishes tidewater (sea-level) predictions. The set partially overlaps physical tide gauges but also includes prediction-only grid points (e.g. Faroes).",
          "envelopemetadata": {
            "type": {"value": "dk.dmi.oceanObs.TidewaterStation"},
            "source": {"value": "{feedurl}", "type": "uritemplate"},
            "subject": {"value": "{station_id}", "type": "uritemplate"}
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/dk.dmi.jstruct/schemas/dk.dmi.oceanObs.TidewaterStation"
        },
        "dk.dmi.oceanObs.Observation": {
          "name": "OceanObservation",
          "envelope": "CloudEvents/1.0",
          "description": "A single oceanographic observation. Parameters are sealev_dvr (sea level vs DVR90 datum, cm), sealev_ln (sea level vs local zero, cm), sea_reg (registered sea level by Kystdirektoratet, cm), and tw (water temperature, deg C). 10-minute cadence.",
          "envelopemetadata": {
            "type": {"value": "dk.dmi.oceanObs.Observation"},
            "source": {"value": "{feedurl}", "type": "uritemplate"},
            "subject": {"value": "{station_id}/{parameter_id}", "type": "uritemplate"}
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/dk.dmi.jstruct/schemas/dk.dmi.oceanObs.Observation"
        },
        "dk.dmi.oceanObs.TidewaterPrediction": {
          "name": "TidewaterPrediction",
          "envelope": "CloudEvents/1.0",
          "description": "A deterministic tidewater (sea-level) prediction for one station and one forecast horizon. predictionType is typically '10minutes'; predictions are issued forward ~30 days.",
          "envelopemetadata": {
            "type": {"value": "dk.dmi.oceanObs.TidewaterPrediction"},
            "source": {"value": "{feedurl}", "type": "uritemplate"},
            "subject": {"value": "{station_id}", "type": "uritemplate"}
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/dk.dmi.jstruct/schemas/dk.dmi.oceanObs.TidewaterPrediction"
        }
      }
    },
    "dk.dmi.lightning": {
      "messages": {
        "dk.dmi.lightning.Sensor": {
          "name": "LightningSensor",
          "envelope": "CloudEvents/1.0",
          "description": "Reference data for one of DMI's lightning detection sensors. Six DMI-owned sensors cover Denmark; third-party sensor IDs that appear in observation.sensors are not catalogued here.",
          "envelopemetadata": {
            "type": {"value": "dk.dmi.lightning.Sensor"},
            "source": {"value": "{feedurl}", "type": "uritemplate"},
            "subject": {"value": "{sensor_id}", "type": "uritemplate"}
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/dk.dmi.jstruct/schemas/dk.dmi.lightning.Sensor"
        },
        "dk.dmi.lightning.Strike": {
          "name": "LightningStrike",
          "envelope": "CloudEvents/1.0",
          "description": "A single triangulated lightning strike. Type 0 = cloud-to-ground negative, 1 = cloud-to-ground positive, 2 = cloud-to-cloud. amp is signed peak current in kA. observed timestamps have microsecond precision.",
          "envelopemetadata": {
            "type": {"value": "dk.dmi.lightning.Strike"},
            "source": {"value": "{feedurl}", "type": "uritemplate"},
            "subject": {"value": "{strike_id}", "type": "uritemplate"}
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/dk.dmi.jstruct/schemas/dk.dmi.lightning.Strike"
        }
      }
    },
    "dk.dmi.metObs.kafka": {
      "messages": {
        "dk.dmi.metObs.kafka.Station": {
          "name": "Station",
          "basemessageurl": "/messagegroups/dk.dmi.metObs/messages/dk.dmi.metObs.Station",
          "protocol": "KAFKA",
          "protocolmetadata": {
            "key": {
              "type": "uritemplate",
              "value": "{station_id}",
              "description": "Kafka partition key - stable DMI station identifier matching the CloudEvent subject."
            }
          }
        },
        "dk.dmi.metObs.kafka.Observation": {
          "name": "Observation",
          "basemessageurl": "/messagegroups/dk.dmi.metObs/messages/dk.dmi.metObs.Observation",
          "protocol": "KAFKA",
          "protocolmetadata": {
            "key": {
              "type": "uritemplate",
              "value": "{station_id}/{parameter_id}",
              "description": "Kafka partition key - stationId/parameterId, matching the CloudEvent subject so all values for one (station,parameter) land in the same partition."
            }
          }
        }
      }
    },
    "dk.dmi.oceanObs.kafka": {
      "messages": {
        "dk.dmi.oceanObs.kafka.Station": {
          "name": "OceanStation",
          "basemessageurl": "/messagegroups/dk.dmi.oceanObs/messages/dk.dmi.oceanObs.Station",
          "protocol": "KAFKA",
          "protocolmetadata": {
            "key": {"type": "uritemplate", "value": "{station_id}"}
          }
        },
        "dk.dmi.oceanObs.kafka.TidewaterStation": {
          "name": "TidewaterStation",
          "basemessageurl": "/messagegroups/dk.dmi.oceanObs/messages/dk.dmi.oceanObs.TidewaterStation",
          "protocol": "KAFKA",
          "protocolmetadata": {
            "key": {"type": "uritemplate", "value": "{station_id}"}
          }
        },
        "dk.dmi.oceanObs.kafka.Observation": {
          "name": "OceanObservation",
          "basemessageurl": "/messagegroups/dk.dmi.oceanObs/messages/dk.dmi.oceanObs.Observation",
          "protocol": "KAFKA",
          "protocolmetadata": {
            "key": {"type": "uritemplate", "value": "{station_id}/{parameter_id}"}
          }
        },
        "dk.dmi.oceanObs.kafka.TidewaterPrediction": {
          "name": "TidewaterPrediction",
          "basemessageurl": "/messagegroups/dk.dmi.oceanObs/messages/dk.dmi.oceanObs.TidewaterPrediction",
          "protocol": "KAFKA",
          "protocolmetadata": {
            "key": {"type": "uritemplate", "value": "{station_id}"}
          }
        }
      }
    },
    "dk.dmi.lightning.kafka": {
      "messages": {
        "dk.dmi.lightning.kafka.Sensor": {
          "name": "LightningSensor",
          "basemessageurl": "/messagegroups/dk.dmi.lightning/messages/dk.dmi.lightning.Sensor",
          "protocol": "KAFKA",
          "protocolmetadata": {
            "key": {"type": "uritemplate", "value": "{sensor_id}"}
          }
        },
        "dk.dmi.lightning.kafka.Strike": {
          "name": "LightningStrike",
          "basemessageurl": "/messagegroups/dk.dmi.lightning/messages/dk.dmi.lightning.Strike",
          "protocol": "KAFKA",
          "protocolmetadata": {
            "key": {
              "type": "uritemplate",
              "value": "{strike_id}",
              "description": "Kafka partition key - DMI-assigned strike identifier (e.g. 'u1xrxj10262553824830001-03'). Stable per strike."
            }
          }
        }
      }
    },
    "dk.dmi.metObs.mqtt": {
      "messages": {
        "dk.dmi.metObs.mqtt.Station": {
          "name": "Station",
          "basemessageurl": "/messagegroups/dk.dmi.metObs/messages/dk.dmi.metObs.Station",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "properties": {
              "topic": {
                "type": "uritemplate",
                "value": "weather/dk/dmi/met-obs/{station_id}/info",
                "description": "Unified Namespace topic carrying the station's identity and location as a retained last-known-value."
              },
              "qos": {"type": "integer", "value": 1},
              "retain": {"type": "boolean", "value": true}
            }
          }
        },
        "dk.dmi.metObs.mqtt.Observation": {
          "name": "Observation",
          "basemessageurl": "/messagegroups/dk.dmi.metObs/messages/dk.dmi.metObs.Observation",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "properties": {
              "topic": {
                "type": "uritemplate",
                "value": "weather/dk/dmi/met-obs/{station_id}/{parameter_id}",
                "description": "Unified Namespace topic carrying the latest meteorological observation value for one (station, parameter) pair as a retained LKV."
              },
              "qos": {"type": "integer", "value": 1},
              "retain": {"type": "boolean", "value": true}
            }
          }
        }
      }
    },
    "dk.dmi.oceanObs.mqtt": {
      "messages": {
        "dk.dmi.oceanObs.mqtt.Station": {
          "name": "OceanStation",
          "basemessageurl": "/messagegroups/dk.dmi.oceanObs/messages/dk.dmi.oceanObs.Station",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "properties": {
              "topic": {"type": "uritemplate", "value": "ocean/dk/dmi/ocean-obs/{station_id}/info"},
              "qos": {"type": "integer", "value": 1},
              "retain": {"type": "boolean", "value": true}
            }
          }
        },
        "dk.dmi.oceanObs.mqtt.TidewaterStation": {
          "name": "TidewaterStation",
          "basemessageurl": "/messagegroups/dk.dmi.oceanObs/messages/dk.dmi.oceanObs.TidewaterStation",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "properties": {
              "topic": {"type": "uritemplate", "value": "ocean/dk/dmi/tidewater/{station_id}/info"},
              "qos": {"type": "integer", "value": 1},
              "retain": {"type": "boolean", "value": true}
            }
          }
        },
        "dk.dmi.oceanObs.mqtt.Observation": {
          "name": "OceanObservation",
          "basemessageurl": "/messagegroups/dk.dmi.oceanObs/messages/dk.dmi.oceanObs.Observation",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "properties": {
              "topic": {"type": "uritemplate", "value": "ocean/dk/dmi/ocean-obs/{station_id}/{parameter_id}"},
              "qos": {"type": "integer", "value": 1},
              "retain": {"type": "boolean", "value": true}
            }
          }
        },
        "dk.dmi.oceanObs.mqtt.TidewaterPrediction": {
          "name": "TidewaterPrediction",
          "basemessageurl": "/messagegroups/dk.dmi.oceanObs/messages/dk.dmi.oceanObs.TidewaterPrediction",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "properties": {
              "topic": {"type": "uritemplate", "value": "ocean/dk/dmi/tidewater/{station_id}/prediction"},
              "qos": {"type": "integer", "value": 1},
              "retain": {"type": "boolean", "value": true}
            }
          }
        }
      }
    }
  },
  "schemagroups": {
    "dk.dmi.jstruct": {
      "schemas": {
        "dk.dmi.metObs.Station": {
          "format": "JsonStructure/draft-02",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/extended/v0/#",
                "$id": "https://github.com/clemensv/real-time-sources/dmi/schemas/dk/dmi/metObs/Station",
                "name": "Station",
                "type": "object",
                "description": "A meteorological observation station owned and operated by (or on behalf of) DMI. See https://opendatadocs.dmi.govcloud.dk/en/Data/Meteorological_Observation_Data for the canonical field list. Identity is stable per stationId; metadata is slowly-changing via validFrom/validTo.",
                "required": ["station_id", "name", "country", "latitude", "longitude"],
                "properties": {
                  "station_id": {
                    "type": "string",
                    "description": "Stable DMI station identifier (e.g. '06030', '04202' for Pituffik in Greenland). Used as the Kafka partition key and CloudEvent subject.",
                    "altnames": {"json": "stationId"}
                  },
                  "wmo_station_id": {
                    "type": ["string", "null"],
                    "description": "World Meteorological Organization (WMO) station identifier when registered with WMO.",
                    "altnames": {"json": "wmoStationId"}
                  },
                  "wmo_country_code": {
                    "type": ["string", "null"],
                    "description": "WMO country code as an integer string (e.g. '06' for Denmark).",
                    "altnames": {"json": "wmoCountryCode"}
                  },
                  "name": {
                    "type": "string",
                    "description": "Human-readable station name."
                  },
                  "country": {
                    "type": "string",
                    "description": "ISO 3166-1 alpha-3 country code: 'DNK' (Denmark), 'GRL' (Greenland), 'FRO' (Faroe Islands).",
                    "altenums": {
                      "iso3166-1-alpha-3": {
                        "DNK": "Denmark",
                        "GRL": "Greenland",
                        "FRO": "Faroe Islands"
                      }
                    }
                  },
                  "owner": {
                    "type": ["string", "null"],
                    "description": "Organisation that owns/operates the station (typically 'DMI')."
                  },
                  "region_id": {
                    "type": ["string", "null"],
                    "description": "DMI region identifier within the country.",
                    "altnames": {"json": "regionId"}
                  },
                  "type": {
                    "type": ["string", "null"],
                    "description": "Station type as classified by DMI (e.g. 'Synop', 'PluvioSync')."
                  },
                  "status": {
                    "type": ["string", "null"],
                    "description": "Operational status (e.g. 'Active', 'Inactive')."
                  },
                  "parameter_id": {
                    "type": {"type": "array", "items": "string"},
                    "description": "List of DMI parameterId values this station reports (e.g. ['temp_dry','wind_speed','humidity']).",
                    "altnames": {"json": "parameterId"}
                  },
                  "latitude": {
                    "type": "double",
                    "description": "Station latitude in decimal degrees (WGS84). Derived from GeoJSON geometry.coordinates[1].",
                    "unit": "deg"
                  },
                  "longitude": {
                    "type": "double",
                    "description": "Station longitude in decimal degrees (WGS84). Derived from GeoJSON geometry.coordinates[0].",
                    "unit": "deg"
                  },
                  "station_height": {
                    "type": ["double", "null"],
                    "description": "Height of the station above mean sea level.",
                    "unit": "m",
                    "altnames": {"json": "stationHeight"}
                  },
                  "barometer_height": {
                    "type": ["double", "null"],
                    "description": "Height of the barometer above mean sea level.",
                    "unit": "m",
                    "altnames": {"json": "barometerHeight"}
                  },
                  "anemometer_height": {
                    "type": ["double", "null"],
                    "description": "Height of the anemometer above ground level.",
                    "unit": "m",
                    "altnames": {"json": "anemometerHeight"}
                  },
                  "valid_from": {
                    "type": ["string", "null"],
                    "format": "date-time",
                    "description": "Timestamp from which this station-metadata version is valid.",
                    "altnames": {"json": "validFrom"}
                  },
                  "valid_to": {
                    "type": ["string", "null"],
                    "format": "date-time",
                    "description": "Timestamp after which this station-metadata version is no longer valid; null while current.",
                    "altnames": {"json": "validTo"}
                  },
                  "operation_from": {
                    "type": ["string", "null"],
                    "format": "date-time",
                    "description": "Timestamp from which the station began operating.",
                    "altnames": {"json": "operationFrom"}
                  },
                  "operation_to": {
                    "type": ["string", "null"],
                    "format": "date-time",
                    "description": "Timestamp at which the station stopped operating; null while operational.",
                    "altnames": {"json": "operationTo"}
                  },
                  "created": {
                    "type": ["string", "null"],
                    "format": "date-time",
                    "description": "Timestamp when this metadata row was created by DMI."
                  },
                  "updated": {
                    "type": ["string", "null"],
                    "format": "date-time",
                    "description": "Timestamp when this metadata row was last updated by DMI."
                  }
                }
              }
            }
          }
        },
        "dk.dmi.metObs.Observation": {
          "format": "JsonStructure/draft-02",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/extended/v0/#",
                "$id": "https://github.com/clemensv/real-time-sources/dmi/schemas/dk/dmi/metObs/Observation",
                "name": "Observation",
                "type": "object",
                "description": "A single meteorological observation: one parameter, one station, one timestamp. Units are SI: degC, hPa, m/s, %, m, mm, degrees. wind_dir=0 means calm (not north).",
                "required": ["station_id", "parameter_id", "observed", "value"],
                "properties": {
                  "observation_id": {
                    "type": ["string", "null"],
                    "description": "DMI-assigned per-row identifier. Not stable across re-ingestions; use (station_id, parameter_id, observed) for idempotency.",
                    "altnames": {"json": "id"}
                  },
                  "station_id": {
                    "type": "string",
                    "description": "Reporting station identifier (foreign key to Station).",
                    "altnames": {"json": "stationId"}
                  },
                  "parameter_id": {
                    "type": "string",
                    "description": "DMI parameter identifier (e.g. 'temp_dry', 'wind_speed', 'humidity', 'pressure_at_sea').",
                    "altnames": {"json": "parameterId"}
                  },
                  "observed": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Timestamp at which the value was observed (UTC, ISO 8601)."
                  },
                  "value": {
                    "type": "double",
                    "description": "Numeric measurement value. Units depend on parameter_id (see DMI documentation)."
                  },
                  "latitude": {
                    "type": ["double", "null"],
                    "description": "Station latitude (decimal degrees, WGS84) at observation time.",
                    "unit": "deg"
                  },
                  "longitude": {
                    "type": ["double", "null"],
                    "description": "Station longitude (decimal degrees, WGS84) at observation time.",
                    "unit": "deg"
                  }
                }
              }
            }
          }
        },
        "dk.dmi.oceanObs.Station": {
          "format": "JsonStructure/draft-02",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/extended/v0/#",
                "$id": "https://github.com/clemensv/real-time-sources/dmi/schemas/dk/dmi/oceanObs/Station",
                "name": "OceanStation",
                "type": "object",
                "description": "An oceanographic observation station (typically a tide gauge). Owners include DMI and Kystdirektoratet (Danish Coastal Authority). See https://opendatadocs.dmi.govcloud.dk/en/Data/Oceanographic_Observation_Data.",
                "required": ["station_id", "name", "latitude", "longitude"],
                "properties": {
                  "station_id": {
                    "type": "string",
                    "description": "Stable DMI ocean station identifier.",
                    "altnames": {"json": "stationId"}
                  },
                  "name": {
                    "type": "string",
                    "description": "Human-readable station name."
                  },
                  "country": {
                    "type": ["string", "null"],
                    "description": "ISO 3166-1 alpha-3 country code (DNK, GRL, FRO).",
                    "altenums": {
                      "iso3166-1-alpha-3": {
                        "DNK": "Denmark",
                        "GRL": "Greenland",
                        "FRO": "Faroe Islands"
                      }
                    }
                  },
                  "owner": {
                    "type": ["string", "null"],
                    "description": "Operating agency (e.g. 'DMI', 'Kystdirektoratet')."
                  },
                  "type": {
                    "type": ["string", "null"],
                    "description": "Station type (e.g. 'Tide-gauge-primary')."
                  },
                  "status": {
                    "type": ["string", "null"],
                    "description": "Operational status."
                  },
                  "parameter_id": {
                    "type": {"type": "array", "items": "string"},
                    "description": "Parameter IDs supported by this station (subset of {sealev_dvr, sealev_ln, sea_reg, tw}).",
                    "altnames": {"json": "parameterId"}
                  },
                  "latitude": {
                    "type": "double",
                    "description": "Station latitude (decimal degrees, WGS84).",
                    "unit": "deg"
                  },
                  "longitude": {
                    "type": "double",
                    "description": "Station longitude (decimal degrees, WGS84).",
                    "unit": "deg"
                  },
                  "valid_from": {
                    "type": ["string", "null"],
                    "format": "date-time",
                    "description": "Metadata-validity start.",
                    "altnames": {"json": "validFrom"}
                  },
                  "valid_to": {
                    "type": ["string", "null"],
                    "format": "date-time",
                    "description": "Metadata-validity end.",
                    "altnames": {"json": "validTo"}
                  },
                  "operation_from": {
