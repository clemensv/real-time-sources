.alter table ['JP.JMA.Volcano.Volcano'] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'JP.JMA.Volcano.Volcano') | project['volcano_code'] = tostring(data.['volcano_code']),['name_jp'] = tostring(data.['name_jp']),['name_en'] = tostring(data.['name_en']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),['elevation_m'] = toreal(data.['elevation_m']),['level_operation'] = tobool(data.['level_operation']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

