.create materialized-view with (backfill=true) ['JP.JMA.Volcano.VolcanoLatest'] on table ['JP.JMA.Volcano.Volcano'] {
    ['JP.JMA.Volcano.Volcano'] | summarize arg_max(___time, *) by ___type, ___source, ___subject
