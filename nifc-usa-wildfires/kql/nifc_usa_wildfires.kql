.drop materialized-view WildfireIncidentLatest ifexists;

.create materialized-view with (backfill=true) WildfireIncidentLatest on table WildfireIncident {
    WildfireIncident | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [WildfireIncident] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'Gov.NIFC.Wildfires.WildfireIncident') | project['irwin_id'] = tostring(data.['irwin_id']),['incident_name'] = tostring(data.['incident_name']),['unique_fire_identifier'] = tostring(data.['unique_fire_identifier']),['incident_type_category'] = tostring(data.['incident_type_category']),['incident_type_kind'] = tostring(data.['incident_type_kind']),['fire_discovery_datetime'] = tostring(data.['fire_discovery_datetime']),['daily_acres'] = toreal(data.['daily_acres']),['calculated_acres'] = toreal(data.['calculated_acres']),['discovery_acres'] = toreal(data.['discovery_acres']),['percent_contained'] = toreal(data.['percent_contained']),['poo_state'] = tostring(data.['poo_state']),['poo_county'] = tostring(data.['poo_county']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),['fire_cause'] = tostring(data.['fire_cause']),['fire_cause_general'] = tostring(data.['fire_cause_general']),['gacc'] = tostring(data.['gacc']),['total_incident_personnel'] = toint(data.['total_incident_personnel']),['incident_management_organization'] = tostring(data.['incident_management_organization']),['fire_mgmt_complexity'] = tostring(data.['fire_mgmt_complexity']),['residences_destroyed'] = toint(data.['residences_destroyed']),['other_structures_destroyed'] = toint(data.['other_structures_destroyed']),['injuries'] = toint(data.['injuries']),['fatalities'] = toint(data.['fatalities']),['containment_datetime'] = tostring(data.['containment_datetime']),['control_datetime'] = tostring(data.['control_datetime']),['fire_out_datetime'] = tostring(data.['fire_out_datetime']),['final_acres'] = toreal(data.['final_acres']),['modified_on_datetime'] = tostring(data.['modified_on_datetime']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

