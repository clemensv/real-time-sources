.alter table [RoadEvent] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type in ('DE.Autobahn.RoadworkAppeared', 'DE.Autobahn.RoadworkUpdated', 'DE.Autobahn.RoadworkResolved', 'DE.Autobahn.ShortTermRoadworkAppeared', 'DE.Autobahn.ShortTermRoadworkUpdated', 'DE.Autobahn.ShortTermRoadworkResolved', 'DE.Autobahn.ClosureAppeared', 'DE.Autobahn.ClosureUpdated', 'DE.Autobahn.ClosureResolved', 'DE.Autobahn.EntryExitClosureAppeared', 'DE.Autobahn.EntryExitClosureUpdated', 'DE.Autobahn.EntryExitClosureResolved', 'DE.Autobahn.WeightLimit35RestrictionAppeared', 'DE.Autobahn.WeightLimit35RestrictionUpdated', 'DE.Autobahn.WeightLimit35RestrictionResolved')) | project['identifier'] = tostring(data.['identifier']),['road_ids'] = todynamic(data.['road_ids']),['event_time'] = todatetime(data.['event_time']),['display_type'] = tostring(data.['display_type']),['title'] = tostring(data.['title']),['subtitle'] = tostring(data.['subtitle']),['description_lines'] = todynamic(data.['description_lines']),['future'] = tobool(data.['future']),['is_blocked'] = tobool(data.['is_blocked']),['icon'] = tostring(data.['icon']),['start_lc_position'] = toint(data.['start_lc_position']),['start_timestamp'] = todatetime(data.['start_timestamp']),['extent'] = tostring(data.['extent']),['point'] = tostring(data.['point']),['coordinate_lat'] = toreal(data.['coordinate_lat']),['coordinate_lon'] = toreal(data.['coordinate_lon']),['geometry_json'] = tostring(data.['geometry_json']),['impact_lower'] = tostring(data.['impact_lower']),['impact_upper'] = tostring(data.['impact_upper']),['impact_symbols'] = todynamic(data.['impact_symbols']),['route_recommendation_json'] = tostring(data.['route_recommendation_json']),['footer_lines'] = todynamic(data.['footer_lines']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

