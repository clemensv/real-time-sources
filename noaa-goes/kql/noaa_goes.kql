.create-merge table [SolarWindMagField] (
   [observation_time]: string,
   [bx_gsm]: real,
   [by_gsm]: real,
   [bz_gsm]: real,
   [lon_gsm]: real,
   [lat_gsm]: real,
   [bt]: real,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [SolarWindMagField] docstring "{\"description\": \"One-minute resolution interplanetary magnetic field (IMF) vector measurement from the DSCOVR satellite magnetometer at the L1 Lagrange point, as reported by the SWPC solar-wind/mag-7-day endpoint. Provides the full magnetic field vector in Geocentric Solar Magnetospheric (GSM) coordinates plus total magnitude. The Bz GSM component is the primary indicator of geomagnetic storm potential.\"}";

.alter table [SolarWindMagField] column-docstrings (
   [observation_time]: "{\"description\": \"UTC date-time of the magnetic field measurement, in 'YYYY-MM-DD HH:MM:SS.fff' format.\"}",
   [bx_gsm]: "{\"description\": \"IMF X-component in GSM coordinates, directed from Earth toward the Sun along the Earth-Sun line.\"}",
   [by_gsm]: "{\"description\": \"IMF Y-component in GSM coordinates, perpendicular to the Earth-Sun line in the magnetic equatorial plane. Influences the dawn-dusk electric field in the magnetosphere.\"}",
   [bz_gsm]: "{\"description\": \"IMF Z-component in GSM coordinates (north-south). Sustained negative (southward) Bz is the primary driver of geomagnetic storms through magnetic reconnection at the dayside magnetopause. Values below -10 nT can produce G2+ storms.\"}",
   [lon_gsm]: "{\"description\": \"IMF longitude angle in GSM coordinates, measured in the GSM X-Y plane from the Earth-Sun line.\"}",
   [lat_gsm]: "{\"description\": \"IMF latitude angle in GSM coordinates, measured from the GSM X-Y plane toward the Z-axis.\"}",
   [bt]: "{\"description\": \"Total interplanetary magnetic field magnitude, computed as the vector sum sqrt(Bx\\u00b2 + By\\u00b2 + Bz\\u00b2). Typical quiet-time values are 3-6 nT; values above 20 nT indicate strong solar wind magnetic driving.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

