);

.alter table [GoesProtonFlux] docstring "{\"description\": \"Five-minute resolution integral proton flux measurement from the GOES primary satellite SEISS/SGPS (Space Environment In-Situ Suite / Solar and Galactic Proton Sensor) instrument, as reported by the SWPC goes/primary/integral-protons-7-day endpoint. Four energy thresholds are reported. The >= 10 MeV channel is used for the official NOAA S-scale solar radiation storm classification (S1-S5).\"}";

.alter table [GoesProtonFlux] column-docstrings (
   [time_tag]: "{\"description\": \"UTC date-time of the proton flux measurement in ISO 8601 format.\"}",
   [satellite]: "{\"description\": \"GOES satellite number providing the measurement (e.g., 19 for GOES-19).\"}",
   [flux]: "{\"description\": \"Integral proton flux above the specified energy threshold, in particle flux units (pfu = protons/cm\\u00b2/sr/s). An S1 minor radiation storm is declared when >= 10 MeV flux exceeds 10 pfu. S5 extreme: >= 100,000 pfu.\"}",
   [energy]: "{\"description\": \"Proton energy threshold identifier: '>=10 MeV' (NOAA S-scale metric), '>=50 MeV', '>=100 MeV', or '>=500 MeV'. Higher thresholds indicate more energetic and penetrating radiation.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

