.drop materialized-view StationLatest ifexists;

.create materialized-view with (backfill=true) StationLatest on table Station {
    Station | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [Station] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'AU.Gov.BOM.Weather.Station') | project['station_wmo'] = toint(data.['station_wmo']),['name'] = tostring(data.['name']),['product_id'] = tostring(data.['product_id']),['state'] = tostring(data.['state']),['time_zone'] = tostring(data.['time_zone']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

.create-merge table [WeatherObservation] (
   [station_wmo]: int,
   [station_name]: string,
   [observation_time_utc]: datetime,
   [local_time]: string,
   [air_temp]: real,
   [apparent_temp]: real,
   [dewpt]: real,
   [rel_hum]: int,
   [delta_t]: real,
   [wind_dir]: string,
   [wind_spd_kmh]: int,
   [wind_spd_kt]: int,
   [gust_kmh]: int,
   [gust_kt]: int,
   [press]: real,
   [press_qnh]: real,
   [press_msl]: real,
   [press_tend]: string,
   [rain_trace]: string,
   [cloud]: string,
   [cloud_oktas]: int,
   [cloud_base_m]: int,
   [cloud_type]: string,
   [vis_km]: string,
   [weather]: string,
   [sea_state]: string,
   [swell_dir_worded]: string,
   [swell_height]: real,
   [swell_period]: real,
   [latitude]: real,
   [longitude]: real,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [WeatherObservation] docstring "{\"description\": \"Half-hourly surface weather observation from a BOM automatic weather station. Each record contains temperature, wind, pressure, humidity, rainfall, cloud, and visibility measurements as reported in the station's 72-hour observation product.\"}";

.alter table [WeatherObservation] column-docstrings (
   [station_wmo]: "{\"description\": \"WMO station number identifying the reporting station.\"}",
   [station_name]: "{\"description\": \"Human-readable name of the reporting station.\"}",
   [observation_time_utc]: "{\"description\": \"Timestamp of the observation in UTC, derived from the BOM 'aifstime_utc' field in YYYYMMDDHHmmss format.\"}",
   [local_time]: "{\"description\": \"Local date and time string as provided by BOM in 'local_date_time_full' format (YYYYMMDDHHmmss).\"}",
   [air_temp]: "{\"description\": \"Air temperature measured at the station.\"}",
   [apparent_temp]: "{\"description\": \"Apparent (feels-like) temperature combining air temperature, humidity, and wind chill effects.\"}",
   [dewpt]: "{\"description\": \"Dew point temperature at the station.\"}",
   [rel_hum]: "{\"description\": \"Relative humidity as a percentage.\"}",
   [delta_t]: "{\"description\": \"Wet bulb depression (difference between dry and wet bulb temperatures), used for bushfire danger calculations.\"}",
   [wind_dir]: "{\"description\": \"Compass direction the wind is blowing from, e.g. 'N', 'NNE', 'SSW', 'CALM'.\"}",
   [wind_spd_kmh]: "{\"description\": \"Sustained wind speed in kilometres per hour.\"}",
   [wind_spd_kt]: "{\"description\": \"Sustained wind speed in knots (nautical miles per hour).\"}",
   [gust_kmh]: "{\"description\": \"Maximum wind gust speed recorded in the observation period in kilometres per hour.\"}",
   [gust_kt]: "{\"description\": \"Maximum wind gust speed recorded in the observation period in knots.\"}",
   [press]: "{\"description\": \"Atmospheric pressure at station level.\"}",
   [press_qnh]: "{\"description\": \"QNH pressure \\u2014 atmospheric pressure adjusted to mean sea level using the International Standard Atmosphere, used in aviation altimetry.\"}",
   [press_msl]: "{\"description\": \"Mean sea level pressure \\u2014 station pressure reduced to sea level, used for synoptic weather analysis.\"}",
   [press_tend]: "{\"description\": \"Pressure tendency description indicating whether pressure is rising, falling, or steady over the past 3 hours. May be a numeric code or textual description.\"}",
   [rain_trace]: "{\"description\": \"Rainfall since 9am local time as reported by BOM. Value is a string that may be '0.0', a numeric amount in mm, or 'Trace' for very small amounts.\"}",
   [cloud]: "{\"description\": \"Textual cloud cover description, e.g. 'Partly cloudy', 'Clear', 'Overcast'.\"}",
   [cloud_oktas]: "{\"description\": \"Cloud cover in oktas (eighths of sky covered), ranging from 0 (clear) to 8 (overcast).\"}",
   [cloud_base_m]: "{\"description\": \"Height of the lowest cloud base above ground level.\"}",
   [cloud_type]: "{\"description\": \"Cloud type classification as reported by the station, e.g. 'Cu', 'Cb', 'St'. May be '-' when not reported.\"}",
   [vis_km]: "{\"description\": \"Horizontal visibility in kilometres. Reported as a string as BOM may include qualifiers.\"}",
   [weather]: "{\"description\": \"Present weather description, e.g. 'Rain', 'Fog', 'Thunderstorm'. May be '-' when no significant weather.\"}",
   [sea_state]: "{\"description\": \"Sea state description for coastal stations, e.g. 'Smooth', 'Slight', 'Moderate'.\"}",
   [swell_dir_worded]: "{\"description\": \"Dominant swell direction as a compass bearing word for coastal stations.\"}",
   [swell_height]: "{\"description\": \"Dominant swell height for coastal stations.\"}",
   [swell_period]: "{\"description\": \"Dominant swell period for coastal stations.\"}",
   [latitude]: "{\"description\": \"Latitude of the station at observation time.\"}",
   [longitude]: "{\"description\": \"Longitude of the station at observation time.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

