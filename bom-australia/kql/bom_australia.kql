  {"column": "product_id", "path": "$.data.product_id"},
  {"column": "state", "path": "$.data.state"},
  {"column": "time_zone", "path": "$.data.time_zone"},
  {"column": "latitude", "path": "$.data.latitude"},
  {"column": "longitude", "path": "$.data.longitude"},
]
