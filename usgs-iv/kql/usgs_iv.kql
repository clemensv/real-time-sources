.alter table ['USGS.Sites.Site'] docstring "{\"description\": \"USGS site metadata.\"}";

.alter table ['USGS.Sites.Site'] column-docstrings (
   [agency_cd]: "{\"description\": \"Agency code.\"}",
   [site_no]: "{\"description\": \"USGS site number.\"}",
   [station_nm]: "{\"description\": \"Station name.\"}",
   [site_tp_cd]: "{\"description\": \"Site type code.\"}",
   [lat_va]: "{\"description\": \"DMS latitude.\"}",
   [long_va]: "{\"description\": \"DMS longitude.\"}",
   [dec_lat_va]: "{\"description\": \"Decimal latitude.\"}",
   [dec_long_va]: "{\"description\": \"Decimal longitude.\"}",
   [coord_meth_cd]: "{\"description\": \"Latitude-longitude method code.\"}",
   [coord_acy_cd]: "{\"description\": \"Coordinate accuracy code.\"}",
   [coord_datum_cd]: "{\"description\": \"Latitude-longitude datum code.\"}",
   [dec_coord_datum_cd]: "{\"description\": \"Decimal latitude-longitude datum code.\"}",
   [district_cd]: "{\"description\": \"District code.\"}",
   [state_cd]: "{\"description\": \"State code.\"}",
   [county_cd]: "{\"description\": \"County code.\"}",
   [country_cd]: "{\"description\": \"Country code.\"}",
   [land_net_ds]: "{\"description\": \"Land net location description.\"}",
   [map_nm]: "{\"description\": \"Location map name.\"}",
   [map_scale_fc]: "{\"description\": \"Location map scale factor.\"}",
   [alt_va]: "{\"description\": \"Altitude.\"}",
   [alt_meth_cd]: "{\"description\": \"Method altitude determined code.\"}",
   [alt_acy_va]: "{\"description\": \"Altitude accuracy.\"}",
   [alt_datum_cd]: "{\"description\": \"Altitude datum code.\"}",
   [huc_cd]: "{\"description\": \"Hydrologic unit code.\"}",
   [basin_cd]: "{\"description\": \"Drainage basin code.\"}",
   [topo_cd]: "{\"description\": \"Topographic setting code.\"}",
   [instruments_cd]: "{\"description\": \"Flags for instruments at site.\"}",
   [construction_dt]: "{\"description\": \"Date of first construction.\"}",
   [inventory_dt]: "{\"description\": \"Date site established or inventoried.\"}",
   [drain_area_va]: "{\"description\": \"Drainage area.\"}",
   [contrib_drain_area_va]: "{\"description\": \"Contributing drainage area.\"}",
   [tz_cd]: "{\"description\": \"Time Zone abbreviation.\"}",
   [local_time_fg]: "{\"description\": \"Site honors Daylight Savings Time flag.\"}",
   [reliability_cd]: "{\"description\": \"Data reliability code.\"}",
   [gw_file_cd]: "{\"description\": \"Data-other GW files code.\"}",
   [nat_aqfr_cd]: "{\"description\": \"National aquifer code.\"}",
   [aqfr_cd]: "{\"description\": \"Local aquifer code.\"}",
   [aqfr_type_cd]: "{\"description\": \"Local aquifer type code.\"}",
   [well_depth_va]: "{\"description\": \"Well depth.\"}",
   [hole_depth_va]: "{\"description\": \"Hole depth.\"}",
   [depth_src_cd]: "{\"description\": \"Source of depth data.\"}",
   [project_no]: "{\"description\": \"Project number.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

