{
  "endpoints": {
    "BR.INPE.DETER.Kafka": {
      "usage": [
        "producer"
      ],
      "protocol": "KAFKA",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "structured",
        "format": "application/cloudevents+json"
      },
      "protocoloptions": {
        "deployed": false,
        "options": {
          "topic": "inpe-deter-brazil",
          "key": "{biome}/{alert_id}"
        }
      },
      "messagegroups": [
        "#/messagegroups/BR.INPE.DETER"
      ]
    },
    "BR.INPE.DETER.Mqtt": {
      "usage": [
        "producer"
      ],
      "protocol": "MQTT/5.0",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "binary"
      },
      "protocoloptions": {
        "deployed": false,
        "endpoints": [
          {
            "uri": "mqtt://localhost:1883"
          }
        ]
      },
      "messagegroups": [
        "#/messagegroups/BR.INPE.DETER.mqtt"
      ],
      "description": "MQTT/5.0 binary-mode CloudEvents producer for the INPE DETER deforestation UNS topic tree."
    }
  },
  "messagegroups": {
    "BR.INPE.DETER": {
      "messages": {
        "BR.INPE.DETER.DeforestationAlert": {
          "name": "DeforestationAlert",
          "envelope": "CloudEvents/1.0",
          "description": "INPE DETER deforestation alert for Amazon and Cerrado biomes.",
          "envelopemetadata": {
            "type": {
              "value": "BR.INPE.DETER.DeforestationAlert"
            },
            "source": {
              "value": "{source_uri}",
              "type": "uritemplate"
            },
            "subject": {
              "value": "{biome}/{alert_id}",
              "type": "uritemplate"
            },
            "time": {
              "value": "{view_date}T00:00:00Z",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/BR.INPE.DETER.jstruct/schemas/BR.INPE.DETER.DeforestationAlert"
        }
      }
    },
    "BR.INPE.DETER.mqtt": {
      "description": "MQTT/5.0 transport variants for INPE DETER Brazil deforestation and related land-disturbance alerts. The UNS topic tree is deforestation/br/inpe/inpe-deter-brazil/{biome}/{state_slug}/{class_slug}/{alert_id}/alert. Payloads are JSON binary-mode CloudEvents. QoS 1 is used for at-least-once alert delivery; consumers MUST deduplicate by alert_id. retain=false is used because DETER alerts are immutable historical events and retaining each alert_id topic would create an unbounded retained-message graveyard. A Message Expiry Interval of 604800 seconds bounds queued delivery for offline durable subscribers. The state_slug axis is a lowercased Brazilian UF code or unknown when INPE omits or publishes an unsupported UF; class_slug is a supported topic-safe lowercase-kebab DETER class or unknown.",
      "messages": {
        "BR.INPE.DETER.mqtt.DeforestationAlert": {
          "name": "DeforestationAlert",
          "basemessageurl": "/messagegroups/BR.INPE.DETER/messages/BR.INPE.DETER.DeforestationAlert",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "topic_name": "deforestation/br/inpe/inpe-deter-brazil/{biome}/{state_slug}/{class_slug}/{alert_id}/alert",
            "qos": 1,
            "retain": false,
            "message_expiry_interval": 604800
          }
        }
      }
    }
  },
  "schemagroups": {
    "BR.INPE.DETER.jstruct": {
      "schemas": {
        "BR.INPE.DETER.DeforestationAlert": {
          "name": "DeforestationAlert",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/core/v0/#",
                "$id": "https://example.com/schemas/BR/INPE/DETER/DeforestationAlert",
                "name": "DeforestationAlert",
                "$root": "#/definitions/BR/INPE/DETER/DeforestationAlert",
                "definitions": {
                  "BR": {
                    "INPE": {
                      "DETER": {
                        "DeforestationAlert": {
                          "name": "DeforestationAlert",
                          "type": "object",
                          "properties": {
                            "alert_id": {
                              "type": "string",
                              "description": "Stable reference ID from INPE (gid)."
                            },
                            "biome": {
                              "type": "string",
                              "description": "Biome of the alert: amazon or cerrado.",
                              "enum": [
                                "amazon",
                                "cerrado"
                              ]
                            },
                            "classname": {
                              "type": "string",
                              "description": "Deforestation class: DESMATAMENTO_CR, DEGRADACAO, MINERACAO, CS_DESORDENADO, etc."
                            },
                            "view_date": {
                              "type": "string",
                              "description": "Observation date in YYYY-MM-DD format."
                            },
                            "satellite": {
                              "type": "string",
                              "description": "Satellite name (CBERS-4, Amazonia-1, etc.)."
                            },
                            "sensor": {
                              "type": "string",
                              "description": "Sensor name (AWFI, WFI, MSI)."
                            },
                            "area_km2": {
                              "type": "double",
                              "description": "Area of the deforestation polygon in square kilometers."
                            },
                            "municipality": {
                              "type": [
                                "string",
                                "null"
                              ],
                              "description": "Municipality name."
                            },
                            "state_code": {
                              "type": [
                                "string",
                                "null"
                              ],
                              "description": "Brazilian state code (UF), e.g. PA, MT, when provided by INPE; null when omitted. The topic-safe state_slug field is used for MQTT routing."
                            },
                            "path_row": {
                              "type": [
                                "string",
                                "null"
                              ],
                              "description": "Satellite path/row identifier."
                            },
                            "publish_month": {
                              "type": [
                                "string",
                                "null"
                              ],
                              "description": "Publication month in YYYY-MM-DD format."
                            },
                            "centroid_latitude": {
                              "type": "double",
                              "description": "Latitude of the polygon centroid in decimal degrees."
                            },
                            "centroid_longitude": {
                              "type": "double",
                              "description": "Longitude of the polygon centroid in decimal degrees."
                            },
                            "state_slug": {
                              "type": "string",
                              "description": "Lowercased Brazilian state code (UF), e.g. pa, mt, used as a topic-safe MQTT routing axis; unknown when INPE omits the UF.",
                              "pattern": "^([a-z]{2}|unknown)$"
                            },
                            "class_slug": {
                              "type": "string",
                              "description": "Lowercase-kebab normalized DETER class used as a topic-safe MQTT routing axis, e.g. desmatamento-cr, degradacao, mineracao.",
                              "pattern": "^[a-z0-9][a-z0-9-]*$",
                              "enum": [
                                "desmatamento-cr",
                                "desmatamento-veg",
                                "degradacao",
                                "mineracao",
                                "cs-desordenado",
                                "cs-geometrico",
                                "cicatriz-de-queimada",
                                "corte-seletivo",
                                "unknown"
                              ]
                            }
                          },
                          "required": [
                            "alert_id",
                            "biome",
                            "classname",
                            "view_date",
                            "satellite",
                            "sensor",
                            "area_km2",
                            "centroid_latitude",
                            "centroid_longitude"
                          ],
                          "description": "INPE DETER deforestation alert for Amazon and Cerrado biomes."
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
