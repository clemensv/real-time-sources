{
  "endpoints": {
    "BR.INPE.DETER.Kafka": {
      "usage": [
        "producer"
      ],
      "protocol": "KAFKA",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "structured",
        "format": "application/cloudevents+json"
      },
      "protocoloptions": {
        "deployed": false,
        "options": {
          "topic": "inpe-deter-brazil",
          "key": "{biome}/{alert_id}"
        }
      },
      "messagegroups": [
        "#/messagegroups/BR.INPE.DETER"
      ],
      "description": "Kafka producer endpoint for INPE DETER Brazil CloudEvents on the `inpe-deter-brazil` topic keyed by `{biome}/{alert_id}`."
    },
    "BR.INPE.DETER.Mqtt": {
      "usage": [
        "producer"
      ],
      "protocol": "MQTT/5.0",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "binary"
      },
      "protocoloptions": {
        "deployed": false,
        "endpoints": [
          {
            "uri": "mqtt://localhost:1883"
          }
        ]
      },
      "messagegroups": [
        "#/messagegroups/BR.INPE.DETER.mqtt"
      ],
      "description": "MQTT 5 producer endpoint for INPE DETER Brazil CloudEvents using the alert topic hierarchy and retain settings declared in this manifest."
    },
    "BR.INPE.DETER.Amqp": {
      "usage": [
        "producer"
      ],
      "protocol": "AMQP/1.0",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "binary"
      },
      "protocoloptions": {
        "deployed": false,
        "endpoints": [
          {
            "uri": "amqps://localhost:5671/inpe-deter-brazil"
          }
        ]
      },
      "messagegroups": [
        "#/messagegroups/BR.INPE.DETER.amqp"
      ],
      "description": "AMQP 1.0 producer endpoint for inpe-deter-brazil CloudEvents on the configured broker address."
    }
  },
  "messagegroups": {
    "BR.INPE.DETER": {
      "messages": {
        "BR.INPE.DETER.DeforestationAlert": {
          "name": "DeforestationAlert",
          "envelope": "CloudEvents/1.0",
          "description": "INPE DETER deforestation alert for Amazon and Cerrado biomes.",
          "envelopemetadata": {
            "type": {
              "value": "BR.INPE.DETER.DeforestationAlert"
            },
            "source": {
              "value": "{source_uri}",
              "type": "uritemplate"
            },
            "subject": {
              "value": "{biome}/{alert_id}",
              "type": "uritemplate"
            },
            "time": {
              "value": "{view_date}T00:00:00Z",
              "type": "timestamp"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/BR.INPE.DETER.jstruct/schemas/BR.INPE.DETER.DeforestationAlert"
        }
      },
      "description": "Events from INPE DETER Brazil covering Brazilian deforestation alert areas. Alert and incident records describe the current upstream hazard state and update when the provider changes that state."
    },
    "BR.INPE.DETER.mqtt": {
      "description": "MQTT 5 variant of the INPE DETER Brazil events. It carries the same alert semantics as the base events with MQTT topic routing and retain behavior declared per message.",
      "messages": {
        "BR.INPE.DETER.mqtt.DeforestationAlert": {
          "name": "DeforestationAlert",
          "basemessageurl": "/messagegroups/BR.INPE.DETER/messages/BR.INPE.DETER.DeforestationAlert",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "topic_name": "deforestation/br/inpe/inpe-deter-brazil/{biome}/{state_slug}/{class_slug}/{alert_id}/alert",
            "qos": 1,
            "retain": false,
            "message_expiry_interval": 604800
          }
        }
      }
    },
    "BR.INPE.DETER.amqp": {
      "description": "AMQP 1.0 transport variant for inpe-deter-brazil events. It carries the same CloudEvents and payload schemas as the source events on one broker address for queue- and topic-oriented consumers.",
      "messages": {
        "BR.INPE.DETER.amqp.DeforestationAlert": {
          "name": "DeforestationAlert",
          "basemessageurl": "/messagegroups/BR.INPE.DETER/messages/BR.INPE.DETER.DeforestationAlert",
          "protocol": "AMQP/1.0",
          "protocoloptions": {
            "properties": {
              "subject": {
                "type": "uritemplate",
                "value": "{biome}/{alert_id}",
                "description": "AMQP message subject — stable entity identifier matching the CloudEvent subject and Kafka key for this event family."
              }
            }
          }
        }
      }
    }
  },
  "schemagroups": {
    "BR.INPE.DETER.jstruct": {
      "schemas": {
        "BR.INPE.DETER.DeforestationAlert": {
          "name": "DeforestationAlert",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/core/v0/#",
                "$id": "https://example.com/schemas/BR/INPE/DETER/DeforestationAlert",
                "name": "DeforestationAlert",
                "$root": "#/definitions/BR/INPE/DETER/DeforestationAlert",
                "definitions": {
                  "BR": {
                    "INPE": {
                      "DETER": {
                        "DeforestationAlert": {
                          "name": "DeforestationAlert",
                          "type": "object",
                          "properties": {
                            "alert_id": {
                              "type": "string",
                              "description": "Stable reference ID from INPE (gid)."
                            },
                            "biome": {
                              "type": "string",
                              "description": "Biome of the alert: amazon or cerrado.",
                              "enum": [
                                "amazon",
                                "cerrado"
                              ]
                            },
                            "classname": {
                              "type": "string",
                              "description": "Deforestation class: DESMATAMENTO_CR, DEGRADACAO, MINERACAO, CS_DESORDENADO, etc."
                            },
                            "view_date": {
                              "type": "string",
                              "description": "Observation date in YYYY-MM-DD format."
                            },
                            "satellite": {
                              "type": "string",
                              "description": "Satellite name (CBERS-4, Amazonia-1, etc.)."
                            },
                            "sensor": {
                              "type": "string",
                              "description": "Sensor name (AWFI, WFI, MSI)."
                            },
                            "area_km2": {
                              "type": "double",
                              "description": "Area of the deforestation polygon in square kilometers."
                            },
                            "municipality": {
                              "type": [
                                "string",
                                "null"
                              ],
                              "description": "Municipality name."
                            },
                            "state_code": {
                              "type": [
                                "string",
                                "null"
                              ],
                              "description": "Brazilian state code (UF), e.g. PA, MT, when provided by INPE; null when omitted. The topic-safe state_slug field is used for MQTT routing."
                            },
                            "path_row": {
                              "type": [
                                "string",
                                "null"
                              ],
                              "description": "Satellite path/row identifier."
                            },
                            "publish_month": {
                              "type": [
                                "string",
                                "null"
                              ],
                              "description": "Publication month in YYYY-MM-DD format."
                            },
                            "centroid_latitude": {
                              "type": "double",
                              "description": "Latitude of the polygon centroid in decimal degrees."
                            },
                            "centroid_longitude": {
                              "type": "double",
                              "description": "Longitude of the polygon centroid in decimal degrees."
                            },
                            "state_slug": {
                              "type": "string",
                              "description": "Lowercased Brazilian state code (UF), e.g. pa, mt, used as a topic-safe MQTT routing axis; unknown when INPE omits the UF.",
                              "pattern": "^([a-z]{2}|unknown)$"
                            },
                            "class_slug": {
                              "type": "string",
                              "description": "Lowercase-kebab normalized DETER class used as a topic-safe MQTT routing axis, e.g. desmatamento-cr, degradacao, mineracao.",
                              "pattern": "^[a-z0-9][a-z0-9-]*$",
                              "enum": [
                                "desmatamento-cr",
                                "desmatamento-veg",
                                "degradacao",
                                "mineracao",
                                "cs-desordenado",
                                "cs-geometrico",
                                "cicatriz-de-queimada",
                                "corte-seletivo",
                                "unknown"
                              ]
                            }
                          },
                          "required": [
                            "alert_id",
                            "biome",
                            "classname",
                            "view_date",
                            "satellite",
                            "sensor",
                            "area_km2",
                            "centroid_latitude",
                            "centroid_longitude"
                          ],
                          "description": "INPE DETER deforestation alert for Amazon and Cerrado biomes."
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "BR.INPE.DETER.avro": {
      "schemas": {
        "BR.INPE.DETER.DeforestationAlert": {
          "name": "DeforestationAlert",
          "format": "Avro/1.11.3",
          "description": "INPE DETER deforestation alert for Amazon and Cerrado biomes.",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "Avro/1.11.3",
              "schema": {
                "type": "record",
                "name": "DeforestationAlert",
                "namespace": "BR.INPE.DETER",
                "doc": "INPE DETER deforestation alert for Amazon and Cerrado biomes.",
                "fields": [
                  {
                    "name": "alert_id",
                    "type": "string",
                    "doc": "Stable reference ID from INPE (gid)."
                  },
                  {
                    "name": "biome",
                    "type": "string",
                    "doc": "Biome of the alert: amazon or cerrado."
                  },
                  {
                    "name": "classname",
                    "type": "string",
                    "doc": "Deforestation class: DESMATAMENTO_CR, DEGRADACAO, MINERACAO, CS_DESORDENADO, etc."
                  },
                  {
                    "name": "view_date",
                    "type": "string",
                    "doc": "Observation date in YYYY-MM-DD format."
                  },
                  {
                    "name": "satellite",
                    "type": "string",
                    "doc": "Satellite name (CBERS-4, Amazonia-1, etc.)."
                  },
                  {
                    "name": "sensor",
                    "type": "string",
                    "doc": "Sensor name (AWFI, WFI, MSI)."
                  },
                  {
                    "name": "area_km2",
                    "type": "double",
                    "doc": "Area of the deforestation polygon in square kilometers."
                  },
                  {
                    "name": "municipality",
                    "type": [
                      "string",
                      "null"
                    ],
                    "doc": "Municipality name."
                  },
                  {
                    "name": "state_code",
                    "type": [
                      "string",
                      "null"
                    ],
                    "doc": "Brazilian state code (UF), e.g. PA, MT, when provided by INPE; null when omitted. The topic-safe state_slug field is used for MQTT routing."
                  },
                  {
                    "name": "state_slug",
                    "type": "string",
                    "doc": "Lowercased Brazilian state code (UF), e.g. pa, mt, used as a topic-safe MQTT routing axis; unknown when INPE omits or publishes an unsupported UF.",
                    "default": "unknown"
                  },
                  {
                    "name": "class_slug",
                    "type": "string",
                    "doc": "Lowercase-kebab normalized DETER class used as a topic-safe MQTT routing axis; unknown when the class is omitted or outside the supported DETER vocabulary.",
                    "default": "unknown"
                  },
                  {
                    "name": "path_row",
                    "type": [
                      "string",
                      "null"
                    ],
                    "doc": "Satellite path/row identifier."
                  },
                  {
                    "name": "publish_month",
                    "type": [
                      "string",
                      "null"
                    ],
                    "doc": "Publication month in YYYY-MM-DD format."
                  },
                  {
                    "name": "centroid_latitude",
                    "type": "double",
                    "doc": "Latitude of the polygon centroid in decimal degrees."
                  },
                  {
                    "name": "centroid_longitude",
                    "type": "double",
                    "doc": "Longitude of the polygon centroid in decimal degrees."
                  }
                ],
                "description": "Payload for an official alert or bulletin from Brazil's National Institute for Space Research (INPE). It carries DETER deforestation alerts for the affected area and validity period published by the upstream source."
              }
            }
          }
        }
      }
    }
  },
  "description": "INPE DETER Brazil publishes DETER deforestation alerts from Brazil's National Institute for Space Research (INPE) for Brazilian deforestation alert areas. These events help consumers monitor hazards, route notifications, and correlate public-warning updates without polling the upstream source directly.",
  "documentation": {
    "description": "Source documentation for INPE DETER Brazil, including upstream feed context and bridge deployment notes.",
    "url": "README.md"
  }
}
