{
  "endpoints": {
    "BR.INPE.DETER.Kafka": {
      "usage": [
        "producer"
      ],
      "protocol": "KAFKA",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "structured",
        "format": "application/cloudevents+json"
      },
      "protocoloptions": {
        "deployed": false,
        "options": {
          "topic": "inpe-deter-brazil",
          "key": "{biome}/{alert_id}"
        }
      },
      "messagegroups": [
        "#/messagegroups/BR.INPE.DETER"
      ]
    }
  },
