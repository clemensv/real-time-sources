.drop materialized-view DeforestationAlertLatest ifexists;

.create materialized-view with (backfill=true) DeforestationAlertLatest on table DeforestationAlert {
    DeforestationAlert | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [DeforestationAlert] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'BR.INPE.DETER.DeforestationAlert') | project['alert_id'] = tostring(data.['alert_id']),['biome'] = tostring(data.['biome']),['classname'] = tostring(data.['classname']),['view_date'] = tostring(data.['view_date']),['satellite'] = tostring(data.['satellite']),['sensor'] = tostring(data.['sensor']),['area_km2'] = toreal(data.['area_km2']),['municipality'] = tostring(data.['municipality']),['state_code'] = tostring(data.['state_code']),['path_row'] = tostring(data.['path_row']),['publish_month'] = tostring(data.['publish_month']),['centroid_latitude'] = toreal(data.['centroid_latitude']),['centroid_longitude'] = toreal(data.['centroid_longitude']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

