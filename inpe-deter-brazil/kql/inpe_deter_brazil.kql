.create-merge table [_cloudevents_dispatch] (
    [specversion]: string,
    [type]: string,
    [source]: string,
    [id]: string,
    [time]: datetime,
    [subject]: string,
    [datacontenttype]: string,
    [dataschema]: string,
    [data]: dynamic
);

.create-or-alter table [_cloudevents_dispatch] ingestion json mapping "_cloudevents_dispatch_json"
```
[
  {"column": "specversion", "path": "$.specversion"},
  {"column": "type", "path": "$.type"},
  {"column": "source", "path": "$.source"},
  {"column": "id", "path": "$.id"},
  {"column": "time", "path": "$.time"},
  {"column": "subject", "path": "$.subject"},
  {"column": "datacontenttype", "path": "$.datacontenttype"},
  {"column": "dataschema", "path": "$.dataschema"},
  {"column": "data", "path": "$.data"}
]
```

.create-merge table [DeforestationAlert] (
   [alert_id]: string,
   [biome]: string,
   [classname]: string,
   [view_date]: string,
   [satellite]: string,
   [sensor]: string,
   [area_km2]: real,
   [municipality]: string,
   [state_code]: string,
   [path_row]: string,
   [publish_month]: string,
   [centroid_latitude]: real,
   [centroid_longitude]: real,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [DeforestationAlert] docstring "{\"description\": \"INPE DETER deforestation alert for Amazon and Cerrado biomes.\"}";

.alter table [DeforestationAlert] column-docstrings (
   [alert_id]: "{\"description\": \"Stable reference ID from INPE (gid).\"}",
   [biome]: "{\"description\": \"Biome of the alert: amazon or cerrado.\"}",
   [classname]: "{\"description\": \"Deforestation class: DESMATAMENTO_CR, DEGRADACAO, MINERACAO, CS_DESORDENADO, etc.\"}",
   [view_date]: "{\"description\": \"Observation date in YYYY-MM-DD format.\"}",
   [satellite]: "{\"description\": \"Satellite name (CBERS-4, Amazonia-1, etc.).\"}",
   [sensor]: "{\"description\": \"Sensor name (AWFI, WFI, MSI).\"}",
   [area_km2]: "{\"description\": \"Area of the deforestation polygon in square kilometers.\"}",
   [municipality]: "{\"description\": \"Municipality name.\"}",
   [state_code]: "{\"description\": \"Brazilian state code (UF), e.g. PA, MT.\"}",
   [path_row]: "{\"description\": \"Satellite path/row identifier.\"}",
   [publish_month]: "{\"description\": \"Publication month in YYYY-MM-DD format.\"}",
   [centroid_latitude]: "{\"description\": \"Latitude of the polygon centroid in decimal degrees.\"}",
   [centroid_longitude]: "{\"description\": \"Longitude of the polygon centroid in decimal degrees.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

