  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'fi.digitraffic.marine.ais.VesselMetadata') | project ['mmsi'] = toint(data.['mmsi']), ['timestamp_ms'] = tolong(data.['timestamp']), ['name'] = tostring(data.['name']), ['call_sign'] = tostring(data.['callSign']), ['imo'] = toint(data.['imo']), ['ship_type'] = toint(data.['type']), ['draught'] = toint(data.['draught']), ['eta'] = toint(data.['eta']), ['destination'] = tostring(data.['destination']), ['pos_type'] = toint(data.['posType']), ['ref_a'] = toint(data.['refA']), ['ref_b'] = toint(data.['refB']), ['ref_c'] = toint(data.['refC']), ['ref_d'] = toint(data.['refD']), ___type = type, ___source = source, ___id = ['id'], ___time = ['time'], ___subject = subject",
