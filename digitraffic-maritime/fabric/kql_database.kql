```
{ "SoftDeletePeriod": "30.00:00:00", "Recoverability": "Enabled" }
```


// ===== Materialized views — latest state per vessel =====

// Latest position per vessel (MMSI)
.create-or-alter materialized-view with (backfill=true) VesselLocationLatest on table VesselLocation
{
    VesselLocation
    | summarize arg_max(___time, *) by mmsi
}

// Latest metadata per vessel (MMSI)
.create-or-alter materialized-view with (backfill=true) VesselMetadataLatest on table VesselMetadata
{
    VesselMetadata
    | summarize arg_max(___time, *) by mmsi
}


// ===== Functions =====

// All vessel positions joined with latest metadata for map display
.create-or-alter function with (docstring="Latest Finnish/Baltic vessel positions joined with metadata (name, type, destination) for map display") VesselPositionsFI() {
    let ship_type_lookup = datatable(ship_type: int, ship_type_name: string) [
        0, "Not available",
        20, "Wing in ground",
        21, "Wing in ground - Hazardous A",
        22, "Wing in ground - Hazardous B",
        23, "Wing in ground - Hazardous C",
        24, "Wing in ground - Hazardous D",
        30, "Fishing",
        31, "Towing",
        32, "Towing (large)",
        33, "Dredging/underwater ops",
        34, "Diving ops",
        35, "Military ops",
        36, "Sailing",
        37, "Pleasure craft",
        40, "High speed craft",
        41, "High speed craft - Hazardous A",
        42, "High speed craft - Hazardous B",
        43, "High speed craft - Hazardous C",
        44, "High speed craft - Hazardous D",
        50, "Pilot vessel",
        51, "Search and rescue",
        52, "Tug",
        53, "Port tender",
        54, "Anti-pollution",
        55, "Law enforcement",
        56, "Spare - Local vessel",
        57, "Spare - Local vessel",
        58, "Medical transport",
        59, "Noncombatant ship (RR Resolution No. 18)",
        60, "Passenger",
        61, "Passenger - Hazardous A",
        62, "Passenger - Hazardous B",
        63, "Passenger - Hazardous C",
        64, "Passenger - Hazardous D",
        70, "Cargo",
        71, "Cargo - Hazardous A",
        72, "Cargo - Hazardous B",
        73, "Cargo - Hazardous C",
        74, "Cargo - Hazardous D",
        80, "Tanker",
        81, "Tanker - Hazardous A",
        82, "Tanker - Hazardous B",
        83, "Tanker - Hazardous C",
        84, "Tanker - Hazardous D",
        90, "Other",
        91, "Other - Hazardous A",
        92, "Other - Hazardous B",
        93, "Other - Hazardous C",
        94, "Other - Hazardous D"
    ];
    let nav_status_lookup = datatable(nav_stat: int, nav_status_name: string) [
        0, "Under way using engine",
        1, "At anchor",
        2, "Not under command",
        3, "Restricted manoeuvrability",
        4, "Constrained by draught",
        5, "Moored",
        6, "Aground",
        7, "Engaged in fishing",
        8, "Under way sailing",
        11, "Power-driven vessel towing astern",
        12, "Power-driven vessel pushing ahead or towing alongside",
        14, "AIS-SART (active)",
        15, "Not defined"
    ];
    VesselLocationLatest
    | join kind=leftouter VesselMetadataLatest on mmsi
    | lookup ship_type_lookup on ship_type
    | lookup nav_status_lookup on nav_stat
    | project
        mmsi,
        name,
        call_sign,
        ship_type,
        ship_type_name = coalesce(ship_type_name, "Unknown"),
        imo,
        latitude,
        longitude,
        sog,
        cog,
        heading,
        nav_stat,
        nav_status_name = coalesce(nav_status_name, "Unknown"),
        destination,
        draught,
        last_update = ___time
}

// Message counts and vessel counts in the last hour
.create-or-alter function with (docstring="Message counts and unique vessel counts per event type in the last hour") AISStatistics() {
    union
        (VesselLocation | where ___time > ago(1h) | summarize messages=count(), vessels=dcount(mmsi) | extend type="VesselLocation"),
        (VesselMetadata | where ___time > ago(1h) | summarize messages=count(), vessels=dcount(mmsi) | extend type="VesselMetadata")
    | project type, messages, vessels
}

// Vessel track history for a given MMSI and time window
.create-or-alter function with (docstring="Vessel track history for a given MMSI over a time range") VesselTrack(target_mmsi: int, lookback: timespan = 24h) {
    VesselLocation
    | where mmsi == target_mmsi and ___time > ago(lookback)
    | order by ___time asc
    | project ___time, latitude, longitude, sog, cog, heading, nav_stat
}
