// ===== CloudEvents dispatch table (ingestion target) =====

.create-merge table [_cloudevents_dispatch] (
    [specversion]: string,
    [type]: string,
    [source]: string,
    [id]: string,
    [time]: datetime,
    [subject]: string,
    [datacontenttype]: string,
    [dataschema]: string,
    [data]: dynamic
);


.create-or-alter table [_cloudevents_dispatch] ingestion json mapping "_cloudevents_dispatch_json"
```
[
  {"column": "specversion", "path": "$.specversion"},
  {"column": "type", "path": "$.type"},
  {"column": "source", "path": "$.source"},
  {"column": "id", "path": "$.id"},
  {"column": "time", "path": "$.time"},
  {"column": "subject", "path": "$.subject"},
  {"column": "datacontenttype", "path": "$.datacontenttype"},
  {"column": "dataschema", "path": "$.dataschema"},
  {"column": "data", "path": "$.data"}
]
```


// ===== Typed tables =====

.create-merge table [VesselLocation] (
   [mmsi]: int,
   [time_epoch]: long,
   [sog]: real,
   [cog]: real,
   [nav_stat]: int,
   [rot]: int,
   [pos_acc]: bool,
   [raim]: bool,
   [heading]: int,
   [longitude]: real,
   [latitude]: real,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [VesselLocation] column-docstrings (
   [mmsi]: 'Maritime Mobile Service Identity (9 digits)',
   [time_epoch]: 'AIS timestamp in epoch seconds',
   [sog]: 'Speed over ground in knots (1/10 knot precision)',
   [cog]: 'Course over ground in degrees (1/10 degree precision)',
   [nav_stat]: 'Navigational status (0=under way using engine, 1=at anchor, 2=not under command, etc.)',
   [rot]: 'Rate of turn in degrees/minute (-127=left, 127=right, -128=not available)',
   [pos_acc]: 'Position accuracy — true if DGPS-quality (< 10 m)',
   [raim]: 'RAIM (Receiver Autonomous Integrity Monitoring) flag',
   [heading]: 'True heading in degrees (0-359, 511=not available)',
   [longitude]: 'Longitude in decimal degrees (WGS-84)',
   [latitude]: 'Latitude in decimal degrees (WGS-84)',
   [___type]: 'CloudEvents type',
   [___source]: 'CloudEvents source',
   [___id]: 'CloudEvents event identifier',
   [___time]: 'CloudEvents event time',
   [___subject]: 'CloudEvents subject'
);

.create-or-alter table [VesselLocation] ingestion json mapping "VesselLocation_json_flat"
```
[
  {"column": "___type", "path": "$.type"},
  {"column": "___source", "path": "$.source"},
  {"column": "___id", "path": "$.id"},
  {"column": "___time", "path": "$.time"},
  {"column": "___subject", "path": "$.subject"},
  {"column": "mmsi", "path": "$.data.mmsi"},
  {"column": "time_epoch", "path": "$.data.time"},
  {"column": "sog", "path": "$.data.sog"},
  {"column": "cog", "path": "$.data.cog"},
  {"column": "nav_stat", "path": "$.data.navStat"},
  {"column": "rot", "path": "$.data.rot"},
  {"column": "pos_acc", "path": "$.data.posAcc"},
  {"column": "raim", "path": "$.data.raim"},
  {"column": "heading", "path": "$.data.heading"},
  {"column": "longitude", "path": "$.data.lon"},
  {"column": "latitude", "path": "$.data.lat"}
]
```

.alter table [VesselLocation] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'fi.digitraffic.marine.ais.VesselLocation') | project ['mmsi'] = toint(data.['mmsi']), ['time_epoch'] = tolong(data.['time']), ['sog'] = toreal(data.['sog']), ['cog'] = toreal(data.['cog']), ['nav_stat'] = toint(data.['navStat']), ['rot'] = toint(data.['rot']), ['pos_acc'] = tobool(data.['posAcc']), ['raim'] = tobool(data.['raim']), ['heading'] = toint(data.['heading']), ['longitude'] = toreal(data.['lon']), ['latitude'] = toreal(data.['lat']), ___type = type, ___source = source, ___id = ['id'], ___time = ['time'], ___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true
}]
```


.create-merge table [VesselMetadata] (
   [mmsi]: int,
   [timestamp_ms]: long,
   [name]: string,
   [call_sign]: string,
   [imo]: int,
   [ship_type]: int,
   [draught]: int,
   [eta]: int,
   [destination]: string,
   [pos_type]: int,
   [ref_a]: int,
   [ref_b]: int,
   [ref_c]: int,
   [ref_d]: int,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [VesselMetadata] column-docstrings (
   [mmsi]: 'Maritime Mobile Service Identity',
   [timestamp_ms]: 'Metadata update timestamp in epoch milliseconds',
   [name]: 'Vessel name (up to 20 characters)',
   [call_sign]: 'International radio callsign (up to 7 characters)',
   [imo]: 'IMO ship identification number (0 if not available)',
   [ship_type]: 'Ship and cargo type code (0-99)',
   [draught]: 'Maximum present static draught in 1/10 m',
   [eta]: 'Estimated time of arrival — encoded as MMDDHHMM',
   [destination]: 'Destination port (up to 20 characters)',
   [pos_type]: 'Type of electronic position fixing device',
   [ref_a]: 'Distance from reference point to bow in meters',
   [ref_b]: 'Distance from reference point to stern in meters',
   [ref_c]: 'Distance from reference point to port side in meters',
   [ref_d]: 'Distance from reference point to starboard side in meters',
   [___type]: 'CloudEvents type',
   [___source]: 'CloudEvents source',
   [___id]: 'CloudEvents event identifier',
   [___time]: 'CloudEvents event time',
   [___subject]: 'CloudEvents subject'
);

.create-or-alter table [VesselMetadata] ingestion json mapping "VesselMetadata_json_flat"
