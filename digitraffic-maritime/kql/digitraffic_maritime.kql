.drop materialized-view PortLocationLatest ifexists;

.create materialized-view with (backfill=true) PortLocationLatest on table PortLocation {
    PortLocation | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [PortLocation] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'fi.digitraffic.marine.portcall.PortLocation') | project['locode'] = tostring(data.['locode']),['data_updated_time'] = todatetime(data.['data_updated_time']),['location_name'] = tostring(data.['location_name']),['country'] = tostring(data.['country']),['longitude'] = toreal(data.['longitude']),['latitude'] = toreal(data.['latitude']),['port_areas'] = todynamic(data.['port_areas']),['berths'] = todynamic(data.['berths']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

