[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'fi.digitraffic.marine.ais.VesselLocation') | project['mmsi'] = toint(data.['mmsi']),['time'] = toint(data.['time']),['sog'] = toreal(data.['sog']),['cog'] = toreal(data.['cog']),['navStat'] = toint(data.['navStat']),['rot'] = toint(data.['rot']),['posAcc'] = tobool(data.['posAcc']),['raim'] = tobool(data.['raim']),['heading'] = toint(data.['heading']),['lon'] = toreal(data.['lon']),['lat'] = toreal(data.['lat']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

