.create-merge table [PortCall] (
   [port_call_id]: int,
   [updated_at]: datetime,
   [customs_reference]: string,
   [port_to_visit]: string,
   [previous_port]: string,
   [next_port]: string,
   [mmsi]: int,
   [imo_lloyds]: int,
   [vessel_name]: string,
   [vessel_name_prefix]: string,
   [radio_call_sign]: string,
   [nationality]: string,
   [vessel_type_code]: int,
   [domestic_traffic_arrival]: bool,
   [domestic_traffic_departure]: bool,
   [arrival_with_cargo]: bool,
   [not_loading]: bool,
   [discharge]: int,
   [current_security_level]: int,
   [agents]: dynamic,
   [port_areas]: dynamic,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [PortCall] docstring "{\"description\": \"Port call update from Digitraffic's Portnet-backed port-call API. Each event represents one vessel visit plan or update keyed by the Digitraffic port call identifier and carries the vessel identity, routing context, assigned agents, and berth-area timing details.\"}";

.alter table [PortCall] column-docstrings (
   [port_call_id]: "{\"description\": \"Digitraffic port call identifier for this Portnet vessel visit record.\"}",
   [updated_at]: "{\"description\": \"Timestamp when this port call record was last updated in Digitraffic, from the portCallTimestamp field.\"}",
   [customs_reference]: "{\"description\": \"Customs reference string carried with the port call when available.\"}",
   [port_to_visit]: "{\"description\": \"UN/LOCODE of the destination port that this call is scheduled to visit.\"}",
   [previous_port]: "{\"description\": \"UN/LOCODE of the vessel's previous port when reported by Portnet.\"}",
   [next_port]: "{\"description\": \"UN/LOCODE of the vessel's next announced port when reported by Portnet.\"}",
   [mmsi]: "{\"description\": \"Maritime Mobile Service Identity associated with the visiting vessel, when available.\"}",
   [imo_lloyds]: "{\"description\": \"IMO or Lloyd's vessel number carried with the port call when available.\"}",
   [vessel_name]: "{\"description\": \"Reported vessel name for the visit.\"}",
   [vessel_name_prefix]: "{\"description\": \"Reported vessel name prefix such as 'ms' or 'mt' when present.\"}",
   [radio_call_sign]: "{\"description\": \"Radio call sign for the visiting vessel when reported by Portnet.\"}",
   [nationality]: "{\"description\": \"Flag or nationality code reported for the vessel.\"}",
   [vessel_type_code]: "{\"description\": \"Digitraffic vessel type code for the visiting vessel.\"}",
   [domestic_traffic_arrival]: "{\"description\": \"True when the arrival leg is domestic traffic.\"}",
   [domestic_traffic_departure]: "{\"description\": \"True when the departure leg is domestic traffic.\"}",
   [arrival_with_cargo]: "{\"description\": \"True when the vessel is reported as arriving with cargo.\"}",
   [not_loading]: "{\"description\": \"True when the vessel is reported as not loading cargo at the call.\"}",
   [discharge]: "{\"description\": \"Digitraffic discharge indicator value for the call when reported.\"}",
   [current_security_level]: "{\"description\": \"Current ISPS security level reported for the vessel at this call.\"}",
   [agents]: "{\"description\": \"Agent and manager organizations attached to the port call.\", \"schema\": {\"type\": \"array\", \"description\": \"Agent and manager organizations attached to the port call.\", \"items\": {\"type\": \"object\", \"name\": \"PortCallAgent\", \"description\": \"One agent or manager assignment attached to the port call.\", \"required\": [\"name\", \"port_call_direction\", \"role\"], \"properties\": {\"name\": {\"type\": \"string\", \"description\": \"Organization name for the assigned ship agent or manager.\"}, \"port_call_direction\": {\"type\": \"string\", \"description\": \"Direction scope for the assignment, such as arrival, departure, or whole port call.\"}, \"role\": {\"type\": \"int32\", \"description\": \"Digitraffic role code for the assignment, for example agent or ship manager.\"}}}}}",
   [port_areas]: "{\"description\": \"Planned or actual berth and port-area timing details associated with the call.\", \"schema\": \"{ \\\"doc\\\": \\\"Schema too large to inline. Please refer to the JSON Structure schema for more details.\\\" }\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

.create-or-alter table [PortCall] ingestion json mapping "PortCall_json_flat"
