.create-merge table [PortLocation] (
   [locode]: string,
   [data_updated_time]: datetime,
   [location_name]: string,
   [country]: string,
   [longitude]: real,
   [latitude]: real,
   [port_areas]: dynamic,
   [berths]: dynamic,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [PortLocation] docstring "{\"description\": \"Reference record from Digitraffic's Port Call ports API. Each event represents one SafeSeaNet port location keyed by UN/LOCODE together with its point geometry, port-area definitions, and berth catalog from the same upstream snapshot.\"}";

.alter table [PortLocation] column-docstrings (
   [locode]: "{\"description\": \"UN/LOCODE identifying the port location. This value is used as the CloudEvents subject and Kafka record key for port-location reference events.\"}",
   [data_updated_time]: "{\"description\": \"Timestamp when the ports snapshot used for this location was last updated in Digitraffic.\"}",
   [location_name]: "{\"description\": \"Human-readable port or location name from the ssnLocations feature properties.\"}",
   [country]: "{\"description\": \"Country name reported for the location in the ssnLocations feature properties.\"}",
   [longitude]: "{\"description\": \"Longitude of the port location point in decimal degrees east when the upstream feature includes geometry.\"}",
   [latitude]: "{\"description\": \"Latitude of the port location point in decimal degrees north when the upstream feature includes geometry.\"}",
   [port_areas]: "{\"description\": \"Port areas associated with this location from the portAreas feature collection.\", \"schema\": {\"type\": \"array\", \"description\": \"Port areas associated with this location from the portAreas feature collection.\", \"items\": {\"type\": \"object\", \"name\": \"PortArea\", \"required\": [\"port_area_code\", \"port_area_name\"], \"properties\": {\"port_area_code\": {\"type\": \"string\", \"description\": \"Port-area code identifying one sub-area of the port location.\"}, \"port_area_name\": {\"type\": \"string\", \"description\": \"Human-readable name of the port area.\"}, \"longitude\": {\"type\": \"double\", \"description\": \"Longitude of the port-area point in decimal degrees east when the upstream feature includes geometry.\", \"unit\": \"deg\", \"symbol\": \"deg\"}, \"latitude\": {\"type\": \"double\", \"description\": \"Latitude of the port-area point in decimal degrees north when the upstream feature includes geometry.\", \"unit\": \"deg\", \"symbol\": \"deg\"}}}}}",
   [berths]: "{\"description\": \"Berth catalog entries associated with this location from the berths collection.\", \"schema\": {\"type\": \"array\", \"description\": \"Berth catalog entries associated with this location from the berths collection.\", \"items\": {\"type\": \"object\", \"name\": \"Berth\", \"required\": [\"port_area_code\", \"berth_code\", \"berth_name\"], \"properties\": {\"port_area_code\": {\"type\": \"string\", \"description\": \"Code of the port area that contains this berth.\"}, \"berth_code\": {\"type\": \"string\", \"description\": \"Berth code within the port area.\"}, \"berth_name\": {\"type\": \"string\", \"description\": \"Human-readable berth name.\"}}}}}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

