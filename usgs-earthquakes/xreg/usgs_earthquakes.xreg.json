{
  "endpoints": {
    "USGS.Earthquakes.Kafka": {
      "usage": [
        "producer"
      ],
      "protocol": "KAFKA",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "structured",
        "format": "application/cloudevents+json"
      },
      "protocoloptions": {
        "deployed": false,
        "options": {
          "topic": "usgs-earthquakes",
          "key": "{net}/{code}"
        }
      },
      "messagegroups": [
        "#/messagegroups/USGS.Earthquakes"
      ]
    },
    "USGS.Earthquakes.Mqtt": {
      "usage": [
        "producer"
      ],
      "protocol": "MQTT/5.0",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "binary"
      },
      "deployed": false,
      "endpoints": [
        {
          "uri": "mqtt://localhost:1883"
        }
      ],
      "messagegroups": [
        "#/messagegroups/USGS.Earthquakes.mqtt"
      ]
    },
    "USGS.Earthquakes.Amqp": {
      "usage": [
        "producer"
      ],
      "protocol": "AMQP/1.0",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "binary"
      },
      "protocoloptions": {
        "deployed": false,
        "endpoints": [
          {
            "uri": "amqps://localhost:5671/usgs-earthquakes"
          }
        ]
      },
      "messagegroups": [
        "#/messagegroups/USGS.Earthquakes.amqp"
      ],
      "description": "AMQP 1.0 producer endpoint for usgs-earthquakes CloudEvents on the configured broker address."
    }
  },
  "messagegroups": {
    "USGS.Earthquakes": {
      "messages": {
        "USGS.Earthquakes.Event": {
          "name": "Event",
          "envelope": "CloudEvents/1.0",
          "description": "USGS earthquake event data from the Earthquake Hazards Program.",
          "envelopemetadata": {
            "type": {
              "value": "USGS.Earthquakes.Event"
            },
            "source": {
              "value": "{source_uri}",
              "type": "uritemplate"
            },
            "subject": {
              "value": "{net}/{code}",
              "type": "uritemplate"
            },
            "time": {
              "value": "{event_time}",
              "type": "timestamp"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/USGS.Earthquakes.jstruct/schemas/USGS.Earthquakes.Event"
        }
      }
    },
    "USGS.Earthquakes.mqtt": {
      "description": "MQTT/5.0 transport variant for USGS earthquake events. Non-retained QoS-1 event stream routed by contributor network, magnitude bucket, and event code under seismic/intl/usgs/usgs-earthquakes/... Buckets are m0 for <1 or unknown, m1..m6 for [1,7), and m7plus for >=7.",
      "messages": {
        "USGS.Earthquakes.mqtt.Event": {
          "name": "Event",
          "basemessageuri": "/messagegroups/USGS.Earthquakes/messages/USGS.Earthquakes.Event",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "topic_name": "seismic/intl/usgs/usgs-earthquakes/{net}/{magnitude_bucket}/{code}/quake",
            "qos": 1,
            "retain": false
          }
        }
      }
    },
    "USGS.Earthquakes.amqp": {
      "description": "AMQP 1.0 transport variant for usgs-earthquakes events. It carries the same CloudEvents and payload schemas as the source events on one broker address for queue- and topic-oriented consumers.",
      "messages": {
        "USGS.Earthquakes.amqp.Event": {
          "name": "Event",
          "basemessageuri": "/messagegroups/USGS.Earthquakes/messages/USGS.Earthquakes.Event",
          "protocol": "AMQP/1.0",
          "protocoloptions": {
            "properties": {
              "subject": {
                "type": "uritemplate",
                "value": "{net}/{code}",
                "description": "AMQP message subject — stable entity identifier matching the CloudEvent subject and Kafka key for this event family."
              }
            }
          }
        }
      }
    }
  },
