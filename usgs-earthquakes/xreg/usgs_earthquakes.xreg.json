                            "description": "Link to GeoJSON detail feed for this event."
                          },
                          "felt": {
                            "type": [
                              "int32",
                              "null"
                            ],
                            "description": "Number of felt reports submitted to the DYFI system."
                          },
                          "cdi": {
                            "type": [
                              "double",
                              "null"
                            ],
                            "description": "Maximum reported community determined intensity (DYFI)."
                          },
                          "mmi": {
                            "type": [
                              "double",
                              "null"
                            ],
                            "description": "Maximum estimated instrumental intensity (ShakeMap)."
                          },
                          "alert": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "description": "PAGER alert level (green, yellow, orange, red)."
                          },
                          "status": {
                            "type": "string",
                            "description": "Review status of the event (automatic, reviewed, deleted)."
                          },
                          "tsunami": {
                            "type": "int32",
                            "description": "Flag indicating whether the event has a tsunami advisory (1=yes, 0=no)."
                          },
                          "sig": {
                            "type": [
                              "int32",
                              "null"
                            ],
                            "description": "Significance of the event, a number describing how significant the event is (0-1000)."
                          },
                          "net": {
                            "type": "string",
                            "description": "ID of the data contributor network."
                          },
                          "code": {
                            "type": "string",
                            "description": "Identifying code assigned by the corresponding source for the event."
                          },
                          "sources": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "description": "Comma-separated list of network contributors."
                          },
                          "nst": {
                            "type": [
                              "int32",
                              "null"
                            ],
                            "description": "Number of seismic stations used to determine earthquake location."
                          },
                          "dmin": {
                            "type": [
                              "double",
                              "null"
                            ],
                            "description": "Horizontal distance from the epicenter to the nearest station (degrees)."
                          },
                          "rms": {
                            "type": [
                              "double",
                              "null"
                            ],
                            "description": "Root-mean-square travel time residual (seconds)."
                          },
                          "gap": {
                            "type": [
                              "double",
                              "null"
                            ],
                            "description": "Largest azimuthal gap between azimuthally adjacent stations (degrees)."
                          },
                          "event_type": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "description": "Type of seismic event (earthquake, quarry blast, etc.)."
                          },
                          "latitude": {
                            "type": "double",
                            "description": "Latitude of the earthquake epicenter in decimal degrees."
                          },
                          "longitude": {
                            "type": "double",
                            "description": "Longitude of the earthquake epicenter in decimal degrees."
                          },
                          "depth": {
                            "type": [
                              "double",
                              "null"
                            ],
                            "description": "Depth of the earthquake in kilometers."
                          },
                          "magnitude_bucket": {
                            "type": "string",
                            "description": "Topic-safe magnitude bucket: m0 for magnitude <1 or unknown, m1..m6 for [1,7), and m7plus for magnitude >=7."
                          }
                        },
                        "required": [
                          "id",
                          "event_time",
                          "updated",
                          "status",
                          "tsunami",
                          "net",
                          "code",
                          "latitude",
                          "longitude",
                          "magnitude_bucket"
                        ],
                        "description": "USGS earthquake event data from the Earthquake Hazards Program."
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
