.create-merge table [VesselLocation] (
   [vessel_id]: string,
   [vessel_name]: string,
   [mmsi]: int,
   [in_service]: bool,
   [at_dock]: bool,
   [latitude]: real,
   [longitude]: real,
   [speed]: real,
   [heading]: int,
   [departing_terminal_id]: int,
   [departing_terminal_name]: string,
   [departing_terminal_abbrev]: string,
   [arriving_terminal_id]: int,
   [arriving_terminal_name]: string,
   [arriving_terminal_abbrev]: string,
   [scheduled_departure]: string,
   [left_dock]: string,
   [eta]: string,
   [eta_basis]: string,
   [route_abbreviation]: string,
   [timestamp]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [VesselLocation] docstring "{\"description\": \"Real-time location and status of a Washington State Ferries vessel.\"}";

.alter table [VesselLocation] column-docstrings (
   [vessel_id]: "{\"description\": \"Vessel identifier, stringified from upstream VesselID.\"}",
   [vessel_name]: "{\"description\": \"Ferry vessel name.\"}",
   [mmsi]: "{\"description\": \"Maritime Mobile Service Identity for AIS.\"}",
   [in_service]: "{\"description\": \"True if in active service.\"}",
   [at_dock]: "{\"description\": \"True if docked.\"}",
   [latitude]: "{\"description\": \"Latitude in WGS84.\"}",
   [longitude]: "{\"description\": \"Longitude in WGS84.\"}",
   [speed]: "{\"description\": \"Speed in knots.\"}",
   [heading]: "{\"description\": \"Heading in degrees.\"}",
   [departing_terminal_id]: "{\"description\": \"Departure terminal ID.\"}",
   [departing_terminal_name]: "{\"description\": \"Departure terminal name.\"}",
   [departing_terminal_abbrev]: "{\"description\": \"Departure terminal abbreviation.\"}",
   [arriving_terminal_id]: "{\"description\": \"Arrival terminal ID.\"}",
   [arriving_terminal_name]: "{\"description\": \"Arrival terminal name.\"}",
   [arriving_terminal_abbrev]: "{\"description\": \"Arrival terminal abbreviation.\"}",
   [scheduled_departure]: "{\"description\": \"ISO 8601 UTC scheduled departure.\"}",
   [left_dock]: "{\"description\": \"ISO 8601 UTC actual departure.\"}",
   [eta]: "{\"description\": \"ISO 8601 UTC estimated arrival.\"}",
   [eta_basis]: "{\"description\": \"ETA calculation description.\"}",
   [route_abbreviation]: "{\"description\": \"Current route abbreviation.\"}",
   [timestamp]: "{\"description\": \"ISO 8601 UTC position timestamp.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

