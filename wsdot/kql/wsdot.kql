.alter table [MountainPassCondition] docstring "{\"description\": \"Current conditions at a Washington State mountain pass. WSDOT monitors 16 mountain passes reporting temperature, weather, road conditions, travel advisories, and directional restrictions.\"}";

.alter table [MountainPassCondition] column-docstrings (
   [mountain_pass_id]: "{\"description\": \"Unique pass identifier, stringified from upstream MountainPassId.\"}",
   [mountain_pass_name]: "{\"description\": \"Pass name with highway designation.\"}",
   [elevation_in_feet]: "{\"description\": \"Summit elevation in feet above sea level.\"}",
   [latitude]: "{\"description\": \"Latitude in WGS84.\"}",
   [longitude]: "{\"description\": \"Longitude in WGS84.\"}",
   [temperature_in_fahrenheit]: "{\"description\": \"Temperature at the summit in Fahrenheit. Null if not reporting.\"}",
   [weather_condition]: "{\"description\": \"Current weather condition text. Examples: Clear, Rain, Snow, Fog.\"}",
   [road_condition]: "{\"description\": \"Road surface condition text. Examples: Dry, Wet, Compact Snow, Ice.\"}",
   [travel_advisory_active]: "{\"description\": \"True if a travel advisory is in effect.\"}",
   [restriction_one_direction]: "{\"description\": \"Direction for first restriction.\"}",
   [restriction_one_text]: "{\"description\": \"First restriction text.\"}",
   [restriction_two_direction]: "{\"description\": \"Direction for second restriction.\"}",
   [restriction_two_text]: "{\"description\": \"Second restriction text.\"}",
   [date_updated]: "{\"description\": \"ISO 8601 UTC timestamp of last update.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

