   [start_description]: "{\"description\": \"Start point description.\"}",
   [start_road_name]: "{\"description\": \"Road at start point.\"}",
   [start_direction]: "{\"description\": \"Direction at start point.\"}",
   [start_milepost]: "{\"description\": \"Milepost at start.\"}",
   [start_latitude]: "{\"description\": \"Start latitude in WGS84.\"}",
