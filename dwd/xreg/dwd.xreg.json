    "DE.DWD.IconD2.jstruct": {
      "schemas": {
        "DE.DWD.IconD2.Grid": {
          "name": "Grid",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/extended/v0/#",
                "$id": "https://example.com/schemas/DE/DWD/IconD2/Grid",
                "name": "Grid",
                "type": "object",
                "description": "An ICON-D2 forecast grid for one model run, one parameter, and one lead hour. Values are pre-aggregated to a regular 0.1 degree lat/lon grid by area mean over the source ICON triangular cells. The lats/lons/values arrays have the same length and are aligned by index: cell i has coordinates (lats[i], lons[i]) and value values[i].",
                "required": [
                  "run_id",
                  "run_time",
                  "parameter",
                  "unit",
                  "lead_hour",
                  "valid_time",
                  "produced_at",
                  "source_url",
                  "resolution_deg",
                  "bbox_min_lon",
                  "bbox_min_lat",
                  "bbox_max_lon",
                  "bbox_max_lat",
                  "lats",
                  "lons",
                  "values"
                ],
                "properties": {
                  "run_id": {
                    "type": "string",
                    "description": "Compact run identifier in the form YYYYMMDDHH (UTC). Used in Kafka subject and source URL.",
                    "pattern": "^\\d{10}$"
                  },
                  "run_time": {
                    "type": "string",
                    "description": "Model initialization time in ISO 8601 UTC, e.g. 2026-05-18T00:00:00Z."
                  },
                  "parameter": {
                    "type": "string",
                    "description": "DWD short name of the ICON-D2 parameter, e.g. t_2m, tot_prec, vmax_10m, clct, cape_ml, dbz_cmax, pmsl, h_snow.",
                    "altenums": {
                      "t_2m": "2 m air temperature (K in upstream GRIB, converted to degC by the bridge)",
                      "tot_prec": "Accumulated total precipitation since run start",
                      "vmax_10m": "10 m wind-gust maximum over the past hour",
                      "clct": "Total cloud cover",
                      "cape_ml": "Convective available potential energy, mixed-layer",
                      "dbz_cmax": "Simulated column-maximum radar reflectivity",
                      "pmsl": "Mean sea-level pressure (Pa in upstream GRIB, converted to hPa by the bridge)",
                      "h_snow": "Snow depth (water equivalent depth not included)"
                    }
                  },
                  "unit": {
                    "type": "string",
                    "description": "Unit of the values array after bridge-side conversion (e.g. degC, mm, m/s, %, J/kg, dBZ, hPa, m).",
                    "symbol": "unit"
                  },
                  "lead_hour": {
                    "type": "int32",
                    "description": "Forecast lead time in hours from run_time. ICON-D2 publishes 0..48 inclusive.",
                    "minimum": 0,
                    "maximum": 48
                  },
                  "valid_time": {
                    "type": "string",
                    "description": "ISO 8601 UTC datetime to which the forecast applies = run_time + lead_hour hours."
                  },
                  "produced_at": {
                    "type": "string",
                    "description": "ISO 8601 UTC datetime at which the bridge emitted this event."
                  },
                  "source_url": {
                    "type": "string",
                    "description": "Fully qualified URL of the upstream GRIB2.bz2 file from which this grid was decoded."
                  },
                  "resolution_deg": {
                    "type": "double",
                    "description": "Cell side length in degrees of the regular lat/lon aggregation grid (e.g. 0.1).",
                    "unit": "degree",
                    "symbol": "deg"
                  },
                  "bbox_min_lon": {
                    "type": "double",
                    "unit": "degree",
                    "symbol": "deg",
                    "description": "Minimum longitude of the aggregation bounding box."
                  },
                  "bbox_min_lat": {
                    "type": "double",
                    "unit": "degree",
                    "symbol": "deg",
                    "description": "Minimum latitude of the aggregation bounding box."
                  },
                  "bbox_max_lon": {
                    "type": "double",
                    "unit": "degree",
                    "symbol": "deg",
                    "description": "Maximum longitude of the aggregation bounding box."
                  },
                  "bbox_max_lat": {
                    "type": "double",
                    "unit": "degree",
                    "symbol": "deg",
                    "description": "Maximum latitude of the aggregation bounding box."
                  },
                  "lats": {
                    "type": "array",
                    "description": "Cell centre latitudes in degrees north, aligned by index with lons[] and values[].",
                    "items": {
                      "type": "double",
                      "unit": "degree",
                      "symbol": "deg"
                    }
                  },
                  "lons": {
                    "type": "array",
                    "description": "Cell centre longitudes in degrees east, aligned by index with lats[] and values[].",
                    "items": {
                      "type": "double",
                      "unit": "degree",
                      "symbol": "deg"
                    }
                  },
                  "values": {
                    "type": "array",
                    "description": "Parameter values in the unit advertised by `unit`, aligned by index with lats[] and lons[]. Missing cells are omitted from all three arrays.",
                    "items": {
                      "type": "double"
                    }
                  }
                },
                "namespace": "de.dwd.icond2"
              }
            }
          }
        }
      }
    }
  }
