# syntax=docker/dockerfile:1.6
FROM python:3.10-slim

LABEL org.opencontainers.image.source="https://github.com/clemensv/real-time-sources/tree/main/tfl-road-traffic"
LABEL org.opencontainers.image.title="Tfl Road Traffic â†’ AMQP 1.0 bridge"
LABEL org.opencontainers.image.description="Publishes Tfl Road Traffic CloudEvents over AMQP 1.0 to generic AMQP brokers and Azure Service Bus/Event Hubs via CBS."
LABEL org.opencontainers.image.documentation="https://github.com/clemensv/real-time-sources/blob/main/tfl-road-traffic/CONTAINER.md"
LABEL org.opencontainers.image.license="MIT"

ENV PYTHONUNBUFFERED=1
WORKDIR /app
RUN apt-get update \
 && apt-get install -y --no-install-recommends build-essential cmake pkg-config swig libssl-dev libsasl2-dev python3-dev libsasl2-2 libsasl2-modules \
 && rm -rf /var/lib/apt/lists/*
COPY . /app
RUN pip install --no-cache-dir ./tfl_road_traffic_amqp_producer/tfl_road_traffic_amqp_producer_data \
 && pip install --no-cache-dir ./tfl_road_traffic_amqp_producer/tfl_road_traffic_amqp_producer_amqp_producer \
 && pip install --no-cache-dir ./tfl_road_traffic_mqtt_producer/tfl_road_traffic_mqtt_producer_data \
 && pip install --no-cache-dir ./tfl_road_traffic_producer/tfl_road_traffic_producer_data \
 && pip install --no-cache-dir . \
 && pip install --no-cache-dir ./tfl_road_traffic_mqtt \
 && pip install --no-cache-dir ./tfl_road_traffic_amqp \
 && apt-get purge -y --auto-remove build-essential cmake pkg-config swig libssl-dev libsasl2-dev python3-dev \
 && rm -rf /root/.cache /var/lib/apt/lists/*
ENV AMQP_BROKER_URL=""
ENV AMQP_ADDRESS="tfl-road-traffic"
CMD ["python", "-m", "tfl_road_traffic_amqp", "feed"]
