  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'SE.Gov.SMHI.Weather.WeatherObservation') | project['station_id'] = tostring(data.['station_id']),['station_name'] = tostring(data.['station_name']),['observation_time'] = todatetime(data.['observation_time']),['air_temperature'] = toreal(data.['air_temperature']),['wind_gust'] = toreal(data.['wind_gust']),['dew_point'] = toreal(data.['dew_point']),['air_pressure'] = toreal(data.['air_pressure']),['relative_humidity'] = toint(data.['relative_humidity']),['precipitation_last_hour'] = toreal(data.['precipitation_last_hour']),['wind_direction'] = toreal(data.['wind_direction']),['wind_speed'] = toreal(data.['wind_speed']),['max_wind_speed'] = toreal(data.['max_wind_speed']),['visibility'] = toreal(data.['visibility']),['total_cloud_cover'] = toint(data.['total_cloud_cover']),['present_weather'] = toint(data.['present_weather']),['sunshine_duration'] = toreal(data.['sunshine_duration']),['global_irradiance'] = toreal(data.['global_irradiance']),['precipitation_intensity'] = toreal(data.['precipitation_intensity']),['quality'] = tostring(data.['quality']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
