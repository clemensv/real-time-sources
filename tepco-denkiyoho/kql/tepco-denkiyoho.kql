.create-merge table [_cloudevents_dispatch] (
    [specversion]: string,
    [type]: string,
    [source]: string,
    [id]: string,
    [time]: datetime,
    [subject]: string,
    [datacontenttype]: string,
    [dataschema]: string,
    [data]: dynamic
);

.create-or-alter table [_cloudevents_dispatch] ingestion json mapping "_cloudevents_dispatch_json"
```
[
  {"column": "specversion", "path": "$.specversion"},
  {"column": "type", "path": "$.type"},
  {"column": "source", "path": "$.source"},
  {"column": "id", "path": "$.id"},
  {"column": "time", "path": "$.time"},
  {"column": "subject", "path": "$.subject"},
  {"column": "datacontenttype", "path": "$.datacontenttype"},
  {"column": "dataschema", "path": "$.dataschema"},
  {"column": "data", "path": "$.data"}
]
```

.create-merge table ['jp.tepco.denkiyoho.SupplyCapacity'] (
   [date]: string,
   [time]: string,
   [peak_supply_capacity_mw]: real,
   [peak_supply_capacity_jp_unit_value]: int,
   [peak_time_slot]: string,
   [peak_reserve_margin_pct]: real,
   [peak_usage_pct]: real,
   [daily_max_usage_pct]: real,
   [daily_max_usage_time_slot]: string,
   [update_datetime]: string,
   [update_datetime_local]: string,
   [area_code]: string,
   [area_name_jp]: string,
   [area_name_en]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table ['jp.tepco.denkiyoho.SupplyCapacity'] docstring "{\"description\": \"Daily reference schema for TEPCO Electricity Forecast supply capability and daily maximum-usage summary metadata. The source CSV is Shift-JIS encoded and section 1 reports peak supply capacity, reserve margin, usage percentage, and update time for the Tokyo Electric Power Company service area.\"}";

.alter table ['jp.tepco.denkiyoho.SupplyCapacity'] column-docstrings (
   [date]: "{\"description\": \"Service date for TEPCO's Electricity Forecast daily CSV in local Tokyo time, normalized from the DATE column to ISO 8601 calendar-date form (YYYY-MM-DD). This date is a stable key component for all records from the same operating day.\"}",
   [time]: "{\"description\": \"Stable subject and Kafka key time component. Supply capacity is daily reference data rather than a point-in-time demand measurement, so the bridge sets this field to the sentinel value _supply_capacity_ while using the same jp.tepco.denkiyoho/{date}/{time} key model as demand events.\"}",
   [peak_supply_capacity_mw]: "{\"description\": \"Peak-time available supply capability for the Tokyo service area shown by TEPCO as \\u30d4\\u30fc\\u30af\\u6642\\u4f9b\\u7d66\\u529b(\\u4e07kW). The bridge converts the published 10,000-kilowatt unit to megawatts by multiplying the source value by 10.\"}",
   [peak_supply_capacity_jp_unit_value]: "{\"description\": \"Original integer value from TEPCO's \\u30d4\\u30fc\\u30af\\u6642\\u4f9b\\u7d66\\u529b(\\u4e07kW) header field. TEPCO publishes demand and supply values in \\u4e07kW, where one unit is 10,000 kilowatts, equal to 10 megawatts.\"}",
   [peak_time_slot]: "{\"description\": \"Local Japan Standard Time hour range from TEPCO's section 1 \\u6642\\u9593\\u5e2f column indicating the peak supply-capability time slot, normalized to an ASCII hyphen such as 13:00-14:00.\"}",
   [peak_reserve_margin_pct]: "{\"description\": \"Peak-time reserve margin percentage from TEPCO's section 1 \\u30d4\\u30fc\\u30af\\u6642\\u4e88\\u5099\\u7387(%) column for the published peak supply-capability slot.\"}",
   [peak_usage_pct]: "{\"description\": \"Peak-time usage percentage from TEPCO's section 1 \\u30d4\\u30fc\\u30af\\u6642\\u4f7f\\u7528\\u7387(%) column for the published peak supply-capability slot.\"}",
   [daily_max_usage_pct]: "{\"description\": \"Daily maximum usage percentage from TEPCO's section 4 \\u6700\\u5927\\u4f7f\\u7528\\u7387(%) summary row. The field is null when that section is absent or blank in the CSV.\"}",
   [daily_max_usage_time_slot]: "{\"description\": \"Local Japan Standard Time hour range from TEPCO's section 4 \\u6642\\u9593\\u5e2f column for the daily maximum usage percentage, normalized to an ASCII hyphen such as 4:00-5:00. The field is null when that section is absent or blank.\"}",
   [update_datetime]: "{\"description\": \"Section 1 supply-capability information update timestamp converted from Japan Standard Time to UTC and serialized as an RFC 3339 timestamp. TEPCO publishes the date and time in \\u4f9b\\u7d66\\u529b\\u60c5\\u5831\\u66f4\\u65b0\\u65e5 and \\u4f9b\\u7d66\\u529b\\u60c5\\u5831\\u66f4\\u65b0\\u6642\\u523b.\"}",
   [update_datetime_local]: "{\"description\": \"Section 1 supply-capability information update timestamp in Japan Standard Time serialized as an RFC 3339 timestamp with +09:00 offset, built from TEPCO's \\u4f9b\\u7d66\\u529b\\u60c5\\u5831\\u66f4\\u65b0\\u65e5 and \\u4f9b\\u7d66\\u529b\\u60c5\\u5831\\u66f4\\u65b0\\u6642\\u523b columns.\"}",
   [area_code]: "{\"description\": \"Constant service-area code TEPCO assigned by this bridge for the Tokyo Electric Power Company service area covered by the Electricity Forecast page.\"}",
   [area_name_jp]: "{\"description\": \"Japanese name of the TEPCO Power Grid service area used by the Electricity Forecast page: \\u6771\\u4eac\\u96fb\\u529b\\u30a8\\u30ea\\u30a2. The page defines this as Tokyo plus Kanagawa, Saitama, Chiba, Tochigi, Gunma, Ibaraki, Yamanashi, and the portion of Shizuoka east of the Fujikawa River.\"}",
   [area_name_en]: "{\"description\": \"English display name for the TEPCO service territory covered by the Electricity Forecast page: TEPCO Service Area (Kanto).\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

