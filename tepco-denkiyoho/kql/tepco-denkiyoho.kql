.alter table ['jp.tepco.denkiyoho.DemandActual'] docstring "{\"description\": \"Telemetry schema for actual TEPCO electricity demand in the Tokyo Electric Power Company service area. Hourly rows from section 3 carry usage and supply-capacity context, while five-minute rows from section 5 carry solar generation context.\"}";

.alter table ['jp.tepco.denkiyoho.DemandActual'] column-docstrings (
   [date]: "{\"description\": \"Operating date from the DATE column in TEPCO's hourly actual-demand section or five-minute actual-demand section, normalized to ISO 8601 calendar-date form (YYYY-MM-DD). This is the first stable key component.\"}",
   [time]: "{\"description\": \"Local Japan Standard Time clock time from the TIME column in TEPCO's hourly or five-minute actual-demand section, normalized to zero-padded HH:MM form. This is the second stable key component.\"}",
   [datetime]: "{\"description\": \"Combined DATE and TIME converted from Japan Standard Time to UTC and serialized as an RFC 3339 timestamp for cross-region analytics.\"}",
   [datetime_local]: "{\"description\": \"Combined DATE and TIME serialized as an RFC 3339 timestamp with +09:00 offset for the Japan Standard Time instant represented by the TEPCO CSV row.\"}",
   [actual_demand_mw]: "{\"description\": \"Actual electricity demand for the Tokyo service area, converted to megawatts from TEPCO's \\u5f53\\u65e5\\u5b9f\\u7e3e(\\u4e07kW) hourly column or \\u5f53\\u65e5\\u5b9f\\u7e3e(5\\u5206\\u9593\\u9694\\u5024)(\\u4e07kW) five-minute column by multiplying by 10.\"}",
   [actual_demand_jp_unit_value]: "{\"description\": \"Original integer value from TEPCO's \\u5f53\\u65e5\\u5b9f\\u7e3e(\\u4e07kW) hourly column or \\u5f53\\u65e5\\u5b9f\\u7e3e(5\\u5206\\u9593\\u9694\\u5024)(\\u4e07kW) five-minute column. Rows with 0 or blank actual-demand values are future or unavailable measurements and are skipped by the bridge.\"}",
   [solar_generation_mw]: "{\"description\": \"Solar generation actual value converted to megawatts from TEPCO's section 5 \\u592a\\u967d\\u5149\\u767a\\u96fb\\u5b9f\\u7e3e(5\\u5206\\u9593\\u9694\\u5024)(\\u4e07kW) column. The field is null for hourly section 3 rows and for five-minute rows where TEPCO publishes an empty solar cell.\"}",
   [solar_generation_jp_unit_value]: "{\"description\": \"Original integer solar generation actual value from TEPCO's section 5 \\u592a\\u967d\\u5149\\u767a\\u96fb\\u5b9f\\u7e3e(5\\u5206\\u9593\\u9694\\u5024)(\\u4e07kW) column. The field is null for hourly section 3 rows and for five-minute rows where TEPCO publishes an empty solar cell.\"}",
   [solar_share_pct]: "{\"description\": \"Solar generation percentage of electricity usage from TEPCO's section 5 \\u592a\\u967d\\u5149\\u767a\\u96fb\\u91cf(\\u96fb\\u529b\\u4f7f\\u7528\\u91cf\\u306b\\u5bfe\\u3059\\u308b\\u5272\\u5408)(%) column. The field is null for hourly section 3 rows and for five-minute rows where TEPCO publishes an empty solar-share cell.\"}",
   [usage_pct]: "{\"description\": \"Usage percentage from TEPCO's hourly section 3 \\u4f7f\\u7528\\u7387(%) column. This field is populated only for hourly-cadence DemandActual rows derived from section 3; it is null for five-minute rows derived from section 5. TEPCO may leave future-hour usage blank until actual demand is available.\"}",
   [supply_capacity_mw]: "{\"description\": \"Available supply capacity converted to megawatts from TEPCO's hourly section 3 \\u4f9b\\u7d66\\u529b(\\u4e07kW) column. This field is populated only for hourly-cadence rows derived from section 3; it is null for five-minute rows derived from section 5.\"}",
   [supply_capacity_jp_unit_value]: "{\"description\": \"Original integer supply-capacity value from TEPCO's hourly section 3 \\u4f9b\\u7d66\\u529b(\\u4e07kW) column. This field is populated only for hourly-cadence rows derived from section 3; it is null for five-minute rows derived from section 5.\"}",
   [area_code]: "{\"description\": \"Constant service-area code TEPCO assigned by this bridge for the Tokyo Electric Power Company service area covered by the Electricity Forecast page.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

