}

.alter table ['jp.tepco.denkiyoho.SupplyCapacity'] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'jp.tepco.denkiyoho.SupplyCapacity') | project['date'] = tostring(data.['date']),['time'] = tostring(data.['time']),['peak_supply_capacity_mw'] = toreal(data.['peak_supply_capacity_mw']),['peak_supply_capacity_jp_unit_value'] = toint(data.['peak_supply_capacity_jp_unit_value']),['peak_time_slot'] = tostring(data.['peak_time_slot']),['peak_reserve_margin_pct'] = toreal(data.['peak_reserve_margin_pct']),['peak_usage_pct'] = toreal(data.['peak_usage_pct']),['daily_max_usage_pct'] = toreal(data.['daily_max_usage_pct']),['daily_max_usage_time_slot'] = tostring(data.['daily_max_usage_time_slot']),['update_datetime'] = tostring(data.['update_datetime']),['update_datetime_local'] = tostring(data.['update_datetime_local']),['area_code'] = tostring(data.['area_code']),['area_name_jp'] = tostring(data.['area_name_jp']),['area_name_en'] = tostring(data.['area_name_en']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

