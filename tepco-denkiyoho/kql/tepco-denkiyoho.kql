.create-merge table ['jp.tepco.denkiyoho.DemandForecast'] (
   [date]: string,
   [time]: string,
   [datetime]: string,
   [datetime_local]: string,
   [forecast_demand_mw]: real,
   [forecast_demand_jp_unit_value]: int,
   [usage_pct]: real,
   [supply_capacity_mw]: real,
   [supply_capacity_jp_unit_value]: int,
   [area_code]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table ['jp.tepco.denkiyoho.DemandForecast'] docstring "{\"description\": \"Hourly telemetry schema for TEPCO electricity demand forecasts in the Tokyo Electric Power Company service area, including usage and supply-capacity context from section 3.\"}";

.alter table ['jp.tepco.denkiyoho.DemandForecast'] column-docstrings (
   [date]: "{\"description\": \"Operating date from the DATE column in TEPCO's hourly same-day forecast section, normalized to ISO 8601 calendar-date form (YYYY-MM-DD). This is the first stable key component.\"}",
   [time]: "{\"description\": \"Local Japan Standard Time clock hour from the TIME column in TEPCO's hourly forecast section, normalized to zero-padded HH:MM form. This is the second stable key component.\"}",
   [datetime]: "{\"description\": \"Combined DATE and TIME converted from Japan Standard Time to UTC and serialized as an RFC 3339 timestamp for cross-region analytics.\"}",
   [datetime_local]: "{\"description\": \"Combined DATE and TIME serialized as an RFC 3339 timestamp with +09:00 offset for the Japan Standard Time instant represented by the TEPCO CSV row.\"}",
   [forecast_demand_mw]: "{\"description\": \"Hourly forecast electricity demand for the Tokyo service area, converted to megawatts from TEPCO's section 3 \\u4e88\\u6e2c\\u5024(\\u4e07kW) column by multiplying by 10.\"}",
   [forecast_demand_jp_unit_value]: "{\"description\": \"Original integer value from TEPCO's section 3 \\u4e88\\u6e2c\\u5024(\\u4e07kW) hourly forecast column. The bridge uses this value in forecast de-duplication so revised forecasts for the same date and hour are emitted again.\"}",
   [usage_pct]: "{\"description\": \"Usage percentage from TEPCO's hourly section 3 \\u4f7f\\u7528\\u7387(%) column. This field is populated only for hourly-cadence DemandForecast rows derived from section 3 and can be null when TEPCO leaves future-hour usage blank until actual demand is available.\"}",
   [supply_capacity_mw]: "{\"description\": \"Available supply capacity converted to megawatts from TEPCO's hourly section 3 \\u4f9b\\u7d66\\u529b(\\u4e07kW) column. This field is populated only for hourly-cadence DemandForecast rows derived from section 3.\"}",
   [supply_capacity_jp_unit_value]: "{\"description\": \"Original integer supply-capacity value from TEPCO's hourly section 3 \\u4f9b\\u7d66\\u529b(\\u4e07kW) column. This field is populated only for hourly-cadence DemandForecast rows derived from section 3.\"}",
   [area_code]: "{\"description\": \"Constant service-area code TEPCO assigned by this bridge for the Tokyo Electric Power Company service area covered by the Electricity Forecast page.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

