.alter table ['jp.tepco.denkiyoho.PeakDemandForecast'] docstring "{\"description\": \"Daily reference schema for TEPCO Electricity Forecast section 2 peak-demand forecast metadata for the Tokyo Electric Power Company service area.\"}";

.alter table ['jp.tepco.denkiyoho.PeakDemandForecast'] column-docstrings (
   [date]: "{\"description\": \"Operating date for TEPCO's section 2 peak-demand forecast, normalized from \\u4e88\\u60f3\\u6700\\u5927\\u96fb\\u529b\\u60c5\\u5831\\u66f4\\u65b0\\u65e5 with the CSV update year to ISO 8601 calendar-date form (YYYY-MM-DD). This is the stable date key component.\"}",
   [time]: "{\"description\": \"Stable subject and Kafka key time component for the section 2 peak-demand forecast. The bridge sets this field to the sentinel value _peak_forecast_ so the daily peak forecast shares the same jp.tepco.denkiyoho/{date}/{time} key model as the other TEPCO events without pretending to be an hourly measurement.\"}",
   [peak_demand_forecast_mw]: "{\"description\": \"Forecast maximum electricity demand for the Tokyo service area from TEPCO's section 2 \\u4e88\\u60f3\\u6700\\u5927\\u96fb\\u529b(\\u4e07kW) row, converted from \\u4e07kW to megawatts by multiplying by 10.\"}",
   [peak_demand_forecast_jp_unit_value]: "{\"description\": \"Original integer peak-demand forecast value from TEPCO's section 2 \\u4e88\\u60f3\\u6700\\u5927\\u96fb\\u529b(\\u4e07kW) field.\"}",
   [peak_time_slot]: "{\"description\": \"Local Japan Standard Time hour range from TEPCO's section 2 \\u6642\\u9593\\u5e2f column indicating when the forecast maximum demand is expected, normalized to an ASCII hyphen such as 13:00-14:00.\"}",
   [update_datetime]: "{\"description\": \"Section 2 peak-demand forecast information update timestamp converted from Japan Standard Time to UTC and serialized as an RFC 3339 timestamp. TEPCO publishes the date and time in \\u4e88\\u60f3\\u6700\\u5927\\u96fb\\u529b\\u60c5\\u5831\\u66f4\\u65b0\\u65e5 and \\u4e88\\u60f3\\u6700\\u5927\\u96fb\\u529b\\u60c5\\u5831\\u66f4\\u65b0\\u6642\\u523b.\"}",
   [update_datetime_local]: "{\"description\": \"Section 2 peak-demand forecast information update timestamp in Japan Standard Time serialized as an RFC 3339 timestamp with +09:00 offset, built from TEPCO's \\u4e88\\u60f3\\u6700\\u5927\\u96fb\\u529b\\u60c5\\u5831\\u66f4\\u65b0\\u65e5 and \\u4e88\\u60f3\\u6700\\u5927\\u96fb\\u529b\\u60c5\\u5831\\u66f4\\u65b0\\u6642\\u523b columns.\"}",
   [area_code]: "{\"description\": \"Constant service-area code TEPCO assigned by this bridge for the Tokyo Electric Power Company service area covered by the Electricity Forecast page.\"}",
   [area_name_jp]: "{\"description\": \"Japanese name of the TEPCO Power Grid service area used by the Electricity Forecast page: \\u6771\\u4eac\\u96fb\\u529b\\u30a8\\u30ea\\u30a2. The page defines this as Tokyo plus Kanagawa, Saitama, Chiba, Tochigi, Gunma, Ibaraki, Yamanashi, and the portion of Shizuoka east of the Fujikawa River.\"}",
   [area_name_en]: "{\"description\": \"English display name for the TEPCO service territory covered by the Electricity Forecast page: TEPCO Service Area (Kanto).\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

