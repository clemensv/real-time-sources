.alter table [DripSign] docstring "{\"description\": \"Reference data for a Dynamic Route Information Panel (DRIP) sign from the NDW DATEX II dynamische_route_informatie_paneel feed. Describes the physical installation, location, and type of an individual VMS sign within a VMS controller.\"}";

.alter table [DripSign] column-docstrings (
