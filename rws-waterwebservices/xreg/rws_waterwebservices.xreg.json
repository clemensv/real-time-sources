{
  "endpoints": {
    "NL.RWS.Waterwebservices.Kafka": {
      "usage": [
        "producer"
      ],
      "protocol": "KAFKA",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "structured",
        "format": "application/cloudevents+json"
      },
      "protocoloptions": {
        "deployed": false,
        "options": {
          "topic": "rws-waterwebservices",
          "key": "{station_code}"
        }
      },
      "messagegroups": [
        "#/messagegroups/NL.RWS.Waterwebservices"
      ]
    },
    "NL.RWS.Waterwebservices.Mqtt": {
      "usage": [
        "producer"
      ],
      "protocol": "MQTT/5.0",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "binary"
      },
      "protocoloptions": {
        "deployed": false,
        "endpoints": [
          {
            "uri": "mqtt://localhost:1883"
          }
        ]
      },
      "messagegroups": [
        "#/messagegroups/NL.RWS.Waterwebservices.mqtt"
      ]
    }
  },
  "messagegroups": {
    "NL.RWS.Waterwebservices": {
      "messages": {
        "NL.RWS.Waterwebservices.Station": {
          "name": "Station",
          "envelope": "CloudEvents/1.0",
          "envelopemetadata": {
            "type": {
              "value": "NL.RWS.Waterwebservices.Station"
            },
            "source": {
              "value": "https://waterwebservices.rijkswaterstaat.nl"
            },
            "subject": {
              "value": "{station_code}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/NL.RWS.Waterwebservices.jstruct/schemas/NL.RWS.Waterwebservices.Station"
        },
        "NL.RWS.Waterwebservices.WaterLevelObservation": {
          "name": "WaterLevelObservation",
          "envelope": "CloudEvents/1.0",
          "envelopemetadata": {
            "type": {
              "value": "NL.RWS.Waterwebservices.WaterLevelObservation"
            },
            "source": {
              "value": "https://waterwebservices.rijkswaterstaat.nl"
            },
            "subject": {
              "value": "{station_code}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/NL.RWS.Waterwebservices.jstruct/schemas/NL.RWS.Waterwebservices.WaterLevelObservation"
        }
      }
    },
    "NL.RWS.Waterwebservices.mqtt": {
      "description": "MQTT/5.0 transport variants of the RWS Waterwebservices CloudEvents, mapping each message to a retained, QoS-1 Unified Namespace topic under hydro/nl/rws/rws-waterwebservices/{water_body}/{station_code}/... The {water_body} placeholder is sourced from the upstream RWS station catalog (Locatie.Naam field, e.g. 'Hoek van Holland', 'IJmuiden Buitenhaven') and normalized by the bridge to lowercase kebab-case before publishing so subscribers can wildcard whole water bodies (e.g. hydro/nl/rws/rws-waterwebservices/hoek-van-holland/+/water-level).",
      "messages": {
        "NL.RWS.Waterwebservices.mqtt.Station": {
          "name": "Station",
          "basemessageurl": "/messagegroups/NL.RWS.Waterwebservices/messages/NL.RWS.Waterwebservices.Station",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "topic_name": "hydro/nl/rws/rws-waterwebservices/{water_body}/{station_code}/info",
            "qos": 1,
            "retain": true
          }
        },
        "NL.RWS.Waterwebservices.mqtt.WaterLevelObservation": {
          "name": "WaterLevelObservation",
          "basemessageurl": "/messagegroups/NL.RWS.Waterwebservices/messages/NL.RWS.Waterwebservices.WaterLevelObservation",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "topic_name": "hydro/nl/rws/rws-waterwebservices/{water_body}/{station_code}/water-level",
            "qos": 1,
            "retain": true
          }
        }
      }
    }
  },
  "schemagroups": {
    "NL.RWS.Waterwebservices.jstruct": {
      "schemas": {
        "NL.RWS.Waterwebservices.Station": {
          "name": "Station",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/extended/v0/#",
                "type": "object",
                "required": [
                  "station_code",
                  "name",
                  "water_body",
                  "latitude",
                  "longitude"
                ],
                "name": "Station",
                "properties": {
                  "station_code": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string",
                    "altnames": {
                      "lang:nl": "Naam"
                    }
                  },
                  "water_body": {
                    "type": "string",
                    "description": "Display name of the water body / monitoring location (RWS catalog Locatie.Naam field, e.g. 'Hoek van Holland', 'IJmuiden Buitenhaven'). Sourced by the bridge from the station catalog and propagated onto every station event so subscribers do not need an out-of-band catalog join. Used as the {water_body} segment of the MQTT/UNS topic and normalized to lowercase kebab-case before publishing."
                  },
                  "latitude": {
                    "type": "double"
                  },
                  "longitude": {
                    "type": "double"
                  },
                  "coordinate_system": {
                    "type": "string",
                    "altnames": {
                      "lang:nl": "Coordinatenstelsel"
                    }
                  }
                },
                "$id": "https://example.com/schemas/NL/RWS/Waterwebservices/Station",
                "description": "Station"
              }
            }
          }
        },
        "NL.RWS.Waterwebservices.WaterLevelObservation": {
          "name": "WaterLevelObservation",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/extended/v0/#",
                "type": "object",
                "required": [
                  "station_code",
                  "water_body",
                  "timestamp",
                  "value"
                ],
                "name": "WaterLevelObservation",
                "properties": {
                  "station_code": {
                    "type": "string"
                  },
                  "water_body": {
                    "type": "string",
                    "description": "Display name of the water body / monitoring location (RWS catalog Locatie.Naam field, e.g. 'Hoek van Holland', 'IJmuiden Buitenhaven'). Sourced by the bridge from the station catalog at startup and propagated onto every observation so subscribers do not need an out-of-band catalog join to route by location. Used as the {water_body} segment of the MQTT/UNS topic and normalized to lowercase kebab-case before publishing."
                  },
                  "location_name": {
                    "type": "string",
                    "altnames": {
                      "lang:nl": "Naam"
                    }
                  },
                  "timestamp": {
                    "type": "datetime",
                    "altnames": {
                      "lang:nl": "Tijdstip"
                    }
                  },
                  "value": {
                    "type": "double",
                    "altnames": {
                      "lang:nl": "Waarde_Numeriek"
                    }
                  },
                  "unit": {
                    "type": "string"
                  },
                  "quality_code": {
                    "type": "string",
                    "altnames": {
                      "lang:nl": "Kwaliteitswaardecode"
                    }
                  },
                  "status": {
                    "type": "string",
                    "altnames": {
                      "lang:nl": "Statuswaarde"
                    }
                  },
                  "compartment": {
                    "type": "string"
                  },
                  "parameter": {
                    "type": "string"
                  }
                },
                "$id": "https://example.com/schemas/NL/RWS/Waterwebservices/WaterLevelObservation",
                "description": "WaterLevelObservation"
              }
            }
          }
        }
      }
    },
    "NL.RWS.Waterwebservices.avro": {
      "schemas": {
        "NL.RWS.Waterwebservices.Station": {
          "name": "Station",
          "format": "Avro/1.11.3",
