# syntax=docker/dockerfile:1.6
FROM python:3.10-slim

LABEL org.opencontainers.image.source="https://github.com/clemensv/real-time-sources/tree/main/rws-waterwebservices"
LABEL org.opencontainers.image.title="RWS Waterwebservices → MQTT/UNS bridge"
LABEL org.opencontainers.image.description="Polls the Dutch Rijkswaterstaat Waterwebservices API for station catalog and water level observations, and publishes MQTT 5.0 binary-mode CloudEvents into a Unified-Namespace topic tree (hydro/nl/rws/rws-waterwebservices/{water_body}/{station_code}/...)."
LABEL org.opencontainers.image.documentation="https://github.com/clemensv/real-time-sources/blob/main/rws-waterwebservices/CONTAINER.md"
LABEL org.opencontainers.image.license="MIT"
LABEL source.transport="mqtt"

ENV PYTHONUNBUFFERED=1
WORKDIR /app

COPY . /app

RUN pip install --no-cache-dir ./rws_waterwebservices_mqtt_producer/rws_waterwebservices_mqtt_producer_data \
 && pip install --no-cache-dir ./rws_waterwebservices_mqtt_producer/rws_waterwebservices_mqtt_producer_mqtt_client \
 && pip install --no-cache-dir ./rws_waterwebservices_producer/rws_waterwebservices_producer_data \
 && pip install --no-cache-dir ./rws_waterwebservices_producer/rws_waterwebservices_producer_kafka_producer \
 && pip install --no-cache-dir . \
 && pip install --no-cache-dir ./rws_waterwebservices_mqtt

ENV MQTT_BROKER_URL=""

CMD ["python", "-m", "rws_waterwebservices_mqtt", "feed"]
