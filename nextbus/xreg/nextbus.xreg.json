{
  "name": "Nextbus",
  "description": "Nextbus / UMOIQ public XML feed CloudEvents.",
  "endpoints": {
    "nextbus.Kafka": {
      "usage": [
        "producer"
      ],
      "protocol": "KAFKA",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "structured",
        "format": "application/cloudevents+json"
      },
      "protocoloptions": {
        "deployed": false,
        "options": {
          "topic": "nextbus",
          "key": "{agency_id}/{route_tag}"
        }
      },
      "messagegroups": [
        "#/messagegroups/nextbus"
      ],
      "description": "Kafka endpoint for Nextbus events."
    },
    "nextbus.Mqtt": {
      "usage": [
        "producer"
      ],
      "protocol": "MQTT/5.0",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "binary"
      },
      "protocoloptions": {
        "deployed": false,
        "endpoints": [
          {
            "uri": "mqtt://localhost:1883"
          }
        ]
      },
      "messagegroups": [
        "#/messagegroups/nextbus.mqtt"
      ],
      "description": "MQTT/5.0 companion producer endpoint."
    },
    "nextbus.Amqp": {
      "usage": [
        "producer"
      ],
      "protocol": "AMQP/1.0",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "binary"
      },
      "protocoloptions": {
        "deployed": false,
        "options": {
          "content_mode": "binary",
          "address": "nextbus"
        }
      },
      "messagegroups": [
        "#/messagegroups/nextbus.amqp"
      ],
      "description": "AMQP/1.0 companion producer endpoint."
    }
  },
  "messagegroups": {
    "nextbus": {
      "description": "Nextbus vehicle and route reference events.",
      "messages": {
        "nextbus.VehiclePosition": {
          "name": "VehiclePosition",
          "envelope": "CloudEvents/1.0",
          "envelopemetadata": {
            "type": {
              "value": "nextbus.VehiclePosition"
            },
            "source": {
              "value": "https://retro.umoiq.com/service/publicXMLFeed"
            },
            "subject": {
              "value": "{agency_id}/{route_tag}/vehicle/{vehicle_id}",
              "type": "uritemplate"
            },
            "time": {
              "value": "{timestamp}",
              "type": "timestamp"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/nextbus.jstruct/schemas/nextbus.VehiclePosition",
          "description": "Nextbus VehiclePosition event."
        },
        "nextbus.RouteConfig": {
          "name": "RouteConfig",
          "envelope": "CloudEvents/1.0",
          "envelopemetadata": {
            "type": {
              "value": "nextbus.RouteConfig"
            },
            "source": {
              "value": "https://retro.umoiq.com/service/publicXMLFeed"
            },
            "subject": {
              "value": "{agency_id}/{route_tag}/route-config/{stop_or_vehicle_id}",
              "type": "uritemplate"
            },
            "time": {
              "value": "{timestamp}",
              "type": "timestamp"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/nextbus.jstruct/schemas/nextbus.RouteConfig",
          "description": "Nextbus RouteConfig event."
        },
        "nextbus.Schedule": {
          "name": "Schedule",
          "envelope": "CloudEvents/1.0",
          "envelopemetadata": {
            "type": {
              "value": "nextbus.Schedule"
            },
            "source": {
              "value": "https://retro.umoiq.com/service/publicXMLFeed"
            },
            "subject": {
              "value": "{agency_id}/{route_tag}/schedule/{stop_or_vehicle_id}",
              "type": "uritemplate"
            },
            "time": {
              "value": "{timestamp}",
              "type": "timestamp"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/nextbus.jstruct/schemas/nextbus.Schedule",
          "description": "Nextbus Schedule event."
        },
        "nextbus.Message": {
          "name": "Message",
          "envelope": "CloudEvents/1.0",
          "envelopemetadata": {
            "type": {
              "value": "nextbus.Message"
            },
            "source": {
              "value": "https://retro.umoiq.com/service/publicXMLFeed"
            },
            "subject": {
              "value": "{agency_id}/{route_tag}/message/{stop_or_vehicle_id}",
              "type": "uritemplate"
            },
            "time": {
              "value": "{timestamp}",
              "type": "timestamp"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/nextbus.jstruct/schemas/nextbus.Message",
          "description": "Nextbus Message event."
        }
      }
    },
    "nextbus.mqtt": {
      "description": "MQTT 5 UNS topic bindings for nextbus.",
      "messages": {
        "nextbus.VehiclePosition.mqtt": {
          "name": "VehiclePosition",
          "basemessageuri": "/messagegroups/nextbus/messages/nextbus.VehiclePosition",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "topic_name": "transit/intl/nextbus/nextbus/{agency_id}/{route_tag}/{event_type}/{stop_or_vehicle_id}",
            "qos": 1,
            "retain": false
          }
        },
        "nextbus.RouteConfig.mqtt": {
          "name": "RouteConfig",
          "basemessageuri": "/messagegroups/nextbus/messages/nextbus.RouteConfig",
