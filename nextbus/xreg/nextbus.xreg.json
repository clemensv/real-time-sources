          "protocoloptions": {
            "properties": {
              "subject": {
                "type": "uritemplate",
                "value": "{agency_id}/{route_tag}/vehicle/{vehicle_id}",
                "description": "AMQP subject mirrors the CloudEvents subject."
              }
            },
            "message-annotations": {
              "x-opt-partition-key": {
