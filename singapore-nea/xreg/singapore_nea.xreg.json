  "endpoints": {
    "SG.Gov.NEA.Weather.Kafka": {
      "usage": [
        "producer"
      ],
      "protocol": "KAFKA",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "structured",
        "format": "application/cloudevents+json"
      },
      "protocoloptions": {
        "deployed": false,
        "options": {
          "topic": "singapore-nea",
          "key": "{station_id}"
        }
      },
      "messagegroups": [
        "#/messagegroups/SG.Gov.NEA.Weather"
      ],
      "description": "Kafka producer endpoint for Singapore NEA Environment CloudEvents on the `singapore-nea` topic keyed by `{station_id}`."
    },
