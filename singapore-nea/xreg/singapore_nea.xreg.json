  "schemagroups": {
    "SG.Gov.NEA.Weather.jstruct": {
      "schemas": {
        "SG.Gov.NEA.Weather.Station": {
          "name": "Station",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/extended/v0/#",
                "$id": "https://api.data.gov.sg/schemas/SG/Gov/NEA/Weather/Station",
                "type": "object",
                "name": "Station",
                "description": "A reference record published by Singapore's National Environment Agency (NEA). It lets consumers label, group, and route the live measurement or forecast events.",
                "required": [
                  "station_id",
                  "name",
                  "latitude",
                  "longitude"
                ],
                "properties": {
                  "station_id": {
                    "type": "string",
                    "description": "NEA station identifier, e.g. 'S109', 'S50'. Matches the device_id field in the NEA API metadata."
                  },
                  "device_id": {
                    "type": "string",
                    "description": "Device identifier, typically identical to station_id."
                  },
                  "name": {
                    "type": "string",
                    "description": "Human-readable station name describing the location, e.g. 'Ang Mo Kio Avenue 5', 'Changi'."
                  },
                  "latitude": {
                    "type": "double",
                    "description": "WGS84 latitude of the station.",
                    "unit": "degree",
                    "symbol": "°"
                  },
                  "longitude": {
                    "type": "double",
                    "description": "WGS84 longitude of the station.",
                    "unit": "degree",
                    "symbol": "°"
                  },
                  "data_types": {
                    "type": "string",
                    "description": "Comma-separated list of observation types this station reports. Values: 'air_temperature', 'rainfall', 'relative_humidity', 'wind_speed', 'wind_direction'."
                  }
                }
              }
            }
          }
        },
        "SG.Gov.NEA.Weather.WeatherObservation": {
          "name": "WeatherObservation",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/extended/v0/#",
                "$id": "https://api.data.gov.sg/schemas/SG/Gov/NEA/Weather/WeatherObservation",
                "type": "object",
                "name": "WeatherObservation",
                "description": "A current environmental measurement from Singapore's National Environment Agency (NEA). It carries weather observations, air-quality readings, and environmental indexes when the upstream feed reports a new or refreshed value.",
                "required": [
                  "station_id",
                  "station_name",
                  "observation_time"
                ],
                "properties": {
                  "station_id": {
                    "type": "string",
                    "description": "NEA station identifier."
                  },
                  "station_name": {
                    "type": "string",
                    "description": "Station location name."
                  },
                  "observation_time": {
                    "type": "datetime",
                    "description": "Timestamp of the observation in ISO 8601 with Singapore timezone (+08:00)."
                  },
                  "air_temperature": {
                    "type": [
                      "double",
                      "null"
                    ],
                    "description": "Air temperature from the air-temperature endpoint.",
                    "unit": "Cel",
                    "symbol": "°C"
                  },
                  "rainfall": {
                    "type": [
                      "double",
                      "null"
                    ],
                    "description": "Rainfall amount in the last 5 minutes from the rainfall endpoint.",
                    "unit": "mm",
                    "symbol": "mm"
                  },
                  "relative_humidity": {
                    "type": [
                      "double",
                      "null"
                    ],
                    "description": "Relative humidity from the relative-humidity endpoint.",
                    "unit": "percent",
                    "symbol": "%"
                  },
                  "wind_speed": {
                    "type": [
                      "double",
                      "null"
                    ],
                    "description": "Wind speed from the wind-speed endpoint.",
                    "unit": "kn",
                    "symbol": "kn"
                  },
                  "wind_direction": {
                    "type": [
                      "double",
                      "null"
                    ],
                    "description": "Wind direction in degrees clockwise from true north, from the wind-direction endpoint.",
                    "unit": "degree",
                    "symbol": "°"
                  }
                }
              }
            }
          }
        }
      }
    },
    "SG.Gov.NEA.AirQuality.jstruct": {
      "schemas": {
        "SG.Gov.NEA.AirQuality.Region": {
          "name": "Region",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/extended/v0/#",
                "$id": "https://api.data.gov.sg/schemas/SG/Gov/NEA/AirQuality/Region",
                "type": "object",
                "name": "Region",
                "description": "A reference record published by Singapore's National Environment Agency (NEA). It lets consumers label, group, and route the live measurement or forecast events.",
                "required": [
                  "region",
                  "latitude",
                  "longitude"
                ],
                "properties": {
                  "region": {
                    "type": "string",
                    "description": "Region identifier. One of: west, east, central, south, north.",
                    "altenums": [
                      "west",
                      "east",
                      "central",
                      "south",
                      "north"
                    ]
                  },
                  "latitude": {
                    "type": "double",
                    "description": "WGS84 latitude of the region label location as published by the NEA API.",
                    "unit": "degree",
                    "symbol": "°"
                  },
                  "longitude": {
                    "type": "double",
                    "description": "WGS84 longitude of the region label location as published by the NEA API.",
                    "unit": "degree",
                    "symbol": "°"
                  }
                }
              }
            }
          }
        },
        "SG.Gov.NEA.AirQuality.PSIReading": {
          "name": "PSIReading",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/extended/v0/#",
                "$id": "https://api.data.gov.sg/schemas/SG/Gov/NEA/AirQuality/PSIReading",
                "type": "object",
                "name": "PSIReading",
                "description": "A current environmental measurement from Singapore's National Environment Agency (NEA). It carries weather observations, air-quality readings, and environmental indexes when the upstream feed reports a new or refreshed value.",
                "required": [
                  "region",
                  "timestamp",
                  "update_timestamp",
                  "psi_twenty_four_hourly"
                ],
                "properties": {
                  "region": {
                    "type": "string",
                    "description": "Region identifier (west/east/central/south/north).",
                    "altenums": [
                      "west",
                      "east",
                      "central",
                      "south",
                      "north"
                    ]
                  },
                  "timestamp": {
                    "type": "datetime",
                    "description": "Observation period start timestamp in ISO 8601 with timezone."
                  },
                  "update_timestamp": {
                    "type": "datetime",
                    "description": "Timestamp when the NEA API last updated this reading."
                  },
                  "psi_twenty_four_hourly": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "description": "24-hour PSI value. The overall Pollutant Standards Index for the region. Scale: 0-50 Good, 51-100 Moderate, 101-200 Unhealthy, 201-300 Very Unhealthy, above 300 Hazardous.",
                    "minimum": 0
                  },
                  "o3_sub_index": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "description": "Ozone (O3) sub-index component of PSI.",
                    "minimum": 0
                  },
                  "pm10_sub_index": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "description": "PM10 sub-index component of PSI.",
                    "minimum": 0
                  },
                  "pm10_twenty_four_hourly": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "description": "PM10 24-hour concentration used to calculate the PM10 PSI sub-index.",
                    "unit": "ug/m3",
                    "symbol": "µg/m³",
                    "minimum": 0
                  },
                  "pm25_sub_index": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "description": "PM2.5 sub-index component of PSI.",
                    "minimum": 0
                  },
                  "pm25_twenty_four_hourly": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "description": "PM2.5 24-hour concentration.",
                    "unit": "ug/m3",
                    "symbol": "µg/m³",
                    "minimum": 0
                  },
                  "co_sub_index": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "description": "Carbon monoxide (CO) sub-index component of PSI.",
                    "minimum": 0
                  },
                  "co_eight_hour_max": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "description": "CO 8-hour maximum concentration.",
                    "unit": "mg/m3",
                    "symbol": "mg/m³",
                    "minimum": 0
                  },
                  "so2_sub_index": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "description": "Sulphur dioxide (SO2) sub-index component of PSI.",
                    "minimum": 0
                  },
                  "so2_twenty_four_hourly": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "description": "SO2 24-hour concentration.",
                    "unit": "ug/m3",
                    "symbol": "µg/m³",
                    "minimum": 0
                  },
                  "no2_one_hour_max": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "description": "Nitrogen dioxide (NO2) 1-hour maximum concentration.",
                    "unit": "ug/m3",
                    "symbol": "µg/m³",
                    "minimum": 0
                  },
                  "o3_eight_hour_max": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "description": "Ozone (O3) 8-hour maximum concentration.",
                    "unit": "ug/m3",
                    "symbol": "µg/m³",
                    "minimum": 0
                  }
                }
              }
            }
