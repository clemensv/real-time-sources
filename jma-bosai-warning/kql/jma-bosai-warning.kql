.create-merge table [_cloudevents_dispatch] (
    [specversion]: string,
    [type]: string,
    [source]: string,
    [id]: string,
    [time]: datetime,
    [subject]: string,
    [datacontenttype]: string,
    [dataschema]: string,
    [data]: dynamic
);

.create-or-alter table [_cloudevents_dispatch] ingestion json mapping "_cloudevents_dispatch_json"
```
[
  {"column": "specversion", "path": "$.specversion"},
  {"column": "type", "path": "$.type"},
  {"column": "source", "path": "$.source"},
  {"column": "id", "path": "$.id"},
  {"column": "time", "path": "$.time"},
  {"column": "subject", "path": "$.subject"},
  {"column": "datacontenttype", "path": "$.datacontenttype"},
  {"column": "dataschema", "path": "$.dataschema"},
  {"column": "data", "path": "$.data"}
]
```

.create-merge table [Office] (
   [office_code]: string,
   [area_code]: string,
   [name_jp]: string,
   [name_en]: string,
   [parent_office_code]: string,
   [office_type]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [Office] docstring "{\"description\": \"JMA warning office reference record from the Bosai area catalog offices section. These offices are the stable targetArea codes used by warning JSON endpoints and contextualize weather warning area telemetry.\"}";

.alter table [Office] column-docstrings (
   [office_code]: "{\"description\": \"Six-digit JMA Bosai office code from area.json offices. This is the first stable key component for warning reference and telemetry events.\"}",
   [area_code]: "{\"description\": \"Six-digit JMA Bosai office code repeated as the area component for office reference events so reference records use the same numeric warning subject and key shape as area warning telemetry.\"}",
   [name_jp]: "{\"description\": \"Japanese office or warning-region name from area.json offices[].name, such as \\u6771\\u4eac\\u90fd or \\u5b97\\u8c37\\u5730\\u65b9.\"}",
   [name_en]: "{\"description\": \"English office or warning-region name from area.json offices[].enName, such as Tokyo or Soya.\"}",
   [parent_office_code]: "{\"description\": \"Parent JMA regional center code from area.json offices[].parent. Null is emitted only if the upstream catalog omits a parent.\"}",
   [office_type]: "{\"description\": \"Normalized office class. PREFECTURE is used for standard prefectural offices, SUBREGION for Hokkaido/Okinawa-style regional warning offices, and OFFICE for other JMA issuing-office catalog entries.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

.create-or-alter table [Office] ingestion json mapping "Office_json_flat"
```
[
  {"column": "___type", "path": "$.type"},
  {"column": "___source", "path": "$.source"},
  {"column": "___id", "path": "$.id"},
  {"column": "___time", "path": "$.time"},
  {"column": "___subject", "path": "$.subject"},
  {"column": "office_code", "path": "$.office_code"},
  {"column": "area_code", "path": "$.area_code"},
  {"column": "name_jp", "path": "$.name_jp"},
  {"column": "name_en", "path": "$.name_en"},
  {"column": "parent_office_code", "path": "$.parent_office_code"},
  {"column": "office_type", "path": "$.office_type"},
]
```

