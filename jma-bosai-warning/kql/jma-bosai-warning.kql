  {"column": "___time", "path": "$.time"},
  {"column": "___subject", "path": "$.subject"},
  {"column": "office_code", "path": "$.office_code"},
  {"column": "area_code", "path": "$.area_code"},
  {"column": "area_name", "path": "$.area_name"},
