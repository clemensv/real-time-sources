```
[
  {"column": "___type", "path": "$.type"},
  {"column": "___source", "path": "$.source"},
  {"column": "___id", "path": "$.id"},
  {"column": "___time", "path": "$.time"},
  {"column": "___subject", "path": "$.subject"},
  {"column": "office_code", "path": "$.data.office_code"},
  {"column": "area_code", "path": "$.data.area_code"},
  {"column": "name_jp", "path": "$.data.name_jp"},
  {"column": "name_en", "path": "$.data.name_en"},
  {"column": "parent_office_code", "path": "$.data.parent_office_code"},
  {"column": "office_type", "path": "$.data.office_type"},
]
```

.drop materialized-view OfficeLatest ifexists;

.create materialized-view with (backfill=true) OfficeLatest on table Office {
    Office | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [Office] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'JP.JMA.Warning.Office') | project['office_code'] = tostring(data.['office_code']),['area_code'] = tostring(data.['area_code']),['name_jp'] = tostring(data.['name_jp']),['name_en'] = tostring(data.['name_en']),['parent_office_code'] = tostring(data.['parent_office_code']),['office_type'] = tostring(data.['office_type']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

.create-merge table [WeatherWarning] (
   [office_code]: string,
   [area_code]: string,
   [area_name]: string,
   [report_datetime]: string,
   [report_datetime_local]: string,
   [headline_text]: string,
   [warnings]: dynamic,
   [time_defines]: dynamic,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [WeatherWarning] docstring "{\"description\": \"JMA Bosai weather warning/advisory state for one office targetArea and one inner forecast area. The bridge emits one record per (office_code, area_code, report_datetime) change and includes all warning items currently published for that area.\"}";

.alter table [WeatherWarning] column-docstrings (
   [office_code]: "{\"description\": \"Six-digit JMA Bosai office targetArea code used in the warning/{office_code}.json endpoint. This is the first stable key component.\"}",
   [area_code]: "{\"description\": \"JMA inner forecast-area code from timeSeries areas[].code. This is the second stable key component for weather warning telemetry.\"}",
   [area_name]: "{\"description\": \"Japanese inner forecast-area name from the warning payload when present or from area.json class catalogs when the payload only carries a code.\"}",
   [report_datetime]: "{\"description\": \"JMA report publication time converted to an RFC3339 UTC timestamp. JMA publishes reportDatetime with a local Japan time offset.\"}",
   [report_datetime_local]: "{\"description\": \"Original JMA reportDatetime timestamp preserving the upstream local offset, normally Japan Standard Time (+09:00).\"}",
   [headline_text]: "{\"description\": \"Japanese free-text headline from headlineText summarizing areas and hazards requiring attention. Null is emitted when JMA omits the headline.\"}",
   [warnings]: "{\"description\": \"All JMA warning/advisory items published for the inner area in this bulletin. WarningItem is intentionally defined inline to avoid duplicate schema definitions during Avro and producer generation.\", \"schema\": \"{ \\\"doc\\\": \\\"Schema too large to inline. Please refer to the JSON Structure schema for more details.\\\" }\"}",
   [time_defines]: "{\"description\": \"Time definition values from the warning timeSeries converted to RFC3339 UTC timestamps. The original JMA array describes the valid or forecast times associated with the warning area block.\", \"schema\": {\"type\": \"array\", \"description\": \"Time definition values from the warning timeSeries converted to RFC3339 UTC timestamps. The original JMA array describes the valid or forecast times associated with the warning area block.\", \"items\": {\"type\": \"string\", \"format\": \"date-time\"}, \"altnames\": {\"jma-bosai\": \"timeSeries[].timeDefines\"}}}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

.create-or-alter table [WeatherWarning] ingestion json mapping "WeatherWarning_json_flat"
```
