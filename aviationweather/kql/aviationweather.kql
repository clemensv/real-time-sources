}

.alter table [Station] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'gov.noaa.aviationweather.Station') | project['icao_id'] = tostring(data.['icao_id']),['iata_id'] = tostring(data.['iata_id']),['faa_id'] = tostring(data.['faa_id']),['wmo_id'] = tostring(data.['wmo_id']),['name'] = tostring(data.['name']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),['elevation'] = toreal(data.['elevation']),['state'] = tostring(data.['state']),['country'] = tostring(data.['country']),['site_type'] = tostring(data.['site_type']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

.create-merge table [Metar] (
   [icao_id]: string,
   [obs_time]: datetime,
   [report_time]: datetime,
   [temp]: real,
   [dewp]: real,
   [wdir]: int,
   [wspd]: int,
   [wgst]: int,
   [visib]: string,
   [altim]: real,
   [slp]: real,
   [qc_field]: int,
   [wx_string]: string,
   [metar_type]: string,
   [raw_ob]: string,
   [latitude]: real,
   [longitude]: real,
   [elevation]: real,
   [flt_cat]: string,
   [clouds]: string,
   [name]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [Metar] docstring "{\"description\": \"METAR aviation weather observation from the AviationWeather.gov API. Reports surface conditions including temperature, dewpoint, wind, visibility, pressure, clouds, and flight category for an ICAO reporting station.\"}";

.alter table [Metar] column-docstrings (
   [icao_id]: "{\"description\": \"ICAO station identifier for the reporting station (e.g. 'KJFK').\"}",
   [obs_time]: "{\"description\": \"Observation time as a Unix epoch timestamp (seconds since 1970-01-01T00:00:00Z) from the obsTime field in the API response.\"}",
   [report_time]: "{\"description\": \"Report time as an ISO 8601 UTC string from the reportTime field. This is the time the observation was officially reported.\"}",
   [temp]: "{\"description\": \"Air temperature at the station. Unit: degrees Celsius.\"}",
   [dewp]: "{\"description\": \"Dewpoint temperature at the station. Unit: degrees Celsius.\"}",
   [wdir]: "{\"description\": \"Wind direction in degrees true (the direction from which the wind is blowing), averaged over the observation period. Value of 0 indicates variable or calm.\"}",
   [wspd]: "{\"description\": \"Sustained wind speed in knots.\"}",
   [wgst]: "{\"description\": \"Wind gust speed in knots. Null if no gusts reported.\"}",
   [visib]: "{\"description\": \"Prevailing visibility as reported. Value is a string because it can contain qualifiers like '10+' (greater than 10 statute miles) or fractional values. Unit: statute miles.\"}",
   [altim]: "{\"description\": \"Altimeter setting (QNH) in hectopascals.\"}",
   [slp]: "{\"description\": \"Sea level pressure in hectopascals. May be null if not reported.\"}",
   [qc_field]: "{\"description\": \"Quality control flag bitmask from the qcField in the API response.\"}",
   [wx_string]: "{\"description\": \"Present weather string using standard METAR codes (e.g. '-RA' for light rain, 'BR' for mist).\"}",
   [metar_type]: "{\"description\": \"METAR report type: 'METAR' for routine, 'SPECI' for special observation.\"}",
   [raw_ob]: "{\"description\": \"The full raw METAR observation text as received, e.g. 'METAR KJFK 061051Z 32013KT 10SM SCT050 05/M05 A3001'.\"}",
   [latitude]: "{\"description\": \"Station latitude in decimal degrees north from the METAR response.\"}",
   [longitude]: "{\"description\": \"Station longitude in decimal degrees east from the METAR response.\"}",
   [elevation]: "{\"description\": \"Station elevation in meters above mean sea level from the METAR response.\"}",
   [flt_cat]: "{\"description\": \"Flight category derived from ceiling and visibility: VFR, MVFR, IFR, or LIFR.\"}",
   [clouds]: "{\"description\": \"JSON-encoded array of cloud layer objects. Each object has 'cover' (string: SKC, CLR, FEW, SCT, BKN, OVC) and 'base' (integer or null: cloud base in feet AGL). Example: '[{\\\"cover\\\":\\\"SCT\\\",\\\"base\\\":5000}]'.\"}",
   [name]: "{\"description\": \"Human-readable station name included in the METAR response (e.g. 'New York/JF Kennedy Intl, NY, US').\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

