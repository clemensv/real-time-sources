.create-merge table [Station] (
   [icao_id]: string,
   [iata_id]: string,
   [faa_id]: string,
   [wmo_id]: string,
   [name]: string,
   [latitude]: real,
   [longitude]: real,
   [elevation]: real,
   [state]: string,
   [country]: string,
   [site_type]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [Station] docstring "{\"description\": \"Reference record for an aviation weather reporting station. Sourced from the AviationWeather.gov station information endpoint. Fields cover ICAO, IATA, FAA, and WMO identifiers, location, elevation, and available data products.\"}";

.alter table [Station] column-docstrings (
   [icao_id]: "{\"description\": \"ICAO station identifier. Four-character alphanumeric code assigned by ICAO (e.g. 'KJFK' for John F. Kennedy International Airport).\"}",
   [iata_id]: "{\"description\": \"IATA airport code, a three-character code used by the airline industry (e.g. 'JFK'). May be null for non-airport stations.\"}",
   [faa_id]: "{\"description\": \"FAA location identifier. Three or four character code assigned by the FAA. May be null for non-US stations.\"}",
   [wmo_id]: "{\"description\": \"WMO station identifier. Five-digit numeric code assigned by the World Meteorological Organization. May be null.\"}",
   [name]: "{\"description\": \"Human-readable site name from the AviationWeather station database, e.g. 'New York/JF Kennedy Intl'.\"}",
   [latitude]: "{\"description\": \"Station latitude in decimal degrees north. Negative values indicate southern hemisphere.\"}",
   [longitude]: "{\"description\": \"Station longitude in decimal degrees east. Negative values indicate western hemisphere.\"}",
   [elevation]: "{\"description\": \"Station field elevation in meters above mean sea level.\"}",
   [state]: "{\"description\": \"State or province code where the station is located (e.g. 'NY'). May be null for non-US stations.\"}",
   [country]: "{\"description\": \"Two-character ISO 3166-1 alpha-2 country code (e.g. 'US', 'GB').\"}",
   [site_type]: "{\"description\": \"Comma-separated list of data products available at this station from the siteType array (e.g. 'METAR,TAF').\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

