//
// ============================================================================
// Gold tier — CogCatalog
// Populated by the dwd_ingest Spark notebook with one row per published
// Cloud Optimized GeoTIFF in Lakehouse Files/gold/. Read by Fabric Maps
// to resolve the latest COG per (channel, product) for imagery layers.
// ============================================================================
//
.create-merge table [CogCatalog] (
    [channel]: string,           // 'radar' or 'icon-d2'
    [product]: string,           // radar product (e.g. 'wn') or '<param>/<level_type>/<level>'
    [valid_time]: datetime,      // observation time (radar) or run+lead (icon-d2)
    [run]: datetime,             // model run reference time (icon-d2 only)
    [lead_hour]: int,            // forecast lead hour (icon-d2 only)
    [parameter]: string,         // GRIB parameter shortname (icon-d2 only)
    [level_type]: string,        // 'single-level' | 'pressure-level' | ...
    [level]: string,             // hPa or surface tag
    [file_url]: string,          // original opendata.dwd.de URL
    [cog_path]: string,          // OneLake relative path under Files/gold/...
    [bbox]: dynamic,             // [minLon, minLat, maxLon, maxLat] in EPSG:4326
    [crs]: string,               // e.g. 'EPSG:3857'
    [bytes]: long,
    [sha256]: string,
    [written_at]: datetime
);

//
// ============================================================================
// Fabric Maps layer sources
// Functions consumed by Fabric Maps vector layers.
// ============================================================================
//

.create-or-alter function map_stations() {
    StationMetadataLatest
    | project station_id, name = station_name, lat = latitude, lon = longitude, elevation, state
}

.create-or-alter function map_obs_latest() {
    AirTemperature10MinLatest
    | join kind=leftouter (Precipitation10MinLatest | project station_id, precipitation_height) on station_id
    | join kind=leftouter (Wind10MinLatest          | project station_id, wind_speed, wind_direction) on station_id
    | join kind=leftouter (StationMetadataLatest    | project station_id, station_name, latitude, longitude) on station_id
    | project station_id, station_name, lat = latitude, lon = longitude,
              ts = timestamp, air_temperature_2m, precipitation_height, wind_speed, wind_direction
}

.create-or-alter function map_cap_active() {
    WeatherAlertLatest
    | where status =~ 'Actual'
    | where isnull(expires) or expires > now()
    | project identifier, severity, urgency, certainty, event, headline, area_desc,
              effective, onset, expires, geocodes
}

.create-or-alter function map_radar_latest_index() {
    CogCatalog
    | where channel == 'radar'
    | summarize arg_max(valid_time, cog_path, bbox, crs, bytes) by product
}

.create-or-alter function map_icon_d2_latest_index(parameter_name:string, level_type_name:string, level_name:string) {
    CogCatalog
    | where channel == 'icon-d2'
        and parameter == parameter_name
        and level_type == level_type_name
        and level == level_name
    | summarize arg_max(valid_time, run, lead_hour, cog_path, bbox, crs, bytes) by parameter, level_type, level
}
