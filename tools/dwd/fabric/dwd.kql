// DWD-specific KQL assets layered on top of the generic
// _cloudevents_dispatch landing table created by tools/deploy-fabric/deploy-fabric.ps1.
//
// What this script creates:
//   * Typed tables (one per DE.DWD.* CloudEvents type) populated by KQL
//     update policies fanning out of _cloudevents_dispatch.
//   * Materialized "Latest" views (arg_max by station_id / file_url / identifier).
//   * gold.* tables maintained by the dwd_ingest Spark notebook
//     (CogCatalog index for Fabric Maps imagery layers).
//   * map.* KQL functions used as Fabric Maps vector layer sources.
//
// Naming follows the per-source convention used by tools/pugetsound/fabric and
// tools/eurowater/fabric: PascalCase typed table per CloudEvents type + a
// "<Name>Latest" materialized view.

//
// ============================================================================
// Station metadata (DE.DWD.CDC.StationMetadata) — inline payload
// ============================================================================
//
.create-merge table [StationMetadata] (
    [station_id]: string,
    [station_name]: string,
    [latitude]: real,
    [longitude]: real,
    [elevation]: real,
    [state]: string,
    [from_date]: string,
    [to_date]: string,
    [___type]: string,
    [___source]: string,
    [___id]: string,
    [___time]: datetime,
    [___subject]: string
);

.drop materialized-view StationMetadataLatest ifexists;
.create materialized-view with (backfill=true) StationMetadataLatest on table StationMetadata {
    StationMetadata | summarize arg_max(___time, *) by station_id
}

.alter table [StationMetadata] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type =~ 'DE.DWD.CDC.StationMetadata') | project ['station_id'] = tostring(data.['station_id']), ['station_name'] = tostring(data.['station_name']), ['latitude'] = toreal(data.['latitude']), ['longitude'] = toreal(data.['longitude']), ['elevation'] = toreal(data.['elevation']), ['state'] = tostring(data.['state']), ['from_date'] = tostring(data.['from_date']), ['to_date'] = tostring(data.['to_date']), ___type = type, ___source = source, ___id = ['id'], ___time = ['time'], ___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true
}]
```

