  "queries": [
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "a1b2c3d4-4444-4000-8000-000000000001"
      },
      "text": "StationsLatest\n| where latitude != 0 and longitude != 0\n| where (isempty(CountrySelection) or country_code == CountrySelection)\n| where (isempty(RiverSelection) or river_name == RiverSelection)\n| project station_id, station_name, latitude, longitude, country_code\n",
      "id": "a1b2c3d4-2222-4000-8000-000000000001",
      "usedVariables": [
        "CountrySelection",
        "RiverSelection"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "a1b2c3d4-4444-4000-8000-000000000001"
      },
      "text": "let _stations = StationsLatest | where (isempty(CountrySelection) or country_code == CountrySelection) | where (isempty(RiverSelection) or river_name == RiverSelection) | project station_id, station_name;\nMeasurements\n| where parameter == 'water_level'\n| where timestamp > datetime(2000-01-01)\n| where _startTime < timestamp and timestamp < _endTime\n| join kind=inner _stations on station_id\n| project timestamp, value, station_name, station_id\n| sort by timestamp, station_name\n",
      "id": "a1b2c3d4-2222-4000-8000-000000000002",
      "usedVariables": [
        "CountrySelection",
        "RiverSelection",
        "_endTime",
        "_startTime"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "a1b2c3d4-4444-4000-8000-000000000001"
      },
      "text": "Measurements\n| where station_id == StationSelection\n| where timestamp > datetime(2000-01-01)\n| where _startTime < timestamp and timestamp < _endTime\n| project timestamp, value, parameter\n| sort by timestamp asc\n",
      "id": "a1b2c3d4-2222-4000-8000-000000000003",
      "usedVariables": [
        "StationSelection",
        "_endTime",
        "_startTime"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "a1b2c3d4-4444-4000-8000-000000000001"
      },
      "text": "StationsLatest\n| where station_id == StationSelection\n| project station_id, station_name, latitude, longitude, river_name, country_code\n",
      "id": "a1b2c3d4-2222-4000-8000-000000000004",
      "usedVariables": [
        "StationSelection"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "a1b2c3d4-4444-4000-8000-000000000001"
      },
      "text": "Measurements\n| where station_id == StationSelection\n| where parameter == 'water_level'\n| where timestamp > datetime(2000-01-01)\n| where _startTime < timestamp and timestamp < _endTime\n| sort by timestamp asc\n| extend prev_ts = prev(timestamp), prev_value = prev(value)\n| extend hours_diff = toreal(datetime_diff('second', timestamp, prev_ts)) / 3600.0\n| extend rate_of_change_per_hour = iif(isnull(prev_value) or hours_diff == 0, real(null), (value - prev_value) / hours_diff)\n| where isnotempty(rate_of_change_per_hour)\n| project timestamp, rate_of_change_per_hour\n",
      "id": "a1b2c3d4-2222-4000-8000-000000000005",
      "usedVariables": [
        "StationSelection",
        "_endTime",
        "_startTime"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "a1b2c3d4-4444-4000-8000-000000000001"
      },
      "text": "StationsLatest\n| summarize Stations=dcount(station_id) by country_code\n| sort by Stations desc\n",
      "id": "a1b2c3d4-2222-4000-8000-000000000006",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "a1b2c3d4-4444-4000-8000-000000000001"
      },
      "text": "MeasurementsLatest\n| distinct country_code\n| sort by country_code asc\n",
      "id": "a1b2c3d4-2222-4000-8000-000000000007",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "a1b2c3d4-4444-4000-8000-000000000001"
      },
      "text": "let _measured = MeasurementsLatest | distinct station_id;\nStationsLatest\n| where (isempty(CountrySelection) or country_code == CountrySelection)\n| where (isempty(RiverSelection) or river_name == RiverSelection)\n| join kind=inner _measured on station_id\n| project station_id, station_name\n| sort by station_name asc\n",
      "id": "a1b2c3d4-2222-4000-8000-000000000008",
      "usedVariables": [
        "CountrySelection",
        "RiverSelection"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "a1b2c3d4-4444-4000-8000-000000000001"
      },
      "text": "let _measured = MeasurementsLatest | distinct station_id;\nStationsLatest\n| where (isempty(CountrySelection) or country_code == CountrySelection)\n| where river_name != ''\n| join kind=inner _measured on station_id\n| distinct river_name\n| sort by river_name asc\n",
      "id": "a1b2c3d4-2222-4000-8000-000000000009",
      "usedVariables": [
        "CountrySelection"
      ]
    }
  ]
}
