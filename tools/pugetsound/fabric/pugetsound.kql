.alter table ['us.wa.wsdot.bridgeclearances.BridgeClearance'] docstring "{\"description\": \"Reference catalog record of the surveyed vertical clearance of a structure crossing a Washington State highway, used for commercial vehicle routing. Largely static; refreshed periodically.\"}";

.alter table ['us.wa.wsdot.bridgeclearances.BridgeClearance'] column-docstrings (
   [crossing_location_id]: "{\"description\": \"Stable crossing location identifier (CrossingLocationId).\"}",
   [bridge_number]: "{\"description\": \"WSDOT bridge number of the structure.\"}",
   [state_route_id]: "{\"description\": \"State route identifier the structure crosses, or null.\"}",
   [state_structure_id]: "{\"description\": \"Statewide structure identifier.\"}",
   [crossing_description]: "{\"description\": \"Human-readable description of the crossing.\"}",
   [inventory_direction]: "{\"description\": \"Inventory direction of the structure, or null.\"}",
   [srmp]: "{\"description\": \"State route milepost of the crossing.\"}",
   [srmp_ahead_back_indicator]: "{\"description\": \"Ahead/Back indicator disambiguating the milepost, or null.\"}",
   [latitude]: "{\"description\": \"Latitude in WGS84.\"}",
   [longitude]: "{\"description\": \"Longitude in WGS84.\"}",
   [vertical_clearance_maximum_inches]: "{\"description\": \"Maximum vertical clearance, in inches.\"}",
   [vertical_clearance_maximum_feet_inch]: "{\"description\": \"Maximum vertical clearance as a feet-and-inches display string (e.g. '14 ft 3 in').\"}",
   [vertical_clearance_minimum_inches]: "{\"description\": \"Minimum vertical clearance, in inches.\"}",
   [vertical_clearance_minimum_feet_inch]: "{\"description\": \"Minimum vertical clearance as a feet-and-inches display string.\"}",
   [control_entity_guid]: "{\"description\": \"GUID of the controlling entity record.\"}",
   [crossing_record_guid]: "{\"description\": \"GUID of the crossing record.\"}",
   [location_guid]: "{\"description\": \"GUID of the location record.\"}",
   [route_date]: "{\"description\": \"Effective route date as an ISO 8601 UTC timestamp.\"}",
   [api_last_update]: "{\"description\": \"Time the clearance record was last updated upstream, as an ISO 8601 UTC timestamp.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

