    ['us.wa.wsdot.roadweather.RoadWeatherStation'] | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table ['us.wa.wsdot.roadweather.RoadWeatherStation'] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'us.wa.wsdot.roadweather.RoadWeatherStation') | project['station_id'] = tostring(data.['station_id']),['station_name'] = tostring(data.['station_name']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),['elevation'] = toint(data.['elevation']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

.create-merge table ['us.wa.wsdot.roadweather.RoadWeatherReading'] (
   [station_id]: string,
   [station_name]: string,
   [latitude]: real,
   [longitude]: real,
   [elevation]: int,
   [reading_time]: string,
   [air_temperature]: real,
   [relative_humidity]: int,
   [average_wind_speed]: real,
   [average_wind_direction]: int,
   [wind_gust]: real,
   [visibility]: int,
   [precipitation_intensity]: int,
   [precipitation_type]: int,
   [precipitation_past_1_hour]: real,
   [precipitation_past_3_hours]: real,
   [precipitation_past_6_hours]: real,
   [precipitation_past_12_hours]: real,
   [precipitation_past_24_hours]: real,
   [precipitation_accumulation]: real,
   [barometric_pressure]: real,
   [snow_depth]: real,
   [surface_measurements]: dynamic,
   [sub_surface_measurements]: dynamic,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table ['us.wa.wsdot.roadweather.RoadWeatherReading'] docstring "{\"description\": \"A current Scanweb road weather reading including air temperature, humidity, wind, visibility, precipitation totals, and per-sensor road surface and sub-surface measurements.\"}";

.alter table ['us.wa.wsdot.roadweather.RoadWeatherReading'] column-docstrings (
   [station_id]: "{\"description\": \"Stable station identifier, matching the RoadWeatherStation key (StationId, or StationName when StationId is blank).\"}",
   [station_name]: "{\"description\": \"Station name.\"}",
   [latitude]: "{\"description\": \"Latitude in WGS84.\"}",
   [longitude]: "{\"description\": \"Longitude in WGS84.\"}",
   [elevation]: "{\"description\": \"Station elevation above sea level.\"}",
   [reading_time]: "{\"description\": \"Observation time as reported by Scanweb (ISO 8601, without timezone offset; interpreted as the station's local reporting clock).\"}",
   [air_temperature]: "{\"description\": \"Air temperature.\"}",
   [relative_humidity]: "{\"description\": \"Relative humidity percentage. Upstream key is misspelled 'RelativeHumidty'.\"}",
   [average_wind_speed]: "{\"description\": \"Average wind speed.\"}",
   [average_wind_direction]: "{\"description\": \"Average wind direction in degrees from true north.\"}",
   [wind_gust]: "{\"description\": \"Peak wind gust speed.\"}",
   [visibility]: "{\"description\": \"Visibility distance.\"}",
   [precipitation_intensity]: "{\"description\": \"Coded precipitation intensity as an opaque integer reported by the upstream Scanweb feed; WSDOT does not publish the code dictionary, so the value is passed through unmodified. Null when not reported.\"}",
   [precipitation_type]: "{\"description\": \"Coded precipitation type as an opaque integer reported by the upstream Scanweb feed (commonly none, rain, or snow); WSDOT does not publish the full code dictionary, so the value is passed through unmodified. Null when not reported.\"}",
   [precipitation_past_1_hour]: "{\"description\": \"Liquid-equivalent precipitation accumulated in the past 1 hour.\"}",
   [precipitation_past_3_hours]: "{\"description\": \"Liquid-equivalent precipitation accumulated in the past 3 hours.\"}",
   [precipitation_past_6_hours]: "{\"description\": \"Liquid-equivalent precipitation accumulated in the past 6 hours.\"}",
   [precipitation_past_12_hours]: "{\"description\": \"Liquid-equivalent precipitation accumulated in the past 12 hours.\"}",
   [precipitation_past_24_hours]: "{\"description\": \"Liquid-equivalent precipitation accumulated in the past 24 hours.\"}",
   [precipitation_accumulation]: "{\"description\": \"Cumulative precipitation accumulation reported by the gauge, or null.\"}",
   [barometric_pressure]: "{\"description\": \"Barometric pressure, or null when the station has no pressure sensor.\"}",
   [snow_depth]: "{\"description\": \"Measured snow depth, or null when the station has no snow sensor.\"}",
   [surface_measurements]: "{\"description\": \"Per-sensor road surface measurements (temperature, freezing point, surface condition).\"}",
   [sub_surface_measurements]: "{\"description\": \"Per-sensor sub-surface (in-pavement) temperature measurements.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

