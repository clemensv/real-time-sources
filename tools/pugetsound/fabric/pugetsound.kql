.alter table ['us.wa.wsdot.cvrestrictions.CommercialVehicleRestriction'] docstring "{\"description\": \"A commercial vehicle restriction on a Washington State highway bridge or road segment. Restrictions limit vehicle weight, height, length, or width.\"}";

.alter table ['us.wa.wsdot.cvrestrictions.CommercialVehicleRestriction'] column-docstrings (
   [state_route_id]: "{\"description\": \"State route identifier, first part of composite key.\"}",
   [bridge_number]: "{\"description\": \"Bridge or structure number, second part of composite key.\"}",
   [bridge_name]: "{\"description\": \"Bridge or structure name.\"}",
   [location_name]: "{\"description\": \"Location relative to landmarks.\"}",
   [location_description]: "{\"description\": \"Detailed location description.\"}",
   [latitude]: "{\"description\": \"Latitude in WGS84.\"}",
   [longitude]: "{\"description\": \"Longitude in WGS84.\"}",
   [state]: "{\"description\": \"State abbreviation, typically WA.\"}",
   [restriction_type]: "{\"description\": \"Type: BridgeRestriction, RoadRestriction.\"}",
   [vehicle_type]: "{\"description\": \"Affected vehicle type.\"}",
   [restriction_weight_in_pounds]: "{\"description\": \"Axle weight limit in pounds.\"}",
   [maximum_gross_vehicle_weight_in_pounds]: "{\"description\": \"GVW limit in pounds.\"}",
   [restriction_height_in_inches]: "{\"description\": \"Height limit in inches.\"}",
   [restriction_width_in_inches]: "{\"description\": \"Width limit in inches.\"}",
   [restriction_length_in_inches]: "{\"description\": \"Length limit in inches.\"}",
   [is_permanent_restriction]: "{\"description\": \"True if permanent.\"}",
   [is_warning]: "{\"description\": \"True if warning only.\"}",
   [is_detour_available]: "{\"description\": \"True if detour exists.\"}",
   [is_exceptions_allowed]: "{\"description\": \"True if permits available.\"}",
   [restriction_comment]: "{\"description\": \"Additional details.\"}",
   [date_posted]: "{\"description\": \"ISO 8601 UTC date posted.\"}",
   [date_effective]: "{\"description\": \"ISO 8601 UTC date effective.\"}",
   [date_expires]: "{\"description\": \"ISO 8601 UTC date expires.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

