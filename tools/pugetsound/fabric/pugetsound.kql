.alter table ['us.wa.wsdot.cameras.HighwayCamera'] docstring "{\"description\": \"Reference catalog entry for a WSDOT highway traffic camera, including its location and a claim-check image URL. The image bytes are not transported; consumers fetch the most recent frame from ImageURL on demand.\"}";

.alter table ['us.wa.wsdot.cameras.HighwayCamera'] column-docstrings (
   [camera_id]: "{\"description\": \"WSDOT camera identifier (stable).\"}",
   [title]: "{\"description\": \"Human-readable camera title.\"}",
   [description]: "{\"description\": \"Optional camera description.\"}",
   [camera_owner]: "{\"description\": \"Organization that owns/operates the camera.\"}",
   [owner_url]: "{\"description\": \"URL with more information from the camera owner.\"}",
   [image_url]: "{\"description\": \"Claim-check URL of the current camera image. The image bytes are not transported in the event; consumers fetch the latest frame from this URL on demand.\"}",
   [image_width]: "{\"description\": \"Width of the camera image.\"}",
   [image_height]: "{\"description\": \"Height of the camera image.\"}",
   [is_active]: "{\"description\": \"Whether the camera is currently active.\"}",
   [region]: "{\"description\": \"WSDOT region (or area code) for the camera.\"}",
   [sort_order]: "{\"description\": \"WSDOT display sort order.\"}",
   [display_latitude]: "{\"description\": \"Latitude used for map display, in WGS84.\"}",
   [display_longitude]: "{\"description\": \"Longitude used for map display, in WGS84.\"}",
   [location_description]: "{\"description\": \"Description of the camera roadway location.\"}",
   [location_direction]: "{\"description\": \"Travel direction the camera faces.\"}",
   [location_road_name]: "{\"description\": \"Road name/route designation at the camera location.\"}",
   [location_milepost]: "{\"description\": \"Milepost of the camera location.\"}",
   [location_latitude]: "{\"description\": \"Latitude of the camera location in WGS84.\"}",
   [location_longitude]: "{\"description\": \"Longitude of the camera location in WGS84.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

