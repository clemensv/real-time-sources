.alter table ['us.wa.kingcounty.marine.WaterQualityReading'] docstring "{\"description\": \"Normalized King County buoy or mooring reading carrying the documented water-quality and weather measurements published by the current raw-data datasets.\"}";

.alter table ['us.wa.kingcounty.marine.WaterQualityReading'] column-docstrings (
   [station_id]: "{\"description\": \"Stable bridge identifier for the buoy or mooring dataset.\"}",
   [station_name]: "{\"description\": \"Human-readable station name derived from the dataset title.\"}",
   [observation_time]: "{\"description\": \"Observation timestamp normalized to UTC ISO 8601 form.\"}",
   [water_temperature_c]: "{\"description\": \"Water temperature in degrees Celsius.\"}",
   [conductivity_s_m]: "{\"description\": \"Electrical conductivity in siemens per meter.\"}",
   [pressure_dbar]: "{\"description\": \"Water pressure in decibar as published by the raw datasets.\"}",
   [dissolved_oxygen_mg_l]: "{\"description\": \"Dissolved oxygen concentration in milligrams per liter.\"}",
   [ph]: "{\"description\": \"Measured pH value.\"}",
   [chlorophyll_ug_l]: "{\"description\": \"Chlorophyll fluorescence or chlorophyll concentration in micrograms per liter.\"}",
   [turbidity_ntu]: "{\"description\": \"Turbidity in nephelometric turbidity units.\"}",
   [chlorophyll_stddev_ug_l]: "{\"description\": \"Standard deviation of chlorophyll fluorescence in micrograms per liter.\"}",
   [turbidity_stddev_ntu]: "{\"description\": \"Standard deviation of turbidity in nephelometric turbidity units.\"}",
   [salinity_psu]: "{\"description\": \"Salinity in practical salinity units.\"}",
   [specific_conductivity_s_m]: "{\"description\": \"Specific conductivity in siemens per meter.\"}",
   [dissolved_oxygen_saturation_pct]: "{\"description\": \"Dissolved oxygen saturation as a percentage.\"}",
   [nitrate_umol]: "{\"description\": \"Nitrate or nitrate-plus-nitrite concentration in micromoles.\"}",
   [nitrate_mg_l]: "{\"description\": \"Nitrate or nitrate-plus-nitrite concentration in milligrams per liter.\"}",
   [wind_direction_deg]: "{\"description\": \"Wind direction in degrees at the buoy surface.\"}",
   [wind_speed_m_s]: "{\"description\": \"Wind speed in meters per second at the buoy surface.\"}",
   [photosynthetically_active_radiation_umol_s_m2]: "{\"description\": \"Photosynthetically active radiation in micromoles per second per square meter.\"}",
   [air_temperature_f]: "{\"description\": \"Air temperature in degrees Fahrenheit.\"}",
   [air_humidity_pct]: "{\"description\": \"Relative humidity percentage.\"}",
   [air_pressure_in_hg]: "{\"description\": \"Air pressure in inches of mercury.\"}",
   [system_battery_v]: "{\"description\": \"System battery voltage in volts.\"}",
   [sensor_battery_v]: "{\"description\": \"Sensor or sonde battery voltage in volts.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

