   [benchmarks]: "{\"description\": \"Referenced nested object from the NOAA Tides and Currents station metadata schema.\", \"schema\": {\"type\": \"object\", \"properties\": {\"self\": {\"type\": \"string\"}}, \"description\": \"Referenced nested object from the NOAA Tides and Currents station metadata schema.\", \"required\": \"self\"}}",
   [tidePredOffsets]: "{\"description\": \"Referenced nested object from the NOAA Tides and Currents station metadata schema.\", \"schema\": {\"type\": \"object\", \"properties\": {\"self\": {\"type\": \"string\"}}, \"description\": \"Referenced nested object from the NOAA Tides and Currents station metadata schema.\", \"required\": \"self\"}}",
   [ofsMapOffsets]: "{\"description\": \"Referenced nested object from the NOAA Tides and Currents station metadata schema.\", \"schema\": {\"type\": \"object\", \"properties\": {\"self\": {\"type\": \"string\"}}, \"description\": \"Referenced nested object from the NOAA Tides and Currents station metadata schema.\", \"required\": \"self\"}}",
