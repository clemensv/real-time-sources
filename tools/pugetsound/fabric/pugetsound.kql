.alter table ['us.wa.wsdot.roadweather.RoadWeatherStation'] docstring "{\"description\": \"Metadata for a WSDOT Scanweb road weather information system (RWIS) station, including position and elevation. WSDOT operates roughly 105 Scanweb stations reporting pavement and atmospheric conditions across Washington State highways.\"}";

.alter table ['us.wa.wsdot.roadweather.RoadWeatherStation'] column-docstrings (
   [station_id]: "{\"description\": \"Stable station identifier. From upstream StationId; when StationId is blank (a few Scanweb stations report a blank id) the bridge copies the unique StationName into this field so every station has a stable, non-empty key.\"}",
   [station_name]: "{\"description\": \"Station name (unique across the Scanweb network).\"}",
   [latitude]: "{\"description\": \"Latitude in WGS84.\"}",
   [longitude]: "{\"description\": \"Longitude in WGS84.\"}",
   [elevation]: "{\"description\": \"Station elevation above sea level.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

.create-or-alter table ['us.wa.wsdot.roadweather.RoadWeatherStation'] ingestion json mapping "us.wa.wsdot.roadweather.RoadWeatherStation_json_flat"
