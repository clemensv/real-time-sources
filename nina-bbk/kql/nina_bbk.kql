.drop materialized-view CivilWarningLatest ifexists;

.create materialized-view with (backfill=true) CivilWarningLatest on table CivilWarning {
    CivilWarning | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [CivilWarning] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'NINA.CivilWarning') | project['warning_id'] = tostring(data.['warning_id']),['provider'] = tostring(data.['provider']),['version'] = toint(data.['version']),['sender'] = tostring(data.['sender']),['sender_name'] = tostring(data.['sender_name']),['sent'] = todatetime(data.['sent']),['status'] = tostring(data.['status']),['msg_type'] = tostring(data.['msg_type']),['scope'] = tostring(data.['scope']),['references'] = tostring(data.['references']),['event'] = tostring(data.['event']),['event_code'] = tostring(data.['event_code']),['category'] = tostring(data.['category']),['severity'] = tostring(data.['severity']),['urgency'] = tostring(data.['urgency']),['certainty'] = tostring(data.['certainty']),['headline'] = tostring(data.['headline']),['description'] = tostring(data.['description']),['instruction'] = tostring(data.['instruction']),['web'] = tostring(data.['web']),['contact'] = tostring(data.['contact']),['area_desc'] = tostring(data.['area_desc']),['verwaltungsbereiche'] = tostring(data.['verwaltungsbereiche']),['language'] = tostring(data.['language']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

