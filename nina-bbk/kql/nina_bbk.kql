.create-merge table [_cloudevents_dispatch] (
    [specversion]: string,
    [type]: string,
    [source]: string,
    [id]: string,
    [time]: datetime,
    [subject]: string,
    [datacontenttype]: string,
    [dataschema]: string,
    [data]: dynamic
);

.create-or-alter table [_cloudevents_dispatch] ingestion json mapping "_cloudevents_dispatch_json"
```
[
  {"column": "specversion", "path": "$.specversion"},
  {"column": "type", "path": "$.type"},
  {"column": "source", "path": "$.source"},
  {"column": "id", "path": "$.id"},
  {"column": "time", "path": "$.time"},
  {"column": "subject", "path": "$.subject"},
  {"column": "datacontenttype", "path": "$.datacontenttype"},
  {"column": "dataschema", "path": "$.dataschema"},
  {"column": "data", "path": "$.data"}
]
```

.create-merge table [CivilWarning] (
   [warning_id]: string,
   [provider]: string,
   [version]: int,
   [sender]: string,
   [sender_name]: string,
   [sent]: datetime,
   [status]: string,
   [msg_type]: string,
   [scope]: string,
   [references]: string,
   [event]: string,
   [event_code]: string,
   [category]: string,
   [severity]: string,
   [urgency]: string,
   [certainty]: string,
   [headline]: string,
   [description]: string,
   [instruction]: string,
   [web]: string,
   [contact]: string,
   [area_desc]: string,
   [verwaltungsbereiche]: string,
   [language]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [CivilWarning] docstring "{\"description\": \"A civil protection warning from Germany's NINA/BBK system. Contains CAP-structured alert data with multi-language info blocks, BBK event codes, and German administrative area geocodes (Verwaltungsbereiche).\"}";

.alter table [CivilWarning] column-docstrings (
   [warning_id]: "{\"description\": \"The unique warning identifier assigned by the NINA/BBK system (e.g., 'mow.DE-HE-DA-W184-20240723-000').\"}",
   [provider]: "{\"description\": \"The NINA provider that issued the warning.\"}",
   [version]: "{\"description\": \"The version number of this warning, incremented with each update.\"}",
   [sender]: "{\"description\": \"The identifier of the issuing authority (e.g., 'DE-HE-DA-W184').\"}",
   [sender_name]: "{\"description\": \"The human-readable long name of the issuing authority (e.g., 'Integrierte Leitstelle Stadt Darmstadt').\"}",
   [sent]: "{\"description\": \"The date and time when the warning was issued, in ISO-8601 format.\"}",
   [status]: "{\"description\": \"The CAP alert status.\"}",
   [msg_type]: "{\"description\": \"The CAP message type indicating the nature of the warning.\"}",
   [scope]: "{\"description\": \"The CAP scope of the warning. Typically 'Public'.\"}",
   [references]: "{\"description\": \"CAP references to prior related warnings, in the format 'sender,identifier,sent'.\"}",
   [event]: "{\"description\": \"The event type description (e.g., 'Gefahreninformation', 'Hochwasserinformation').\"}",
   [event_code]: "{\"description\": \"The BBK event code identifying the hazard type (e.g., 'BBK-EVC-067' for animal disease, 'BBK-EVC-045' for flood).\"}",
   [category]: "{\"description\": \"The CAP alert category.\"}",
   [severity]: "{\"description\": \"The CAP severity level.\"}",
   [urgency]: "{\"description\": \"The CAP urgency level.\"}",
   [certainty]: "{\"description\": \"The CAP certainty level.\"}",
   [headline]: "{\"description\": \"A brief human-readable headline summarizing the warning.\"}",
   [description]: "{\"description\": \"A detailed description of the warning situation.\"}",
   [instruction]: "{\"description\": \"Recommended protective actions for the public.\"}",
   [web]: "{\"description\": \"A URL to further information about the warning.\"}",
   [contact]: "{\"description\": \"Contact information for the issuing authority.\"}",
   [area_desc]: "{\"description\": \"A textual description of the affected geographic area.\"}",
   [verwaltungsbereiche]: "{\"description\": \"Comma-separated German administrative area codes (Amtliche Gemeindeschl\\u00fcssel) affected by the warning.\"}",
   [language]: "{\"description\": \"The language of the info block used to populate this event (e.g., 'de', 'EN').\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

