{
  "endpoints": {
    "be.issep.airquality.Sensors.Kafka": {
      "usage": [
        "producer"
      ],
      "protocol": "KAFKA",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "structured",
        "format": "application/cloudevents+json"
      },
      "protocoloptions": {
        "deployed": false,
        "options": {
          "topic": "wallonia-issep",
          "key": "{configuration_id}"
        }
      },
      "messagegroups": [
        "#/messagegroups/be.issep.airquality.Sensors"
      ]
    }
  },
  "messagegroups": {
    "be.issep.airquality.Sensors": {
      "messages": {
        "be.issep.airquality.SensorConfiguration": {
          "name": "SensorConfiguration",
