.drop materialized-view ObservationLatest ifexists;

.create materialized-view with (backfill=true) ObservationLatest on table Observation {
    Observation | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [Observation] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'be.issep.airquality.Observation') | project['configuration_id'] = tostring(data.['configuration_id']),['moment'] = tostring(data.['moment']),['co'] = toint(data.['co']),['no'] = toint(data.['no']),['no2'] = toint(data.['no2']),['o3no2'] = toint(data.['o3no2']),['ppbno'] = toreal(data.['ppbno']),['ppbno_statut'] = toint(data.['ppbno_statut']),['ppbno2'] = toreal(data.['ppbno2']),['ppbno2_statut'] = toint(data.['ppbno2_statut']),['ppbo3'] = toreal(data.['ppbo3']),['ppbo3_statut'] = toint(data.['ppbo3_statut']),['ugpcmno'] = toreal(data.['ugpcmno']),['ugpcmno_statut'] = toint(data.['ugpcmno_statut']),['ugpcmno2'] = toreal(data.['ugpcmno2']),['ugpcmno2_statut'] = toint(data.['ugpcmno2_statut']),['ugpcmo3'] = toreal(data.['ugpcmo3']),['ugpcmo3_statut'] = toint(data.['ugpcmo3_statut']),['bme_t'] = toreal(data.['bme_t']),['bme_t_statut'] = toint(data.['bme_t_statut']),['bme_pres'] = toint(data.['bme_pres']),['bme_pres_statut'] = toint(data.['bme_pres_statut']),['bme_rh'] = toreal(data.['bme_rh']),['bme_rh_statut'] = toint(data.['bme_rh_statut']),['pm1'] = toreal(data.['pm1']),['pm1_statut'] = toint(data.['pm1_statut']),['pm25'] = toreal(data.['pm25']),['pm25_statut'] = toint(data.['pm25_statut']),['pm4'] = toreal(data.['pm4']),['pm4_statut'] = toint(data.['pm4_statut']),['pm10'] = toreal(data.['pm10']),['pm10_statut'] = toint(data.['pm10_statut']),['vbat'] = toreal(data.['vbat']),['vbat_statut'] = toint(data.['vbat_statut']),['mwh_bat'] = toreal(data.['mwh_bat']),['mwh_pv'] = toreal(data.['mwh_pv']),['co_rf'] = toreal(data.['co_rf']),['no_rf'] = toreal(data.['no_rf']),['no2_rf'] = toreal(data.['no2_rf']),['o3no2_rf'] = toreal(data.['o3no2_rf']),['o3_rf'] = toreal(data.['o3_rf']),['pm10_rf'] = toreal(data.['pm10_rf']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

