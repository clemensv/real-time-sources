   [ugpcmo3]: real,
   [ugpcmo3_statut]: int,
   [bme_t]: real,
   [bme_t_statut]: int,
   [bme_pres]: int,
   [bme_pres_statut]: int,
   [bme_rh]: real,
   [bme_rh_statut]: int,
   [pm1]: real,
   [pm1_statut]: int,
   [pm25]: real,
   [pm25_statut]: int,
   [pm4]: real,
   [pm4_statut]: int,
   [pm10]: real,
   [pm10_statut]: int,
   [vbat]: real,
   [vbat_statut]: int,
   [mwh_bat]: real,
   [mwh_pv]: real,
   [co_rf]: real,
   [no_rf]: real,
   [no2_rf]: real,
   [o3no2_rf]: real,
