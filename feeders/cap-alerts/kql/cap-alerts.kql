.drop materialized-view ['org.oasis.cap.alerts.CapAlertLatest'] ifexists;

.create materialized-view with (backfill=true) ['org.oasis.cap.alerts.CapAlertLatest'] on table ['org.oasis.cap.alerts.CapAlert'] {
    ['org.oasis.cap.alerts.CapAlert'] | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table ['org.oasis.cap.alerts.CapAlert'] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'org.oasis.cap.alerts.CapAlert') | project['cap_source_id'] = tostring(data.['cap_source_id']),['identifier'] = tostring(data.['identifier']),['sender'] = tostring(data.['sender']),['sent'] = todatetime(data.['sent']),['status'] = tostring(data.['status']),['msg_type'] = tostring(data.['msg_type']),['source'] = tostring(data.['source']),['scope'] = tostring(data.['scope']),['restriction'] = tostring(data.['restriction']),['addresses'] = todynamic(data.['addresses']),['code'] = todynamic(data.['code']),['note'] = tostring(data.['note']),['references'] = todynamic(data.['references']),['incidents'] = todynamic(data.['incidents']),['info'] = todynamic(data.['info']),['provider_url'] = tostring(data.['provider_url']),['raw_cap_xml'] = tostring(data.['raw_cap_xml']),['area_desc'] = tostring(data.['area_desc']),['same_codes'] = todynamic(data.['same_codes']),['ugc_codes'] = todynamic(data.['ugc_codes']),['vtec'] = todynamic(data.['vtec']),['awareness_level'] = tostring(data.['awareness_level']),['awareness_type'] = tostring(data.['awareness_type']),['event_type'] = tostring(data.['event_type']),['state'] = tostring(data.['state']),['affected_zones'] = todynamic(data.['affected_zones']),['raw_source_json'] = tostring(data.['raw_source_json']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true
}]
```

.create-merge table ['org.oasis.cap.alerts.CapZone'] (
   [cap_source_id]: string,
   [zone_id]: string,
   [name]: string,
   [zone_type]: string,
   [state]: string,
   [forecast_office]: string,
   [time_zones]: dynamic,
   [geometry]: string,
   [provider_url]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table ['org.oasis.cap.alerts.CapZone'] docstring @"{""description"": ""Reference event for an alerting zone, forecast zone, MeteoAlarm region, or other area catalog entry exposed by a configured CAP source. The feeder emits zone reference data before alerts when the source exposes metadata such as api.weather.gov /zones, enabling consumers to interpret alert geocodes temporally.""}";

.alter table ['org.oasis.cap.alerts.CapZone'] column-docstrings (
   [cap_source_id]: @"{""description"": ""Configuration-assigned stable source identifier qualifying zone identifiers across agencies and used as the first subject/key segment.""}",
   [zone_id]: @"{""description"": ""Stable upstream zone or region identifier, such as an NWS UGC zone code, county zone id, MeteoAlarm region code, or DWD area code.""}",
   [name]: @"{""description"": ""Human-readable zone or region name supplied by the source metadata endpoint. Null when the source exposes only codes.""}",
   [zone_type]: @"{""description"": ""Provider zone type or category, for example NWS public, marine, county, fire, forecast, or MeteoAlarm region class.""}",
   [state]: @"{""description"": ""State, country, or regional routing token associated with the zone, if supplied by the metadata endpoint.""}",
   [forecast_office]: @"{""description"": ""Responsible office or authority URL/code for this zone, such as an NWS Weather Forecast Office. Null when not supplied.""}",
   [time_zones]: @"{""description"": ""IANA time-zone names associated with the zone when supplied by the metadata endpoint."", ""schema"": {""type"": ""array"", ""description"": ""IANA time-zone names associated with the zone when supplied by the metadata endpoint."", ""items"": {""type"": ""string""}}}",
   [geometry]: @"{""description"": ""GeoJSON geometry serialized as compact JSON text when supplied by the metadata endpoint. Null when no geometry is published or when disabled for payload-size reasons.""}",
   [provider_url]: @"{""description"": ""Metadata endpoint URL from which this zone reference was acquired. Used as CloudEvent source template and traceability link.""}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

