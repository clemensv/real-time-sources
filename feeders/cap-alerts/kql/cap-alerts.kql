.create-merge table [_cloudevents_dispatch] (
    [specversion]: string,
    [type]: string,
    [source]: string,
    [id]: string,
    [time]: datetime,
    [subject]: string,
    [datacontenttype]: string,
    [dataschema]: string,
    [data]: dynamic
);

.create-or-alter table [_cloudevents_dispatch] ingestion json mapping "_cloudevents_dispatch_json"
```
[
  {"column": "specversion", "path": "$.specversion"},
  {"column": "type", "path": "$.type"},
  {"column": "source", "path": "$.source"},
  {"column": "id", "path": "$.id"},
  {"column": "time", "path": "$.time"},
  {"column": "subject", "path": "$.subject"},
  {"column": "datacontenttype", "path": "$.datacontenttype"},
  {"column": "dataschema", "path": "$.dataschema"},
  {"column": "data", "path": "$.data"}
]
```

.create-merge table ['org.oasis.cap.alerts.CapAlert'] (
   [cap_source_id]: string,
   [identifier]: string,
   [sender]: string,
   [sent]: datetime,
   [status]: string,
   [msg_type]: string,
   [source]: string,
   [scope]: string,
   [restriction]: string,
   [addresses]: dynamic,
   [code]: dynamic,
   [note]: string,
   [references]: dynamic,
   [incidents]: dynamic,
   [info]: dynamic,
   [provider_url]: string,
   [raw_cap_xml]: string,
   [area_desc]: string,
   [same_codes]: dynamic,
   [ugc_codes]: dynamic,
   [vtec]: dynamic,
   [awareness_level]: string,
   [awareness_type]: string,
   [event_type]: string,
   [state]: string,
   [affected_zones]: dynamic,
   [raw_source_json]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table ['org.oasis.cap.alerts.CapAlert'] docstring @"{""description"": ""Generalized Common Alerting Protocol (CAP) 1.2 alert message. It preserves the full alert -> info[] -> area[]/resource[] CAP hierarchy plus standardized CAP extension arrays (eventCode, parameter, geocode) so national weather and emergency alert feeds can be represented losslessly. Convenience fields mirror typed fields emitted by existing DWD, MeteoAlarm, NOAA NWS, and NWS Alerts bespoke feeders while keeping the original CAP name/value pairs.""}";

.alter table ['org.oasis.cap.alerts.CapAlert'] column-docstrings (
   [cap_source_id]: @"{""description"": ""Configuration-assigned stable source identifier qualifying CAP alert identifiers across agencies. Examples: nws-us, meteoalarm-belgium, dwd-germany. This value is the first segment of the CloudEvent subject and Kafka key.""}",
   [identifier]: @"{""description"": ""CAP identifier assigned by the sender to this alert message. Unique only within the sender/source, so the feeder qualifies it with cap_source_id for keys. Updates and cancellations use their own identifier; the CAP references field points to prior messages.""}",
   [sender]: @"{""description"": ""CAP sender identifier for the originating alerting authority, such as w-nws.webmaster@noaa.gov or opendata@dwd.de.""}",
   [sent]: @"{""description"": ""CAP sent timestamp when the message was issued by the sender, parsed as an ISO 8601 datetime.""}",
   [status]: @"{""description"": ""CAP status for operational state of this message.""}",
   [msg_type]: @"{""description"": ""CAP msgType indicating whether this message is an alert, update, cancellation, acknowledgement, or error.""}",
   [source]: @"{""description"": ""CAP source: particular source of this alert message when supplied separately from sender. Null when omitted.""}",
   [scope]: @"{""description"": ""CAP scope indicating intended distribution: Public, Restricted, or Private.""}",
   [restriction]: @"{""description"": ""CAP restriction text describing distribution limits for Restricted scope messages. Null when not applicable.""}",
   [addresses]: @"{""description"": ""CAP addresses list for Private messages, split into individual address tokens. Empty for Public and most Restricted alerts."", ""schema"": {""type"": ""array"", ""description"": ""CAP addresses list for Private messages, split into individual address tokens. Empty for Public and most Restricted alerts."", ""items"": {""type"": ""string""}}}",
   [code]: @"{""description"": ""CAP code elements and code-like provider values preserved as name/value pairs. Used for source-specific routing or profile markers."", ""schema"": ""{ \""doc\"": \""Schema too large to inline. Please refer to the JSON Structure schema for more details.\"" }""}",
   [note]: @"{""description"": ""CAP note: message note intended for alert handling, not necessarily public display. Null when omitted.""}",
   [references]: @"{""description"": ""CAP references entries identifying related prior messages that this message updates or cancels. Preserved as strings; not used as the CloudEvent key."", ""schema"": {""type"": ""array"", ""description"": ""CAP references entries identifying related prior messages that this message updates or cancels. Preserved as strings; not used as the CloudEvent key."", ""items"": {""type"": ""string""}}}",
   [incidents]: @"{""description"": ""CAP incidents identifiers listing incident(s) this alert message concerns. Empty when omitted."", ""schema"": {""type"": ""array"", ""description"": ""CAP incidents identifiers listing incident(s) this alert message concerns. Empty when omitted."", ""items"": {""type"": ""string""}}}",
   [info]: @"{""description"": ""All CAP info blocks attached to the alert. Multiple blocks are common for multilingual or multi-instruction alerts and are preserved losslessly."", ""schema"": ""{ \""doc\"": \""Schema too large to inline. Please refer to the JSON Structure schema for more details.\"" }""}",
   [provider_url]: @"{""description"": ""URL of the configured feed or detail resource from which this alert was acquired. Used as CloudEvent source template and for traceability.""}",
   [raw_cap_xml]: @"{""description"": ""Original CAP XML document text when the source supplied XML. Null for JSON-only sources such as api.weather.gov active alerts unless a raw CAP detail URL was fetched.""}",
   [area_desc]: @"{""description"": ""Convenience copy of the first info/area/areaDesc or NWS areaDesc used by existing bespoke feeders. The complete area list is still preserved under info[].area[].""}",
   [same_codes]: @"{""description"": ""Convenience extraction of NWS SAME geocodes from CAP geocode/parameter pairs. The original values are also preserved in generic geocode[] or parameter[] arrays."", ""schema"": {""type"": ""array"", ""description"": ""Convenience extraction of NWS SAME geocodes from CAP geocode/parameter pairs. The original values are also preserved in generic geocode[] or parameter[] arrays."", ""items"": {""type"": ""string""}}}",
   [ugc_codes]: @"{""description"": ""Convenience extraction of NWS UGC zone codes from CAP geocode/parameter pairs. The original values are also preserved in generic geocode[] or parameter[] arrays."", ""schema"": {""type"": ""array"", ""description"": ""Convenience extraction of NWS UGC zone codes from CAP geocode/parameter pairs. The original values are also preserved in generic geocode[] or parameter[] arrays."", ""items"": {""type"": ""string""}}}",
   [vtec]: @"{""description"": ""Convenience extraction of NWS VTEC tracking strings from CAP parameters. The original VTEC values are also present in info[].parameter[]."", ""schema"": {""type"": ""array"", ""description"": ""Convenience extraction of NWS VTEC tracking strings from CAP parameters. The original VTEC values are also present in info[].parameter[]."", ""items"": {""type"": ""string""}}}",
   [awareness_level]: @"{""description"": ""Convenience extraction of MeteoAlarm awareness_level CAP parameter. The original name/value pair is also preserved in info[].parameter[].""}",
   [awareness_type]: @"{""description"": ""Convenience extraction of MeteoAlarm awareness_type CAP parameter. The original name/value pair is also preserved in info[].parameter[].""}",
   [event_type]: @"{""description"": ""Normalized lower-case event or hazard token for routing and legacy feeder compatibility, derived from CAP info.event when available.""}",
   [state]: @"{""description"": ""Provider-specific state, territory, country, or administrative routing token when present in the upstream feed. Null when not derivable.""}",
   [affected_zones]: @"{""description"": ""NWS API affectedZones URI list and equivalent zone references from JSON CAP-equivalent sources. CAP XML feeds generally express the same information as area/geocode entries; this array preserves JSON-native zone URI references for lossless future folds."", ""schema"": {""type"": ""array"", ""description"": ""NWS API affectedZones URI list and equivalent zone references from JSON CAP-equivalent sources. CAP XML feeds generally express the same information as area/geocode entries; this array preserves JSON-native zone URI references for lossless future folds."", ""items"": {""type"": ""uri""}}}",
   [raw_source_json]: @"{""description"": ""Raw upstream JSON object serialized as compact JSON when the source is a CAP-equivalent JSON API such as api.weather.gov. Null for native CAP XML feeds; retained as an escape hatch so future bespoke folds can prove no source-specific field was lost.""}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

