        "CZ.Gov.CHMI.Hydro.WaterLevelObservation": {
          "name": "WaterLevelObservation",
          "format": "Avro/1.11.3",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "Avro/1.11.3",
              "schema": {
                "type": "record",
                "name": "WaterLevelObservation",
                "doc": "Measurement payload for observations in the ČHMÚ Hydrological Data source.",
