# syntax=docker/dockerfile:1.6
FROM python:3.10-slim
LABEL org.opencontainers.image.source="https://github.com/clemensv/real-time-sources/tree/main/feeders/ireland-opw-waterlevel" \
      org.opencontainers.image.title="ireland-opw-waterlevel → MQTT/UNS bridge" \
      org.opencontainers.image.description="Publishes ireland-opw-waterlevel CloudEvents over MQTT 5.0 into the documented Unified Namespace topic tree." \
      org.opencontainers.image.documentation="https://github.com/clemensv/real-time-sources/blob/main/feeders/ireland-opw-waterlevel/CONTAINER.md" \
      org.opencontainers.image.license="MIT"
ENV PYTHONUNBUFFERED=1
WORKDIR /app

ENV SETUPTOOLS_SCM_PRETEND_VERSION=0
COPY . /app
RUN pip install --no-cache-dir confluent-kafka \
 && pip install --no-cache-dir ./ireland_opw_waterlevel_mqtt_producer/ireland_opw_waterlevel_mqtt_producer_data \
 && pip install --no-cache-dir ./ireland_opw_waterlevel_mqtt_producer/ireland_opw_waterlevel_mqtt_producer_mqtt_client \
 && pip install --no-cache-dir ./ireland_opw_waterlevel_producer/ireland_opw_waterlevel_producer_kafka_producer \
 && pip install --no-cache-dir ./ireland_opw_waterlevel_mqtt
ENV MQTT_BROKER_URL=""
# Build-time import smoke: fail the image build if the app module (or any
# companion package it imports) is not importable -- closes the "built but
# never ran" gap. PR-time equivalent: tools/ci/import_smoke.py.
RUN python -c "import importlib, importlib.util as _u; _m = 'ireland_opw_waterlevel_mqtt'; importlib.import_module(_m + '.app' if _u.find_spec(_m + '.app') else _m)"

CMD ["python", "-m", "ireland_opw_waterlevel_mqtt", "feed"]
