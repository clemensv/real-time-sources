# syntax=docker/dockerfile:1.6
FROM python:3.10-slim
LABEL org.opencontainers.image.source="https://github.com/clemensv/real-time-sources/tree/main/feeders/ireland-opw-waterlevel" \
      org.opencontainers.image.title="ireland-opw-waterlevel → AMQP 1.0 bridge" \
      org.opencontainers.image.description="Publishes ireland-opw-waterlevel CloudEvents over AMQP 1.0 to generic brokers and Azure Service Bus/Event Hubs." \
      org.opencontainers.image.documentation="https://github.com/clemensv/real-time-sources/blob/main/feeders/ireland-opw-waterlevel/CONTAINER.md" \
      org.opencontainers.image.license="MIT"
ENV PYTHONUNBUFFERED=1
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends build-essential cmake pkg-config swig libssl-dev libsasl2-dev python3-dev libsasl2-2 libsasl2-modules && rm -rf /var/lib/apt/lists/*
COPY . /app
RUN pip install --no-cache-dir ./ireland_opw_waterlevel_amqp_producer/ireland_opw_waterlevel_amqp_producer_data \
 && pip install --no-cache-dir ./ireland_opw_waterlevel_amqp_producer/ireland_opw_waterlevel_amqp_producer_amqp_producer \
 && pip install --no-cache-dir ./ireland_opw_waterlevel_amqp \
 && apt-get purge -y --auto-remove build-essential cmake pkg-config swig libssl-dev libsasl2-dev python3-dev \
 && rm -rf /root/.cache /var/lib/apt/lists/*
ENV AMQP_BROKER_URL=""
ENV AMQP_ADDRESS="ireland-opw-waterlevel"
CMD ["python", "-m", "ireland_opw_waterlevel_amqp", "feed"]
