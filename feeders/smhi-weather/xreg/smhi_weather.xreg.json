            }
          },
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "topic_name": "weather/se/smhi/smhi-weather/{lan}/{station_id}/observation",
            "qos": 1,
            "retain": true
          },
          "envelope": "CloudEvents/1.0"
        }
      }
    },
    "SE.Gov.SMHI.Weather.amqp": {
      "description": "AMQP 1.0 companion message group for SE.Gov.SMHI.Weather.",
      "messages": {
        "SE.Gov.SMHI.Weather.amqp.Station": {
          "name": "Station",
          "basemessageuri": "/messagegroups/SE.Gov.SMHI.Weather/messages/SE.Gov.SMHI.Weather.Station",
          "envelopemetadata": {
            "type": {
              "value": "SE.Gov.SMHI.Weather.Station"
            },
