.drop materialized-view RecentChangeLatest ifexists;

.create materialized-view with (backfill=true) RecentChangeLatest on table RecentChange {
    RecentChange | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [RecentChange] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'Wikimedia.EventStreams.RecentChange') | project['event_id'] = tostring(data.['event_id']),['event_time'] = tostring(data.['event_time']),['schema_uri'] = tostring(data.['schema_uri']),['meta'] = todynamic(data.['meta']),['id'] = tostring(data.['id']),['type'] = tostring(data.['type']),['namespace'] = toint(data.['namespace']),['title'] = tostring(data.['title']),['title_url'] = tostring(data.['title_url']),['comment'] = tostring(data.['comment']),['timestamp'] = toint(data.['timestamp']),['user'] = tostring(data.['user']),['bot'] = tobool(data.['bot']),['minor'] = tobool(data.['minor']),['patrolled'] = tobool(data.['patrolled']),['length'] = todynamic(data.['length']),['revision'] = todynamic(data.['revision']),['server_url'] = tostring(data.['server_url']),['server_name'] = tostring(data.['server_name']),['server_script_path'] = tostring(data.['server_script_path']),['wiki'] = tostring(data.['wiki']),['parsedcomment'] = tostring(data.['parsedcomment']),['notify_url'] = tostring(data.['notify_url']),['log_type'] = tostring(data.['log_type']),['log_action'] = tostring(data.['log_action']),['log_action_comment'] = tostring(data.['log_action_comment']),['log_id'] = tostring(data.['log_id']),['log_params_json'] = tostring(data.['log_params_json']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

