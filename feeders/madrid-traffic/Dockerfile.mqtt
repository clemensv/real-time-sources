# syntax=docker/dockerfile:1.6
FROM python:3.10-slim
LABEL org.opencontainers.image.source="https://github.com/clemensv/real-time-sources/tree/main/feeders/madrid-traffic"
LABEL org.opencontainers.image.title="Madrid Traffic -> MQTT/UNS bridge"
LABEL org.opencontainers.image.description="Publishes Madrid Traffic CloudEvents over MQTT 5.0 into the source-specific UNS topic tree."
LABEL org.opencontainers.image.documentation="https://github.com/clemensv/real-time-sources/blob/main/feeders/madrid-traffic/CONTAINER.md"
LABEL org.opencontainers.image.license="MIT"
ENV PYTHONUNBUFFERED=1
WORKDIR /app

ENV SETUPTOOLS_SCM_PRETEND_VERSION=0
COPY . /app
RUN pip install --no-cache-dir ./madrid_traffic_mqtt
ENV MQTT_BROKER_URL=""
CMD ["python", "-m", "madrid_traffic_mqtt", "feed"]
