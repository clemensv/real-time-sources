);

.alter table [VolcanicWarning] docstring @"{""description"": ""JMA Bosai active volcanic warning or forecast for a target volcano.""}";

.alter table [VolcanicWarning] column-docstrings (
   [volcano_code]: @"{""description"": ""Three-digit JMA volcano identifier used in the Bosai volcanic warning feeds and the volcano catalog. This is the stable domain key for the volcano and is used in the CloudEvents subject and Kafka key.""}",
   [event_id]: @"{""description"": ""JMA eventId from the Bosai warning record. The warning feed uses this identifier with reportDatetime to identify the active report for a target volcano.""}",
   [report_datetime]: @"{""description"": ""Report issue time converted from JMA local Japan Standard Time to UTC and serialized as an RFC3339 timestamp. This is the normalized time used for cross-region analytics.""}",
   [report_datetime_local]: @"{""description"": ""Original JMA reportDatetime value in Japan Standard Time as published by the Bosai warning feed. Keeping the local timestamp preserves the official bulletin time shown by JMA.""}",
   [alert_level_code]: @"{""description"": ""Raw JMA volcanic warning code as published in the `code` field of warning.json, emitted verbatim as a string. JMA's volcanic warning codes form an OPEN, upstream-controlled vocabulary that changes with volcanic activity, so this field is intentionally not constrained to a closed enum; consumers should treat any unlisted code as a valid JMA code and rely on the sibling `alert_level_name` field for the human-readable label JMA publishes alongside each code. Known codes observed in the live feed and JMA eruption-alert-level guidance: `02` = Crater-area warning (\u706b\u53e3\u5468\u8fba\u8b66\u5831); `03` = Eruption warning for surrounding sea area (\u5674\u706b\u8b66\u5831\uff08\u5468\u8fba\u6d77\u57df\uff09); `04` = Eruption forecast, warning lifted (\u5674\u706b\u4e88\u5831\uff1a\u8b66\u5831\u89e3\u9664); `11` = Active volcano, pay attention (\u6d3b\u52d5\u706b\u5c71\u3067\u3042\u308b\u3053\u3068\u306b\u7559\u610f); `12` = Crater area restriction (\u706b\u53e3\u5468\u8fba\u898f\u5236); `13` = Mountain access restriction (\u5165\u5c71\u898f\u5236); `22` = Crater vicinity danger (\u706b\u53e3\u5468\u8fba\u5371\u967a); `23` = Mountain access danger...""}",
   [alert_level_name]: @"{""description"": ""Japanese alert level or warning label from the target-volcano item, such as \u30ec\u30d9\u30eb\uff13\uff08\u5165\u5c71\u898f\u5236\uff09. JMA uses this text to communicate the public-facing warning level or restriction phrase.""}",
   [previous_level_code]: @"{""description"": ""Previous JMA alert level or warning code from lastCode when the warning feed provides one. It allows consumers to determine whether the current report raised, lowered, continued, or newly issued a level.""}",
   [condition]: @"{""description"": ""Normalized lifecycle condition derived from the Japanese JMA condition text. \u767a\u8868 is mapped to ISSUED, \u5f15\u4e0a\u3052 to RAISED, \u5f15\u4e0b\u3052 to LOWERED, \u7d99\u7d9a to CONTINUED, \u5207\u66ff to SWITCHED, and \u89e3\u9664 to CANCELLED so downstream consumers can compare reports without parsing Japanese status labels.""}",
   [info_type_jp]: @"{""description"": ""Japanese volcanoInfos type label from the JMA feed. For emitted warning events the bridge uses the target-volcano section, normally \u5674\u706b\u8b66\u5831\u30fb\u4e88\u5831\uff08\u5bfe\u8c61\u706b\u5c71\uff09, because that section carries the stable volcano code identity.""}",
   [area_codes]: @"{""description"": ""List of JMA municipal or regional area codes from the outer areas field of the Bosai volcano report. JMA uses these area identifiers to indicate municipalities or regions affected by the volcanic warning or eruption information."", ""schema"": {""type"": ""array"", ""description"": ""List of JMA municipal or regional area codes from the outer areas field of the Bosai volcano report. JMA uses these area identifiers to indicate municipalities or regions affected by the volcanic warning or eruption information."", ""items"": {""type"": ""string"", ""description"": ""Payload for a reference record for an alerting area or region published by the Japan Meteorological Agency. It gives consumers names and identifiers needed to interpret related warnings.""}}}",
   [prefecture]: @"{""description"": ""ASCII-safe Japanese prefecture or region slug used as a MQTT and AMQP routing axis. The bridge derives this from JMA station/volcano metadata when available, otherwise emits unknown.""}",
   [event]: @"{""description"": ""Fixed topic event segment for VolcanicWarning messages.""}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

