   [alert_level_code]: string,
   [alert_level_name]: string,
   [previous_level_code]: string,
   [condition]: string,
   [info_type_jp]: string,
   [area_codes]: dynamic,
   [prefecture]: string,
   [event]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
