    ['IO.OpenChargeMap.ChargingLocation'] | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table ['IO.OpenChargeMap.ChargingLocation'] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'IO.OpenChargeMap.ChargingLocation') | project['poi_id'] = toint(data.['poi_id']),['uuid'] = tostring(data.['uuid']),['data_provider_id'] = toint(data.['data_provider_id']),['operator_id'] = toint(data.['operator_id']),['operator_title'] = tostring(data.['operator_title']),['usage_type_id'] = toint(data.['usage_type_id']),['usage_type_title'] = tostring(data.['usage_type_title']),['usage_cost'] = tostring(data.['usage_cost']),['status_type_id'] = toint(data.['status_type_id']),['status_title'] = tostring(data.['status_title']),['is_operational'] = tobool(data.['is_operational']),['submission_status_type_id'] = toint(data.['submission_status_type_id']),['submission_status_title'] = tostring(data.['submission_status_title']),['data_quality_level'] = toint(data.['data_quality_level']),['number_of_points'] = toint(data.['number_of_points']),['general_comments'] = tostring(data.['general_comments']),['is_recently_verified'] = tobool(data.['is_recently_verified']),['date_created'] = todatetime(data.['date_created']),['date_last_status_update'] = todatetime(data.['date_last_status_update']),['date_last_verified'] = todatetime(data.['date_last_verified']),['date_last_confirmed'] = todatetime(data.['date_last_confirmed']),['date_planned'] = todatetime(data.['date_planned']),['address_id'] = toint(data.['address_id']),['address_title'] = tostring(data.['address_title']),['address_line1'] = tostring(data.['address_line1']),['address_line2'] = tostring(data.['address_line2']),['town'] = tostring(data.['town']),['state_or_province'] = tostring(data.['state_or_province']),['postcode'] = tostring(data.['postcode']),['country_id'] = toint(data.['country_id']),['country_iso_code'] = tostring(data.['country_iso_code']),['country_title'] = tostring(data.['country_title']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),['contact_telephone1'] = tostring(data.['contact_telephone1']),['contact_telephone2'] = tostring(data.['contact_telephone2']),['contact_email'] = tostring(data.['contact_email']),['access_comments'] = tostring(data.['access_comments']),['related_url'] = tostring(data.['related_url']),['connections'] = todynamic(data.['connections']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true
}]
```

.create-merge table ['IO.OpenChargeMap.Operator'] (
   [reference_type]: string,
   [reference_id]: int,
   [title]: string,
   [website_url]: string,
   [comments]: string,
   [phone_primary_contact]: string,
   [phone_secondary_contact]: string,
   [contact_email]: string,
   [booking_url]: string,
   [fault_report_email]: string,
   [is_private_individual]: bool,
   [is_restricted_edit]: bool,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table ['IO.OpenChargeMap.Operator'] docstring @"{""description"": ""One charging-network operator from the Open Charge Map reference data `https://api.openchargemap.io/v3/referencedata/` (`Operators` table, ~977 entries). Operators own or run the charging equipment; a ChargingLocation joins to this event through its `operator_id`. Emitted at startup and on the periodic reference refresh so telemetry consumers can resolve operator identifiers without a separate lookup.""}";

.alter table ['IO.OpenChargeMap.Operator'] column-docstrings (
   [reference_type]: @"{""description"": ""Constant discriminator `operator` identifying this event as an operator reference entity. Forms the first segment of the `{reference_type}/{reference_id}` CloudEvents subject and Kafka key.""}",
   [reference_id]: @"{""description"": ""Open Charge Map operator identifier, from the operator `ID` field, for example `3296`. Matches the `operator_id` carried on ChargingLocation and forms the second segment of the subject/key.""}",
   [title]: @"{""description"": ""Human-readable name of the reference entity, from its `Title` field.""}",
   [website_url]: @"{""description"": ""Operator web site URL, from `WebsiteURL`. Null when unknown.""}",
   [comments]: @"{""description"": ""Free-text notes about the operator, from `Comments`, for example payment or roaming details. Often null.""}",
   [phone_primary_contact]: @"{""description"": ""Primary contact telephone number for the operator, from `PhonePrimaryContact`. Often null.""}",
   [phone_secondary_contact]: @"{""description"": ""Secondary contact telephone number for the operator, from `PhoneSecondaryContact`. Often null.""}",
   [contact_email]: @"{""description"": ""Contact email address for the operator, from `ContactEmail`. Often null.""}",
   [booking_url]: @"{""description"": ""URL for booking or account sign-up with the operator, from `BookingURL`. Often null.""}",
   [fault_report_email]: @"{""description"": ""Email address for reporting faults to the operator, from `FaultReportEmail`. Often null.""}",
   [is_private_individual]: @"{""description"": ""True when the operator record represents a private individual rather than a commercial network, from `IsPrivateIndividual`.""}",
   [is_restricted_edit]: @"{""description"": ""True when records attributed to this operator are edit-restricted in Open Charge Map (only privileged editors may modify them), from `IsRestrictedEdit`. Non-null for the large majority of operators.""}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

