.alter table ['org.datex2.measured.MeasurementSite'] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'org.datex2.measured.MeasurementSite') | project['supplier_id'] = tostring(data.['supplier_id']),['measurement_site_id'] = tostring(data.['measurement_site_id']),['feed_url'] = tostring(data.['feed_url']),['country_code'] = tostring(data.['country_code']),['operator_id'] = tostring(data.['operator_id']),['name'] = tostring(data.['name']),['measurement_site_type'] = tostring(data.['measurement_site_type']),['period_seconds'] = toint(data.['period_seconds']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),['road_number'] = tostring(data.['road_number']),['carriageway'] = tostring(data.['carriageway']),['lane'] = tostring(data.['lane']),['specific_measurements'] = tostring(data.['specific_measurements']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true
}]
```

