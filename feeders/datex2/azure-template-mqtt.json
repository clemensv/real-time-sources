{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Deploys the datex2 MQTT feeder as an Azure Container Instance against an existing MQTT 5 broker."
  },
  "parameters": {
    "brokerUrl": {
      "type": "string",
      "minLength": 1,
      "metadata": {
        "description": "Broker URL, e.g. mqtt://host:1883 or mqtts://host:8883."
      }
    },
    "brokerUsername": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional credentials when MQTT_AUTH_MODE=password (default)."
      }
    },
    "brokerPassword": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Optional credentials when MQTT_AUTH_MODE=password (default)."
      }
    },
    "containerGroupName": {
      "type": "string",
      "defaultValue": "datex2-mqtt",
      "metadata": {
        "description": "Name for the container group resource."
      },
      "maxLength": 63,
      "minLength": 1
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    },
    "imageName": {
      "type": "string",
      "defaultValue": "ghcr.io/clemensv/real-time-sources-datex2-mqtt:latest",
      "metadata": {
        "description": "Container image reference for the MQTT feeder."
      }
    },
    "mqttClientId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "MQTT client identifier (must be globally unique per broker)."
      }
    },
    "datex2Sources": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Primary source selector. Comma-separated catalog entry names to enable from the built-in DATEX II source catalog (for example ndw-measurement-sites,ndw-roadworks). Leave empty to run every entry marked enabled in the catalog; use an asterisk (*) to include disabled templates too. Advanced: set DATEX2_ENDPOINTS for an inline JSON override, or DATEX2_SOURCES_FILE (baked into a derived image) for a fully custom catalog."
      }
    },
    "datex2Endpoints": {
      "type": "string",
      "metadata": {
        "description": "JSON list of endpoint registry entries: id, url, publication, optional country, operator, auth_header."
      },
      "defaultValue": ""
    },
    "datex2Mock": {
      "type": "string",
      "metadata": {
        "description": "Emit deterministic sample DATEX II events for tests."
      },
      "defaultValue": "false"
    },
    "pollingInterval": {
      "type": "string",
      "metadata": {
        "description": "Seconds between polling cycles for Kafka container."
      },
      "defaultValue": "300"
    },
    "onceMode": {
      "type": "string",
      "metadata": {
        "description": "Run one polling cycle and exit; used by validation and scheduled notebook runs."
      },
      "defaultValue": "false"
    },
    "logLevel": {
      "type": "string",
      "metadata": {
        "description": "Python logging level for the DATEX II feeder container."
      },
      "defaultValue": "INFO"
    },
    "stateFile": {
      "type": "string",
      "metadata": {
        "description": "Optional persistent dedupe state file path."
      },
      "defaultValue": ""
    },
    "datex2StateFile": {
      "type": "string",
      "metadata": {
        "description": "Optional DATEX II-specific dedupe state file path."
      },
      "defaultValue": ""
    }
  },
  "variables": {
    "logAnalyticsWorkspaceName": "[concat(parameters('containerGroupName'), '-logs')]"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[variables('logAnalyticsWorkspaceName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[parameters('containerGroupName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName'))]"
      ],
      "properties": {
        "osType": "Linux",
        "restartPolicy": "OnFailure",
        "diagnostics": {
          "logAnalytics": {
            "workspaceId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName')), '2022-10-01').customerId]",
            "workspaceKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName')), '2022-10-01').primarySharedKey]",
            "logType": "ContainerInstanceLogs"
          }
        },
        "containers": [
          {
            "name": "[parameters('containerGroupName')]",
            "properties": {
              "image": "[parameters('imageName')]",
              "resources": {
                "requests": {
                  "cpu": 0.5,
                  "memoryInGB": 1.0
                }
              },
              "environmentVariables": [
                {
                  "name": "MQTT_BROKER_URL",
                  "value": "[parameters('brokerUrl')]"
                },
                {
                  "name": "MQTT_USERNAME",
                  "value": "[parameters('brokerUsername')]"
                },
                {
                  "name": "MQTT_PASSWORD",
                  "secureValue": "[parameters('brokerPassword')]"
                },
                {
                  "name": "MQTT_CLIENT_ID",
                  "value": "[parameters('mqttClientId')]"
                },
                {
                  "name": "DATEX2_SOURCES",
                  "value": "[parameters('datex2Sources')]"
                },
                {
                  "name": "DATEX2_ENDPOINTS",
                  "value": "[parameters('datex2Endpoints')]"
                },
                {
                  "name": "DATEX2_MOCK",
                  "value": "[parameters('datex2Mock')]"
                },
                {
                  "name": "POLLING_INTERVAL",
                  "value": "[parameters('pollingInterval')]"
                },
                {
                  "name": "ONCE_MODE",
                  "value": "[parameters('onceMode')]"
                },
                {
                  "name": "LOG_LEVEL",
                  "value": "[parameters('logLevel')]"
                },
                {
                  "name": "STATE_FILE",
                  "value": "[parameters('stateFile')]"
                },
                {
                  "name": "DATEX2_STATE_FILE",
                  "value": "[parameters('datex2StateFile')]"
                },
                {
                  "name": "LOG_LEVEL",
                  "value": "INFO"
                },
                {
                  "name": "PYTHONUNBUFFERED",
                  "value": "1"
                }
              ]
            }
          }
        ]
      }
    }
  ],
  "outputs": {
    "containerGroupId": {
      "type": "string",
      "value": "[resourceId('Microsoft.ContainerInstance/containerGroups', parameters('containerGroupName'))]"
    },
    "logAnalyticsWorkspaceId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName')), '2022-10-01').customerId]"
    }
  }
}