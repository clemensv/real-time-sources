.drop materialized-view WeatherAlertLatest ifexists;

.create materialized-view with (backfill=true) WeatherAlertLatest on table WeatherAlert {
    WeatherAlert | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [WeatherAlert] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'NWS.WeatherAlert') | project['alert_id'] = tostring(data.['alert_id']),['area_desc'] = tostring(data.['area_desc']),['same_codes'] = tostring(data.['same_codes']),['ugc_codes'] = tostring(data.['ugc_codes']),['sent'] = todatetime(data.['sent']),['effective'] = todatetime(data.['effective']),['onset'] = todatetime(data.['onset']),['expires'] = todatetime(data.['expires']),['ends'] = todatetime(data.['ends']),['status'] = tostring(data.['status']),['message_type'] = tostring(data.['message_type']),['category'] = tostring(data.['category']),['severity'] = tostring(data.['severity']),['certainty'] = tostring(data.['certainty']),['urgency'] = tostring(data.['urgency']),['event'] = tostring(data.['event']),['sender'] = tostring(data.['sender']),['sender_name'] = tostring(data.['sender_name']),['headline'] = tostring(data.['headline']),['description'] = tostring(data.['description']),['instruction'] = tostring(data.['instruction']),['response'] = tostring(data.['response']),['scope'] = tostring(data.['scope']),['code'] = tostring(data.['code']),['nws_headline'] = tostring(data.['nws_headline']),['vtec'] = tostring(data.['vtec']),['web'] = tostring(data.['web']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

