.create-merge table [StationMetadata] (
   [station_id]: string,
   [station_name]: string,
   [latitude]: real,
   [longitude]: real,
   [elevation]: real,
   [state]: string,
   [from_date]: string,
   [to_date]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [StationMetadata] docstring @"{""description"": ""A reference record published by Germany's Deutscher Wetterdienst (DWD). It lets consumers label, group, and route the live measurement or forecast events.""}";

.alter table [StationMetadata] column-docstrings (
   [station_id]: @"{""description"": ""Stable identifier assigned by the upstream provider for the station or monitoring site.""}",
   [station_name]: @"{""description"": ""Human-readable name of the station or monitoring site.""}",
   [latitude]: @"{""description"": ""Latitude of the station or site in WGS 84 coordinates.""}",
   [longitude]: @"{""description"": ""Longitude of the station or site in WGS 84 coordinates.""}",
   [elevation]: @"{""description"": ""Elevation of the station above mean sea level or the provider datum.""}",
   [state]: @"{""description"": ""State, province, or administrative region for the station or area.""}",
   [from_date]: @"{""description"": ""Start date when the station, product, or metadata record is valid.""}",
   [to_date]: @"{""description"": ""End date when the station, product, or metadata record is valid, when known.""}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

.create-or-alter table [StationMetadata] ingestion json mapping "StationMetadata_json_flat"
```
