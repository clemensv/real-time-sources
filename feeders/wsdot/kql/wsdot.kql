   [location_latitude]: @"{""description"": ""Latitude of the camera location in WGS84.""}",
   [location_longitude]: @"{""description"": ""Longitude of the camera location in WGS84.""}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

