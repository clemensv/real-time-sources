.alter table ['us.wa.wsdot.traveltimes.TravelTimeRoute'] docstring @"{""description"": ""A named travel time route monitored by WSDOT. Each route has fixed start and end points on Washington State highways with historical average and current real-time travel times.""}";

.alter table ['us.wa.wsdot.traveltimes.TravelTimeRoute'] column-docstrings (
   [travel_time_id]: @"{""description"": ""Unique route identifier, stringified from upstream TravelTimeID.""}",
   [name]: @"{""description"": ""Short route segment name.""}",
   [description]: @"{""description"": ""Longer description including lane type.""}",
   [distance]: @"{""description"": ""Route distance in miles.""}",
   [average_time]: @"{""description"": ""Historical average travel time in minutes.""}",
   [current_time]: @"{""description"": ""Current real-time travel time in minutes.""}",
   [time_updated]: @"{""description"": ""ISO 8601 UTC timestamp of last update.""}",
   [start_description]: @"{""description"": ""Start point description.""}",
   [start_road_name]: @"{""description"": ""Road at start point.""}",
   [start_direction]: @"{""description"": ""Direction at start point.""}",
   [start_milepost]: @"{""description"": ""Milepost at start.""}",
   [start_latitude]: @"{""description"": ""Start latitude in WGS84.""}",
   [start_longitude]: @"{""description"": ""Start longitude in WGS84.""}",
   [end_description]: @"{""description"": ""End point description.""}",
   [end_road_name]: @"{""description"": ""Road at end point.""}",
   [end_direction]: @"{""description"": ""Direction at end point.""}",
   [end_milepost]: @"{""description"": ""Milepost at end.""}",
   [end_latitude]: @"{""description"": ""End latitude in WGS84.""}",
   [end_longitude]: @"{""description"": ""End longitude in WGS84.""}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

