.create-merge table ['us.wa.wsdot.ferryterminals.TerminalSailingSpace'] (
   [terminal_id]: string,
   [terminal_subject_id]: int,
   [region_id]: int,
   [terminal_name]: string,
   [terminal_abbrev]: string,
   [sort_seq]: int,
   [departing_spaces]: dynamic,
   [is_no_fare_collected]: bool,
   [no_fare_collected_msg]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table ['us.wa.wsdot.ferryterminals.TerminalSailingSpace'] docstring @"{""description"": ""Real-time drive-up and reservable vehicle space availability for upcoming Washington State Ferries departures from a terminal, broken down by sailing and arrival terminal.""}";

.alter table ['us.wa.wsdot.ferryterminals.TerminalSailingSpace'] column-docstrings (
   [terminal_id]: @"{""description"": ""Washington State Ferries terminal identifier (stable).""}",
   [terminal_subject_id]: @"{""description"": ""WSF terminal subject identifier.""}",
   [region_id]: @"{""description"": ""WSF region identifier.""}",
   [terminal_name]: @"{""description"": ""Terminal name.""}",
   [terminal_abbrev]: @"{""description"": ""Terminal abbreviation code.""}",
   [sort_seq]: @"{""description"": ""WSF display sort sequence.""}",
   [departing_spaces]: @"{""description"": ""Upcoming departures from this terminal with per-sailing vehicle space availability."", ""schema"": ""{ \""doc\"": \""Schema too large to inline. Please refer to the JSON Structure schema for more details.\"" }""}",
   [is_no_fare_collected]: @"{""description"": ""Whether no fare is collected at this terminal for the relevant sailings, or null when not applicable.""}",
   [no_fare_collected_msg]: @"{""description"": ""Message explaining the no-fare-collected status, or null.""}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

