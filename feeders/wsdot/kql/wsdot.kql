.alter table ['us.wa.wsdot.cameras.HighwayCamera'] docstring @"{""description"": ""Reference catalog entry for a WSDOT highway traffic camera, including its location and a claim-check image URL. The image bytes are not transported; consumers fetch the most recent frame from ImageURL on demand.""}";

.alter table ['us.wa.wsdot.cameras.HighwayCamera'] column-docstrings (
   [camera_id]: @"{""description"": ""WSDOT camera identifier (stable).""}",
   [title]: @"{""description"": ""Human-readable camera title.""}",
   [description]: @"{""description"": ""Optional camera description.""}",
