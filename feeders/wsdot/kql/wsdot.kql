.alter table ['us.wa.wsdot.bridgeclearances.BridgeClearance'] docstring @"{""description"": ""Reference catalog record of the surveyed vertical clearance of a structure crossing a Washington State highway, used for commercial vehicle routing. Largely static; refreshed periodically.""}";

.alter table ['us.wa.wsdot.bridgeclearances.BridgeClearance'] column-docstrings (
   [crossing_location_id]: @"{""description"": ""Stable crossing location identifier (CrossingLocationId).""}",
   [bridge_number]: @"{""description"": ""WSDOT bridge number of the structure.""}",
   [state_route_id]: @"{""description"": ""State route identifier the structure crosses, or null.""}",
   [state_structure_id]: @"{""description"": ""Statewide structure identifier.""}",
