.alter table ['org.openaq.Location'] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'org.openaq.Location') | project['location_id'] = tolong(data.['location_id']),['name'] = tostring(data.['name']),['locality'] = tostring(data.['locality']),['timezone'] = tostring(data.['timezone']),['country_iso'] = tostring(data.['country_iso']),['country_name'] = tostring(data.['country_name']),['owner_id'] = tolong(data.['owner_id']),['owner_name'] = tostring(data.['owner_name']),['provider_id'] = tolong(data.['provider_id']),['provider_name'] = tostring(data.['provider_name']),['is_mobile'] = tobool(data.['is_mobile']),['is_monitor'] = tobool(data.['is_monitor']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),['datetime_first'] = todatetime(data.['datetime_first']),['datetime_last'] = todatetime(data.['datetime_last']),['license'] = tostring(data.['license']),['sensor_count'] = toint(data.['sensor_count']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true
}]
```

