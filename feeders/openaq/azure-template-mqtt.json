{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Deploys the openaq MQTT feeder as an Azure Container Instance against an existing MQTT 5 broker."
  },
  "parameters": {
    "brokerUrl": {
      "type": "string",
      "minLength": 1,
      "metadata": {
        "description": "MQTT broker URL for bring-your-own-broker deployments, for example mqtt://host:1883 or mqtts://host:8883. Leave empty when individual MQTT host/port/TLS parameters are used."
      }
    },
    "brokerUsername": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Username/password auth or Event Grid client name."
      }
    },
    "brokerPassword": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Username/password auth or Event Grid client name."
      }
    },
    "containerGroupName": {
      "type": "string",
      "defaultValue": "openaq-mqtt",
      "metadata": {
        "description": "Name for the container group resource."
      },
      "maxLength": 63,
      "minLength": 1
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    },
    "imageName": {
      "type": "string",
      "defaultValue": "ghcr.io/clemensv/real-time-sources-openaq-mqtt:latest",
      "metadata": {
        "description": "Container image reference for the MQTT feeder."
      }
    },
    "mqttClientId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Client ID. See feeders/openaq/CONTAINER.md for details."
      }
    },
    "openaqApiKey": {
      "type": "securestring",
      "metadata": {
        "description": "OpenAQ API key sent as X-API-Key. Not required with OPENAQ_MOCK=true."
      },
      "defaultValue": ""
    },
    "openaqSources": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Primary source selector. Comma-separated catalog entry names to enable from the built-in OpenAQ query-slice catalog (for example \"us-all\"). Leave empty to run the enabled entries; use \"*\" for all. Requires OPENAQ_API_KEY. Advanced: OPENAQ_COUNTRIES/OPENAQ_LOCATIONS/OPENAQ_BBOX for an inline single query, or OPENAQ_SOURCES_FILE for a custom catalog."
      }
    },
    "openaqCountries": {
      "type": "string",
      "metadata": {
        "description": "Comma-separated ISO alpha-2 country filters."
      },
      "defaultValue": ""
    },
    "openaqLocations": {
      "type": "string",
      "metadata": {
        "description": "Comma-separated OpenAQ location ids; overrides country paging."
      },
      "defaultValue": ""
    },
    "openaqBbox": {
      "type": "string",
      "metadata": {
        "description": "WGS84 bbox minLon,minLat,maxLon,maxLat."
      },
      "defaultValue": ""
    },
    "openaqPageLimit": {
      "type": "string",
      "metadata": {
        "description": "Maximum number of OpenAQ location records requested per API page during reference catalog discovery. Lower values reduce burst pressure on the upstream API."
      },
      "defaultValue": "25"
    },
    "openaqMaxPages": {
      "type": "string",
      "metadata": {
        "description": "Max pages per country/bbox per reference refresh."
      },
      "defaultValue": "1"
    },
    "pollInterval": {
      "type": "string",
      "metadata": {
        "description": "Seconds between latest-measurement polls."
      },
      "defaultValue": "900"
    },
    "referenceRefreshInterval": {
      "type": "string",
      "metadata": {
        "description": "Seconds between Location/Sensor catalog refreshes."
      },
      "defaultValue": "21600"
    },
    "stateFile": {
      "type": "string",
      "metadata": {
        "description": "Path inside the container volume where the feeder stores measurement deduplication state between polling cycles and container restarts."
      },
      "defaultValue": "/state/openaq-state.json"
    },
    "logLevel": {
      "type": "string",
      "metadata": {
        "description": "Python logging verbosity for the bridge process. Use INFO for normal operations and DEBUG only while diagnosing polling or transport behavior."
      },
      "defaultValue": "INFO"
    },
    "openaqMock": {
      "type": "string",
      "defaultValue": "false",
      "allowedValues": [
        "false",
        "true"
      ],
      "metadata": {
        "description": "Emit deterministic synthetic events and exit once."
      }
    }
  },
  "variables": {
    "logAnalyticsWorkspaceName": "[concat(parameters('containerGroupName'), '-logs')]"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[variables('logAnalyticsWorkspaceName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[parameters('containerGroupName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName'))]"
      ],
      "properties": {
        "osType": "Linux",
        "restartPolicy": "OnFailure",
        "diagnostics": {
          "logAnalytics": {
            "workspaceId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName')), '2022-10-01').customerId]",
            "workspaceKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName')), '2022-10-01').primarySharedKey]",
            "logType": "ContainerInstanceLogs"
          }
        },
        "containers": [
          {
            "name": "[parameters('containerGroupName')]",
            "properties": {
              "image": "[parameters('imageName')]",
              "resources": {
                "requests": {
                  "cpu": 0.5,
                  "memoryInGB": 1.0
                }
              },
              "environmentVariables": [
                {
                  "name": "MQTT_BROKER_URL",
                  "value": "[parameters('brokerUrl')]"
                },
                {
                  "name": "MQTT_USERNAME",
                  "value": "[parameters('brokerUsername')]"
                },
                {
                  "name": "MQTT_PASSWORD",
                  "secureValue": "[parameters('brokerPassword')]"
                },
                {
                  "name": "MQTT_CLIENT_ID",
                  "value": "[parameters('mqttClientId')]"
                },
                {
                  "name": "OPENAQ_API_KEY",
                  "secureValue": "[parameters('openaqApiKey')]"
                },
                {
                  "name": "OPENAQ_SOURCES",
                  "value": "[parameters('openaqSources')]"
                },
                {
                  "name": "OPENAQ_COUNTRIES",
                  "value": "[parameters('openaqCountries')]"
                },
                {
                  "name": "OPENAQ_LOCATIONS",
                  "value": "[parameters('openaqLocations')]"
                },
                {
                  "name": "OPENAQ_BBOX",
                  "value": "[parameters('openaqBbox')]"
                },
                {
                  "name": "OPENAQ_PAGE_LIMIT",
                  "value": "[parameters('openaqPageLimit')]"
                },
                {
                  "name": "OPENAQ_MAX_PAGES",
                  "value": "[parameters('openaqMaxPages')]"
                },
                {
                  "name": "OPENAQ_MOCK",
                  "value": "[parameters('openaqMock')]"
                },
                {
                  "name": "POLL_INTERVAL",
                  "value": "[parameters('pollInterval')]"
                },
                {
                  "name": "REFERENCE_REFRESH_INTERVAL",
                  "value": "[parameters('referenceRefreshInterval')]"
                },
                {
                  "name": "STATE_FILE",
                  "value": "[parameters('stateFile')]"
                },
                {
                  "name": "LOG_LEVEL",
                  "value": "[parameters('logLevel')]"
                },
                {
                  "name": "PYTHONUNBUFFERED",
                  "value": "1"
                }
              ]
            }
          }
        ]
      }
    }
  ],
  "outputs": {
    "containerGroupId": {
      "type": "string",
      "value": "[resourceId('Microsoft.ContainerInstance/containerGroups', parameters('containerGroupName'))]"
    },
    "logAnalyticsWorkspaceId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName')), '2022-10-01').customerId]"
    }
  }
}