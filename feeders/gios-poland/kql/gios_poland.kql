.create-merge table ['pl.gov.gios.airquality.Station'] (
   [station_id]: int,
   [station_code]: string,
   [name]: string,
   [latitude]: real,
   [longitude]: real,
   [city_id]: int,
   [city_name]: string,
   [commune]: string,
   [district]: string,
   [voivodeship]: string,
   [street]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table ['pl.gov.gios.airquality.Station'] docstring "{\"description\": \"Reference record for a GIO\\u015a air quality monitoring station in Poland. Contains the station identifier, code, name, WGS84 coordinates, and administrative location (city, commune, district, voivodeship, street). Fields are mapped from the Polish-language GIO\\u015a REST API /station/findAll endpoint.\"}";

.alter table ['pl.gov.gios.airquality.Station'] column-docstrings (
   [station_id]: "{\"description\": \"Unique numeric identifier of the monitoring station assigned by GIO\\u015a. Mapped from the Polish field 'Identyfikator stacji'.\"}",
   [station_code]: "{\"description\": \"Short alphanumeric code uniquely identifying the station, e.g. 'DsLegAlRzecz'. Mapped from 'Kod stacji'.\"}",
   [name]: "{\"description\": \"Human-readable name of the monitoring station, typically including city and street. Mapped from 'Nazwa stacji'.\"}",
   [latitude]: "{\"description\": \"Latitude of the station in decimal degrees north (WGS84). Mapped from 'WGS84 \\u03c6 N'.\"}",
   [longitude]: "{\"description\": \"Longitude of the station in decimal degrees east (WGS84). Mapped from 'WGS84 \\u03bb E'.\"}",
   [city_id]: "{\"description\": \"Numeric identifier of the city where the station is located. Mapped from 'Identyfikator miasta'.\"}",
   [city_name]: "{\"description\": \"Name of the city where the station is located. Mapped from 'Nazwa miasta'.\"}",
   [commune]: "{\"description\": \"Name of the commune (gmina) where the station is located. Mapped from 'Gmina'.\"}",
   [district]: "{\"description\": \"Name of the district (powiat) where the station is located. Mapped from 'Powiat'.\"}",
   [voivodeship]: "{\"description\": \"Name of the voivodeship (province) where the station is located, in uppercase Polish. Mapped from 'Wojew\\u00f3dztwo'.\"}",
   [street]: "{\"description\": \"Street address of the station, if available. Mapped from 'Ulica'.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

