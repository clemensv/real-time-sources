.alter table ['pl.gov.gios.airquality.Station'] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'pl.gov.gios.airquality.Station') | project['station_id'] = toint(data.['station_id']),['station_code'] = tostring(data.['station_code']),['name'] = tostring(data.['name']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),['city_id'] = toint(data.['city_id']),['city_name'] = tostring(data.['city_name']),['commune'] = tostring(data.['commune']),['district'] = tostring(data.['district']),['voivodeship'] = tostring(data.['voivodeship']),['street'] = tostring(data.['street']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

