.alter table ['pl.gov.gios.airquality.AirQualityIndex'] docstring "{\"description\": \"Current Polish Air Quality Index (Indeks Jako\\u015bci Powietrza) for a GIO\\u015a monitoring station. Includes the overall index value and category plus sub-indices for SO\\u2082, NO\\u2082, PM10, PM2.5, and O\\u2083. Each sub-index uses a 0\\u20135 scale: 0=Bardzo dobry (Very good), 1=Dobry (Good), 2=Umiarkowany (Moderate), 3=Dostateczny (Sufficient), 4=Z\\u0142y (Bad), 5=Bardzo z\\u0142y (Very bad). Fields are mapped from the Polish-language /aqindex/getIndex/{stationId} endpoint.\"}";

.alter table ['pl.gov.gios.airquality.AirQualityIndex'] column-docstrings (
   [station_id]: "{\"description\": \"Numeric identifier of the monitoring station. Mapped from 'Identyfikator stacji pomiarowej'.\"}",
   [calculation_timestamp]: "{\"description\": \"Timestamp when the overall index was calculated (ISO 8601 in local Polish time). Mapped from 'Data wykonania oblicze\\u0144 indeksu'.\"}",
   [index_value]: "{\"description\": \"Overall air quality index value: 0=Bardzo dobry (Very good), 1=Dobry (Good), 2=Umiarkowany (Moderate), 3=Dostateczny (Sufficient), 4=Z\\u0142y (Bad), 5=Bardzo z\\u0142y (Very bad). Mapped from 'Warto\\u015b\\u0107 indeksu'.\"}",
   [index_category]: "{\"description\": \"Polish-language category name of the overall index, e.g. 'Bardzo dobry', 'Dobry', 'Umiarkowany'. Mapped from 'Nazwa kategorii indeksu'.\"}",
   [source_data_timestamp]: "{\"description\": \"Timestamp of the source measurement data used for the overall index calculation. Mapped from 'Data danych \\u017ar\\u00f3d\\u0142owych, z kt\\u00f3rych policzono warto\\u015b\\u0107 indeksu dla wska\\u017anika st'.\"}",
   [so2_calculation_timestamp]: "{\"description\": \"Timestamp when the SO\\u2082 sub-index was calculated. Mapped from 'Data wykonania oblicze\\u0144 indeksu dla wska\\u017anika SO2'.\"}",
   [so2_index_value]: "{\"description\": \"SO\\u2082 sub-index value (0\\u20135 scale). Mapped from 'Warto\\u015b\\u0107 indeksu dla wska\\u017anika SO2'.\"}",
   [so2_index_category]: "{\"description\": \"Polish-language category name for the SO\\u2082 sub-index. Mapped from 'Nazwa kategorii indeksu dla wska\\u017cnika SO2'.\"}",
   [so2_source_data_timestamp]: "{\"description\": \"Timestamp of the source data used for the SO\\u2082 sub-index. Mapped from 'Data danych \\u017ar\\u00f3d\\u0142owych, z kt\\u00f3rych policzono warto\\u015b\\u0107 indeksu dla wska\\u017anika SO2'.\"}",
   [no2_calculation_timestamp]: "{\"description\": \"Timestamp when the NO\\u2082 sub-index was calculated. Mapped from 'Data wykonania oblicze\\u0144 indeksu dla wska\\u017anika NO2'.\"}",
   [no2_index_value]: "{\"description\": \"NO\\u2082 sub-index value (0\\u20135 scale). Mapped from 'Warto\\u015b\\u0107 indeksu dla wska\\u017anika NO2'.\"}",
   [no2_index_category]: "{\"description\": \"Polish-language category name for the NO\\u2082 sub-index. Mapped from 'Nazwa kategorii indeksu dla wska\\u017cnika NO2'.\"}",
   [no2_source_data_timestamp]: "{\"description\": \"Timestamp of the source data used for the NO\\u2082 sub-index. Mapped from 'Data danych \\u017ar\\u00f3d\\u0142owych, z kt\\u00f3rych policzono warto\\u015b\\u0107 indeksu dla wska\\u017anika NO2'.\"}",
   [pm10_calculation_timestamp]: "{\"description\": \"Timestamp when the PM10 sub-index was calculated. Mapped from 'Data wykonania oblicze\\u0144 indeksu dla wska\\u017anika PM10'.\"}",
   [pm10_index_value]: "{\"description\": \"PM10 sub-index value (0\\u20135 scale). Mapped from 'Warto\\u015b\\u0107 indeksu dla wska\\u017anika PM10'.\"}",
   [pm10_index_category]: "{\"description\": \"Polish-language category name for the PM10 sub-index. Mapped from 'Nazwa kategorii indeksu dla wska\\u017cnika PM10'.\"}",
   [pm10_source_data_timestamp]: "{\"description\": \"Timestamp of the source data used for the PM10 sub-index. Mapped from 'Data danych \\u017ar\\u00f3d\\u0142owych, z kt\\u00f3rych policzono warto\\u015b\\u0107 indeksu dla wska\\u017anika PM10'.\"}",
   [pm25_calculation_timestamp]: "{\"description\": \"Timestamp when the PM2.5 sub-index was calculated. Mapped from 'Data wykonania oblicze\\u0144 indeksu dla wska\\u017anika PM2.5'.\"}",
   [pm25_index_value]: "{\"description\": \"PM2.5 sub-index value (0\\u20135 scale). Mapped from 'Warto\\u015b\\u0107 indeksu dla wska\\u017anika PM2.5'.\"}",
   [pm25_index_category]: "{\"description\": \"Polish-language category name for the PM2.5 sub-index. Mapped from 'Nazwa kategorii indeksu dla wska\\u017cnika PM2.5'.\"}",
   [pm25_source_data_timestamp]: "{\"description\": \"Timestamp of the source data used for the PM2.5 sub-index. Mapped from 'Data danych \\u017ar\\u00f3d\\u0142owych, z kt\\u00f3rych policzono warto\\u015b\\u0107 indeksu dla wska\\u017anika PM2.5'.\"}",
   [o3_calculation_timestamp]: "{\"description\": \"Timestamp when the O\\u2083 sub-index was calculated. Mapped from 'Data wykonania oblicze\\u0144 indeksu dla wska\\u017anika O3'.\"}",
   [o3_index_value]: "{\"description\": \"O\\u2083 sub-index value (0\\u20135 scale). Mapped from 'Warto\\u015b\\u0107 indeksu dla wska\\u017anika O3'.\"}",
   [o3_index_category]: "{\"description\": \"Polish-language category name for the O\\u2083 sub-index. Mapped from 'Nazwa kategorii indeksu dla wska\\u017cnika O3'.\"}",
   [o3_source_data_timestamp]: "{\"description\": \"Timestamp of the source data used for the O\\u2083 sub-index. Mapped from 'Data danych \\u017ar\\u00f3d\\u0142owych, z kt\\u00f3rych policzono warto\\u015b\\u0107 indeksu dla wska\\u017anika O3'.\"}",
   [overall_status]: "{\"description\": \"Whether the overall air quality index is currently valid for this station. Mapped from 'Status indeksu og\\u00f3lnego dla stacji pomiarowej'.\"}",
   [critical_pollutant_code]: "{\"description\": \"Code of the pollutant that determined the overall index value, e.g. 'OZON', 'PM10'. Mapped from 'Kod zanieczyszczenia krytycznego'.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

