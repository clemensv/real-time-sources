.drop materialized-view TsunamiBulletinLatest ifexists;

.create materialized-view with (backfill=true) TsunamiBulletinLatest on table TsunamiBulletin {
    TsunamiBulletin | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [TsunamiBulletin] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'PTWC.TsunamiBulletin') | project['bulletin_id'] = tostring(data.['bulletin_id']),['feed'] = tostring(data.['feed']),['center'] = tostring(data.['center']),['title'] = tostring(data.['title']),['updated'] = todatetime(data.['updated']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),['category'] = tostring(data.['category']),['magnitude'] = tostring(data.['magnitude']),['affected_region'] = tostring(data.['affected_region']),['note'] = tostring(data.['note']),['bulletin_url'] = tostring(data.['bulletin_url']),['cap_url'] = tostring(data.['cap_url']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

