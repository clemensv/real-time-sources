.create-merge table [_cloudevents_dispatch] (
    [specversion]: string,
    [type]: string,
    [source]: string,
    [id]: string,
    [time]: datetime,
    [subject]: string,
    [datacontenttype]: string,
    [dataschema]: string,
    [data]: dynamic
);

.create-or-alter table [_cloudevents_dispatch] ingestion json mapping "_cloudevents_dispatch_json"
```
[
  {"column": "specversion", "path": "$.specversion"},
  {"column": "type", "path": "$.type"},
  {"column": "source", "path": "$.source"},
  {"column": "id", "path": "$.id"},
  {"column": "time", "path": "$.time"},
  {"column": "subject", "path": "$.subject"},
  {"column": "datacontenttype", "path": "$.datacontenttype"},
  {"column": "dataschema", "path": "$.dataschema"},
  {"column": "data", "path": "$.data"}
]
```

.create-merge table [TsunamiBulletin] (
   [bulletin_id]: string,
   [feed]: string,
   [center]: string,
   [title]: string,
   [updated]: datetime,
   [latitude]: real,
   [longitude]: real,
   [category]: string,
   [magnitude]: string,
   [affected_region]: string,
   [note]: string,
   [bulletin_url]: string,
   [cap_url]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [TsunamiBulletin] docstring "{\"description\": \"A tsunami bulletin from the US National Tsunami Warning Center (NTWC) or the Pacific Tsunami Warning Center (PTWC). Contains seismic event details and tsunami threat assessment parsed from NOAA Atom feeds.\"}";

.alter table [TsunamiBulletin] column-docstrings (
   [bulletin_id]: "{\"description\": \"The unique bulletin identifier as a URN UUID from the Atom entry (e.g., 'urn:uuid:7a6b0584-8201-4ef6-aac6-e512d77cbfb9').\"}",
   [feed]: "{\"description\": \"The feed this bulletin was obtained from.\"}",
   [center]: "{\"description\": \"The issuing tsunami warning center name (e.g., 'NWS National Tsunami Warning Center Palmer AK', 'NWS PACIFIC TSUNAMI WARNING CENTER HONOLULU HI').\"}",
   [title]: "{\"description\": \"The title of the bulletin, typically the location of the seismic event (e.g., '60 miles SW of Buldir I., Alaska').\"}",
   [updated]: "{\"description\": \"The date and time when the bulletin was last updated, in ISO-8601 format.\"}",
   [latitude]: "{\"description\": \"The latitude of the seismic event epicenter in decimal degrees.\"}",
   [longitude]: "{\"description\": \"The longitude of the seismic event epicenter in decimal degrees.\"}",
   [category]: "{\"description\": \"The tsunami bulletin category indicating the level of threat.\"}",
   [magnitude]: "{\"description\": \"The preliminary earthquake magnitude and type (e.g., '5.2(mb)', '7.1(Mw)').\"}",
   [affected_region]: "{\"description\": \"The affected region description from the bulletin summary.\"}",
   [note]: "{\"description\": \"Additional notes from the bulletin (e.g., 'There is NO tsunami danger from this earthquake.').\"}",
   [bulletin_url]: "{\"description\": \"URL to the full text bulletin on tsunami.gov.\"}",
   [cap_url]: "{\"description\": \"URL to the CAP XML document for this bulletin.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

