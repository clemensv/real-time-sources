.drop materialized-view SupplementalOrbitMeanElementsLatest ifexists;

.create materialized-view with (backfill=true) SupplementalOrbitMeanElementsLatest on table SupplementalOrbitMeanElements {
    SupplementalOrbitMeanElements | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [SupplementalOrbitMeanElements] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'org.celestrak.SupplementalOrbitMeanElements') | project['OBJECT_NAME'] = tostring(data.['OBJECT_NAME']),['OBJECT_ID'] = tostring(data.['OBJECT_ID']),['EPOCH'] = todatetime(data.['EPOCH']),['MEAN_MOTION'] = toreal(data.['MEAN_MOTION']),['ECCENTRICITY'] = toreal(data.['ECCENTRICITY']),['INCLINATION'] = toreal(data.['INCLINATION']),['RA_OF_ASC_NODE'] = toreal(data.['RA_OF_ASC_NODE']),['ARG_OF_PERICENTER'] = toreal(data.['ARG_OF_PERICENTER']),['MEAN_ANOMALY'] = toreal(data.['MEAN_ANOMALY']),['EPHEMERIS_TYPE'] = toint(data.['EPHEMERIS_TYPE']),['CLASSIFICATION_TYPE'] = tostring(data.['CLASSIFICATION_TYPE']),['NORAD_CAT_ID'] = toint(data.['NORAD_CAT_ID']),['ELEMENT_SET_NO'] = toint(data.['ELEMENT_SET_NO']),['REV_AT_EPOCH'] = toint(data.['REV_AT_EPOCH']),['BSTAR'] = toreal(data.['BSTAR']),['MEAN_MOTION_DOT'] = toreal(data.['MEAN_MOTION_DOT']),['MEAN_MOTION_DDOT'] = toreal(data.['MEAN_MOTION_DDOT']),['RMS'] = toreal(data.['RMS']),['DATA_SOURCE'] = tostring(data.['DATA_SOURCE']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true
}]
```

