.drop materialized-view ['nextbus.VehiclePositionLatest'] ifexists;

.create materialized-view with (backfill=true) ['nextbus.VehiclePositionLatest'] on table ['nextbus.VehiclePosition'] {
    ['nextbus.VehiclePosition'] | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table ['nextbus.VehiclePosition'] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'nextbus.VehiclePosition') | project['agency_id'] = tostring(data.['agency_id']),['route_tag'] = tostring(data.['route_tag']),['vehicle_id'] = tostring(data.['vehicle_id']),['stop_or_vehicle_id'] = tostring(data.['stop_or_vehicle_id']),['event_type'] = tostring(data.['event_type']),['lat'] = tostring(data.['lat']),['lon'] = tostring(data.['lon']),['timestamp'] = toreal(data.['timestamp']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

