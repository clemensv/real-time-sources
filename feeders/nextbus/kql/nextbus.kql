.create-merge table [_cloudevents_dispatch] (
    [specversion]: string,
    [type]: string,
    [source]: string,
    [id]: string,
    [time]: datetime,
    [subject]: string,
    [datacontenttype]: string,
    [dataschema]: string,
    [data]: dynamic
);

.create-or-alter table [_cloudevents_dispatch] ingestion json mapping "_cloudevents_dispatch_json"
```
[
  {"column": "specversion", "path": "$.specversion"},
  {"column": "type", "path": "$.type"},
  {"column": "source", "path": "$.source"},
  {"column": "id", "path": "$.id"},
  {"column": "time", "path": "$.time"},
  {"column": "subject", "path": "$.subject"},
  {"column": "datacontenttype", "path": "$.datacontenttype"},
  {"column": "dataschema", "path": "$.dataschema"},
  {"column": "data", "path": "$.data"}
]
```

.create-merge table ['nextbus.VehiclePosition'] (
   [agency_id]: string,
   [route_tag]: string,
   [vehicle_id]: string,
   [stop_or_vehicle_id]: string,
   [event_type]: string,
   [lat]: string,
   [lon]: string,
   [timestamp]: real,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table ['nextbus.VehiclePosition'] docstring "{\"description\": \"Nextbus XML feed event payload.\"}";

.alter table ['nextbus.VehiclePosition'] column-docstrings (
   [agency_id]: "{\"description\": \"agency_id value from the Nextbus XML feed.\"}",
   [route_tag]: "{\"description\": \"route_tag value from the Nextbus XML feed.\"}",
   [vehicle_id]: "{\"description\": \"vehicle_id value from the Nextbus XML feed.\"}",
   [stop_or_vehicle_id]: "{\"description\": \"stop_or_vehicle_id value from the Nextbus XML feed.\"}",
   [event_type]: "{\"description\": \"event_type value from the Nextbus XML feed.\"}",
   [lat]: "{\"description\": \"lat value from the Nextbus XML feed.\"}",
   [lon]: "{\"description\": \"lon value from the Nextbus XML feed.\"}",
   [timestamp]: "{\"description\": \"timestamp value from the Nextbus XML feed.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

.create-or-alter table ['nextbus.VehiclePosition'] ingestion json mapping "nextbus.VehiclePosition_json_flat"
```
[
  {"column": "___type", "path": "$.type"},
  {"column": "___source", "path": "$.source"},
  {"column": "___id", "path": "$.id"},
  {"column": "___time", "path": "$.time"},
  {"column": "___subject", "path": "$.subject"},
  {"column": "agency_id", "path": "$.agency_id"},
  {"column": "route_tag", "path": "$.route_tag"},
  {"column": "vehicle_id", "path": "$.vehicle_id"},
  {"column": "stop_or_vehicle_id", "path": "$.stop_or_vehicle_id"},
  {"column": "event_type", "path": "$.event_type"},
  {"column": "lat", "path": "$.lat"},
  {"column": "lon", "path": "$.lon"},
  {"column": "timestamp", "path": "$.timestamp"},
]
```

.create-or-alter table ['nextbus.VehiclePosition'] ingestion json mapping "nextbus.VehiclePosition_json_ce_structured"
```
[
  {"column": "___type", "path": "$.type"},
  {"column": "___source", "path": "$.source"},
  {"column": "___id", "path": "$.id"},
  {"column": "___time", "path": "$.time"},
  {"column": "___subject", "path": "$.subject"},
  {"column": "agency_id", "path": "$.data.agency_id"},
  {"column": "route_tag", "path": "$.data.route_tag"},
  {"column": "vehicle_id", "path": "$.data.vehicle_id"},
  {"column": "stop_or_vehicle_id", "path": "$.data.stop_or_vehicle_id"},
  {"column": "event_type", "path": "$.data.event_type"},
  {"column": "lat", "path": "$.data.lat"},
  {"column": "lon", "path": "$.data.lon"},
  {"column": "timestamp", "path": "$.data.timestamp"},
]
