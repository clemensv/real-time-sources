{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "variables": {
    "storageAccountName": "[take(concat(replace(replace(parameters('containerGroupName'), '-', ''), '_', ''), 'stg', uniqueString(resourceGroup().id)), 24)]",
    "fileShareName": "bridge-state",
    "imageName": "ghcr.io/clemensv/real-time-sources-ticketmaster:latest",
    "eventHubNamespaceName": "[concat(parameters('containerGroupName'), '-ehns')]",
    "eventHubName": "[parameters('containerGroupName')]",
    "authRuleName": "bridge-send-listen",
    "authRuleResourceId": "[resourceId('Microsoft.EventHub/namespaces/eventhubs/authorizationRules', variables('eventHubNamespaceName'), variables('eventHubName'), variables('authRuleName'))]",
    "logAnalyticsWorkspaceName": "[concat(parameters('containerGroupName'), '-logs')]"
  },
  "outputs": {
    "eventHubNamespaceName": {
      "value": "[variables('eventHubNamespaceName')]",
      "type": "string"
    },
    "containerGroupId": {
      "value": "[resourceId('Microsoft.ContainerInstance/containerGroups', parameters('containerGroupName'))]",
      "type": "string"
    },
    "eventHubName": {
      "value": "[variables('eventHubName')]",
      "type": "string"
    }
  },
  "parameters": {
    "containerGroupName": {
      "metadata": {
        "description": "Name for the container group and base name for all resources."
      },
      "maxLength": 63,
      "minLength": 1,
      "type": "string",
      "defaultValue": "ticketmaster"
    },
    "eventHubSku": {
      "allowedValues": [
        "Basic",
        "Standard"
      ],
      "metadata": {
        "description": "Event Hub namespace SKU."
      },
      "type": "string",
      "defaultValue": "Standard"
    },
    "location": {
      "metadata": {
        "description": "Azure region for all resources."
      },
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "ticketmasterApiKey": {
      "metadata": {
        "description": "Ticketmaster Discovery API key used to authenticate upstream event and reference-data requests; obtain it from the Ticketmaster developer portal before deployment."
      },
      "type": "secureString",
      "defaultValue": ""
    },
    "countryCodes": {
      "metadata": {
        "description": "Codes. See feeders/ticketmaster/CONTAINER.md for details."
      },
      "type": "string",
      "defaultValue": "AU,AT,BE,CA,CZ,DK,FI,FR,DE,GR,HU,IE,IT,MX,NL,NZ,NO,PL,PT,ES,SE,CH,GB,US"
    },
    "pollInterval": {
      "metadata": {
        "description": "Interval. See feeders/ticketmaster/CONTAINER.md for details."
      },
      "type": "string",
      "defaultValue": "300"
    },
    "referenceRefresh": {
      "metadata": {
        "description": "Refresh. See feeders/ticketmaster/CONTAINER.md for details."
      },
      "type": "string",
      "defaultValue": "3600"
    },
    "lookaheadDays": {
      "metadata": {
        "description": "Lookahead days. See feeders/ticketmaster/CONTAINER.md for details."
      },
      "type": "string",
      "defaultValue": "90"
    }
  },
  "resources": [
    {
      "apiVersion": "2022-10-01",
      "name": "[variables('logAnalyticsWorkspaceName')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      },
      "type": "Microsoft.OperationalInsights/workspaces",
      "location": "[parameters('location')]"
    },
    {
      "location": "[parameters('location')]",
      "name": "[variables('eventHubNamespaceName')]",
      "apiVersion": "2024-01-01",
      "properties": {
        "kafkaEnabled": true,
        "minimumTlsVersion": "1.2",
        "isAutoInflateEnabled": false
      },
      "type": "Microsoft.EventHub/namespaces",
      "sku": {
        "name": "[parameters('eventHubSku')]",
        "capacity": 1,
        "tier": "[parameters('eventHubSku')]"
      }
    },
    {
      "apiVersion": "2024-01-01",
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces', variables('eventHubNamespaceName'))]"
      ],
      "name": "[concat(variables('eventHubNamespaceName'), '/', variables('eventHubName'))]",
      "type": "Microsoft.EventHub/namespaces/eventhubs",
      "properties": {
        "messageRetentionInDays": 1,
        "partitionCount": 4
      }
    },
    {
      "apiVersion": "2024-01-01",
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces/eventhubs', variables('eventHubNamespaceName'), variables('eventHubName'))]"
      ],
      "name": "[concat(variables('eventHubNamespaceName'), '/', variables('eventHubName'), '/', variables('authRuleName'))]",
      "type": "Microsoft.EventHub/namespaces/eventhubs/authorizationRules",
      "properties": {
        "rights": [
          "Send",
          "Listen"
        ]
      }
    },
    {
      "location": "[parameters('location')]",
      "name": "[parameters('containerGroupName')]",
      "apiVersion": "2023-05-01",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName'))]",
        "[variables('authRuleResourceId')]"
      ],
      "properties": {
        "diagnostics": {
          "logAnalytics": {
            "workspaceId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName')), '2022-10-01').customerId]",
            "workspaceKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName')), '2022-10-01').primarySharedKey]",
            "logType": "ContainerInstanceLogs"
          }
        },
        "restartPolicy": "Always",
        "containers": [
          {
            "properties": {
              "resources": {
                "requests": {
                  "cpu": 1.0,
                  "memoryInGB": 2.0
                }
              },
              "command": [
                "python",
                "-m",
                "ticketmaster",
                "feed"
              ],
              "image": "[variables('imageName')]",
              "environmentVariables": [
                {
                  "secureValue": "[listKeys(variables('authRuleResourceId'), '2024-01-01').primaryConnectionString]",
                  "name": "CONNECTION_STRING"
                },
                {
                  "value": "INFO",
                  "name": "LOG_LEVEL"
                },
                {
                  "value": "1",
                  "name": "PYTHONUNBUFFERED"
                },
                {
                  "secureValue": "[parameters('ticketmasterApiKey')]",
                  "name": "TICKETMASTER_API_KEY"
                },
                {
                  "value": "[parameters('countryCodes')]",
                  "name": "COUNTRY_CODES"
                },
                {
                  "value": "[parameters('pollInterval')]",
                  "name": "POLL_INTERVAL"
                },
                {
                  "value": "[parameters('referenceRefresh')]",
                  "name": "REFERENCE_REFRESH"
                },
                {
                  "value": "[parameters('lookaheadDays')]",
                  "name": "TICKETMASTER_LOOKAHEAD_DAYS"
                }
              ]
            },
            "name": "[parameters('containerGroupName')]"
          }
        ],
        "osType": "Linux"
      },
      "type": "Microsoft.ContainerInstance/containerGroups"
    }
  ],
  "metadata": {
    "description": "Deploys the ticketmaster bridge with a new Event Hub namespace, event hub, and Azure Container Instance with Log Analytics diagnostics."
  },
  "contentVersion": "1.0.0.0"
}
