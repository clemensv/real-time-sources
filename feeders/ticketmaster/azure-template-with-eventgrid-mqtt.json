{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Deploys the ticketmaster MQTT feeder together with a new Azure Event Grid namespace MQTT broker, an ticketmaster-scoped topic space, and a user-assigned managed identity for broker publishing."
  },
  "parameters": {
    "namePrefix": {
      "type": "string",
      "defaultValue": "ticketmaster",
      "minLength": 3,
      "maxLength": 24,
      "metadata": {
        "description": "Base name for all resources."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    },
    "topicRoot": {
      "type": "string",
      "defaultValue": "civic-events/intl/ticketmaster/ticketmaster/#",
      "metadata": {
        "description": "Topic-space root for the ticketmaster UNS publish surface."
      }
    },
    "imageName": {
      "type": "string",
      "defaultValue": "ghcr.io/clemensv/real-time-sources-ticketmaster-mqtt:latest",
      "metadata": {
        "description": "Container image reference for the MQTT feeder."
      }
    },
    "mqttClientId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional MQTT client identifier override. Defaults to the managed identity principal id."
      }
    },
    "countryCodes": {
      "type": "string",
      "metadata": {
        "description": "Comma-separated ISO 3166-1 alpha-2 country codes for Ticketmaster event polling and reference-data refreshes."
      },
      "defaultValue": "AU,AT,BE,CA,CZ,DK,FI,FR,DE,GR,HU,IE,IT,MX,NL,NZ,NO,PL,PT,ES,SE,CH,GB,US"
    },
    "pollInterval": {
      "type": "string",
      "metadata": {
        "description": "Seconds between upstream polling cycles for this feeder."
      },
      "defaultValue": "300"
    },
    "referenceRefresh": {
      "type": "string",
      "metadata": {
        "description": "Seconds between Ticketmaster reference-data refreshes."
      },
      "defaultValue": "3600"
    },
    "ticketmasterApiKey": {
      "type": "securestring",
      "metadata": {
        "description": "Ticketmaster Discovery API key used to authenticate upstream event and reference-data requests; obtain it from the Ticketmaster developer portal before deployment."
      }
    },
    "ticketmasterAttractionId": {
      "type": "string",
      "metadata": {
        "description": "Ticketmaster attraction identifier used to limit events to an artist, team, or production."
      },
      "defaultValue": ""
    },
    "ticketmasterCity": {
      "type": "string",
      "metadata": {
        "description": "City name filter applied to Ticketmaster event search."
      },
      "defaultValue": ""
    },
    "ticketmasterEndDatetime": {
      "type": "string",
      "metadata": {
        "description": "Absolute UTC upper bound for Ticketmaster event search in ISO 8601 format."
      },
      "defaultValue": ""
    },
    "ticketmasterGenreId": {
      "type": "string",
      "metadata": {
        "description": "Ticketmaster genre identifier used to limit events within the selected segment."
      },
      "defaultValue": ""
    },
    "ticketmasterLocale": {
      "type": "string",
      "metadata": {
        "description": "Ticketmaster Discovery API locale for event queries; * requests all locales."
      },
      "defaultValue": "*"
    },
    "ticketmasterLookaheadDays": {
      "type": "string",
      "metadata": {
        "description": "Relative Ticketmaster event search window in days when explicit start and end datetimes are not set."
      },
      "defaultValue": "30"
    },
    "ticketmasterMarketId": {
      "type": "string",
      "metadata": {
        "description": "Ticketmaster market identifier used to limit event search results."
      },
      "defaultValue": ""
    },
    "ticketmasterPageSize": {
      "type": "string",
      "metadata": {
        "description": "Ticketmaster Discovery API page size per request, up to 200."
      },
      "defaultValue": "100"
    },
    "ticketmasterPostalCode": {
      "type": "string",
      "metadata": {
        "description": "Postal or ZIP code filter applied to Ticketmaster event search."
      },
      "defaultValue": ""
    },
    "ticketmasterSegmentId": {
      "type": "string",
      "metadata": {
        "description": "Ticketmaster segment identifier used to limit events, such as Music or Sports."
      },
      "defaultValue": ""
    },
    "ticketmasterSort": {
      "type": "string",
      "metadata": {
        "description": "Ticketmaster Discovery API sort order, such as date,asc or name,desc."
      },
      "defaultValue": "date,asc"
    },
    "ticketmasterStartDatetime": {
      "type": "string",
      "metadata": {
        "description": "Absolute UTC lower bound for Ticketmaster event search in ISO 8601 format."
      },
      "defaultValue": ""
    },
    "ticketmasterSubGenreId": {
      "type": "string",
      "metadata": {
        "description": "Ticketmaster sub-genre identifier used to limit event search results."
      },
      "defaultValue": ""
    },
    "ticketmasterVenueId": {
      "type": "string",
      "metadata": {
        "description": "Ticketmaster venue identifier used to limit events to a single venue."
      },
      "defaultValue": ""
    }
  },
  "variables": {
    "namespaceName": "[concat(parameters('namePrefix'), '-egns')]",
    "topicSpaceName": "ticketmaster",
    "userIdentityName": "[concat(parameters('namePrefix'), '-mi')]",
    "containerGroupName": "[concat(parameters('namePrefix'), '-mqtt')]",
    "logAnalyticsWorkspaceName": "[concat(parameters('namePrefix'), '-logs')]",
    "publisherRoleId": "/providers/Microsoft.Authorization/roleDefinitions/a12b0b94-b317-4dcd-84a8-502ce99884c6",
    "userIdentityResourceId": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('userIdentityName'))]",
    "namespaceResourceId": "[resourceId('Microsoft.EventGrid/namespaces', variables('namespaceName'))]",
    "topicSpaceResourceId": "[resourceId('Microsoft.EventGrid/namespaces/topicSpaces', variables('namespaceName'), variables('topicSpaceName'))]",
    "roleAssignmentName": "[guid(variables('topicSpaceResourceId'), variables('userIdentityResourceId'), variables('publisherRoleId'))]"
  },
  "resources": [
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[variables('userIdentityName')]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[variables('logAnalyticsWorkspaceName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.EventGrid/namespaces",
      "apiVersion": "2025-07-15-preview",
      "name": "[variables('namespaceName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard",
        "capacity": 1
      },
      "properties": {
        "topicSpacesConfiguration": {
          "state": "Enabled"
        }
      }
    },
    {
      "type": "Microsoft.EventGrid/namespaces/topicSpaces",
      "apiVersion": "2025-07-15-preview",
      "name": "[concat(variables('namespaceName'), '/', variables('topicSpaceName'))]",
      "dependsOn": [
        "[variables('namespaceResourceId')]"
      ],
      "properties": {
        "topicTemplates": [
          "[parameters('topicRoot')]"
        ]
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[variables('roleAssignmentName')]",
      "scope": "[concat('Microsoft.EventGrid/namespaces/', variables('namespaceName'), '/topicSpaces/', variables('topicSpaceName'))]",
      "dependsOn": [
        "[variables('topicSpaceResourceId')]",
        "[variables('userIdentityResourceId')]"
      ],
      "properties": {
        "roleDefinitionId": "[variables('publisherRoleId')]",
        "principalId": "[reference(variables('userIdentityResourceId'), '2023-01-31').principalId]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[variables('containerGroupName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[variables('userIdentityResourceId')]": {}
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName'))]",
        "[variables('namespaceResourceId')]",
        "[variables('topicSpaceResourceId')]",
        "[extensionResourceId(variables('topicSpaceResourceId'), 'Microsoft.Authorization/roleAssignments', variables('roleAssignmentName'))]"
      ],
      "properties": {
        "osType": "Linux",
        "restartPolicy": "Always",
        "diagnostics": {
          "logAnalytics": {
            "workspaceId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName')), '2022-10-01').customerId]",
            "workspaceKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName')), '2022-10-01').primarySharedKey]",
            "logType": "ContainerInstanceLogs"
          }
        },
        "containers": [
          {
            "name": "[variables('containerGroupName')]",
            "properties": {
              "image": "[parameters('imageName')]",
              "resources": {
                "requests": {
                  "cpu": 0.5,
                  "memoryInGB": 1.0
                }
              },
              "environmentVariables": [
                {
                  "name": "MQTT_BROKER_URL",
                  "value": "[concat('mqtts://', reference(variables('namespaceResourceId'), '2025-07-15-preview').topicSpacesConfiguration.hostname, ':8883')]"
                },
                {
                  "name": "MQTT_AUTH_MODE",
                  "value": "entra"
                },
                {
                  "name": "MQTT_ENTRA_AUDIENCE",
                  "value": "https://eventgrid.azure.net/"
                },
                {
                  "name": "MQTT_ENTRA_CLIENT_ID",
                  "value": "[reference(variables('userIdentityResourceId'), '2023-01-31').clientId]"
                },
                {
                  "name": "MQTT_CLIENT_ID",
                  "value": "[if(empty(parameters('mqttClientId')), reference(variables('userIdentityResourceId'), '2023-01-31').principalId, parameters('mqttClientId'))]"
                },
                {
                  "name": "COUNTRY_CODES",
                  "value": "[parameters('countryCodes')]"
                },
                {
                  "name": "POLL_INTERVAL",
                  "value": "[parameters('pollInterval')]"
                },
                {
                  "name": "REFERENCE_REFRESH",
                  "value": "[parameters('referenceRefresh')]"
                },
                {
                  "name": "TICKETMASTER_API_KEY",
                  "secureValue": "[parameters('ticketmasterApiKey')]"
                },
                {
                  "name": "TICKETMASTER_ATTRACTION_ID",
                  "value": "[parameters('ticketmasterAttractionId')]"
                },
                {
                  "name": "TICKETMASTER_CITY",
                  "value": "[parameters('ticketmasterCity')]"
                },
                {
                  "name": "TICKETMASTER_END_DATETIME",
                  "value": "[parameters('ticketmasterEndDatetime')]"
                },
                {
                  "name": "TICKETMASTER_GENRE_ID",
                  "value": "[parameters('ticketmasterGenreId')]"
                },
                {
                  "name": "TICKETMASTER_LOCALE",
                  "value": "[parameters('ticketmasterLocale')]"
                },
                {
                  "name": "TICKETMASTER_LOOKAHEAD_DAYS",
                  "value": "[parameters('ticketmasterLookaheadDays')]"
                },
                {
                  "name": "TICKETMASTER_MARKET_ID",
                  "value": "[parameters('ticketmasterMarketId')]"
                },
                {
                  "name": "TICKETMASTER_PAGE_SIZE",
                  "value": "[parameters('ticketmasterPageSize')]"
                },
                {
                  "name": "TICKETMASTER_POSTAL_CODE",
                  "value": "[parameters('ticketmasterPostalCode')]"
                },
                {
                  "name": "TICKETMASTER_SEGMENT_ID",
                  "value": "[parameters('ticketmasterSegmentId')]"
                },
                {
                  "name": "TICKETMASTER_SORT",
                  "value": "[parameters('ticketmasterSort')]"
                },
                {
                  "name": "TICKETMASTER_START_DATETIME",
                  "value": "[parameters('ticketmasterStartDatetime')]"
                },
                {
                  "name": "TICKETMASTER_SUB_GENRE_ID",
                  "value": "[parameters('ticketmasterSubGenreId')]"
                },
                {
                  "name": "TICKETMASTER_VENUE_ID",
                  "value": "[parameters('ticketmasterVenueId')]"
                },
                {
                  "name": "LOG_LEVEL",
                  "value": "INFO"
                },
                {
                  "name": "PYTHONUNBUFFERED",
                  "value": "1"
                }
              ]
            }
          }
        ]
      }
    }
  ],
  "outputs": {
    "namespaceName": {
      "type": "string",
      "value": "[variables('namespaceName')]"
    },
    "mqttHostname": {
      "type": "string",
      "value": "[reference(variables('namespaceResourceId'), '2025-07-15-preview').topicSpacesConfiguration.hostname]"
    },
    "topicSpaceName": {
      "type": "string",
      "value": "[variables('topicSpaceName')]"
    },
    "managedIdentityClientId": {
      "type": "string",
      "value": "[reference(variables('userIdentityResourceId'), '2023-01-31').clientId]"
    },
    "containerGroupId": {
      "type": "string",
      "value": "[resourceId('Microsoft.ContainerInstance/containerGroups', variables('containerGroupName'))]"
    },
    "logAnalyticsWorkspaceId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName')), '2022-10-01').customerId]"
    }
  }
}
