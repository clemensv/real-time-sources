.alter table ['Ticketmaster.Events.Event'] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'Ticketmaster.Events.Event') | project['event_id'] = tostring(data.['event_id']),['name'] = tostring(data.['name']),['type'] = tostring(data.['type']),['url'] = tostring(data.['url']),['locale'] = tostring(data.['locale']),['start_date'] = tostring(data.['start_date']),['start_time'] = tostring(data.['start_time']),['start_datetime_local'] = tostring(data.['start_datetime_local']),['start_datetime_utc'] = tostring(data.['start_datetime_utc']),['status'] = tostring(data.['status']),['segment_id'] = tostring(data.['segment_id']),['segment_name'] = tostring(data.['segment_name']),['genre_id'] = tostring(data.['genre_id']),['genre_name'] = tostring(data.['genre_name']),['subgenre_id'] = tostring(data.['subgenre_id']),['subgenre_name'] = tostring(data.['subgenre_name']),['venue_id'] = tostring(data.['venue_id']),['venue_name'] = tostring(data.['venue_name']),['venue_city'] = tostring(data.['venue_city']),['venue_state_code'] = tostring(data.['venue_state_code']),['venue_country_code'] = tostring(data.['venue_country_code']),['venue_latitude'] = toreal(data.['venue_latitude']),['venue_longitude'] = toreal(data.['venue_longitude']),['price_min'] = toreal(data.['price_min']),['price_max'] = toreal(data.['price_max']),['currency'] = tostring(data.['currency']),['attraction_ids'] = tostring(data.['attraction_ids']),['attraction_names'] = tostring(data.['attraction_names']),['onsale_start_datetime'] = tostring(data.['onsale_start_datetime']),['onsale_end_datetime'] = tostring(data.['onsale_end_datetime']),['info'] = tostring(data.['info']),['please_note'] = tostring(data.['please_note']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

.create-merge table ['Ticketmaster.Reference.Venue'] (
   [entity_id]: string,
   [name]: string,
   [url]: string,
   [locale]: string,
   [timezone]: string,
   [city]: string,
   [state_code]: string,
   [country_code]: string,
   [address]: string,
   [postal_code]: string,
   [latitude]: real,
   [longitude]: real,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table ['Ticketmaster.Reference.Venue'] docstring "{\"description\": \"Reference data for a Ticketmaster venue. Carries the venue's stable identifier, location details, timezone, and geographic coordinates as returned by the Discovery API v2 /venues endpoint.\"}";

.alter table ['Ticketmaster.Reference.Venue'] column-docstrings (
   [entity_id]: "{\"description\": \"Stable Ticketmaster venue identifier (e.g. 'KovZpaFVAeA'). Used as both the Kafka message key and the CloudEvents subject. Matches the venue_id field in Event records.\"}",
   [name]: "{\"description\": \"Human-readable name of the venue as listed on Ticketmaster (e.g. 'Madison Square Garden', 'The O2 Arena').\"}",
   [url]: "{\"description\": \"URL to the venue page on Ticketmaster.com.\"}",
   [locale]: "{\"description\": \"BCP-47 locale string for the venue page (e.g. 'en-us').\"}",
   [timezone]: "{\"description\": \"IANA timezone database name for the venue's local time (e.g. 'America/New_York', 'Europe/London'). Used to interpret local start times in Event records.\"}",
   [city]: "{\"description\": \"City name where the venue is located.\"}",
   [state_code]: "{\"description\": \"ISO 3166-2 state or province code (e.g. 'NY', 'CA'). Populated for US and Canadian venues; absent for most international venues.\"}",
   [country_code]: "{\"description\": \"ISO 3166-1 alpha-2 country code (e.g. 'US', 'GB', 'DE', 'AU').\"}",
   [address]: "{\"description\": \"Street address line 1 for the venue (e.g. '4 Pennsylvania Plaza').\"}",
   [postal_code]: "{\"description\": \"Postal or ZIP code for the venue address.\"}",
   [latitude]: "{\"description\": \"WGS-84 latitude of the venue in decimal degrees. North is positive.\"}",
   [longitude]: "{\"description\": \"WGS-84 longitude of the venue in decimal degrees. East is positive.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

