{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "containerGroupName": {
      "type": "string",
      "defaultValue": "ticketmaster-bridge",
      "metadata": {
        "description": "Name of the Azure Container Instance group that will run the Ticketmaster bridge."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the container group."
      }
    },
    "image": {
      "type": "string",
      "defaultValue": "ghcr.io/clemensv/real-time-sources-ticketmaster:latest",
      "metadata": {
        "description": "Container image to run. Override this if you want a pinned image tag instead of latest."
      }
    },
    "cpuCores": {
      "type": "int",
      "defaultValue": 1,
      "metadata": {
        "description": "CPU cores reserved for the Ticketmaster bridge container."
      }
    },
    "memoryInGb": {
      "type": "int",
      "defaultValue": 2,
      "metadata": {
        "description": "Memory reserved for the Ticketmaster bridge container, in GiB."
      }
    },
    "connectionString": {
      "type": "secureString",
      "metadata": {
        "description": "String. See feeders/ticketmaster/CONTAINER.md for details."
      }
    },
    "ticketmasterApiKey": {
      "type": "secureString",
      "defaultValue": "",
      "metadata": {
        "description": "Ticketmaster Discovery API key used to authenticate upstream event and reference-data requests; obtain it from the Ticketmaster developer portal before deployment."
      }
    },
    "countryCodes": {
      "type": "string",
      "defaultValue": "AU,AT,BE,CA,CZ,DK,FI,FR,DE,GR,HU,IE,IT,MX,NL,NZ,NO,PL,PT,ES,SE,CH,GB,US",
      "metadata": {
        "description": "Codes. See feeders/ticketmaster/CONTAINER.md for details."
      }
    },
    "pollInterval": {
      "type": "string",
      "defaultValue": "300",
      "metadata": {
        "description": "Interval. See feeders/ticketmaster/CONTAINER.md for details."
      }
    },
    "referenceRefresh": {
      "type": "string",
      "defaultValue": "3600",
      "metadata": {
        "description": "Refresh. See feeders/ticketmaster/CONTAINER.md for details."
      }
    },
    "logLevel": {
      "type": "string",
      "defaultValue": "INFO",
      "allowedValues": [
        "DEBUG",
        "INFO",
        "WARNING",
        "ERROR"
      ],
      "metadata": {
        "description": "Level. See feeders/ticketmaster/CONTAINER.md for details."
      }
    },
    "kafkaEnableTls": {
      "type": "string",
      "defaultValue": "true",
      "allowedValues": [
        "true",
        "false"
      ],
      "metadata": {
        "description": "Enable TLS. See feeders/ticketmaster/CONTAINER.md for details."
      }
    },
    "city": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "City. See feeders/ticketmaster/CONTAINER.md for details."
      }
    },
    "venueId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Venue ID. See feeders/ticketmaster/CONTAINER.md for details."
      }
    },
    "attractionId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Attraction ID. See feeders/ticketmaster/CONTAINER.md for details."
      }
    },
    "segmentId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Segment ID. See feeders/ticketmaster/CONTAINER.md for details."
      }
    },
    "genreId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Genre ID. See feeders/ticketmaster/CONTAINER.md for details."
      }
    },
    "subGenreId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Sub genre ID. See feeders/ticketmaster/CONTAINER.md for details."
      }
    },
    "marketId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Market ID. See feeders/ticketmaster/CONTAINER.md for details."
      }
    },
    "postalCode": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Postal code. See feeders/ticketmaster/CONTAINER.md for details."
      }
    },
    "locale": {
      "type": "string",
      "defaultValue": "*",
      "metadata": {
        "description": "Locale. See feeders/ticketmaster/CONTAINER.md for details."
      }
    },
    "sort": {
      "type": "string",
      "defaultValue": "date,asc",
      "metadata": {
        "description": "Sort. See feeders/ticketmaster/CONTAINER.md for details."
      }
    },
    "pageSize": {
      "type": "string",
      "defaultValue": "200",
      "metadata": {
        "description": "Page size. See feeders/ticketmaster/CONTAINER.md for details."
      }
    },
    "startDatetime": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Start datetime. See feeders/ticketmaster/CONTAINER.md for details."
      }
    },
    "endDatetime": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "End datetime. See feeders/ticketmaster/CONTAINER.md for details."
      }
    },
    "lookaheadDays": {
      "type": "string",
      "defaultValue": "90",
      "metadata": {
        "description": "Lookahead days. See feeders/ticketmaster/CONTAINER.md for details."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[parameters('containerGroupName')]",
      "location": "[parameters('location')]",
      "properties": {
        "osType": "Linux",
        "restartPolicy": "Always",
        "containers": [
          {
            "name": "ticketmaster",
            "properties": {
              "image": "[parameters('image')]",
              "command": [
                "python",
                "-m",
                "ticketmaster",
                "feed"
              ],
              "resources": {
                "requests": {
                  "cpu": "[parameters('cpuCores')]",
                  "memoryInGB": "[parameters('memoryInGb')]"
                }
              },
              "environmentVariables": [
                {
                  "name": "CONNECTION_STRING",
                  "secureValue": "[parameters('connectionString')]"
                },
                {
                  "name": "TICKETMASTER_API_KEY",
                  "secureValue": "[parameters('ticketmasterApiKey')]"
                },
                {
                  "name": "COUNTRY_CODES",
                  "value": "[parameters('countryCodes')]"
                },
                {
                  "name": "POLL_INTERVAL",
                  "value": "[parameters('pollInterval')]"
                },
                {
                  "name": "REFERENCE_REFRESH",
                  "value": "[parameters('referenceRefresh')]"
                },
                {
                  "name": "LOG_LEVEL",
                  "value": "[parameters('logLevel')]"
                },
                {
                  "name": "KAFKA_ENABLE_TLS",
                  "value": "[parameters('kafkaEnableTls')]"
                },
                {
                  "name": "TICKETMASTER_CITY",
                  "value": "[parameters('city')]"
                },
                {
                  "name": "TICKETMASTER_VENUE_ID",
                  "value": "[parameters('venueId')]"
                },
                {
                  "name": "TICKETMASTER_ATTRACTION_ID",
                  "value": "[parameters('attractionId')]"
                },
                {
                  "name": "TICKETMASTER_SEGMENT_ID",
                  "value": "[parameters('segmentId')]"
                },
                {
                  "name": "TICKETMASTER_GENRE_ID",
                  "value": "[parameters('genreId')]"
                },
                {
                  "name": "TICKETMASTER_SUB_GENRE_ID",
                  "value": "[parameters('subGenreId')]"
                },
                {
                  "name": "TICKETMASTER_MARKET_ID",
                  "value": "[parameters('marketId')]"
                },
                {
                  "name": "TICKETMASTER_POSTAL_CODE",
                  "value": "[parameters('postalCode')]"
                },
                {
                  "name": "TICKETMASTER_LOCALE",
                  "value": "[parameters('locale')]"
                },
                {
                  "name": "TICKETMASTER_SORT",
                  "value": "[parameters('sort')]"
                },
                {
                  "name": "TICKETMASTER_PAGE_SIZE",
                  "value": "[parameters('pageSize')]"
                },
                {
                  "name": "TICKETMASTER_START_DATETIME",
                  "value": "[parameters('startDatetime')]"
                },
                {
                  "name": "TICKETMASTER_END_DATETIME",
                  "value": "[parameters('endDatetime')]"
                },
                {
                  "name": "TICKETMASTER_LOOKAHEAD_DAYS",
                  "value": "[parameters('lookaheadDays')]"
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
