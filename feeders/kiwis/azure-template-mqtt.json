{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Deploys the kiwis MQTT feeder as an Azure Container Instance against an existing MQTT 5 broker."
  },
  "parameters": {
    "brokerUrl": {
      "type": "string",
      "minLength": 1,
      "metadata": {
        "description": "Broker URL, e.g. mqtt://host:1883 or mqtts://host:8883."
      }
    },
    "brokerUsername": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional credentials when MQTT_AUTH_MODE=password (default)."
      }
    },
    "brokerPassword": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Optional credentials when MQTT_AUTH_MODE=password (default)."
      }
    },
    "containerGroupName": {
      "type": "string",
      "defaultValue": "kiwis-mqtt",
      "metadata": {
        "description": "Name for the container group resource."
      },
      "maxLength": 63,
      "minLength": 1
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    },
    "imageName": {
      "type": "string",
      "defaultValue": "ghcr.io/clemensv/real-time-sources-kiwis-mqtt:latest",
      "metadata": {
        "description": "Container image reference for the MQTT feeder."
      }
    },
    "mqttClientId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "MQTT client identifier (must be globally unique per broker)."
      }
    },
    "kiwisSources": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Primary source selector. Comma-separated catalog entry names to enable from the built-in KISTERS KiWIS endpoint catalog (for example sepa-scotland). Leave empty to run the enabled entries; use an asterisk (*) for all. Advanced: KIWIS_ENDPOINTS for an inline override, or KIWIS_SOURCES_FILE for a custom catalog."
      }
    },
    "kiwisEndpoints": {
      "type": "string",
      "metadata": {
        "description": "CSV/JSON endpoint list or @file: kiwis_id,base_url,datasource,station_filter,timeseries_filter,ts_ids,period,api_key."
      },
      "defaultValue": ""
    },
    "kiwisMock": {
      "type": "string",
      "metadata": {
        "description": "true emits one offline station, timeseries, and value for E2E."
      },
      "defaultValue": "false"
    },
    "kiwisMaxTimeseries": {
      "type": "string",
      "metadata": {
        "description": "Safety cap for discovered timeseries per endpoint."
      },
      "defaultValue": "10"
    },
    "pollingInterval": {
      "type": "string",
      "metadata": {
        "description": "Seconds between polling cycles."
      },
      "defaultValue": "300"
    },
    "kiwisStateFile": {
      "type": "string",
      "metadata": {
        "description": "JSON dedupe state path used by container and Azure templates."
      },
      "defaultValue": ""
    }
  },
  "variables": {
    "logAnalyticsWorkspaceName": "[concat(parameters('containerGroupName'), '-logs')]"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[variables('logAnalyticsWorkspaceName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[parameters('containerGroupName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName'))]"
      ],
      "properties": {
        "osType": "Linux",
        "restartPolicy": "OnFailure",
        "diagnostics": {
          "logAnalytics": {
            "workspaceId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName')), '2022-10-01').customerId]",
            "workspaceKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName')), '2022-10-01').primarySharedKey]",
            "logType": "ContainerInstanceLogs"
          }
        },
        "containers": [
          {
            "name": "[parameters('containerGroupName')]",
            "properties": {
              "image": "[parameters('imageName')]",
              "resources": {
                "requests": {
                  "cpu": 0.5,
                  "memoryInGB": 1.0
                }
              },
              "environmentVariables": [
                {
                  "name": "MQTT_BROKER_URL",
                  "value": "[parameters('brokerUrl')]"
                },
                {
                  "name": "MQTT_USERNAME",
                  "value": "[parameters('brokerUsername')]"
                },
                {
                  "name": "MQTT_PASSWORD",
                  "secureValue": "[parameters('brokerPassword')]"
                },
                {
                  "name": "MQTT_CLIENT_ID",
                  "value": "[parameters('mqttClientId')]"
                },
                {
                  "name": "KIWIS_SOURCES",
                  "value": "[parameters('kiwisSources')]"
                },
                {
                  "name": "KIWIS_ENDPOINTS",
                  "value": "[parameters('kiwisEndpoints')]"
                },
                {
                  "name": "KIWIS_MOCK",
                  "value": "[parameters('kiwisMock')]"
                },
                {
                  "name": "KIWIS_MAX_TIMESERIES",
                  "value": "[parameters('kiwisMaxTimeseries')]"
                },
                {
                  "name": "POLLING_INTERVAL",
                  "value": "[parameters('pollingInterval')]"
                },
                {
                  "name": "KIWIS_STATE_FILE",
                  "value": "[parameters('kiwisStateFile')]"
                },
                {
                  "name": "LOG_LEVEL",
                  "value": "INFO"
                },
                {
                  "name": "PYTHONUNBUFFERED",
                  "value": "1"
                }
              ]
            }
          }
        ]
      }
    }
  ],
  "outputs": {
    "containerGroupId": {
      "type": "string",
      "value": "[resourceId('Microsoft.ContainerInstance/containerGroups', parameters('containerGroupName'))]"
    },
    "logAnalyticsWorkspaceId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName')), '2022-10-01').customerId]"
    }
  }
}