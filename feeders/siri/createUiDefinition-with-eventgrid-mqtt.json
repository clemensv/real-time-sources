{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "basics": [],
    "steps": [
      {
        "name": "config",
        "label": "Feeder configuration",
        "elements": [
          {
            "name": "namePrefix",
            "type": "Microsoft.Common.TextBox",
            "label": "Name prefix",
            "defaultValue": "siri",
            "toolTip": "Base name for all resources.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "eventGridSku",
            "type": "Microsoft.Common.DropDown",
            "label": "Event grid sku",
            "toolTip": "Event Grid namespace SKU.",
            "constraints": {
              "allowedValues": [
                {
                  "label": "Standard",
                  "value": "Standard"
                }
              ],
              "required": true
            },
            "visible": true,
            "defaultValue": "Standard"
          },
          {
            "name": "eventGridCapacity",
            "type": "Microsoft.Common.TextBox",
            "label": "Event grid capacity",
            "defaultValue": "1",
            "toolTip": "Event Grid namespace throughput units.",
            "constraints": {
              "required": false,
              "regex": "^-?[0-9]+$",
              "validationMessage": "Enter a whole number."
            },
            "visible": true
          },
          {
            "name": "topicRoot",
            "type": "Microsoft.Common.TextBox",
            "label": "Topic root",
            "defaultValue": "transit/siri/#",
            "toolTip": "Topic-space root for the MQTT/UNS publish surface. Defaults to transit/siri/# which covers all siri output (transit/siri/...).",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "siriApiKey",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Siri api key",
              "confirmPassword": "Confirm siri api key"
            },
            "toolTip": "Optional API key used for provider profiles that require upstream authentication; leave empty for public BODS bulk archive or Entur.",
            "constraints": {
              "required": false,
              "regex": "^.{8,}$",
              "validationMessage": "Enter at least 8 characters."
            },
            "visible": true
          },
          {
            "name": "pollInterval",
            "type": "Microsoft.Common.TextBox",
            "label": "Poll interval",
            "defaultValue": "30",
            "toolTip": "Polling interval in seconds for the SIRI bulk AVL archive.",
            "constraints": {
              "required": false,
              "regex": "^-?[0-9]+$",
              "validationMessage": "Enter a whole number."
            },
            "visible": true
          },
          {
            "name": "siriOperators",
            "type": "Microsoft.Common.TextBox",
            "label": "Siri operators",
            "defaultValue": "",
            "toolTip": "Optional comma-separated operator filter or Trafiklab URL-template expansion values.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "imageName",
            "type": "Microsoft.Common.TextBox",
            "label": "Image name",
            "defaultValue": "ghcr.io/clemensv/real-time-sources-siri-mqtt:latest",
            "toolTip": "Container image reference. Defaults to the public ghcr.io image published by the real-time-sources repo build.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "siriSources",
            "type": "Microsoft.Common.DropDown",
            "label": "Upstream sources",
            "multiselect": true,
            "selectAll": true,
            "filter": true,
            "toolTip": "Primary source selector. Comma-separated catalog entry names to enable from the built-in SIRI source catalog (for example uk-bods-bulk-archive). Leave empty to run the enabled entries; use an asterisk (*) for all. Advanced: set SIRI_PROVIDER/SIRI_URL for a single inline provider, or SIRI_SOURCES_FILE for a custom catalog.",
            "constraints": {
              "allowedValues": [
                {
                  "label": "uk-bods-bulk-archive",
                  "value": "uk-bods-bulk-archive"
                },
                {
                  "label": "trafiklab-sweden",
                  "value": "trafiklab-sweden"
                },
                {
                  "label": "key-protected-siri-template",
                  "value": "key-protected-siri-template"
                }
              ],
              "required": false
            },
            "visible": true,
            "defaultValue": [
              "uk-bods-bulk-archive"
            ]
          },
          {
            "name": "siriProvider",
            "type": "Microsoft.Common.DropDown",
            "label": "Siri provider",
            "toolTip": "SIRI provider profile to use.",
            "constraints": {
              "allowedValues": [
                {
                  "label": "bods",
                  "value": "bods"
                },
                {
                  "label": "trafiklab",
                  "value": "trafiklab"
                },
                {
                  "label": "entur",
                  "value": "entur"
                },
                {
                  "label": "custom",
                  "value": "custom"
                }
              ],
              "required": true
            },
            "visible": true,
            "defaultValue": "bods"
          },
          {
            "name": "siriHeaders",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Siri headers",
              "confirmPassword": "Confirm siri headers"
            },
            "toolTip": "Optional semicolon-separated Name=Value request headers sent on every SIRI request; use for provider-specific client identification or custom upstream headers.",
            "constraints": {
              "required": false,
              "regex": "^.{8,}$",
              "validationMessage": "Enter at least 8 characters."
            },
            "visible": true
          },
          {
            "name": "siriEtClientName",
            "type": "Microsoft.Common.TextBox",
            "label": "Siri et client name",
            "defaultValue": "",
            "toolTip": "Optional Entur ET-Client-Name request header value. Leave empty to use the feeder's Entur default when SIRI_PROVIDER is entur.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "siriDataTypes",
            "type": "Microsoft.Common.TextBox",
            "label": "Siri data types",
            "defaultValue": "vm",
            "toolTip": "Comma-separated SIRI data types to fetch from provider URL templates, such as vm, et, or sx; VehicleMonitoring payloads emit the current contract.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "siriUrl",
            "type": "Microsoft.Common.TextBox",
            "label": "Siri url",
            "defaultValue": "",
            "toolTip": "Optional SIRI URL override or URL template. Leave empty to use the provider default.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          }
        ]
      }
    ],
    "outputs": {
      "namePrefix": "[steps('config').namePrefix]",
      "eventGridSku": "[steps('config').eventGridSku]",
      "eventGridCapacity": "[int(steps('config').eventGridCapacity)]",
      "topicRoot": "[steps('config').topicRoot]",
      "siriApiKey": "[steps('config').siriApiKey]",
      "pollInterval": "[int(steps('config').pollInterval)]",
      "siriOperators": "[steps('config').siriOperators]",
      "imageName": "[steps('config').imageName]",
      "siriSources": "[if(empty(steps('config').siriSources), '', replace(replace(replace(string(steps('config').siriSources), '[\"', ''), '\"]', ''), '\",\"', ','))]",
      "siriProvider": "[steps('config').siriProvider]",
      "siriHeaders": "[steps('config').siriHeaders]",
      "siriEtClientName": "[steps('config').siriEtClientName]",
      "siriDataTypes": "[steps('config').siriDataTypes]",
      "siriUrl": "[steps('config').siriUrl]",
      "location": "[location()]"
    }
  }
}
