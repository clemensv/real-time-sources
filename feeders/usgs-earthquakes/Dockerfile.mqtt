# syntax=docker/dockerfile:1.6
FROM python:3.10-slim

LABEL org.opencontainers.image.source="https://github.com/clemensv/real-time-sources/tree/main/feeders/usgs-earthquakes"
LABEL org.opencontainers.image.title="USGS Earthquakes → MQTT/UNS bridge"
LABEL org.opencontainers.image.description="Polls USGS earthquake GeoJSON feeds and publishes MQTT 5.0 binary-mode CloudEvents into seismic/intl/usgs/usgs-earthquakes/{net}/{magnitude_bucket}/{code}/quake topics."
LABEL org.opencontainers.image.documentation="https://github.com/clemensv/real-time-sources/blob/main/feeders/usgs-earthquakes/CONTAINER.md"
LABEL org.opencontainers.image.license="MIT"
LABEL source.transport="mqtt"

ENV PYTHONUNBUFFERED=1
WORKDIR /app

ENV SETUPTOOLS_SCM_PRETEND_VERSION=0

COPY . /app

RUN pip install --no-cache-dir ./usgs_earthquakes_mqtt_producer/usgs_earthquakes_mqtt_producer_data \
 && pip install --no-cache-dir ./usgs_earthquakes_mqtt_producer/usgs_earthquakes_mqtt_producer_mqtt_client \
 && pip install --no-cache-dir ./usgs_earthquakes_producer/usgs_earthquakes_producer_data \
 && pip install --no-cache-dir . \
 && pip install --no-cache-dir ./usgs_earthquakes_mqtt

ENV MQTT_BROKER_URL=""

CMD ["python", "-m", "usgs_earthquakes_mqtt", "feed"]
