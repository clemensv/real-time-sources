.alter table [DataLinkManagementMessage] docstring @"{""description"": ""Data link management message (ITU-R M.1371 message 20) relayed by aisstream.io. A base station broadcasts it to reserve TDMA slots (offset, number of slots, time-out and increment) for its own use, managing the AIS data link.""}";

.alter table [DataLinkManagementMessage] column-docstrings (
   [MessageID]: @"{""description"": ""AIS message type number per ITU-R M.1371, carried in the first six bits of every AIS message; for this data link management message it is 20.""}",
   [RepeatIndicator]: @"{""description"": ""Repeat indicator set by AIS repeater stations to count how many times the message has been repeated: 0 = original transmission, 3 = do not repeat any more.""}",
   [UserID]: @"{""description"": ""Maritime Mobile Service Identity (MMSI) of the transmitting station - the nine-digit identity of the vessel or station and the partition/event key for this stream.""}",
   [Valid]: @"{""description"": ""aisstream.io decoder flag: true = the AIS sentence was decoded successfully and the fields in this message are reliable; false = the message could not be fully decoded.""}",
   [Spare]: @"{""description"": ""Spare bits reserved by ITU-R M.1371 for future use; transmitted as zero and carry no semantic meaning.""}",
   [Data]: @"{""description"": ""Map of the TDMA slot reservations carried by this message (keyed by index, up to four entries), each describing a reserved block by slot offset, number of slots, time-out and increment; the aisstream.io feed encodes each reservation as a string value."", ""schema"": {""type"": ""map"", ""values"": {""type"": ""string""}, ""description"": ""Map of the TDMA slot reservations carried by this message (keyed by index, up to four entries), each describing a reserved block by slot offset, number of slots, time-out and increment; the aisstream.io feed encodes each reservation as a string value.""}}",
