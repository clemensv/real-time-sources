.alter table [BinaryBroadcastMessage] docstring @"{""description"": ""Binary broadcast message (ITU-R M.1371 message 8) relayed by aisstream.io. It broadcasts an application-specific binary payload, identified by an application identifier (DAC/FI), to all stations within radio range.""}";

