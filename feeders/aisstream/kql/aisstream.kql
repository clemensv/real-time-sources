.alter table [PositionReport] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'IO.AISstream.PositionReport') | project['MessageID'] = toint(data.['MessageID']),['RepeatIndicator'] = toint(data.['RepeatIndicator']),['UserID'] = toint(data.['UserID']),['Valid'] = tobool(data.['Valid']),['NavigationalStatus'] = toint(data.['NavigationalStatus']),['RateOfTurn'] = toint(data.['RateOfTurn']),['Sog'] = toreal(data.['Sog']),['PositionAccuracy'] = tobool(data.['PositionAccuracy']),['Longitude'] = toreal(data.['Longitude']),['Latitude'] = toreal(data.['Latitude']),['Cog'] = toreal(data.['Cog']),['TrueHeading'] = toint(data.['TrueHeading']),['Timestamp'] = toint(data.['Timestamp']),['SpecialManoeuvreIndicator'] = toint(data.['SpecialManoeuvreIndicator']),['Spare'] = toint(data.['Spare']),['Raim'] = tobool(data.['Raim']),['CommunicationState'] = toint(data.['CommunicationState']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true
}]
```

