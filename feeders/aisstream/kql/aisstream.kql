.alter table [StaticDataReport] docstring @"{""description"": ""Class B static data report (ITU-R M.1371 message 24) relayed by aisstream.io. The report is split into Part A (vessel name) and Part B (ship type, vendor identification, call sign, dimensions/antenna reference point and electronic fix type); PartNumber selects which part this message carries.""}";

.alter table [StaticDataReport] column-docstrings (
   [MessageID]: @"{""description"": ""AIS message type number per ITU-R M.1371, carried in the first six bits of every AIS message; for this Class B static data report it is 24.""}",
   [RepeatIndicator]: @"{""description"": ""Repeat indicator set by AIS repeater stations to count how many times the message has been repeated: 0 = original transmission, 3 = do not repeat any more.""}",
   [UserID]: @"{""description"": ""Maritime Mobile Service Identity (MMSI) of the transmitting station - the nine-digit identity of the vessel or station and the partition/event key for this stream.""}",
   [Valid]: @"{""description"": ""aisstream.io decoder flag: true = the AIS sentence was decoded successfully and the fields in this message are reliable; false = the message could not be fully decoded.""}",
   [Reserved]: @"{""description"": ""Reserved field defined by ITU-R M.1371 for regional or future use; not semantically meaningful.""}",
   [PartNumber]: @"{""description"": ""Selects which part of the Class B static data report this message carries: false (0) = Part A (vessel name), true (1) = Part B (ship type, vendor ID, call sign, dimensions and fix type).""}",
   [ReportA]: @"{""description"": ""Part A of the Class B static data report, carrying the vessel name (present when PartNumber = 0)."", ""schema"": {""type"": ""object"", ""required"": [""Valid"", ""Name""], ""name"": ""ReportA"", ""properties"": {""Valid"": {""type"": ""boolean"", ""description"": ""Flag indicating Part A of the static data report was present and successfully decoded.""}, ""Name"": {""type"": ""string"", ""description"": ""Name of the vessel from Part A of the static data report, as up to 20 six-bit ASCII characters (right-padded with '@').""}}, ""description"": ""Part A of the Class B static data report, carrying the vessel name (present when PartNumber = 0).""}}",
   [ReportB]: @"{""description"": ""Part B of the Class B static data report, carrying ship type, vendor identification, call sign, dimensions and fix type (present when PartNumber = 1)."", ""schema"": ""{ \""doc\"": \""Schema too large to inline. Please refer to the JSON Structure schema for more details.\"" }""}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
