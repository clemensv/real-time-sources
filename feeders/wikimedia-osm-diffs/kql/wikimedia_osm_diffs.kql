.drop materialized-view MapChangeLatest ifexists;

.create materialized-view with (backfill=true) MapChangeLatest on table MapChange {
    MapChange | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [MapChange] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'Org.OpenStreetMap.Diffs.MapChange') | project['change_type'] = tostring(data.['change_type']),['element_type'] = tostring(data.['element_type']),['element_id'] = tolong(data.['element_id']),['version'] = toint(data.['version']),['timestamp'] = todatetime(data.['timestamp']),['changeset_id'] = tolong(data.['changeset_id']),['user_name'] = tostring(data.['user_name']),['user_id'] = tolong(data.['user_id']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),['tags'] = tostring(data.['tags']),['sequence_number'] = tolong(data.['sequence_number']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

.create-merge table [ReplicationState] (
   [sequence_number]: long,
   [timestamp]: datetime,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [ReplicationState] docstring "{\"description\": \"The current replication state of the OpenStreetMap minutely diff feed. Published once per poll cycle. The sequence_number and timestamp are parsed from the Java-properties-style state.txt file at https://planet.openstreetmap.org/replication/minute/state.txt.\"}";

.alter table [ReplicationState] column-docstrings (
   [sequence_number]: "{\"description\": \"The monotonically increasing sequence number of the latest processed minutely diff file. Each diff file corresponds to exactly one sequence number.\"}",
   [timestamp]: "{\"description\": \"The UTC timestamp associated with the replication state, indicating the point in time up to which the diff file covers OSM edits.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

.create-or-alter table [ReplicationState] ingestion json mapping "ReplicationState_json_flat"
```
[
  {"column": "___type", "path": "$.type"},
  {"column": "___source", "path": "$.source"},
  {"column": "___id", "path": "$.id"},
  {"column": "___time", "path": "$.time"},
  {"column": "___subject", "path": "$.subject"},
  {"column": "sequence_number", "path": "$.sequence_number"},
  {"column": "timestamp", "path": "$.timestamp"},
]
```

.create-or-alter table [ReplicationState] ingestion json mapping "ReplicationState_json_ce_structured"
```
[
  {"column": "___type", "path": "$.type"},
  {"column": "___source", "path": "$.source"},
  {"column": "___id", "path": "$.id"},
  {"column": "___time", "path": "$.time"},
  {"column": "___subject", "path": "$.subject"},
  {"column": "sequence_number", "path": "$.data.sequence_number"},
  {"column": "timestamp", "path": "$.data.timestamp"},
]
```

.drop materialized-view ReplicationStateLatest ifexists;

.create materialized-view with (backfill=true) ReplicationStateLatest on table ReplicationState {
    ReplicationState | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [ReplicationState] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'Org.OpenStreetMap.Diffs.ReplicationState') | project['sequence_number'] = tolong(data.['sequence_number']),['timestamp'] = todatetime(data.['timestamp']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

