{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "basics": [],
    "steps": [
      {
        "name": "config",
        "label": "Feeder configuration",
        "elements": [
          {
            "name": "namePrefix",
            "type": "Microsoft.Common.TextBox",
            "label": "Name prefix",
            "defaultValue": "gtfs",
            "toolTip": "Base name for all resources.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "topicRoot",
            "type": "Microsoft.Common.TextBox",
            "label": "Topic root",
            "defaultValue": "transit/intl/gtfs/gtfs/#",
            "toolTip": "Topic-space root for the gtfs UNS publish surface.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "imageName",
            "type": "Microsoft.Common.TextBox",
            "label": "Image name",
            "defaultValue": "ghcr.io/clemensv/real-time-sources-gtfs-mqtt:latest",
            "toolTip": "Container image reference for the MQTT feeder.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "mqttClientId",
            "type": "Microsoft.Common.TextBox",
            "label": "Mqtt client id",
            "defaultValue": "",
            "toolTip": "Optional MQTT client identifier override. Defaults to the managed identity principal id.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "agency",
            "type": "Microsoft.Common.TextBox",
            "label": "Agency",
            "defaultValue": "",
            "toolTip": "The tag of the agency to get vehicle locations for.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "cacheDir",
            "type": "Microsoft.Common.TextBox",
            "label": "Cache dir",
            "defaultValue": "",
            "toolTip": "The directory to store the GTFS schedule files.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "fabricApiBase",
            "type": "Microsoft.Common.TextBox",
            "label": "Fabric api base",
            "defaultValue": "https://api.fabric.microsoft.com/v1",
            "toolTip": "Fabric api base option used to filter or tune the gtfs upstream feeder.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "fabricKqlDbId",
            "type": "Microsoft.Common.TextBox",
            "label": "Fabric kql db id",
            "defaultValue": "",
            "toolTip": "Fabric kql db id option used to filter or tune the gtfs upstream feeder.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "fabricMapId",
            "type": "Microsoft.Common.TextBox",
            "label": "Fabric map id",
            "defaultValue": "",
            "toolTip": "Fabric map id option used to filter or tune the gtfs upstream feeder.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "fabricWorkspaceId",
            "type": "Microsoft.Common.TextBox",
            "label": "Fabric workspace id",
            "defaultValue": "",
            "toolTip": "Fabric workspace id option used to filter or tune the gtfs upstream feeder.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "gtfsHeaders",
            "type": "Microsoft.Common.TextBox",
            "label": "Gtfs headers",
            "defaultValue": "",
            "toolTip": "Optional headers used when fetching the GTFS schedule feed URLs.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "gtfsRtHeaders",
            "type": "Microsoft.Common.TextBox",
            "label": "Gtfs rt headers",
            "defaultValue": "",
            "toolTip": "Optional headers used when fetching the GTFS-Realtime feed URLs.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "gtfsSources",
            "type": "Microsoft.Common.DropDown",
            "label": "Upstream sources",
            "multiselect": true,
            "selectAll": true,
            "filter": true,
            "toolTip": "Source selector against the built-in GTFS agency catalog: comma-separated catalog entry names, or an asterisk (*) for all catalog entries. Takes effect only when the inline GTFS_RT_URLS/GTFS_URLS overrides are empty; the packaged catalog ships no entries enabled by default, so the inline URLs drive a single-agency deployment unless you enable catalog entries with an asterisk (*). Advanced: GTFS_SOURCES_FILE for a custom catalog.",
            "constraints": {
              "allowedValues": [
                {
                  "label": "mbta-boston",
                  "value": "mbta-boston"
                },
                {
                  "label": "tfnsw-sydney",
                  "value": "tfnsw-sydney"
                },
                {
                  "label": "keyed-operator-template",
                  "value": "keyed-operator-template"
                }
              ],
              "required": false
            },
            "visible": true
          },
          {
            "name": "gtfsRtUrls",
            "type": "Microsoft.Common.TextBox",
            "label": "Gtfs rt urls",
            "defaultValue": "",
            "toolTip": "Comma-separated GTFS-Realtime feed URLs to poll for trip updates, alerts, and vehicle positions.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "gtfsUrls",
            "type": "Microsoft.Common.TextBox",
            "label": "Gtfs urls",
            "defaultValue": "",
            "toolTip": "Comma-separated GTFS schedule feed URLs to download before publishing static entities.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "kustoClusterUri",
            "type": "Microsoft.Common.TextBox",
            "label": "Kusto cluster uri",
            "defaultValue": "",
            "toolTip": "Kusto cluster uri option used to filter or tune the gtfs upstream feeder.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "kustoDb",
            "type": "Microsoft.Common.TextBox",
            "label": "Kusto db",
            "defaultValue": "gtfs",
            "toolTip": "Kusto db option used to filter or tune the gtfs upstream feeder.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "mdbSourceId",
            "type": "Microsoft.Common.TextBox",
            "label": "Mdb source id",
            "defaultValue": "",
            "toolTip": "The Mobility Database source ID of the GTFS Realtime feed.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "pollInterval",
            "type": "Microsoft.Common.TextBox",
            "label": "Poll interval",
            "defaultValue": "",
            "toolTip": "Seconds between upstream polling cycles for this feeder.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "route",
            "type": "Microsoft.Common.TextBox",
            "label": "Route",
            "defaultValue": "",
            "toolTip": "Optional route ID filter; leave unset or * to publish all routes from the configured realtime feeds.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "schedulePollInterval",
            "type": "Microsoft.Common.TextBox",
            "label": "Schedule poll interval",
            "defaultValue": "",
            "toolTip": "The number of seconds to wait between polling the GTFS schedule.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "sourceRoot",
            "type": "Microsoft.Common.TextBox",
            "label": "Source root",
            "defaultValue": "",
            "toolTip": "Filesystem root for source-specific static or generated input files used by this feeder.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          }
        ]
      }
    ],
    "outputs": {
      "namePrefix": "[steps('config').namePrefix]",
      "topicRoot": "[steps('config').topicRoot]",
      "imageName": "[steps('config').imageName]",
      "mqttClientId": "[steps('config').mqttClientId]",
      "agency": "[steps('config').agency]",
      "cacheDir": "[steps('config').cacheDir]",
      "fabricApiBase": "[steps('config').fabricApiBase]",
      "fabricKqlDbId": "[steps('config').fabricKqlDbId]",
      "fabricMapId": "[steps('config').fabricMapId]",
      "fabricWorkspaceId": "[steps('config').fabricWorkspaceId]",
      "gtfsHeaders": "[steps('config').gtfsHeaders]",
      "gtfsRtHeaders": "[steps('config').gtfsRtHeaders]",
      "gtfsSources": "[if(empty(steps('config').gtfsSources), '', replace(replace(replace(string(steps('config').gtfsSources), '[\"', ''), '\"]', ''), '\",\"', ','))]",
      "gtfsRtUrls": "[steps('config').gtfsRtUrls]",
      "gtfsUrls": "[steps('config').gtfsUrls]",
      "kustoClusterUri": "[steps('config').kustoClusterUri]",
      "kustoDb": "[steps('config').kustoDb]",
      "mdbSourceId": "[steps('config').mdbSourceId]",
      "pollInterval": "[steps('config').pollInterval]",
      "route": "[steps('config').route]",
      "schedulePollInterval": "[steps('config').schedulePollInterval]",
      "sourceRoot": "[steps('config').sourceRoot]",
      "location": "[location()]"
    }
  }
}
