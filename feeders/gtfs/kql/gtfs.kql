.alter table ['GeneralTransitFeed.StopTimes'] docstring "{\"description\": \"Represents times that a vehicle arrives at and departs from individual stops for each trip.\"}";

.alter table ['GeneralTransitFeed.StopTimes'] column-docstrings (
   [tripId]: "{\"description\": \"Identifies a trip.\"}",
   [arrivalTime]: "{\"description\": \"Arrival time at the stop for a specific trip.\"}",
   [departureTime]: "{\"description\": \"Departure time from the stop for a specific trip.\"}",
   [stopId]: "{\"description\": \"Identifies the serviced stop.\"}",
   [stopSequence]: "{\"description\": \"Order of stops for a particular trip.\"}",
   [stopHeadsign]: "{\"description\": \"Text that appears on signage identifying the trip's destination to riders.\"}",
   [pickupType]: "{\"description\": \"Indicates pickup method.\"}",
   [dropOffType]: "{\"description\": \"Indicates drop off method.\"}",
   [continuousPickup]: "{\"description\": \"Indicates continuous stopping pickup.\"}",
   [continuousDropOff]: "{\"description\": \"Indicates continuous stopping drop off.\"}",
   [shapeDistTraveled]: "{\"description\": \"Actual distance traveled along the shape from the first stop to the stop specified in this record.\"}",
   [timepoint]: "{\"description\": \"Indicates if arrival and departure times for a stop are strictly adhered to by the vehicle or if they are instead approximate and/or interpolated times.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

