);

.alter table ['GeneralTransitFeed.Alert'] docstring "{\"description\": \"An alert, indicating some sort of incident in the public transit network.\"}";

.alter table ['GeneralTransitFeed.Alert'] column-docstrings (
   [active_period]: "{\"description\": \"Time when the alert should be shown to the user. If missing, the alert will be shown as long as it appears in the feed. If multiple ranges are given, the alert will be shown during all of them.\", \"schema\": {\"type\": \"array\", \"items\": {\"$ref\": \"#/definitions/GeneralTransitFeedRealTime/Alert/TimeRange\"}, \"description\": \"Time when the alert should be shown to the user. If missing, the alert will be shown as long as it appears in the feed. If multiple ranges are given, the alert will be shown during all of them.\"}}",
   [informed_entity]: "{\"description\": \"Entities whose users we should notify of this alert.\", \"schema\": {\"type\": \"array\", \"items\": {\"$ref\": \"#/definitions/GeneralTransitFeedRealTime/Alert/EntitySelector\"}, \"description\": \"Entities whose users we should notify of this alert.\"}}",
   [url]: "{\"description\": \"The URL which provides additional information about the alert.\"}",
   [header_text]: "{\"description\": \"Alert header. Contains a short summary of the alert text as plain-text. Full description for the alert as plain-text. The information in the\"}",
   [description_text]: "{\"description\": \"description should add to the information of the header.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

