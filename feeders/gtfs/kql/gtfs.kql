.create-merge table ['GeneralTransitFeed.VehiclePosition'] (
   [trip]: dynamic,
   [vehicle]: dynamic,
   [position]: dynamic,
   [current_stop_sequence]: int,
   [stop_id]: string,
   [current_status]: string,
   [timestamp]: long,
   [congestion_level]: string,
   [occupancy_status]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table ['GeneralTransitFeed.VehiclePosition'] docstring "{\"description\": \"Realtime positioning information for a given vehicle.\"}";

.alter table ['GeneralTransitFeed.VehiclePosition'] column-docstrings (
   [trip]: "{\"description\": \"The Trip that this vehicle is serving. Can be empty or partial if the vehicle can not be identified with a given trip instance.\"}",
   [vehicle]: "{\"description\": \"Additional information on the vehicle that is serving this trip.\"}",
   [position]: "{\"description\": \"Current position of this vehicle. The stop sequence index of the current stop. The meaning of\"}",
   [current_stop_sequence]: "{\"description\": \"current_stop_sequence (i.e., the stop that it refers to) is determined by current_status. If current_status is missing IN_TRANSIT_TO is assumed. Identifies the current stop. The value must be the same as in stops.txt in\"}",
   [stop_id]: "{\"description\": \"the corresponding GTFS feed.\"}",
   [current_status]: "{\"description\": \"The exact status of the vehicle with respect to the current stop. Ignored if current_stop_sequence is missing. Moment at which the vehicle's position was measured. In POSIX time\"}",
   [timestamp]: "{\"description\": \"(i.e., number of seconds since January 1st 1970 00:00:00 UTC).\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

