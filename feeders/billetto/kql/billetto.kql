.drop materialized-view EventLatest ifexists;

.create materialized-view with (backfill=true) EventLatest on table Event {
    Event | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [Event] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'Billetto.Events.Event') | project['event_id'] = toint(data.['event_id']),['title'] = tostring(data.['title']),['description'] = tostring(data.['description']),['startdate'] = tostring(data.['startdate']),['enddate'] = tostring(data.['enddate']),['url'] = tostring(data.['url']),['image_link'] = tostring(data.['image_link']),['status'] = tostring(data.['status']),['location_city'] = tostring(data.['location_city']),['location_name'] = tostring(data.['location_name']),['location_address'] = tostring(data.['location_address']),['location_zip_code'] = tostring(data.['location_zip_code']),['location_country_code'] = tostring(data.['location_country_code']),['location_latitude'] = toreal(data.['location_latitude']),['location_longitude'] = toreal(data.['location_longitude']),['organiser_id'] = toint(data.['organiser_id']),['organiser_name'] = tostring(data.['organiser_name']),['minimum_price_amount_in_cents'] = toint(data.['minimum_price_amount_in_cents']),['minimum_price_currency'] = tostring(data.['minimum_price_currency']),['availability'] = tostring(data.['availability']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true
}]
```

