{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "containerGroupName": {
      "type": "string",
      "defaultValue": "billetto-bridge",
      "metadata": {
        "description": "Name of the Azure Container Instance group that will run the Billetto bridge."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the container group."
      }
    },
    "image": {
      "type": "string",
      "defaultValue": "ghcr.io/clemensv/real-time-sources-billetto:latest",
      "metadata": {
        "description": "Container image to run. Override this if you want a pinned tag instead of latest."
      }
    },
    "cpuCores": {
      "type": "int",
      "defaultValue": 1,
      "metadata": {
        "description": "CPU cores reserved for the Billetto bridge container."
      }
    },
    "memoryInGb": {
      "type": "int",
      "defaultValue": 2,
      "metadata": {
        "description": "Memory reserved for the Billetto bridge container, in GiB."
      }
    },
    "connectionString": {
      "type": "secureString",
      "metadata": {
        "description": "String. See feeders/billetto/CONTAINER.md for details."
      }
    },
    "billettoApiKeypair": {
      "type": "secureString",
      "defaultValue": "",
      "metadata": {
        "description": "Billetto API key pair used to authenticate upstream public-events API requests; obtain it from the Billetto developer portal before deployment."
      }
    },
    "kafkaTopic": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Topic. See feeders/billetto/CONTAINER.md for details."
      }
    },
    "kafkaEnableTls": {
      "type": "string",
      "defaultValue": "true",
      "allowedValues": [
        "true",
        "false"
      ],
      "metadata": {
        "description": "Enable TLS. See feeders/billetto/CONTAINER.md for details."
      }
    },
    "pollingInterval": {
      "type": "string",
      "defaultValue": "300",
      "metadata": {
        "description": "Interval. See feeders/billetto/CONTAINER.md for details."
      }
    },
    "logLevel": {
      "type": "string",
      "defaultValue": "INFO",
      "allowedValues": [
        "DEBUG",
        "INFO",
        "WARNING",
        "ERROR"
      ],
      "metadata": {
        "description": "Level. See feeders/billetto/CONTAINER.md for details."
      }
    },
    "billettoBaseUrl": {
      "type": "string",
      "defaultValue": "https://billetto.dk",
      "metadata": {
        "description": "Base URL. See feeders/billetto/CONTAINER.md for details."
      }
    },
    "postalCode": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Postal code. See feeders/billetto/CONTAINER.md for details."
      }
    },
    "macroregion": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Macroregion. See feeders/billetto/CONTAINER.md for details."
      }
    },
    "region": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Region. See feeders/billetto/CONTAINER.md for details."
      }
    },
    "subregion": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Subregion. See feeders/billetto/CONTAINER.md for details."
      }
    },
    "organizerId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Organizer ID. See feeders/billetto/CONTAINER.md for details."
      }
    },
    "eventType": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Event type. See feeders/billetto/CONTAINER.md for details."
      }
    },
    "category": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Category. See feeders/billetto/CONTAINER.md for details."
      }
    },
    "subcategory": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Subcategory. See feeders/billetto/CONTAINER.md for details."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[parameters('containerGroupName')]",
      "location": "[parameters('location')]",
      "properties": {
        "osType": "Linux",
        "restartPolicy": "Always",
        "containers": [
          {
            "name": "billetto",
            "properties": {
              "image": "[parameters('image')]",
              "command": [
                "python",
                "-m",
                "billetto",
                "feed"
              ],
              "resources": {
                "requests": {
                  "cpu": "[parameters('cpuCores')]",
                  "memoryInGB": "[parameters('memoryInGb')]"
                }
              },
              "environmentVariables": [
                {
                  "name": "CONNECTION_STRING",
                  "secureValue": "[parameters('connectionString')]"
                },
                {
                  "name": "BILLETTO_API_KEYPAIR",
                  "secureValue": "[parameters('billettoApiKeypair')]"
                },
                {
                  "name": "KAFKA_TOPIC",
                  "value": "[parameters('kafkaTopic')]"
                },
                {
                  "name": "KAFKA_ENABLE_TLS",
                  "value": "[parameters('kafkaEnableTls')]"
                },
                {
                  "name": "POLLING_INTERVAL",
                  "value": "[parameters('pollingInterval')]"
                },
                {
                  "name": "LOG_LEVEL",
                  "value": "[parameters('logLevel')]"
                },
                {
                  "name": "BILLETTO_BASE_URL",
                  "value": "[parameters('billettoBaseUrl')]"
                },
                {
                  "name": "BILLETTO_POSTAL_CODE",
                  "value": "[parameters('postalCode')]"
                },
                {
                  "name": "BILLETTO_MACROREGION",
                  "value": "[parameters('macroregion')]"
                },
                {
                  "name": "BILLETTO_REGION",
                  "value": "[parameters('region')]"
                },
                {
                  "name": "BILLETTO_SUBREGION",
                  "value": "[parameters('subregion')]"
                },
                {
                  "name": "BILLETTO_ORGANIZER_ID",
                  "value": "[parameters('organizerId')]"
                },
                {
                  "name": "BILLETTO_EVENT_TYPE",
                  "value": "[parameters('eventType')]"
                },
                {
                  "name": "BILLETTO_CATEGORY",
                  "value": "[parameters('category')]"
                },
                {
                  "name": "BILLETTO_SUBCATEGORY",
                  "value": "[parameters('subcategory')]"
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
