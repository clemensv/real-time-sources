FROM python:3.10-slim

LABEL org.opencontainers.image.source="https://github.com/clemensv/real-time-sources/tree/main/feeders/jma-bosai-amedas"
LABEL org.opencontainers.image.title="JMA Bosai AMeDAS → MQTT bridge"
LABEL org.opencontainers.image.description="Publishes JMA AMeDAS station metadata and observations over transport companion feed."
LABEL org.opencontainers.image.documentation="https://github.com/clemensv/real-time-sources/blob/main/feeders/jma-bosai-amedas/CONTAINER.md"
LABEL org.opencontainers.image.license="MIT"
LABEL source.transport="mqtt"

ENV PYTHONUNBUFFERED=1
WORKDIR /app

ENV SETUPTOOLS_SCM_PRETEND_VERSION=0
COPY . /app
RUN pip install --no-cache-dir confluent-kafka \
 && pip install --no-cache-dir ./jma_bosai_amedas_producer/jma_bosai_amedas_producer_data \
 && pip install --no-cache-dir ./jma_bosai_amedas_producer/jma_bosai_amedas_producer_kafka_producer \
 && pip install --no-cache-dir ./jma_bosai_amedas_mqtt_producer/jma_bosai_amedas_mqtt_producer_data

ENV MQTT_BROKER_URL=""
CMD ["python", "-m", "jma_bosai_amedas_mqtt", "feed"]
