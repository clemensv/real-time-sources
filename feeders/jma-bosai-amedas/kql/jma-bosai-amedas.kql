.drop materialized-view ['JP.JMA.Amedas.ObservationLatest'] ifexists;

.create materialized-view with (backfill=true) ['JP.JMA.Amedas.ObservationLatest'] on table ['JP.JMA.Amedas.Observation'] {
    ['JP.JMA.Amedas.Observation'] | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

