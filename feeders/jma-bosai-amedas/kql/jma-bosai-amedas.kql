.drop materialized-view ['JP.JMA.Amedas.StationLatest'] ifexists;

.create materialized-view with (backfill=true) ['JP.JMA.Amedas.StationLatest'] on table ['JP.JMA.Amedas.Station'] {
    ['JP.JMA.Amedas.Station'] | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table ['JP.JMA.Amedas.Station'] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'JP.JMA.Amedas.Station') | project['station_code'] = tostring(data.['station_code']),['kj_name'] = tostring(data.['kj_name']),['kana'] = tostring(data.['kana']),['en_name'] = tostring(data.['en_name']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),['altitude_m'] = toreal(data.['altitude_m']),['station_type'] = tostring(data.['station_type']),['elems_bitmask'] = tostring(data.['elems_bitmask']),['enabled_measurements'] = todynamic(data.['enabled_measurements']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

