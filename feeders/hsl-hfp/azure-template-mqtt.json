{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Deploy HSL HFP MQTT feeder to Azure Container Instances (bring your own MQTT broker)."
  },
  "parameters": {
    "containerGroupName": {
      "type": "string",
      "defaultValue": "hsl-hfp-mqtt",
      "metadata": {
        "description": "Azure Container Instance group name for the HSL HFP MQTT bridge deployment."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the HSL HFP MQTT container group."
      }
    },
    "imageName": {
      "type": "string",
      "defaultValue": "ghcr.io/clemensv/real-time-sources-hsl-hfp-mqtt:latest",
      "metadata": {
        "description": "Container image to deploy for the HSL HFP MQTT bridge. Use the -mqtt tag published from this repository."
      }
    },
    "brokerUrl": {
      "type": "string",
      "metadata": {
        "description": "MQTT broker URL, e.g. mqtt://host:1883 or mqtts://host:8883."
      }
    },
    "mqttUsername": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional downstream MQTT username for password authentication."
      }
    },
    "mqttPassword": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Optional downstream MQTT password for password authentication."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[parameters('containerGroupName')]",
      "location": "[parameters('location')]",
      "properties": {
        "osType": "Linux",
        "restartPolicy": "Always",
        "containers": [
          {
            "name": "[parameters('containerGroupName')]",
            "properties": {
              "image": "[parameters('imageName')]",
              "resources": {
                "requests": {
                  "cpu": 0.5,
                  "memoryInGB": 1
                }
              },
              "environmentVariables": [
                {
                  "name": "MQTT_BROKER_URL",
                  "value": "[parameters('brokerUrl')]"
                },
                {
                  "name": "MQTT_USERNAME",
                  "value": "[parameters('mqttUsername')]"
                },
                {
                  "name": "MQTT_PASSWORD",
                  "secureValue": "[parameters('mqttPassword')]"
                },
                {
                  "name": "MQTT_CLIENT_ID",
                  "value": "hsl-hfp-aci"
                },
                {
                  "name": "MQTT_CONTENT_MODE",
                  "value": "binary"
                },
                {
                  "name": "MQTT_AUTH_MODE",
                  "value": "password"
                },
                {
                  "name": "MQTT_CA_FILE",
                  "value": ""
                },
                {
                  "name": "HFP_MQTT_HOST",
                  "value": "mqtt.hsl.fi"
                },
                {
                  "name": "HFP_MQTT_PORT",
                  "value": "8883"
                },
                {
                  "name": "HFP_MQTT_TLS",
                  "value": "true"
                },
                {
                  "name": "HFP_TOPIC_FILTERS",
                  "value": "/hfp/v2/journey/#"
                },
                {
                  "name": "REFERENCE_REFRESH_INTERVAL",
                  "value": "43200"
                },
                {
                  "name": "SKIP_REFERENCE",
                  "value": "false"
                },
                {
                  "name": "HSL_GTFS_URL",
                  "value": "https://infopalvelut.storage.hsldev.com/gtfs/hsl.zip"
                },
                {
                  "name": "LOG_LEVEL",
                  "value": "INFO"
                },
                {
                  "name": "PYTHONUNBUFFERED",
                  "value": "1"
                }
              ]
            }
          }
        ]
      }
    }
  ],
  "outputs": {
    "containerGroupId": {
      "type": "string",
      "value": "[resourceId('Microsoft.ContainerInstance/containerGroups', parameters('containerGroupName'))]"
    }
  }
}
