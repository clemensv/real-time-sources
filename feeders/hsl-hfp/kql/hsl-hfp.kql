.drop materialized-view ['fi.hsl.hfp.VehicleEventLatest'] ifexists;

.create materialized-view with (backfill=true) ['fi.hsl.hfp.VehicleEventLatest'] on table ['fi.hsl.hfp.VehicleEvent'] {
    ['fi.hsl.hfp.VehicleEvent'] | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table ['fi.hsl.hfp.VehicleEvent'] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type in ('fi.hsl.hfp.vp', 'fi.hsl.hfp.due', 'fi.hsl.hfp.arr', 'fi.hsl.hfp.dep', 'fi.hsl.hfp.ars', 'fi.hsl.hfp.pde', 'fi.hsl.hfp.pas', 'fi.hsl.hfp.wait', 'fi.hsl.hfp.doo', 'fi.hsl.hfp.doc', 'fi.hsl.hfp.vja', 'fi.hsl.hfp.vjout', 'fi.hsl.hfp.upstream.vp', 'fi.hsl.hfp.upstream.due', 'fi.hsl.hfp.upstream.arr', 'fi.hsl.hfp.upstream.dep', 'fi.hsl.hfp.upstream.ars', 'fi.hsl.hfp.upstream.pde', 'fi.hsl.hfp.upstream.pas', 'fi.hsl.hfp.upstream.wait', 'fi.hsl.hfp.upstream.doo', 'fi.hsl.hfp.upstream.doc', 'fi.hsl.hfp.upstream.vja', 'fi.hsl.hfp.upstream.vjout')) | project['oper'] = toint(data.['oper']),['veh'] = toint(data.['veh']),['tst'] = tostring(data.['tst']),['tsi'] = toint(data.['tsi']),['operator_id'] = tostring(data.['operator_id']),['vehicle_number'] = tostring(data.['vehicle_number']),['temporal_type'] = tostring(data.['temporal_type']),['transport_mode'] = tostring(data.['transport_mode']),['route_id'] = tostring(data.['route_id']),['direction_id'] = tostring(data.['direction_id']),['headsign'] = tostring(data.['headsign']),['start_time'] = tostring(data.['start_time']),['next_stop'] = tostring(data.['next_stop']),['geohash_level'] = tostring(data.['geohash_level']),['geohash'] = tostring(data.['geohash']),['desi'] = tostring(data.['desi']),['dir'] = tostring(data.['dir']),['dl'] = toint(data.['dl']),['oday'] = tostring(data.['oday']),['jrn'] = toint(data.['jrn']),['line'] = toint(data.['line']),['start'] = tostring(data.['start']),['stop'] = toint(data.['stop']),['route'] = tostring(data.['route']),['occu'] = toint(data.['occu']),['seq'] = toint(data.['seq']),['label'] = tostring(data.['label']),['spd'] = toreal(data.['spd']),['hdg'] = toint(data.['hdg']),['lat'] = toreal(data.['lat']),['long'] = toreal(data.['long']),['acc'] = toreal(data.['acc']),['odo'] = toint(data.['odo']),['drst'] = toint(data.['drst']),['loc'] = tostring(data.['loc']),['ttarr'] = tostring(data.['ttarr']),['ttdep'] = tostring(data.['ttdep']),['dr_type'] = toint(data.['dr_type']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true
}]
```

