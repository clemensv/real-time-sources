# syntax=docker/dockerfile:1.6
FROM python:3.10-slim
LABEL org.opencontainers.image.source="https://github.com/clemensv/real-time-sources/tree/main/feeders/canada-eccc-wateroffice" \
      org.opencontainers.image.title="canada-eccc-wateroffice → MQTT/UNS bridge" \
      org.opencontainers.image.description="Publishes canada-eccc-wateroffice CloudEvents over MQTT 5.0 into the documented Unified Namespace topic tree." \
      org.opencontainers.image.documentation="https://github.com/clemensv/real-time-sources/blob/main/feeders/canada-eccc-wateroffice/CONTAINER.md" \
      org.opencontainers.image.license="MIT"
ENV PYTHONUNBUFFERED=1
WORKDIR /app
COPY . /app
RUN pip install --no-cache-dir ./canada_eccc_wateroffice_mqtt_producer/canada_eccc_wateroffice_mqtt_producer_data \
 && pip install --no-cache-dir ./canada_eccc_wateroffice_mqtt_producer/canada_eccc_wateroffice_mqtt_producer_mqtt_client \
 && pip install --no-cache-dir ./canada_eccc_wateroffice_mqtt
ENV MQTT_BROKER_URL=""
CMD ["python", "-m", "canada_eccc_wateroffice_mqtt", "feed"]
