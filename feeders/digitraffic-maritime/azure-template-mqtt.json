{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Deploy Digitraffic Maritime MQTT feeder to Azure Container Instances (bring your own MQTT broker)."
  },
  "parameters": {
    "containerGroupName": {
      "type": "string",
      "defaultValue": "digitraffic-maritime-mqtt"
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "imageName": {
      "type": "string",
      "defaultValue": "ghcr.io/clemensv/real-time-sources-digitraffic-maritime-mqtt:latest"
    },
    "brokerUrl": {
      "type": "string",
      "metadata": {
        "description": "Broker URL. See feeders/digitraffic-maritime/CONTAINER.md for details."
      }
    },
    "mqttUsername": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Username. See feeders/digitraffic-maritime/CONTAINER.md for details."
      }
    },
    "mqttPassword": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Password. See feeders/digitraffic-maritime/CONTAINER.md for details."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[parameters('containerGroupName')]",
      "location": "[parameters('location')]",
      "properties": {
        "osType": "Linux",
        "restartPolicy": "Always",
        "containers": [
          {
            "name": "[parameters('containerGroupName')]",
            "properties": {
              "image": "[parameters('imageName')]",
              "resources": {
                "requests": {
                  "cpu": 0.5,
                  "memoryInGB": 1
                }
              },
              "environmentVariables": [
                {
                  "name": "MQTT_BROKER_URL",
                  "value": "[parameters('brokerUrl')]"
                },
                {
                  "name": "MQTT_USERNAME",
                  "value": "[parameters('mqttUsername')]"
                },
                {
                  "name": "MQTT_PASSWORD",
                  "secureValue": "[parameters('mqttPassword')]"
                },
                {
                  "name": "MQTT_CONTENT_MODE",
                  "value": "binary"
                },
                {
                  "name": "LOG_LEVEL",
                  "value": "INFO"
                },
                {
                  "name": "PYTHONUNBUFFERED",
                  "value": "1"
                }
              ]
            }
          }
        ]
      }
    }
  ],
  "outputs": {
    "containerGroupId": {
      "type": "string",
      "value": "[resourceId('Microsoft.ContainerInstance/containerGroups', parameters('containerGroupName'))]"
    }
  }
}
