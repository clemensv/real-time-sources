}

.alter table ['uk.gov.dft.bods.VehiclePosition'] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'uk.gov.dft.bods.VehiclePosition') | project['operator_ref'] = tostring(data.['operator_ref']),['vehicle_ref'] = tostring(data.['vehicle_ref']),['line_ref'] = tostring(data.['line_ref']),['direction_ref'] = tostring(data.['direction_ref']),['published_line_name'] = tostring(data.['published_line_name']),['origin_ref'] = tostring(data.['origin_ref']),['origin_name'] = tostring(data.['origin_name']),['destination_ref'] = tostring(data.['destination_ref']),['destination_name'] = tostring(data.['destination_name']),['longitude'] = toreal(data.['longitude']),['latitude'] = toreal(data.['latitude']),['bearing'] = toint(data.['bearing']),['recorded_at_time'] = todatetime(data.['recorded_at_time']),['valid_until_time'] = todatetime(data.['valid_until_time']),['block_ref'] = tostring(data.['block_ref']),['vehicle_journey_ref'] = tostring(data.['vehicle_journey_ref']),['origin_aimed_departure_time'] = todatetime(data.['origin_aimed_departure_time']),['data_frame_ref'] = tostring(data.['data_frame_ref']),['dated_vehicle_journey_ref'] = tostring(data.['dated_vehicle_journey_ref']),['item_identifier'] = tostring(data.['item_identifier']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

.create-merge table ['uk.gov.dft.bods.Operator'] (
   [operator_ref]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table ['uk.gov.dft.bods.Operator'] docstring "{\"description\": \"Reference payload for a distinct bus operator code observed in the UK BODS SIRI-VM bulk AVL archive. The bridge emits these records so telemetry consumers can keep operator identity in-stream instead of consulting a separate registry out of band.\"}";

.alter table ['uk.gov.dft.bods.Operator'] column-docstrings (
   [operator_ref]: "{\"description\": \"Operator code from `MonitoredVehicleJourney/OperatorRef`, typically the National Operator Code (NOC) of the bus operator providing the AVL feed to BODS. This is the stable identity of the operator reference event and the prefix of every vehicle subject emitted by the source.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

.create-or-alter table ['uk.gov.dft.bods.Operator'] ingestion json mapping "uk.gov.dft.bods.Operator_json_flat"
```
[
  {"column": "___type", "path": "$.type"},
  {"column": "___source", "path": "$.source"},
  {"column": "___id", "path": "$.id"},
  {"column": "___time", "path": "$.time"},
  {"column": "___subject", "path": "$.subject"},
  {"column": "operator_ref", "path": "$.operator_ref"},
]
```

