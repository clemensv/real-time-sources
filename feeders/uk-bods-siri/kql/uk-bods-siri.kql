.create-merge table [_cloudevents_dispatch] (
    [specversion]: string,
    [type]: string,
    [source]: string,
    [id]: string,
    [time]: datetime,
    [subject]: string,
    [datacontenttype]: string,
    [dataschema]: string,
    [data]: dynamic
);

.create-or-alter table [_cloudevents_dispatch] ingestion json mapping "_cloudevents_dispatch_json"
```
[
  {"column": "specversion", "path": "$.specversion"},
  {"column": "type", "path": "$.type"},
  {"column": "source", "path": "$.source"},
  {"column": "id", "path": "$.id"},
  {"column": "time", "path": "$.time"},
  {"column": "subject", "path": "$.subject"},
  {"column": "datacontenttype", "path": "$.datacontenttype"},
  {"column": "dataschema", "path": "$.dataschema"},
  {"column": "data", "path": "$.data"}
]
```

.create-merge table ['uk.gov.dft.bods.VehiclePosition'] (
   [operator_ref]: string,
   [vehicle_ref]: string,
   [line_ref]: string,
   [direction_ref]: string,
   [published_line_name]: string,
   [origin_ref]: string,
   [origin_name]: string,
   [destination_ref]: string,
   [destination_name]: string,
   [longitude]: real,
   [latitude]: real,
   [bearing]: int,
   [recorded_at_time]: datetime,
   [valid_until_time]: datetime,
   [block_ref]: string,
   [vehicle_journey_ref]: string,
   [origin_aimed_departure_time]: datetime,
   [data_frame_ref]: string,
   [dated_vehicle_journey_ref]: string,
   [item_identifier]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table ['uk.gov.dft.bods.VehiclePosition'] docstring "{\"description\": \"Normalized payload for one BODS SIRI 2.0 VehicleActivity element from the Department for Transport Bus Open Data Service AVL bulk archive. The bridge emits one event per monitored vehicle activity in each poll cycle, keyed by the stable operator code and vehicle fleet reference.\"}";

.alter table ['uk.gov.dft.bods.VehiclePosition'] column-docstrings (
   [operator_ref]: "{\"description\": \"Bus Open Data Service operator code from `MonitoredVehicleJourney/OperatorRef`. In BODS this is typically the National Operator Code (NOC) that identifies the bus operator publishing the AVL feed. This field anchors reference records, the vehicle subject/key, MQTT topic segments, and AMQP routing properties.\"}",
   [vehicle_ref]: "{\"description\": \"Operator-scoped vehicle identifier from `MonitoredVehicleJourney/VehicleRef`. Usually the fleet number or run identifier configured in the operator AVL system. Combined with `operator_ref` it forms the stable vehicle identity for CloudEvents subjects and transport routing.\"}",
   [line_ref]: "{\"description\": \"Service or route identifier from `MonitoredVehicleJourney/LineRef`. In the BODS SIRI-VM profile this is the line reference used to match AVL messages to the operator's published timetable data. Null when the source omits a line identifier for the monitored journey.\"}",
   [direction_ref]: "{\"description\": \"Direction label from `MonitoredVehicleJourney/DirectionRef`, such as `inbound` or `outbound`. BODS uses this together with line and dated journey references to align live positions with the scheduled journey pattern.\"}",
   [published_line_name]: "{\"description\": \"Public-facing route label from `MonitoredVehicleJourney/PublishedLineName`, for example `T12`. This is the human-readable service number or line name shown to passengers.\"}",
   [origin_ref]: "{\"description\": \"NaPTAN stop reference from `MonitoredVehicleJourney/OriginRef` naming the first advertised stop of the monitored journey. Null when the AVL producer omits the origin stop code.\"}",
   [origin_name]: "{\"description\": \"Human-readable stop name from `MonitoredVehicleJourney/OriginName` for the first advertised stop of the monitored journey.\"}",
   [destination_ref]: "{\"description\": \"NaPTAN stop reference from `MonitoredVehicleJourney/DestinationRef` naming the last advertised stop of the monitored journey.\"}",
   [destination_name]: "{\"description\": \"Human-readable stop name from `MonitoredVehicleJourney/DestinationName` for the final advertised destination of the monitored journey.\"}",
   [longitude]: "{\"description\": \"WGS84 longitude from `MonitoredVehicleJourney/VehicleLocation/Longitude` expressed in decimal degrees. Positive values are east of Greenwich. Null when the AVL feed does not provide a usable vehicle location.\"}",
   [latitude]: "{\"description\": \"WGS84 latitude from `MonitoredVehicleJourney/VehicleLocation/Latitude` expressed in decimal degrees. Positive values are north of the equator. Null when the AVL feed does not provide a usable vehicle location.\"}",
   [bearing]: "{\"description\": \"Vehicle heading from `MonitoredVehicleJourney/Bearing` in whole degrees clockwise from true north. Null when the AVL producer omits heading information.\"}",
   [recorded_at_time]: "{\"description\": \"Timestamp from `VehicleActivity/RecordedAtTime` stating when the AVL system recorded this vehicle activity snapshot. Encoded as an ISO 8601 / RFC 3339 date-time string with an explicit UTC offset.\"}",
   [valid_until_time]: "{\"description\": \"Expiry timestamp from `VehicleActivity/ValidUntilTime` after which consumers should treat the vehicle activity as stale if it has not been refreshed by a newer message.\"}",
   [block_ref]: "{\"description\": \"Block or duty identifier from `MonitoredVehicleJourney/BlockRef` describing the operational vehicle block used by the operator scheduling system.\"}",
   [vehicle_journey_ref]: "{\"description\": \"Vehicle journey identifier from `MonitoredVehicleJourney/VehicleJourneyRef` used within the operator AVL system to refer to the monitored trip instance.\"}",
   [origin_aimed_departure_time]: "{\"description\": \"Scheduled departure time from `MonitoredVehicleJourney/OriginAimedDepartureTime` for the origin stop of the monitored journey, encoded as an ISO 8601 / RFC 3339 date-time string.\"}",
   [data_frame_ref]: "{\"description\": \"Service day identifier from `MonitoredVehicleJourney/FramedVehicleJourneyRef/DataFrameRef`. In BODS SIRI-VM this is normally the operating date used to pair the live journey with scheduled timetable data.\"}",
   [dated_vehicle_journey_ref]: "{\"description\": \"Dated journey identifier from `MonitoredVehicleJourney/FramedVehicleJourneyRef/DatedVehicleJourneyRef`. This value disambiguates the scheduled journey instance within the service day defined by `data_frame_ref`.\"}",
   [item_identifier]: "{\"description\": \"Unique `VehicleActivity/ItemIdentifier` value assigned by the BODS archive snapshot. The bridge uses this field for deduplication so repeated snapshots of the same unchanged vehicle activity are not re-emitted.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

