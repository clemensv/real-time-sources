.drop materialized-view StationLatest ifexists;

.create materialized-view with (backfill=true) StationLatest on table Station {
    Station | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [Station] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'DE.Waters.Hydrology.Station') | project['station_id'] = tostring(data.['station_id']),['station_name'] = tostring(data.['station_name']),['water_body'] = tostring(data.['water_body']),['state'] = tostring(data.['state']),['region'] = tostring(data.['region']),['provider'] = tostring(data.['provider']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),['river_km'] = toreal(data.['river_km']),['altitude'] = toreal(data.['altitude']),['station_type'] = tostring(data.['station_type']),['warn_level_cm'] = toreal(data.['warn_level_cm']),['alarm_level_cm'] = toreal(data.['alarm_level_cm']),['warn_level_m3s'] = toreal(data.['warn_level_m3s']),['alarm_level_m3s'] = toreal(data.['alarm_level_m3s']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true
}]
```

.create-merge table [WaterLevelObservation] (
   [station_id]: string,
   [provider]: string,
   [water_body]: string,
   [water_level]: real,
   [water_level_unit]: string,
   [water_level_timestamp]: datetime,
   [discharge]: real,
   [discharge_unit]: string,
   [discharge_timestamp]: datetime,
   [trend]: int,
   [situation]: int,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [WaterLevelObservation] docstring @"{""description"": ""Measurement payload for water level and discharge observations in the German Waters source.""}";

.alter table [WaterLevelObservation] column-docstrings (
   [station_id]: @"{""description"": ""Stable identifier assigned by the upstream provider for the monitoring station or site.""}",
   [provider]: @"{""description"": ""Provider-supplied provider value for this record.""}",
   [water_body]: @"{""description"": ""Name of the water body the station observes (e.g. 'Rhein', 'Donau', 'Elbe'). Sourced by the bridge from the per-provider station catalog (Station.water_body field) and propagated onto every observation so subscribers do not need an out-of-band catalog join to route by river. Used as the {water_body} segment of the MQTT/UNS topic and normalized to lowercase kebab-case before publishing.""}",
   [water_level]: @"{""description"": ""Current water level reported for the station.""}",
   [water_level_unit]: @"{""description"": ""Unit used for the water-level value.""}",
   [water_level_timestamp]: @"{""description"": ""Time associated with the water-level measurement.""}",
   [discharge]: @"{""description"": ""Current streamflow or discharge reported for the station.""}",
   [discharge_unit]: @"{""description"": ""Unit used for the discharge value.""}",
   [discharge_timestamp]: @"{""description"": ""Time associated with the discharge measurement.""}",
   [trend]: @"{""description"": ""Provider-supplied trend value for this record.""}",
   [situation]: @"{""description"": ""Provider-supplied situation value for this record.""}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

