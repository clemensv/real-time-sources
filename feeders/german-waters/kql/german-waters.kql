.create-merge table [Station] (
   [station_id]: string,
   [station_name]: string,
   [water_body]: string,
   [state]: string,
   [region]: string,
   [provider]: string,
   [latitude]: real,
   [longitude]: real,
   [river_km]: real,
   [altitude]: real,
   [station_type]: string,
   [warn_level_cm]: real,
   [alarm_level_cm]: real,
   [warn_level_m3s]: real,
   [alarm_level_m3s]: real,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [Station] docstring @"{""description"": ""Reference details for one monitoring station or site in the German Waters source.""}";

.alter table [Station] column-docstrings (
   [station_id]: @"{""description"": ""Stable identifier assigned by the upstream provider for the monitoring station or site.""}",
   [station_name]: @"{""description"": ""Human-readable name of the monitoring station.""}",
   [water_body]: @"{""description"": ""Provider-supplied water body value for this record.""}",
   [state]: @"{""description"": ""State, province, or region containing the station.""}",
   [region]: @"{""description"": ""Provider-supplied region value for this record.""}",
   [provider]: @"{""description"": ""Provider-supplied provider value for this record.""}",
   [latitude]: @"{""description"": ""Latitude of the station in WGS 84 coordinates.""}",
   [longitude]: @"{""description"": ""Longitude of the station in WGS 84 coordinates.""}",
   [river_km]: @"{""description"": ""Provider-supplied river km value for this record.""}",
   [altitude]: @"{""description"": ""Provider-supplied altitude value for this record.""}",
   [station_type]: @"{""description"": ""Provider-supplied station type value for this record.""}",
   [warn_level_cm]: @"{""description"": ""Provider-supplied warn level cm value for this record.""}",
   [alarm_level_cm]: @"{""description"": ""Provider-supplied alarm level cm value for this record.""}",
   [warn_level_m3s]: @"{""description"": ""Provider-supplied warn level m3s value for this record.""}",
   [alarm_level_m3s]: @"{""description"": ""Provider-supplied alarm level m3s value for this record.""}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

