# syntax=docker/dockerfile:1.6
FROM python:3.10-slim
LABEL org.opencontainers.image.source="https://github.com/clemensv/real-time-sources/tree/main/feeders/sensor-community"
LABEL org.opencontainers.image.title="Sensor Community → MQTT/UNS bridge"
LABEL org.opencontainers.image.description="Publishes Sensor Community CloudEvents to MQTT 5.0 binary mode topics under air-quality/intl/sensor-community/sensor-community/..."
LABEL org.opencontainers.image.documentation="https://github.com/clemensv/real-time-sources/blob/main/feeders/sensor-community/CONTAINER.md"
LABEL org.opencontainers.image.license="MIT"
LABEL source.transport="mqtt"
ENV PYTHONUNBUFFERED=1
WORKDIR /app

ENV SETUPTOOLS_SCM_PRETEND_VERSION=0
COPY . /app
RUN pip install --no-cache-dir confluent-kafka \
 && pip install --no-cache-dir ./sensor_community_producer/sensor_community_producer_kafka_producer \
 && pip install --no-cache-dir ./sensor_community_mqtt_producer/sensor_community_mqtt_producer_data
ENV MQTT_BROKER_URL=""
CMD ["python", "-m", "sensor_community_mqtt", "feed"]
