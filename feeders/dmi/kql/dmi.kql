.alter table [TidewaterPrediction] docstring @"{""description"": ""A deterministic tidewater (sea-level) prediction for one station and one forecast horizon. Predictions are issued every model cycle and span ~30 days at 10-minute granularity.""}";

.alter table [TidewaterPrediction] column-docstrings (
   [prediction_id]: @"{""description"": ""DMI-assigned row identifier.""}",
   [prediction_type]: @"{""description"": ""Granularity of the prediction series (typically '10minutes').""}",
   [prediction_time]: @"{""description"": ""Target time for which the value is predicted.""}",
   [value]: @"{""description"": ""Predicted sea level (cm vs DVR90 unless otherwise noted).""}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

