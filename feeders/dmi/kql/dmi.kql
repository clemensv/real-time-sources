   [owner]: @"{""description"": ""Operating agency (e.g. 'DMI', 'Kystdirektoratet').""}",
   [type]: @"{""description"": ""Station type (e.g. 'Tide-gauge-primary').""}",
   [status]: @"{""description"": ""Operational status.""}",
