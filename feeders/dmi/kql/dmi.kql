.create-merge table [MetObsObservation] (
   [observation_id]: string,
   [station_id]: string,
   [parameter_id]: string,
   [observed]: datetime,
   [value]: real,
   [latitude]: real,
   [longitude]: real,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [MetObsObservation] docstring @"{""description"": ""A single meteorological observation: one parameter, one station, one timestamp. Units are SI: degC, hPa, m/s, %, m, mm, degrees. wind_dir=0 means calm (not north).""}";

.alter table [MetObsObservation] column-docstrings (
   [observation_id]: @"{""description"": ""DMI-assigned per-row identifier. Not stable across re-ingestions; use (station_id, parameter_id, observed) for idempotency.""}",
   [station_id]: @"{""description"": ""Reporting station identifier (foreign key to Station).""}",
   [parameter_id]: @"{""description"": ""DMI parameter identifier (e.g. 'temp_dry', 'wind_speed', 'humidity', 'pressure_at_sea').""}",
   [observed]: @"{""description"": ""Timestamp at which the value was observed (UTC, ISO 8601).""}",
   [value]: @"{""description"": ""Numeric measurement value. Units depend on parameter_id (see DMI documentation).""}",
   [latitude]: @"{""description"": ""Station latitude (decimal degrees, WGS84) at observation time.""}",
   [longitude]: @"{""description"": ""Station longitude (decimal degrees, WGS84) at observation time.""}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

