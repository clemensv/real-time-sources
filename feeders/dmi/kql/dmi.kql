.alter table [LightningStrike] docstring @"{""description"": ""A single triangulated lightning strike. See https://opendatadocs.dmi.govcloud.dk/en/Data/Lightning_Data. observed timestamps have microsecond precision; location accuracy is approximately +/- 500-2000 m.""}";

.alter table [LightningStrike] column-docstrings (
   [strike_id]: @"{""description"": ""Stable DMI-assigned strike identifier (e.g. 'u1xrxj10262553824830001-03').""}",
   [observed]: @"{""description"": ""Strike timestamp (UTC, microsecond precision).""}",
   [created]: @"{""description"": ""Timestamp when DMI ingested the strike.""}",
   [type]: @"{""description"": ""Strike type code published by the DMI lightning API: 0 = cloud-to-ground negative (CG-), 1 = cloud-to-ground positive (CG+), and 2 = cloud-to-cloud (CC).""}",
   [amp]: @"{""description"": ""Signed peak current.""}",
   [strokes]: @"{""description"": ""Number of return strokes.""}",
   [sensors]: @"{""description"": ""Comma-separated list of sensor IDs that contributed to triangulation (may include third-party sensors not in the Sensor catalog).""}",
   [latitude]: @"{""description"": ""Strike latitude (decimal degrees, WGS84).""}",
   [longitude]: @"{""description"": ""Strike longitude (decimal degrees, WGS84).""}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

