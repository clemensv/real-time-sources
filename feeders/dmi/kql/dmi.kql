.create-merge table [MetObsStation] (
   [station_id]: string,
   [wmo_station_id]: string,
   [wmo_country_code]: string,
   [name]: string,
   [country]: string,
   [owner]: string,
   [region_id]: string,
   [type]: string,
   [status]: string,
   [parameter_id]: dynamic,
   [latitude]: real,
   [longitude]: real,
   [station_height]: real,
   [barometer_height]: real,
   [anemometer_height]: real,
   [valid_from]: datetime,
   [valid_to]: datetime,
   [operation_from]: datetime,
   [operation_to]: datetime,
   [created]: datetime,
   [updated]: datetime,
   [___type]: string,
   [___source]: string,
   [___id]: string,
