.alter table [OceanObservation] docstring @"{""description"": ""A single oceanographic measurement. parameter_id is one of: sealev_dvr (sea level vs DVR90 datum, cm; preferred since 1997), sealev_ln (sea level vs local zero, cm; preferred before 1997), sea_reg (sea-level registration by Kystdirektoratet, cm), tw (water temperature, deg C; indicative).""}";

.alter table [OceanObservation] column-docstrings (
   [observation_id]: @"{""description"": ""DMI-assigned row identifier (not stable across re-ingestions).""}",
   [parameter_id]: @"{""description"": ""DMI oceanographic parameter identifier: sealev_dvr (sea level relative to DVR90 datum, cm), sealev_ln (sea level relative to local zero, cm), sea_reg (sea-level registration by Kystdirektoratet, cm), or tw (water temperature, deg C).""}",
   [value]: @"{""description"": ""Numeric value. cm for sealev_*/sea_reg, deg C for tw.""}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

