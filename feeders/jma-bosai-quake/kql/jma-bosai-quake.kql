.drop materialized-view ['JP.JMA.Quake.EarthquakeReportLatest'] ifexists;

.create materialized-view with (backfill=true) ['JP.JMA.Quake.EarthquakeReportLatest'] on table ['JP.JMA.Quake.EarthquakeReport'] {
    ['JP.JMA.Quake.EarthquakeReport'] | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table ['JP.JMA.Quake.EarthquakeReport'] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'JP.JMA.Quake.EarthquakeReport') | project['event_id'] = tostring(data.['event_id']),['report_id'] = tostring(data.['report_id']),['serial'] = toint(data.['serial']),['info_type'] = tostring(data.['info_type']),['report_datetime'] = tostring(data.['report_datetime']),['report_datetime_local'] = tostring(data.['report_datetime_local']),['control_datetime'] = tostring(data.['control_datetime']),['control_datetime_local'] = tostring(data.['control_datetime_local']),['origin_datetime'] = tostring(data.['origin_datetime']),['origin_datetime_local'] = tostring(data.['origin_datetime_local']),['title_jp'] = tostring(data.['title_jp']),['title_en'] = tostring(data.['title_en']),['epicenter_area_code'] = tostring(data.['epicenter_area_code']),['epicenter_area_jp'] = tostring(data.['epicenter_area_jp']),['epicenter_area_en'] = tostring(data.['epicenter_area_en']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),['depth_km'] = toreal(data.['depth_km']),['magnitude'] = toreal(data.['magnitude']),['max_intensity'] = tostring(data.['max_intensity']),['bulletin_type'] = tostring(data.['bulletin_type']),['detail_url'] = tostring(data.['detail_url']),['affected_prefectures'] = todynamic(data.['affected_prefectures']),['affected_cities'] = todynamic(data.['affected_cities']),['tsunami_possible'] = tobool(data.['tsunami_possible']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

