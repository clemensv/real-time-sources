.alter table [PSIReading] docstring "{\"description\": \"Pollutant Standards Index (PSI) reading for a Singapore NEA air quality region. PSI is a composite index calculated from six pollutant sub-indices. Published hourly by the NEA via data.gov.sg.\"}";

.alter table [PSIReading] column-docstrings (
   [region]: "{\"description\": \"Region identifier (west/east/central/south/north).\"}",
   [timestamp]: "{\"description\": \"Observation period start timestamp in ISO 8601 with timezone.\"}",
   [update_timestamp]: "{\"description\": \"Timestamp when the NEA API last updated this reading.\"}",
   [psi_twenty_four_hourly]: "{\"description\": \"24-hour PSI value. The overall Pollutant Standards Index for the region. Scale: 0-50 Good, 51-100 Moderate, 101-200 Unhealthy, 201-300 Very Unhealthy, above 300 Hazardous.\"}",
   [o3_sub_index]: "{\"description\": \"Ozone (O3) sub-index component of PSI.\"}",
   [pm10_sub_index]: "{\"description\": \"PM10 sub-index component of PSI.\"}",
   [pm10_twenty_four_hourly]: "{\"description\": \"PM10 24-hour concentration used to calculate the PM10 PSI sub-index.\"}",
   [pm25_sub_index]: "{\"description\": \"PM2.5 sub-index component of PSI.\"}",
   [pm25_twenty_four_hourly]: "{\"description\": \"PM2.5 24-hour concentration.\"}",
   [co_sub_index]: "{\"description\": \"Carbon monoxide (CO) sub-index component of PSI.\"}",
   [co_eight_hour_max]: "{\"description\": \"CO 8-hour maximum concentration.\"}",
   [so2_sub_index]: "{\"description\": \"Sulphur dioxide (SO2) sub-index component of PSI.\"}",
   [so2_twenty_four_hourly]: "{\"description\": \"SO2 24-hour concentration.\"}",
   [no2_one_hour_max]: "{\"description\": \"Nitrogen dioxide (NO2) 1-hour maximum concentration.\"}",
   [o3_eight_hour_max]: "{\"description\": \"Ozone (O3) 8-hour maximum concentration.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

