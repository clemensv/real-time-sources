.drop materialized-view StationLatest ifexists;

.create materialized-view with (backfill=true) StationLatest on table Station {
    Station | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [Station] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'SG.Gov.NEA.Weather.Station') | project['station_id'] = tostring(data.['station_id']),['device_id'] = tostring(data.['device_id']),['name'] = tostring(data.['name']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),['data_types'] = tostring(data.['data_types']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

.create-merge table [WeatherObservation] (
   [station_id]: string,
   [station_name]: string,
   [observation_time]: datetime,
   [air_temperature]: real,
   [rainfall]: real,
   [relative_humidity]: real,
   [wind_speed]: real,
   [wind_direction]: real,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [WeatherObservation] docstring "{\"description\": \"Real-time weather observation from a Singapore NEA station assembled from multiple endpoints. Temperature updates every minute, rainfall every 5 minutes, humidity and wind every minute. Fields are null when the station does not report that parameter.\"}";

.alter table [WeatherObservation] column-docstrings (
   [station_id]: "{\"description\": \"NEA station identifier.\"}",
   [station_name]: "{\"description\": \"Station location name.\"}",
   [observation_time]: "{\"description\": \"Timestamp of the observation in ISO 8601 with Singapore timezone (+08:00).\"}",
   [air_temperature]: "{\"description\": \"Air temperature from the air-temperature endpoint.\"}",
   [rainfall]: "{\"description\": \"Rainfall amount in the last 5 minutes from the rainfall endpoint.\"}",
   [relative_humidity]: "{\"description\": \"Relative humidity from the relative-humidity endpoint.\"}",
   [wind_speed]: "{\"description\": \"Wind speed from the wind-speed endpoint.\"}",
   [wind_direction]: "{\"description\": \"Wind direction in degrees clockwise from true north, from the wind-direction endpoint.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

