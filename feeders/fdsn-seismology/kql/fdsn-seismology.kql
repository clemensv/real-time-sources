.drop materialized-view ['org.fdsn.event.EarthquakeLatest'] ifexists;

.create materialized-view with (backfill=true) ['org.fdsn.event.EarthquakeLatest'] on table ['org.fdsn.event.Earthquake'] {
    ['org.fdsn.event.Earthquake'] | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table ['org.fdsn.event.Earthquake'] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'org.fdsn.event.Earthquake') | project['event_id'] = tostring(data.['event_id']),['time'] = todatetime(data.['time']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),['depth_km'] = toreal(data.['depth_km']),['author'] = tostring(data.['author']),['catalog'] = tostring(data.['catalog']),['contributor'] = tostring(data.['contributor']),['contributor_id'] = tostring(data.['contributor_id']),['magnitude_type'] = tostring(data.['magnitude_type']),['magnitude'] = toreal(data.['magnitude']),['magnitude_author'] = tostring(data.['magnitude_author']),['event_location_name'] = tostring(data.['event_location_name']),['event_type'] = tostring(data.['event_type']),['node_url'] = tostring(data.['node_url']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

.create-merge table ['org.fdsn.event.Node'] (
   [node_id]: string,
   [name]: string,
   [base_url]: string,
   [coverage]: string,
   [country]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table ['org.fdsn.event.Node'] docstring "{\"description\": \"Reference-data record describing one pre-configured FDSN Event web-service node that the feeder polls for earthquake detections.\"}";

.alter table ['org.fdsn.event.Node'] column-docstrings (
   [node_id]: "{\"description\": \"Short identifier for the FDSN node, e.g. 'emsc', 'gfz', 'ingv', 'ethz', 'resif'.\"}",
   [name]: "{\"description\": \"Full institution name operating the FDSN event service.\"}",
   [base_url]: "{\"description\": \"Base URL for the FDSN event web service endpoint, e.g. 'https://seismicportal.eu/fdsnws/event/1/'.\"}",
   [coverage]: "{\"description\": \"Geographic or magnitude coverage description, e.g. 'Global aggregator', 'Italy + Mediterranean'.\"}",
   [country]: "{\"description\": \"ISO 3166-1 alpha-2 country code of the operating institution.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

