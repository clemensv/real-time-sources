.create-merge table [_cloudevents_dispatch] (
    [specversion]: string,
    [type]: string,
    [source]: string,
    [id]: string,
    [time]: datetime,
    [subject]: string,
    [datacontenttype]: string,
    [dataschema]: string,
    [data]: dynamic
);

.create-or-alter table [_cloudevents_dispatch] ingestion json mapping "_cloudevents_dispatch_json"
```
[
  {"column": "specversion", "path": "$.specversion"},
  {"column": "type", "path": "$.type"},
  {"column": "source", "path": "$.source"},
  {"column": "id", "path": "$.id"},
  {"column": "time", "path": "$.time"},
  {"column": "subject", "path": "$.subject"},
  {"column": "datacontenttype", "path": "$.datacontenttype"},
  {"column": "dataschema", "path": "$.dataschema"},
  {"column": "data", "path": "$.data"}
]
```

.create-merge table ['org.fdsn.event.Earthquake'] (
   [event_id]: string,
   [time]: datetime,
   [latitude]: real,
   [longitude]: real,
   [depth_km]: real,
   [author]: string,
   [catalog]: string,
   [contributor]: string,
   [contributor_id]: string,
   [magnitude_type]: string,
   [magnitude]: real,
   [magnitude_author]: string,
   [event_location_name]: string,
   [event_type]: string,
   [node_url]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table ['org.fdsn.event.Earthquake'] docstring "{\"description\": \"Preferred-origin earthquake event record returned by an FDSN Event web-service node in text format. The record carries origin time, hypocenter, magnitude, provenance, and human-readable region metadata for one seismic event.\"}";

.alter table ['org.fdsn.event.Earthquake'] column-docstrings (
   [event_id]: "{\"description\": \"Unique identifier assigned by the contributing institution, e.g. '20260604_0000095' or 'gfz2026kvsq'.\"}",
   [time]: "{\"description\": \"Origin time of the seismic event in ISO 8601 UTC format as reported by the authoritative source.\"}",
   [latitude]: "{\"description\": \"Epicenter latitude in decimal degrees, WGS84 datum, range -90 to 90.\"}",
   [longitude]: "{\"description\": \"Epicenter longitude in decimal degrees, WGS84 datum, range -180 to 180.\"}",
   [depth_km]: "{\"description\": \"Hypocentral depth in kilometers below the Earth's surface; null if unconstrained.\"}",
   [author]: "{\"description\": \"Agency or analyst who computed the preferred origin solution, e.g. 'EMSC', 'GFZ', 'SURVEY-INGV'.\"}",
   [catalog]: "{\"description\": \"Name of the event catalog this earthquake belongs to, e.g. 'EMSC-RTS', 'SED'.\"}",
   [contributor]: "{\"description\": \"Short code of the institution that contributed this event record to the FDSN node, e.g. 'CSN', 'GFZ', 'EMSC'.\"}",
   [contributor_id]: "{\"description\": \"Contributor's internal identifier for this event, may differ from event_id.\"}",
   [magnitude_type]: "{\"description\": \"Scale used for the preferred magnitude: 'ML' (local), 'mb' (body-wave), 'Mw' (moment), 'Ms' (surface), 'm' (unspecified).\"}",
   [magnitude]: "{\"description\": \"Preferred magnitude value on the scale indicated by magnitude_type; null if no magnitude computed.\"}",
   [magnitude_author]: "{\"description\": \"Agency that computed the preferred magnitude, may differ from the origin author.\"}",
   [event_location_name]: "{\"description\": \"Human-readable geographic description of the epicenter region, typically a Flinn-Engdahl region name.\"}",
   [event_type]: "{\"description\": \"Seismological event classification: 'earthquake', 'quarry blast', 'explosion', 'induced or triggered event', etc.\"}",
   [node_url]: "{\"description\": \"Base URL of the FDSN node that served this event record, identifying the data source.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

