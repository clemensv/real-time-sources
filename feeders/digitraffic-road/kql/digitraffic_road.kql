.alter table [WeatherStation] docstring "{\"description\": \"Road weather station metadata from the Finnish national road network operated by Fintraffic. Over 350 road weather stations measure atmospheric and road surface conditions. Station metadata includes geographic location, road address, municipality, sensor list, collection parameters, and administrative details. This reference data contextualizes the real-time WeatherSensorData telemetry events and is fetched from the Digitraffic REST API at https://tie.digitraffic.fi/api/weather/v1/stations. See https://www.digitraffic.fi/en/road-traffic/ for full documentation.\"}";

.alter table [WeatherStation] column-docstrings (
   [station_id]: "{\"description\": \"Road weather station numeric identifier as assigned by Fintraffic (e.g. 1012). Uniqueness scope is road weather stations. Corresponds to the station_id in WeatherSensorData telemetry events.\"}",
   [name]: "{\"description\": \"Internal station name used by Fintraffic, typically encoding road type, municipality and area (e.g. \\\"kt51_Espoo_Kivenlahti\\\"). Not intended for display.\"}",
   [names_fi]: "{\"description\": \"Finnish display name for the station (e.g. \\\"Tie 51 Espoo, Kivenlahti\\\").\"}",
   [names_sv]: "{\"description\": \"Swedish display name for the station (e.g. \\\"V\\u00e4g 51 Esbo, Stensvik\\\"). Null if no translation available.\"}",
   [names_en]: "{\"description\": \"English display name for the station (e.g. \\\"Road 51 Espoo, Kivenlahti\\\"). Null if no translation available.\"}",
   [longitude]: "{\"description\": \"Station longitude in WGS84 (EPSG:4326) decimal degrees.\"}",
   [latitude]: "{\"description\": \"Station latitude in WGS84 (EPSG:4326) decimal degrees.\"}",
   [altitude]: "{\"description\": \"Station altitude in meters above sea level. Null or 0.0 if altitude data is not available.\"}",
   [municipality]: "{\"description\": \"Name of the Finnish municipality where the station is located.\"}",
   [municipality_code]: "{\"description\": \"Finnish municipality code as defined by Statistics Finland.\"}",
   [province]: "{\"description\": \"Name of the Finnish province (maakunta) where the station is located.\"}",
   [province_code]: "{\"description\": \"Finnish province code as defined by Statistics Finland.\"}",
   [road_number]: "{\"description\": \"Finnish road number where the station is installed.\"}",
   [road_section]: "{\"description\": \"Road section number within the road.\"}",
   [distance_from_section_start]: "{\"description\": \"Distance from the start of the road section in meters.\"}",
   [carriageway]: "{\"description\": \"Carriageway type at the station location. Values include \\\"DUAL_CARRIAGEWAY_RIGHT_IN_INCREASING_DIRECTION\\\", \\\"DUAL_CARRIAGEWAY_LEFT_IN_INCREASING_DIRECTION\\\", \\\"ONE_CARRIAGEWAY\\\". Null if not specified.\"}",
   [side]: "{\"description\": \"Side of the road. Values: \\\"LEFT\\\", \\\"RIGHT\\\", \\\"BETWEEN\\\", \\\"UNKNOWN\\\". Null if not specified.\"}",
   [contract_area]: "{\"description\": \"Road maintenance contract area name (e.g. \\\"Espoo 19-24\\\"). Identifies the maintenance contract responsible for the road section. Null if not assigned.\"}",
   [contract_area_code]: "{\"description\": \"Numeric code for the maintenance contract area (e.g. 142). Null if not assigned.\"}",
   [station_type]: "{\"description\": \"Weather station type code indicating the hardware configuration (e.g. \\\"RWS_200\\\" for a Rosa RWS-200 station). Determines available sensor capabilities.\"}",
   [master]: "{\"description\": \"Whether this is a master station. Master stations are the primary data source; non-master stations may be auxiliary or backup installations at the same location.\"}",
   [collection_status]: "{\"description\": \"Current data collection status. Values: \\\"GATHERING\\\" (actively collecting), \\\"REMOVED_TEMPORARILY\\\", \\\"REMOVED_PERMANENTLY\\\".\"}",
   [collection_interval]: "{\"description\": \"Data collection interval in seconds. Typical value is 300 (5 minutes) for road weather stations.\"}",
   [state]: "{\"description\": \"Operational state of the station hardware. Null if state information is not available from the upstream API.\"}",
   [start_time]: "{\"description\": \"ISO 8601 UTC timestamp when the station started collecting data.\"}",
   [livi_id]: "{\"description\": \"Legacy identifier from the Finnish Transport Infrastructure Agency. Null if not assigned.\"}",
   [sensors]: "{\"description\": \"Array of sensor identifiers available at this station. Each ID corresponds to a sensor producing WeatherSensorData telemetry. Common sensors: ILMA (1, air temp), TIE_1 (3, road surface temp), KASTEPISTE (9, dew point), KESKITUULI (16, avg wind), ILMAN_KOSTEUS (19, humidity). Full list at /api/weather/v1/sensors.\", \"schema\": {\"type\": \"array\", \"items\": {\"type\": \"int32\"}, \"description\": \"Array of sensor identifiers available at this station. Each ID corresponds to a sensor producing WeatherSensorData telemetry. Common sensors: ILMA (1, air temp), TIE_1 (3, road surface temp), KASTEPISTE (9, dew point), KESKITUULI (16, avg wind), ILMAN_KOSTEUS (19, humidity). Full list at /api/weather/v1/sensors.\"}}",
   [data_updated_time]: "{\"description\": \"ISO 8601 UTC timestamp when the station metadata was last updated. Null if not tracked.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

