.create-merge table [MaintenanceTracking] (
   [domain]: string,
   [time]: int,
   [source]: string,
   [tasks]: dynamic,
   [x]: real,
   [y]: real,
   [direction]: real,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [MaintenanceTracking] docstring "{\"description\": \"Road maintenance vehicle tracking update from the Finnish national road network operated by Fintraffic. Each message represents a position and task report from a maintenance vehicle, delivered in real time via the Digitraffic MQTT stream at wss://tie.digitraffic.fi/mqtt on topic maintenance-v2/routes/{domain}. Data originates from the Finnish Transport Infrastructure Agency's Harja system for state roads and from municipal systems for other domains. Updates arrive approximately every minute. A new tracking event is created when the vehicle's task changes, the gap between consecutive positions exceeds 5 minutes, or the calculated speed exceeds 140 km/h. See https://www.digitraffic.fi/en/road-traffic/ for the full API documentation and task type taxonomy at /api/maintenance/v1/tracking/tasks.\"}";

.alter table [MaintenanceTracking] column-docstrings (
   [domain]: "{\"description\": \"Data domain identifying the source system. Primary domain is 'state-roads' for data from the Finnish Transport Infrastructure Agency's Harja system. Other domains include municipal systems such as 'autori-kuopio', 'autori-oulu', and 'paikannin-kuopio'. The domain value comes from the MQTT topic path.\"}",
   [time]: "{\"description\": \"Tracking timestamp as Unix epoch seconds (UTC). Indicates when the position and task were recorded by the vehicle.\"}",
   [source]: "{\"description\": \"Name of the source system that produced the tracking data (e.g. 'Harja/V\\u00e4yl\\u00e4virasto' for the state road maintenance system). May be null if the source system is not identified.\"}",
   [tasks]: "{\"description\": \"Array of maintenance task type identifiers being performed by the vehicle at this position. Task types follow the Fintraffic taxonomy, e.g. 'BRUSHING', 'SALTING', 'PLOUGHING_AND_SLUSH_REMOVAL', 'LEVELLING_GRAVEL_ROAD_SURFACE'. Full task type list with Finnish, English, and Swedish names is available at /api/maintenance/v1/tracking/tasks.\", \"schema\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}, \"description\": \"Array of maintenance task type identifiers being performed by the vehicle at this position. Task types follow the Fintraffic taxonomy, e.g. 'BRUSHING', 'SALTING', 'PLOUGHING_AND_SLUSH_REMOVAL', 'LEVELLING_GRAVEL_ROAD_SURFACE'. Full task type list with Finnish, English, and Swedish names is available at /api/maintenance/v1/tracking/tasks.\"}}",
   [x]: "{\"description\": \"Longitude of the vehicle position in WGS84 (EPSG:4326) decimal degrees.\"}",
   [y]: "{\"description\": \"Latitude of the vehicle position in WGS84 (EPSG:4326) decimal degrees.\"}",
   [direction]: "{\"description\": \"Vehicle heading in degrees (0-360, clockwise from north). May be null or absent if heading information is not available from the tracking device.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

