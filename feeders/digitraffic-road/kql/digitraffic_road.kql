.alter table [TmsSensorData] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'fi.digitraffic.road.sensors.TmsSensorData') | project['station_id'] = toint(data.['station_id']),['sensor_id'] = toint(data.['sensor_id']),['value'] = toreal(data.['value']),['time'] = toint(data.['time']),['start'] = toint(data.['start']),['end'] = toint(data.['end']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

