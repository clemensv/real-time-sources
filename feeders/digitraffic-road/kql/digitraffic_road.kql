.create materialized-view with (backfill=true) WeatherStationLatest on table WeatherStation {
    WeatherStation | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [WeatherStation] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'fi.digitraffic.road.stations.WeatherStation') | project['station_id'] = toint(data.['station_id']),['name'] = tostring(data.['name']),['names_fi'] = tostring(data.['names_fi']),['names_sv'] = tostring(data.['names_sv']),['names_en'] = tostring(data.['names_en']),['longitude'] = toreal(data.['longitude']),['latitude'] = toreal(data.['latitude']),['altitude'] = toreal(data.['altitude']),['municipality'] = tostring(data.['municipality']),['municipality_code'] = toint(data.['municipality_code']),['province'] = tostring(data.['province']),['province_code'] = toint(data.['province_code']),['road_number'] = toint(data.['road_number']),['road_section'] = toint(data.['road_section']),['distance_from_section_start'] = toint(data.['distance_from_section_start']),['carriageway'] = tostring(data.['carriageway']),['side'] = tostring(data.['side']),['contract_area'] = tostring(data.['contract_area']),['contract_area_code'] = toint(data.['contract_area_code']),['station_type'] = tostring(data.['station_type']),['master'] = tobool(data.['master']),['collection_status'] = tostring(data.['collection_status']),['collection_interval'] = toint(data.['collection_interval']),['state'] = tostring(data.['state']),['start_time'] = tostring(data.['start_time']),['livi_id'] = tostring(data.['livi_id']),['sensors'] = todynamic(data.['sensors']),['data_updated_time'] = tostring(data.['data_updated_time']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

.create-merge table [MaintenanceTaskType] (
   [task_id]: string,
   [name_fi]: string,
   [name_en]: string,
   [name_sv]: string,
   [data_updated_time]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [MaintenanceTaskType] docstring "{\"description\": \"Maintenance task type reference from the Finnish road maintenance system operated by Fintraffic. Each task type classifies a specific road maintenance activity such as ploughing, salting, or brush clearing. Task type identifiers appear in the tasks array of MaintenanceTracking telemetry events. This reference data provides multilingual human-readable names for each task identifier and is fetched from the Digitraffic REST API at https://tie.digitraffic.fi/api/maintenance/v1/tracking/tasks. Approximately 40 task types are defined. See https://www.digitraffic.fi/en/road-traffic/ for full documentation.\"}";

.alter table [MaintenanceTaskType] column-docstrings (
   [task_id]: "{\"description\": \"Unique task type identifier using SCREAMING_SNAKE_CASE convention (e.g. \\\"PLOUGHING_AND_SLUSH_REMOVAL\\\", \\\"SALTING\\\", \\\"BRUSHING\\\"). This identifier appears in the tasks array of MaintenanceTracking telemetry events.\"}",
   [name_fi]: "{\"description\": \"Finnish name for the maintenance task type (e.g. \\\"Auraus ja sohjonpoisto\\\", \\\"Suolaus\\\", \\\"Harjaus\\\").\"}",
   [name_en]: "{\"description\": \"English name for the maintenance task type (e.g. \\\"Ploughing and slush removal\\\", \\\"Salting\\\", \\\"Brushing\\\").\"}",
   [name_sv]: "{\"description\": \"Swedish name for the maintenance task type (e.g. \\\"Pl\\u00f6jning och sn\\u00f6slaskborttagning\\\", \\\"Saltning\\\", \\\"Borstning\\\").\"}",
   [data_updated_time]: "{\"description\": \"ISO 8601 UTC timestamp when this task type definition was last updated in the Digitraffic system (e.g. \\\"2020-03-30T00:00:00Z\\\"). Null if not tracked.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

