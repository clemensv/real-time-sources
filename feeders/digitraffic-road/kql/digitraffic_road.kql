  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type in ('fi.digitraffic.road.messages.TrafficAnnouncement', 'fi.digitraffic.road.messages.RoadWork', 'fi.digitraffic.road.messages.WeightRestriction', 'fi.digitraffic.road.messages.ExemptedTransport')) | project['situation_id'] = tostring(data.['situation_id']),['situation_type'] = tostring(data.['situation_type']),['traffic_announcement_type'] = tostring(data.['traffic_announcement_type']),['version'] = toint(data.['version']),['release_time'] = tostring(data.['release_time']),['version_time'] = tostring(data.['version_time']),['title'] = tostring(data.['title']),['language'] = tostring(data.['language']),['sender'] = tostring(data.['sender']),['location_description'] = tostring(data.['location_description']),['start_time'] = tostring(data.['start_time']),['end_time'] = tostring(data.['end_time']),['features_json'] = tostring(data.['features_json']),['road_work_phases_json'] = tostring(data.['road_work_phases_json']),['comment'] = tostring(data.['comment']),['additional_information'] = tostring(data.['additional_information']),['contact_phone'] = tostring(data.['contact_phone']),['contact_email'] = tostring(data.['contact_email']),['announcements_json'] = tostring(data.['announcements_json']),['geometry_type'] = tostring(data.['geometry_type']),['geometry_coordinates_json'] = tostring(data.['geometry_coordinates_json']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
