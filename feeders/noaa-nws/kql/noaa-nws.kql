.create-merge table [ObservationStation] (
   [station_id]: string,
   [name]: string,
   [elevation_m]: real,
   [time_zone]: string,
   [forecast_zone]: string,
   [county]: string,
   [fire_weather_zone]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [ObservationStation] docstring "{\"description\": \"NWS surface weather observation station reference data from the api.weather.gov /stations endpoint. Each station represents a fixed automated or manual observing site in the US.\"}";

.alter table [ObservationStation] column-docstrings (
   [station_id]: "{\"description\": \"Station identifier, typically a 4-character ICAO code such as 'KJFK' or a cooperative observer ID.\"}",
   [name]: "{\"description\": \"Human-readable station name, e.g. 'New York, Kennedy International Airport'.\"}",
   [elevation_m]: "{\"description\": \"Station elevation above mean sea level.\"}",
   [time_zone]: "{\"description\": \"IANA timezone of the station, e.g. 'America/New_York'.\"}",
   [forecast_zone]: "{\"description\": \"NWS forecast zone identifier associated with this station.\"}",
   [county]: "{\"description\": \"NWS county zone identifier for the station's location.\"}",
   [fire_weather_zone]: "{\"description\": \"NWS fire weather zone identifier for the station's location.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

