  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'Microsoft.OpenData.US.NOAA.NWS.WeatherAlert') | project['alert_id'] = tostring(data.['alert_id']),['area_desc'] = tostring(data.['area_desc']),['sent'] = todatetime(data.['sent']),['effective'] = todatetime(data.['effective']),['expires'] = todatetime(data.['expires']),['status'] = tostring(data.['status']),['message_type'] = tostring(data.['message_type']),['category'] = tostring(data.['category']),['severity'] = tostring(data.['severity']),['certainty'] = tostring(data.['certainty']),['urgency'] = tostring(data.['urgency']),['event'] = tostring(data.['event']),['sender_name'] = tostring(data.['sender_name']),['headline'] = tostring(data.['headline']),['description'] = tostring(data.['description']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

.create-merge table [Zone] (
   [zone_id]: string,
   [name]: string,
   [type]: string,
   [state]: string,
   [forecast_office]: string,
   [timezone]: string,
   [radar_station]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [Zone] docstring "{\"description\": \"NWS forecast zone reference data. Zones partition the US into geographic areas for which forecasts and warnings are issued.\"}";

.alter table [Zone] column-docstrings (
   [zone_id]: "{\"description\": \"NWS zone identifier, e.g. 'NYZ072' for New York City.\"}",
   [name]: "{\"description\": \"Human-readable zone name.\"}",
   [type]: "{\"description\": \"Zone type: 'forecast', 'county', 'fire', 'coastal', or 'offshore'.\"}",
   [state]: "{\"description\": \"Two-letter US state or territory abbreviation.\"}",
   [forecast_office]: "{\"description\": \"NWS Weather Forecast Office (WFO) responsible for this zone, e.g. 'OKX'.\"}",
   [timezone]: "{\"description\": \"IANA timezone name for the zone, e.g. 'America/New_York'.\"}",
   [radar_station]: "{\"description\": \"Nearest NEXRAD radar station identifier, or null if none assigned.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

