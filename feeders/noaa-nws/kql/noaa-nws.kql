.create-merge table [WeatherObservation] (
   [station_id]: string,
   [timestamp]: datetime,
   [text_description]: string,
   [temperature]: real,
   [dewpoint]: real,
   [wind_direction]: real,
   [wind_speed]: real,
   [wind_gust]: real,
   [barometric_pressure]: real,
   [sea_level_pressure]: real,
   [visibility]: real,
   [relative_humidity]: real,
   [wind_chill]: real,
   [heat_index]: real,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table [WeatherObservation] docstring "{\"description\": \"Latest weather observation from a NWS surface station. Observations are fetched from the api.weather.gov /stations/{stationId}/observations/latest endpoint. Measurement values are extracted from NWS quantity objects (unitCode + value + qualityControl).\"}";

.alter table [WeatherObservation] column-docstrings (
   [station_id]: "{\"description\": \"ICAO or cooperative observer station identifier.\"}",
   [timestamp]: "{\"description\": \"UTC timestamp of the observation.\"}",
   [text_description]: "{\"description\": \"Brief text summary of current conditions, e.g. 'Clear', 'Mostly Cloudy', 'Rain'.\"}",
   [temperature]: "{\"description\": \"Air temperature at the time of observation.\"}",
   [dewpoint]: "{\"description\": \"Dew point temperature.\"}",
   [wind_direction]: "{\"description\": \"Wind direction in degrees from which the wind is blowing.\"}",
   [wind_speed]: "{\"description\": \"Sustained wind speed.\"}",
   [wind_gust]: "{\"description\": \"Peak wind gust speed, null if no gusts observed.\"}",
   [barometric_pressure]: "{\"description\": \"Station barometric pressure (not reduced to sea level).\"}",
   [sea_level_pressure]: "{\"description\": \"Atmospheric pressure reduced to mean sea level.\"}",
   [visibility]: "{\"description\": \"Horizontal visibility.\"}",
   [relative_humidity]: "{\"description\": \"Relative humidity percentage.\"}",
   [wind_chill]: "{\"description\": \"Calculated wind chill temperature, null when conditions do not warrant it.\"}",
   [heat_index]: "{\"description\": \"Calculated heat index temperature, null when conditions do not warrant it.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

