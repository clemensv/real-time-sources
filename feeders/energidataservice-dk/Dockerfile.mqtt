# syntax=docker/dockerfile:1.6
FROM python:3.10-slim
LABEL org.opencontainers.image.source="https://github.com/clemensv/real-time-sources/tree/main/feeders/energidataservice-dk"
LABEL org.opencontainers.image.title="energidataservice-dk -> MQTT companion bridge"
LABEL org.opencontainers.image.description="Publishes energidataservice-dk CloudEvents over MQTT as a companion to the Kafka feeder."
LABEL org.opencontainers.image.documentation="https://github.com/clemensv/real-time-sources/blob/main/feeders/energidataservice-dk/CONTAINER.md"
LABEL org.opencontainers.image.license="MIT"
ENV PYTHONUNBUFFERED=1
WORKDIR /app

ENV SETUPTOOLS_SCM_PRETEND_VERSION=0
COPY . /app
RUN pip install --no-cache-dir confluent-kafka \
 && pip install --no-cache-dir ./energidataservice_dk_producer/energidataservice_dk_producer_kafka_producer \
 && pip install --no-cache-dir ./energidataservice_dk_mqtt_producer/energidataservice_dk_mqtt_producer_data \
 && pip install --no-cache-dir ./energidataservice_dk_mqtt_producer/energidataservice_dk_mqtt_producer_mqtt_client \
 && pip install --no-cache-dir ./energidataservice_dk_mqtt
CMD ["python", "-m", "energidataservice_dk_mqtt", "feed"]
