# syntax=docker/dockerfile:1.6
FROM python:3.10-slim
LABEL org.opencontainers.image.source="https://github.com/clemensv/real-time-sources/tree/main/feeders/nifc-usa-wildfires"
LABEL org.opencontainers.image.title="NIFC USA wildfires -> MQTT/UNS bridge"
LABEL org.opencontainers.image.description="Publishes NIFC wildfire incident CloudEvents to MQTT 5.0 topics."
LABEL org.opencontainers.image.documentation="https://github.com/clemensv/real-time-sources/blob/main/feeders/nifc-usa-wildfires/CONTAINER.md"
LABEL org.opencontainers.image.license="MIT"
ENV PYTHONUNBUFFERED=1
WORKDIR /app

ENV SETUPTOOLS_SCM_PRETEND_VERSION=0
COPY . /app
RUN pip install --no-cache-dir confluent-kafka \
 && pip install --no-cache-dir ./nifc_usa_wildfires_producer/nifc_usa_wildfires_producer_data \
 && pip install --no-cache-dir ./nifc_usa_wildfires_producer/nifc_usa_wildfires_producer_kafka_producer \
 && pip install --no-cache-dir ./nifc_usa_wildfires_mqtt_producer/nifc_usa_wildfires_mqtt_producer_data
ENV MQTT_BROKER_URL=""
CMD ["python", "-m", "nifc_usa_wildfires_mqtt", "feed"]
