{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "basics": [],
    "steps": [
      {
        "name": "config",
        "label": "Feeder configuration",
        "elements": [
          {
            "name": "brokerUrl",
            "type": "Microsoft.Common.TextBox",
            "label": "Broker url",
            "defaultValue": "",
            "toolTip": "Broker URL, e.g. mqtt://host:1883 or mqtts://host:8883.",
            "constraints": {
              "required": true,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "brokerUsername",
            "type": "Microsoft.Common.TextBox",
            "label": "Broker username",
            "defaultValue": "",
            "toolTip": "Credentials for MQTT_AUTH_MODE=password.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "brokerPassword",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Broker password",
              "confirmPassword": "Confirm broker password"
            },
            "toolTip": "Credentials for MQTT_AUTH_MODE=password.",
            "constraints": {
              "required": false,
              "regex": "^.{8,}$",
              "validationMessage": "Enter at least 8 characters."
            },
            "visible": true
          },
          {
            "name": "containerGroupName",
            "type": "Microsoft.Common.TextBox",
            "label": "Container group name",
            "defaultValue": "nasa-firms-mqtt",
            "toolTip": "Name for the container group resource.",
            "constraints": {
              "required": false,
              "regex": "^[\\s\\S]*$",
              "validationMessage": "Enter a valid value."
            },
            "visible": true
          },
          {
            "name": "firmsSources",
            "type": "Microsoft.Common.DropDown",
            "label": "Upstream sources",
            "multiselect": true,
            "selectAll": true,
            "filter": true,
            "toolTip": "Source selector. Comma-separated FIRMS dataset specifications to poll, each SENSOR or SENSOR:REGION (for example VIIRS_SNPP_NRT,MODIS_NRT). When set, replaces the built-in default dataset list. Requires FIRMS_MAP_KEY.",
            "constraints": {
              "allowedValues": [
                {
                  "label": "VIIRS_SNPP_NRT",
                  "value": "VIIRS_SNPP_NRT"
                },
                {
                  "label": "VIIRS_NOAA20_NRT",
                  "value": "VIIRS_NOAA20_NRT"
                },
                {
                  "label": "VIIRS_NOAA21_NRT",
                  "value": "VIIRS_NOAA21_NRT"
                },
                {
                  "label": "MODIS_NRT",
                  "value": "MODIS_NRT"
                }
              ],
              "required": false
            },
            "visible": true,
            "defaultValue": [
              "VIIRS_SNPP_NRT",
              "VIIRS_NOAA20_NRT",
              "VIIRS_NOAA21_NRT",
              "MODIS_NRT"
            ]
          },
          {
            "name": "firmsMapKey",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Firms map key",
              "confirmPassword": "Confirm firms map key"
            },
            "toolTip": "NASA FIRMS MAP_KEY (free Earthdata key from https://firms.modaps.eosdis.nasa.gov/api/map_key/).",
            "constraints": {
              "required": true,
              "regex": "^.{8,}$",
              "validationMessage": "Enter at least 8 characters."
            },
            "visible": true
          }
        ]
      }
    ],
    "outputs": {
      "brokerUrl": "[steps('config').brokerUrl]",
      "brokerUsername": "[steps('config').brokerUsername]",
      "brokerPassword": "[steps('config').brokerPassword]",
      "containerGroupName": "[steps('config').containerGroupName]",
      "firmsSources": "[if(empty(steps('config').firmsSources), '', replace(replace(replace(string(steps('config').firmsSources), '[\"', ''), '\"]', ''), '\",\"', ','))]",
      "firmsMapKey": "[steps('config').firmsMapKey]",
      "location": "[location()]"
    }
  }
}
