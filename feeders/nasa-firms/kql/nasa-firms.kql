.alter table ['NASA.FIRMS.FireDetection'] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'NASA.FIRMS.FireDetection') | project['source'] = tostring(data.['source']),['record_id'] = tostring(data.['record_id']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),['brightness'] = toreal(data.['brightness']),['bright_t31'] = toreal(data.['bright_t31']),['bright_ti4'] = toreal(data.['bright_ti4']),['bright_ti5'] = toreal(data.['bright_ti5']),['scan'] = toreal(data.['scan']),['track'] = toreal(data.['track']),['acq_date'] = todatetime(data.['acq_date']),['acq_time'] = tostring(data.['acq_time']),['acq_datetime'] = todatetime(data.['acq_datetime']),['satellite'] = tostring(data.['satellite']),['instrument'] = tostring(data.['instrument']),['confidence'] = tostring(data.['confidence']),['confidence_level'] = tostring(data.['confidence_level']),['version'] = tostring(data.['version']),['frp'] = toreal(data.['frp']),['daynight'] = tostring(data.['daynight']),['tile'] = tostring(data.['tile']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

.create-merge table ['NASA.FIRMS.DataAvailability'] (
   [source]: string,
   [record_id]: string,
   [data_id]: string,
   [min_date]: datetime,
   [max_date]: datetime,
   [instrument]: string,
   [satellite]: string,
   [resolution_m]: real,
   [retrieved_at]: datetime,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table ['NASA.FIRMS.DataAvailability'] docstring "{\"description\": \"Reference record describing one FIRMS product source: its current data-availability window (min/max date), sensor family, platform, and nominal resolution. Emitted at bridge startup and refreshed periodically so consumers can interpret detection freshness and coverage on the same topic as the telemetry.\"}";

.alter table ['NASA.FIRMS.DataAvailability'] column-docstrings (
   [source]: "{\"description\": \"FIRMS product source identifier this coverage record describes, e.g. `VIIRS_SNPP_NRT`, `VIIRS_NOAA20_NRT`, `VIIRS_NOAA21_NRT`, `MODIS_NRT`. First segment of the identity key `{source}/{record_id}`; joins to `FireDetection.source`.\"}",
   [record_id]: "{\"description\": \"Constant literal `coverage` \\u2014 the second identity-key segment for the single reference record per source (`{source}/coverage`). Keeps the reference family on the same `{source}/{record_id}` shape and topic as telemetry while remaining a stable, idempotent per-source key.\"}",
   [data_id]: "{\"description\": \"Raw FIRMS data-availability product identifier as returned by the `/api/data_availability` endpoint (the CSV `data_id` column), e.g. `VIIRS_SNPP_NRT`. Usually equal to `source`; preserved verbatim.\"}",
   [min_date]: "{\"description\": \"Earliest UTC date (`YYYY-MM-DD`) for which this FIRMS source currently has data available via the Area API, from the `min_date` column of the data-availability response.\"}",
   [max_date]: "{\"description\": \"Most recent UTC date (`YYYY-MM-DD`) for which this FIRMS source currently has data available \\u2014 the effective freshness horizon of the source, from the `max_date` column.\"}",
   [instrument]: "{\"description\": \"Sensor family of the source: `VIIRS` or `MODIS`. Derived by the bridge from the source identifier.\"}",
   [satellite]: "{\"description\": \"Human-readable platform name(s) carried by the source, e.g. `Suomi-NPP`, `NOAA-20`, `NOAA-21`, `Terra`, `Aqua`. Derived by the bridge from the source identifier.\"}",
   [resolution_m]: "{\"description\": \"Nominal nadir spatial resolution of the source sensor in metres (375 for VIIRS I-band fire product, 1000 for MODIS). Static sensor fact supplied by the bridge for downstream scaling/symbology.\"}",
   [retrieved_at]: "{\"description\": \"UTC ISO-8601 timestamp at which the bridge fetched this availability record.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

