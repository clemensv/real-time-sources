.drop materialized-view ['NASA.FIRMS.FireDetectionLatest'] ifexists;

.create materialized-view with (backfill=true) ['NASA.FIRMS.FireDetectionLatest'] on table ['NASA.FIRMS.FireDetection'] {
    ['NASA.FIRMS.FireDetection'] | summarize arg_max(___time, *) by ___type, ___source, ___subject
