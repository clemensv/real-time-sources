              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/de.wsv.pegelonline.jstruct/schemas/de.wsv.pegelonline.Station"
        },
        "de.wsv.pegelonline.CurrentMeasurement": {
          "name": "CurrentMeasurement",
          "envelope": "CloudEvents/1.0",
          "description": "PegelOnline current water level measurement.",
          "envelopemetadata": {
            "type": {
              "value": "de.wsv.pegelonline.CurrentMeasurement"
            },
            "source": {
              "value": "{feedurl}",
              "type": "uritemplate"
            },
            "subject": {
              "value": "{station_id}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/de.wsv.pegelonline.jstruct/schemas/de.wsv.pegelonline.CurrentMeasurement"
        }
      }
    },
    "de.wsv.pegelonline.kafka": {
      "description": "Kafka-transport variants of the PegelOnline CloudEvents, adding per-message Kafka key for partitioning.",
      "messages": {
        "de.wsv.pegelonline.kafka.Station": {
          "name": "Station",
          "basemessageurl": "/messagegroups/de.wsv.pegelonline/messages/de.wsv.pegelonline.Station",
          "protocol": "KAFKA",
          "protocolmetadata": {
            "key": {
              "type": "uritemplate",
              "value": "{station_id}",
              "description": "Kafka partition key — stable station identifier matching the CloudEvent subject."
            }
          }
        },
        "de.wsv.pegelonline.kafka.CurrentMeasurement": {
          "name": "CurrentMeasurement",
          "basemessageurl": "/messagegroups/de.wsv.pegelonline/messages/de.wsv.pegelonline.CurrentMeasurement",
          "protocol": "KAFKA",
          "protocolmetadata": {
            "key": {
              "type": "uritemplate",
              "value": "{station_id}",
              "description": "Kafka partition key — stable station identifier matching the CloudEvent subject."
            }
          }
        }
      }
    },
    "de.wsv.pegelonline.mqtt": {
      "description": "MQTT/5.0 transport variants of the PegelOnline CloudEvents, mapping each message to a retained, QoS-1 Unified Namespace topic under hydro/de/wsv/pegelonline/...",
      "messages": {
        "de.wsv.pegelonline.mqtt.Station": {
          "name": "Station",
          "basemessageurl": "/messagegroups/de.wsv.pegelonline/messages/de.wsv.pegelonline.Station",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "properties": {
              "topic": {
                "type": "uritemplate",
                "value": "hydro/de/wsv/pegelonline/{water_shortname}/{station_id}/info",
                "description": "Unified Namespace topic carrying the station's identity and location as a retained last-known-value."
              },
              "qos": {
                "type": "integer",
                "value": 1
              },
              "retain": {
                "type": "boolean",
                "value": true
              }
            }
          }
        },
        "de.wsv.pegelonline.mqtt.CurrentMeasurement": {
          "name": "CurrentMeasurement",
          "basemessageurl": "/messagegroups/de.wsv.pegelonline/messages/de.wsv.pegelonline.CurrentMeasurement",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "properties": {
              "topic": {
                "type": "uritemplate",
                "value": "hydro/de/wsv/pegelonline/{water_shortname}/{station_id}/water-level",
                "description": "Unified Namespace topic carrying the station's latest water-level measurement as a retained last-known-value."
              },
              "qos": {
                "type": "integer",
                "value": 1
              },
              "retain": {
                "type": "boolean",
                "value": true
              }
            }
          }
        }
      }
    },
    "de.wsv.pegelonline.amqp": {
      "description": "AMQP 1.0 transport variants of the PegelOnline CloudEvents, sent in binary CloudEvents mode to a single AMQP node ('pegelonline') — works with generic brokers (ActiveMQ, RabbitMQ AMQP 1.0 plugin) and with Azure Service Bus / Event Hubs via CBS + Entra ID.",
      "messages": {
        "de.wsv.pegelonline.amqp.Station": {
          "name": "Station",
          "basemessageurl": "/messagegroups/de.wsv.pegelonline/messages/de.wsv.pegelonline.Station",
          "protocol": "AMQP/1.0",
          "protocoloptions": {
            "properties": {
              "subject": {
                "type": "uritemplate",
                "value": "{station_id}",
                "description": "AMQP message subject — stable station identifier matching the CloudEvent subject so SB/EH consumers can correlate."
              }
            },
            "application_properties": {
              "water_shortname": {
                "type": "string",
                "description": "Lowercase ASCII water-body shortname (e.g. 'rhein'); copied here so message routers/filters don't have to crack the JSON body."
              }
            }
          }
        },
        "de.wsv.pegelonline.amqp.CurrentMeasurement": {
          "name": "CurrentMeasurement",
          "basemessageurl": "/messagegroups/de.wsv.pegelonline/messages/de.wsv.pegelonline.CurrentMeasurement",
          "protocol": "AMQP/1.0",
          "protocoloptions": {
            "properties": {
              "subject": {
                "type": "uritemplate",
                "value": "{station_id}",
                "description": "AMQP message subject — stable station identifier matching the CloudEvent subject so SB/EH consumers can correlate."
              }
            },
            "application_properties": {
              "water_shortname": {
                "type": "string",
                "description": "Lowercase ASCII water-body shortname (e.g. 'rhein'); copied here so message routers/filters don't have to crack the JSON body."
              }
            }
          }
        }
      }
    }
  },
