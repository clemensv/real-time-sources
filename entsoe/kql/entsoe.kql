// ENTSO-E Transparency Platform — KQL database schema
//
// Tables:
//   _cloudevents_dispatch         — raw CloudEvents ingestion (Event Stream target)
//   ActualGenerationPerType       — A75 generation per production type
//   DayAheadPrices                — A44 day-ahead electricity prices
//   ActualTotalLoad               — A65 actual total electricity load
//
// Update policies on _cloudevents_dispatch split events by type.
// Materialized views provide latest values per bidding zone.

// ===== Dispatch table =====

.create-merge table [_cloudevents_dispatch] (
    [specversion]: string,
    [type]: string,
    [source]: string,
    [id]: string,
    [time]: datetime,
    [subject]: string,
    [datacontenttype]: string,
    [dataschema]: string,
    [data]: dynamic
)

.create-or-alter table [_cloudevents_dispatch] ingestion json mapping "_cloudevents_dispatch_json"
```
[
  {"column": "specversion", "path": "$.specversion"},
  {"column": "type", "path": "$.type"},
  {"column": "source", "path": "$.source"},
  {"column": "id", "path": "$.id"},
  {"column": "time", "path": "$.time"},
  {"column": "subject", "path": "$.subject"},
  {"column": "datacontenttype", "path": "$.datacontenttype"},
  {"column": "dataschema", "path": "$.dataschema"},
  {"column": "data", "path": "$.data"}
]
```

.alter table [_cloudevents_dispatch] policy retention
```
{ "SoftDeletePeriod": "1.00:00:00", "Recoverability": "Disabled" }
```

.alter table [_cloudevents_dispatch] policy ingestionbatching
```
{ "MaximumBatchingTimeSpan": "00:00:30", "MaximumNumberOfItems": 10000, "MaximumRawDataSizeMB": 200 }
```


// ===== ActualGenerationPerType (document type A75) =====

.create-merge table [ActualGenerationPerType] (
   [inDomain]: string,
   [psrType]: string,
   [quantity]: real,
   [resolution]: string,
   [businessType]: string,
   [documentType]: string,
   [unitName]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
)

.alter table [ActualGenerationPerType] column-docstrings (
   [inDomain]: 'EIC code of the bidding zone',
   [psrType]: 'Production type code (B01=Biomass, B02=Lignite, B04=Natural Gas, B05=Hard Coal, B06=Oil, B09=Geothermal, B10=Hydro Pumped Storage, B11=Hydro Run-of-river, B12=Hydro Water Reservoir, B14=Nuclear, B15=Other renewable, B16=Solar, B18=Wind Offshore, B19=Wind Onshore, B20=Other)',
   [quantity]: 'Generated power in MW',
   [resolution]: 'ISO 8601 duration (PT15M, PT60M)',
   [businessType]: 'Business type code (A01=Production, A04=Consumption)',
   [documentType]: 'ENTSO-E document type code (A75)',
   [unitName]: 'Unit of measurement (MAW)',
   [___type]: 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
)

.alter table [ActualGenerationPerType] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'eu.entsoe.transparency.ActualGenerationPerType') | project ['inDomain'] = tostring(data.['inDomain']), ['psrType'] = tostring(data.['psrType']), ['quantity'] = toreal(data.['quantity']), ['resolution'] = tostring(data.['resolution']), ['businessType'] = tostring(data.['businessType']), ['documentType'] = tostring(data.['documentType']), ['unitName'] = tostring(data.['unitName']), ___type = type, ___source = source, ___id = ['id'], ___time = ['time'], ___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true
}]
```

.alter table [ActualGenerationPerType] policy ingestionbatching
```
{ "MaximumBatchingTimeSpan": "00:00:30", "MaximumNumberOfItems": 10000, "MaximumRawDataSizeMB": 200 }
```

.alter table [ActualGenerationPerType] policy retention
```
{ "SoftDeletePeriod": "365.00:00:00", "Recoverability": "Enabled" }
```


// ===== DayAheadPrices (document type A44) =====

.create-merge table [DayAheadPrices] (
   [inDomain]: string,
   [price]: real,
   [currency]: string,
   [unitName]: string,
   [resolution]: string,
   [documentType]: string,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
)

.alter table [DayAheadPrices] column-docstrings (
   [inDomain]: 'EIC code of the bidding zone',
   [price]: 'Day-ahead electricity price',
   [currency]: 'Currency code (EUR)',
   [unitName]: 'Price unit (MWH)',
   [resolution]: 'ISO 8601 duration (PT60M)',
   [documentType]: 'ENTSO-E document type code (A44)',
   [___type]: 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
)

.alter table [DayAheadPrices] policy update
```
