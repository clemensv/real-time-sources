  {"column": "station_id", "path": "$.data.station_id"},
  {"column": "sensor_num", "path": "$.data.sensor_num"},
  {"column": "sensor_type", "path": "$.data.sensor_type"},
  {"column": "value", "path": "$.data.value"},
