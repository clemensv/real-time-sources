.drop materialized-view ReservoirReadingLatest ifexists;

.create materialized-view with (backfill=true) ReservoirReadingLatest on table ReservoirReading {
    ReservoirReading | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [ReservoirReading] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'gov.ca.water.cdec.ReservoirReading') | project['station_id'] = tostring(data.['station_id']),['sensor_num'] = toint(data.['sensor_num']),['sensor_type'] = tostring(data.['sensor_type']),['value'] = toreal(data.['value']),['units'] = tostring(data.['units']),['date'] = tostring(data.['date']),['dur_code'] = tostring(data.['dur_code']),['data_flag'] = tostring(data.['data_flag']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

