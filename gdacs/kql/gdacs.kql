.drop materialized-view DisasterAlertLatest ifexists;

.create materialized-view with (backfill=true) DisasterAlertLatest on table DisasterAlert {
    DisasterAlert | summarize arg_max(___time, *) by ___type, ___source, ___subject
}

.alter table [DisasterAlert] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'GDACS.DisasterAlert') | project['event_type'] = tostring(data.['event_type']),['event_id'] = tostring(data.['event_id']),['episode_id'] = tostring(data.['episode_id']),['alert_level'] = tostring(data.['alert_level']),['alert_score'] = toreal(data.['alert_score']),['episode_alert_level'] = tostring(data.['episode_alert_level']),['episode_alert_score'] = toreal(data.['episode_alert_score']),['event_name'] = tostring(data.['event_name']),['severity_value'] = toreal(data.['severity_value']),['severity_unit'] = tostring(data.['severity_unit']),['severity_text'] = tostring(data.['severity_text']),['country'] = tostring(data.['country']),['iso3'] = tostring(data.['iso3']),['latitude'] = toreal(data.['latitude']),['longitude'] = toreal(data.['longitude']),['from_date'] = todatetime(data.['from_date']),['to_date'] = todatetime(data.['to_date']),['population_value'] = toreal(data.['population_value']),['population_unit'] = tostring(data.['population_unit']),['vulnerability'] = toreal(data.['vulnerability']),['bbox_min_lon'] = toreal(data.['bbox_min_lon']),['bbox_max_lon'] = toreal(data.['bbox_max_lon']),['bbox_min_lat'] = toreal(data.['bbox_min_lat']),['bbox_max_lat'] = toreal(data.['bbox_max_lat']),['is_current'] = tobool(data.['is_current']),['version'] = toint(data.['version']),['description'] = tostring(data.['description']),['link'] = tostring(data.['link']),['pub_date'] = todatetime(data.['pub_date']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

