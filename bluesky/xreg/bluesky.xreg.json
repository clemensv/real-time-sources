                "definitions": {
                  "Bluesky": {
                    "Feed": {
                      "Post": {
                        "name": "Post",
                        "type": "object",
                        "properties": {
                          "uri": {
                            "type": "string",
                            "description": "AT-URI of the post (at://did:plc:xxx/app.bsky.feed.post/xxx)"
                          },
                          "cid": {
                            "type": "string",
                            "description": "Content Identifier (CID) of the post"
                          },
                          "did": {
                            "type": "string",
                            "description": "Decentralized Identifier of the author"
                          },
                          "handle": {
                            "type": "string",
                            "default": null,
                            "description": "Handle of the author"
                          },
                          "text": {
                            "type": "string",
                            "description": "Text content of the post"
                          },
                          "langs": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            },
                            "default": [],
                            "description": "Language codes for the post"
                          },
                          "reply_parent": {
                            "type": "string",
                            "default": null,
                            "description": "AT-URI of parent post if this is a reply"
                          },
                          "reply_root": {
                            "type": "string",
                            "default": null,
                            "description": "AT-URI of root post in thread"
                          },
                          "embed_type": {
                            "type": "string",
                            "default": null,
                            "description": "Type of embedded content (images, external, record, etc.)"
                          },
                          "embed_uri": {
                            "type": "string",
                            "default": null,
                            "description": "URI of embedded content"
                          },
                          "facets": {
                            "type": "string",
                            "default": null,
                            "description": "JSON string of rich text facets (mentions, links, tags)"
                          },
                          "tags": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            },
                            "default": [],
                            "description": "Hashtags in the post"
                          },
                          "created_at": {
                            "type": "string",
                            "description": "ISO 8601 timestamp of post creation"
                          },
                          "indexed_at": {
                            "type": "string",
                            "description": "ISO 8601 timestamp of when the post was indexed"
                          },
                          "seq": {
                            "type": "int64",
                            "description": "Firehose sequence number"
                          }
                        },
                        "required": [
                          "uri",
                          "cid",
                          "did",
                          "text",
                          "langs",
                          "tags",
                          "created_at",
                          "indexed_at",
                          "seq"
                        ],
                        "description": "A post in the Bluesky feed"
                      }
                    }
                  }
                }
              }
            }
          }
        },
