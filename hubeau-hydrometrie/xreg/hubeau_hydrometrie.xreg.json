    "schemagroups": {
        "FR.Gov.Eaufrance.HubEau.Hydrometrie": {
            "schemas": {
                "FR.Gov.Eaufrance.HubEau.Hydrometrie.Station": {
                    "format": "JsonSchema/draft-07",
                    "versions": {
                        "1.0": {
                            "format": "JsonSchema/draft-07",
                            "schema": {
                                "$schema": "http://json-schema.org/draft-07/schema#",
                                "type": "object",
                                "title": "Station",
                                "namespace": "FR.Gov.Eaufrance.HubEau.Hydrometrie",
