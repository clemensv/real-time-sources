{
  "endpoints": {
    "FR.Gov.Eaufrance.HubEau.Hydrometrie.Kafka": {
      "usage": [
        "producer"
      ],
      "protocol": "KAFKA",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "structured",
        "format": "application/cloudevents+json"
      },
      "protocoloptions": {
        "deployed": false,
        "options": {
          "topic": "hubeau-hydrometrie",
          "key": "{code_station}"
        }
      },
      "messagegroups": [
        "#/messagegroups/FR.Gov.Eaufrance.HubEau.Hydrometrie"
      ],
      "description": "Kafka producer endpoint for Hub'Eau Hydrométrie CloudEvents on the `hubeau-hydrometrie` topic keyed by `{code_station}`."
    },
    "FR.Gov.Eaufrance.HubEau.Hydrometrie.Mqtt": {
      "usage": [
        "producer"
      ],
      "protocol": "MQTT/5.0",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "binary"
      },
      "protocoloptions": {
        "deployed": false,
        "endpoints": [
          {
            "uri": "mqtt://localhost:1883"
          }
        ]
      },
      "messagegroups": [
        "#/messagegroups/FR.Gov.Eaufrance.HubEau.Hydrometrie.mqtt"
      ],
      "description": "MQTT 5 producer endpoint for hubeau-hydrometrie CloudEvents using the documented UNS topic hierarchy."
    },
    "FR.Gov.Eaufrance.HubEau.Hydrometrie.Amqp": {
      "usage": [
        "producer"
      ],
      "protocol": "AMQP/1.0",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "binary"
      },
      "protocoloptions": {
        "deployed": false,
        "endpoints": [
          {
            "uri": "amqps://localhost:5671/hubeau-hydrometrie"
          }
        ]
      },
      "messagegroups": [
        "#/messagegroups/FR.Gov.Eaufrance.HubEau.Hydrometrie.amqp"
      ],
      "description": "AMQP 1.0 producer endpoint for hubeau-hydrometrie CloudEvents on the configured broker address."
    }
  },
  "messagegroups": {
    "FR.Gov.Eaufrance.HubEau.Hydrometrie": {
      "messages": {
        "FR.Gov.Eaufrance.HubEau.Hydrometrie.Station": {
          "name": "Station",
          "envelope": "CloudEvents/1.0",
          "envelopemetadata": {
            "type": {
              "value": "FR.Gov.Eaufrance.HubEau.Hydrometrie.Station"
            },
            "source": {
              "value": "https://hubeau.eaufrance.fr/api/v2/hydrometrie"
            },
            "subject": {
              "value": "{code_station}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/FR.Gov.Eaufrance.HubEau.Hydrometrie.jstruct/schemas/FR.Gov.Eaufrance.HubEau.Hydrometrie.Station",
          "description": "A reference record for one French hydrometric monitoring station published by the French Eaufrance Hub'Eau hydrometry API. It fires when the bridge publishes or refreshes the station catalog so consumers can interpret measurement events."
        },
        "FR.Gov.Eaufrance.HubEau.Hydrometrie.Observation": {
          "name": "Observation",
          "envelope": "CloudEvents/1.0",
          "envelopemetadata": {
            "type": {
              "value": "FR.Gov.Eaufrance.HubEau.Hydrometrie.Observation"
            },
            "source": {
              "value": "https://hubeau.eaufrance.fr/api/v2/hydrometrie"
            },
            "subject": {
              "value": "{code_station}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/FR.Gov.Eaufrance.HubEau.Hydrometrie.jstruct/schemas/FR.Gov.Eaufrance.HubEau.Hydrometrie.Observation",
          "description": "A current measurement from the French Eaufrance Hub'Eau hydrometry API for one monitoring site. It carries water height and discharge observations when the upstream feed reports a new or refreshed value."
        }
      },
      "description": "Events from Hub'Eau Hydrométrie covering French hydrometric monitoring stations and their current measurements. Use the reference records to identify stations and the measurement records for the latest observations."
    },
    "FR.Gov.Eaufrance.HubEau.Hydrometrie.mqtt": {
      "description": "MQTT 5 variant of hubeau-hydrometrie events with UNS topics for wildcard subscribers.",
      "messages": {
        "FR.Gov.Eaufrance.HubEau.Hydrometrie.mqtt.Station": {
          "name": "Station",
          "basemessageurl": "/messagegroups/FR.Gov.Eaufrance.HubEau.Hydrometrie/messages/FR.Gov.Eaufrance.HubEau.Hydrometrie.Station",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "topic_name": "hydro/fr/hubeau/hubeau-hydrometrie/{basin}/{code_station}/info",
            "qos": 1,
            "retain": true
          }
        },
        "FR.Gov.Eaufrance.HubEau.Hydrometrie.mqtt.Observation": {
          "name": "Observation",
          "basemessageurl": "/messagegroups/FR.Gov.Eaufrance.HubEau.Hydrometrie/messages/FR.Gov.Eaufrance.HubEau.Hydrometrie.Observation",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "topic_name": "hydro/fr/hubeau/hubeau-hydrometrie/{basin}/{code_station}/observation",
            "qos": 1,
            "retain": true
          }
        }
      }
    },
    "FR.Gov.Eaufrance.HubEau.Hydrometrie.amqp": {
      "description": "AMQP 1.0 variant of hubeau-hydrometrie events for queue-oriented consumers and Azure Service Bus.",
      "messages": {
        "FR.Gov.Eaufrance.HubEau.Hydrometrie.amqp.Station": {
          "name": "Station",
          "basemessageurl": "/messagegroups/FR.Gov.Eaufrance.HubEau.Hydrometrie/messages/FR.Gov.Eaufrance.HubEau.Hydrometrie.Station",
          "protocol": "AMQP/1.0",
          "protocoloptions": {
            "properties": {
              "subject": {
                "type": "uritemplate",
                "value": "{code_station}",
                "description": "AMQP message subject matching the CloudEvent subject and Kafka key identity."
              }
            },
            "application_properties": {
              "basin": {
                "type": "uritemplate",
                "value": "{basin}",
                "description": "Routing property for AMQP subscription filters (basin)."
              }
            },
            "message_annotations": {
              "x-opt-partition-key": {
                "type": "uritemplate",
                "value": "{code_station}",
                "description": "Service Bus/Event Hubs partition key matching the stable CloudEvent subject."
              }
            }
          }
        },
        "FR.Gov.Eaufrance.HubEau.Hydrometrie.amqp.Observation": {
          "name": "Observation",
          "basemessageurl": "/messagegroups/FR.Gov.Eaufrance.HubEau.Hydrometrie/messages/FR.Gov.Eaufrance.HubEau.Hydrometrie.Observation",
          "protocol": "AMQP/1.0",
          "protocoloptions": {
            "properties": {
              "subject": {
                "type": "uritemplate",
                "value": "{code_station}",
                "description": "AMQP message subject matching the CloudEvent subject and Kafka key identity."
              }
            },
            "application_properties": {
              "basin": {
                "type": "uritemplate",
                "value": "{basin}",
                "description": "Routing property for AMQP subscription filters (basin)."
              }
            },
            "message_annotations": {
              "x-opt-partition-key": {
                "type": "uritemplate",
                "value": "{code_station}",
                "description": "Service Bus/Event Hubs partition key matching the stable CloudEvent subject."
              }
            }
          }
        }
      }
    }
  },
  "schemagroups": {
    "FR.Gov.Eaufrance.HubEau.Hydrometrie.jstruct": {
      "schemas": {
        "FR.Gov.Eaufrance.HubEau.Hydrometrie.Station": {
          "name": "Station",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/extended/v0/#",
                "type": "object",
                "required": [
                  "code_station",
                  "libelle_station",
                  "longitude_station",
                  "latitude_station"
                ],
                "name": "Station",
                "properties": {
                  "code_station": {
                    "type": "string",
                    "description": "Permanent hydrometry-station code assigned by the French monitoring network. Use it as the stable identity for station records and related observations."
                  },
                  "libelle_station": {
                    "type": "string",
                    "description": "Display label for the hydrometry station as published by Hub'Eau. It is useful for maps and UI labels but should not be used as a stable key."
                  },
                  "code_site": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Optional Hub'Eau site code grouping one or more stations at the same monitoring location."
                  },
                  "longitude_station": {
                    "type": "double",
                    "description": "Longitude of the station in WGS 84 coordinates."
                  },
                  "latitude_station": {
                    "type": "double",
                    "description": "Latitude of the station in WGS 84 coordinates."
                  },
                  "libelle_cours_eau": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Name of the river or watercourse monitored by the station."
                  },
                  "libelle_commune": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Municipality where the station is located."
                  },
                  "code_departement": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "French department code for the station location."
                  },
                  "en_service": {
                    "type": [
                      "boolean",
                      "null"
                    ],
                    "description": "Whether Hub'Eau marks the station as currently in service."
                  },
                  "date_ouverture_station": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Date when the station began operating, when the upstream catalog provides it."
                  },
                  "basin": {
                    "type": "string",
                    "description": "Stable routing axis used by MQTT and AMQP transport templates for hubeau-hydrometrie."
                  }
                },
                "$id": "https://example.com/schemas/FR/Gov/Eaufrance/HubEau/Hydrometrie/Station",
                "description": "Reference details for one monitoring station or site in the Hub'Eau Hydrométrie source."
              }
            }
          }
        },
        "FR.Gov.Eaufrance.HubEau.Hydrometrie.Observation": {
          "name": "Observation",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/extended/v0/#",
                "type": "object",
                "required": [
                  "code_station",
                  "date_obs",
                  "resultat_obs",
                  "grandeur_hydro"
                ],
                "name": "Observation",
                "properties": {
                  "code_station": {
                    "type": "string",
                    "description": "Permanent hydrometry-station code assigned by the French monitoring network. Use it as the stable identity for station records and related observations."
                  },
                  "date_obs": {
                    "type": "datetime",
                    "description": "Observation timestamp published by Hub'Eau for this measurement."
                  },
                  "resultat_obs": {
                    "type": "double",
                    "description": "Measured hydrometric value. Interpret the quantity and unit from `grandeur_hydro`, such as discharge or water height."
                  },
                  "grandeur_hydro": {
                    "type": "string",
                    "description": "Hydrometric quantity code identifying what `resultat_obs` measures, such as discharge or water height."
                  },
                  "libelle_methode_obs": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Provider label for the observation method used to produce the measurement."
                  },
                  "libelle_qualification_obs": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Provider quality label describing how Hub'Eau qualifies the observation."
                  },
                  "basin": {
                    "type": "string",
                    "description": "Stable routing axis used by MQTT and AMQP transport templates for hubeau-hydrometrie."
                  }
                },
                "$id": "https://example.com/schemas/FR/Gov/Eaufrance/HubEau/Hydrometrie/Observation",
                "description": "Measurement payload for water height and discharge observations in the Hub'Eau Hydrométrie source."
              }
            }
          }
        }
      }
    },
