                            "schema": {
                                "$schema": "http://json-schema.org/draft-07/schema#",
                                "type": "object",
                                "title": "Observation",
                                "namespace": "FR.Gov.Eaufrance.HubEau.Hydrometrie",
                                "properties": {
                                    "code_station": { "type": "string", "description": "Station code for this observation" },
                                    "date_obs": { "type": "string", "format": "date-time", "description": "Observation timestamp in ISO 8601" },
                                    "resultat_obs": { "type": "number", "description": "Observation value (mm for H, L/s for Q)" },
                                    "grandeur_hydro": { "type": "string", "description": "Hydrometric quantity: H (height) or Q (discharge)" },
                                    "libelle_methode_obs": { "type": "string", "description": "Observation method label" },
                                    "libelle_qualification_obs": { "type": "string", "description": "Quality qualification label" }
                                },
                                "required": ["code_station", "date_obs", "resultat_obs", "grandeur_hydro"]
