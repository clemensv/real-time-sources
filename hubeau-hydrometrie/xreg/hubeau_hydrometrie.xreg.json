                                    "libelle_cours_eau": { "type": "string", "description": "River/waterway name" },
                                    "libelle_commune": { "type": "string", "description": "Municipality name" },
                                    "code_departement": { "type": "string", "description": "Department code" },
                                    "en_service": { "type": "boolean", "description": "Whether the station is currently active" },
                                    "date_ouverture_station": { "type": "string", "description": "Station opening date in ISO 8601" }
                                },
                                "required": ["code_station", "libelle_station", "longitude_station", "latitude_station"]
                            }
                        }
                    }
                },
                "FR.Gov.Eaufrance.HubEau.Hydrometrie.Observation": {
                    "format": "JsonSchema/draft-07",
                    "versions": {
