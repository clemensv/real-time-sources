        "endpoints": [
          {
            "uri": "amqps://localhost:5671/uk-ea-flood-monitoring"
          }
        ]
      },
      "messagegroups": [
        "#/messagegroups/UK.Gov.Environment.EA.FloodMonitoring.amqp"
      ],
      "description": "AMQP 1.0 producer endpoint for uk-ea-flood-monitoring CloudEvents on the configured broker address."
    }
  },
