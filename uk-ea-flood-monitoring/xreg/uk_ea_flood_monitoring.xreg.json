      },
      "protocoloptions": {
        "deployed": false,
        "endpoints": [
          {
            "uri": "mqtt://localhost:1883"
          }
        ]
      },
      "messagegroups": [
        "#/messagegroups/UK.Gov.Environment.EA.FloodMonitoring.mqtt"
      ],
      "description": "MQTT 5 producer endpoint for uk-ea-flood-monitoring CloudEvents using the documented UNS topic hierarchy."
