# syntax=docker/dockerfile:1.6
FROM python:3.10-slim

LABEL org.opencontainers.image.source="https://github.com/clemensv/real-time-sources/tree/main/cbp-border-wait"
LABEL org.opencontainers.image.title="Cbp Border Wait â†’ AMQP 1.0 bridge"
LABEL org.opencontainers.image.description="Publishes Cbp Border Wait CloudEvents over AMQP 1.0 to generic AMQP brokers and Azure Service Bus/Event Hubs via CBS."
LABEL org.opencontainers.image.documentation="https://github.com/clemensv/real-time-sources/blob/main/cbp-border-wait/CONTAINER.md"
LABEL org.opencontainers.image.license="MIT"

ENV PYTHONUNBUFFERED=1
WORKDIR /app
RUN apt-get update \
 && apt-get install -y --no-install-recommends build-essential cmake pkg-config swig libssl-dev libsasl2-dev python3-dev libsasl2-2 libsasl2-modules \
 && rm -rf /var/lib/apt/lists/*
COPY . /app
RUN pip install --no-cache-dir ./cbp_border_wait_amqp_producer/cbp_border_wait_amqp_producer_data \
 && pip install --no-cache-dir ./cbp_border_wait_amqp_producer/cbp_border_wait_amqp_producer_amqp_producer \
 && pip install --no-cache-dir ./cbp_border_wait_mqtt_producer/cbp_border_wait_mqtt_producer_data \
 && pip install --no-cache-dir ./cbp_border_wait_producer/cbp_border_wait_producer_data \
 && pip install --no-cache-dir . \
 && pip install --no-cache-dir ./cbp_border_wait_mqtt \
 && pip install --no-cache-dir ./cbp_border_wait_amqp \
 && apt-get purge -y --auto-remove build-essential cmake pkg-config swig libssl-dev libsasl2-dev python3-dev \
 && rm -rf /root/.cache /var/lib/apt/lists/*
ENV AMQP_BROKER_URL=""
ENV AMQP_ADDRESS="cbp-border-wait"
CMD ["python", "-m", "cbp_border_wait_amqp", "feed"]
