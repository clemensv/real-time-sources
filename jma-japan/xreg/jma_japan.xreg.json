{
  "endpoints": {
    "jp.go.jma.WeatherBulletins.Kafka": {
      "usage": [
        "producer"
      ],
      "protocol": "KAFKA",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "structured",
        "format": "application/cloudevents+json"
      },
      "protocoloptions": {
        "deployed": false,
        "options": {
          "topic": "jma-japan",
          "key": "{bulletin_id}"
        }
      },
      "messagegroups": [
        "#/messagegroups/jp.go.jma.WeatherBulletins"
      ],
      "description": "Kafka producer endpoint for JMA Japan Bulletins CloudEvents on the `jma-japan` topic keyed by `{bulletin_id}`."
    },
    "jp.go.jma.WeatherBulletins.Mqtt": {
      "usage": [
        "producer"
      ],
      "protocol": "MQTT/5.0",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "binary"
      },
      "protocoloptions": {
        "deployed": false,
        "endpoints": [
          {
            "uri": "mqtt://localhost:1883"
          }
        ]
      },
      "messagegroups": [
        "#/messagegroups/jp.go.jma.WeatherBulletins.mqtt"
      ],
      "description": "MQTT 5 producer endpoint for jma-japan."
    },
    "jp.go.jma.WeatherBulletins.Amqp": {
      "usage": [
        "producer"
      ],
      "protocol": "AMQP/1.0",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "binary"
      },
      "protocoloptions": {
        "deployed": false,
        "endpoints": [
          {
            "uri": "amqps://localhost:5671/jma-japan"
          }
        ]
      },
      "messagegroups": [
        "#/messagegroups/jp.go.jma.WeatherBulletins.amqp"
      ],
      "description": "AMQP 1.0 producer endpoint for jma-japan."
    }
  },
  "messagegroups": {
    "jp.go.jma.WeatherBulletins": {
      "messages": {
        "jp.go.jma.WeatherBulletin": {
          "name": "WeatherBulletin",
          "envelope": "CloudEvents/1.0",
          "envelopemetadata": {
            "type": {
              "value": "jp.go.jma.WeatherBulletin"
            },
            "source": {
              "value": "https://www.data.jma.go.jp"
            },
            "subject": {
              "value": "{bulletin_id}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/jp.go.jma.jstruct/schemas/jp.go.jma.WeatherBulletin",
          "description": "An official alert or bulletin from the Japan Meteorological Agency. It carries official bulletin messages for the affected area and validity period published by the upstream source."
        }
      },
      "description": "Events from JMA Japan Bulletins covering Japanese bulletin feeds. Alert and incident records describe the current upstream hazard state and update when the provider changes that state."
    },
    "jp.go.jma.WeatherBulletins.mqtt": {
      "description": "MQTT 5 companion message group for jp.go.jma.WeatherBulletins.",
      "messages": {
        "jp.go.jma.WeatherBulletins.mqtt.WeatherBulletin": {
          "name": "WeatherBulletin",
          "basemessageurl": "/messagegroups/jp.go.jma.WeatherBulletins/messages/jp.go.jma.WeatherBulletin",
          "envelopemetadata": {
            "type": {
              "value": "jp.go.jma.WeatherBulletin"
            },
            "source": {
              "value": "https://www.data.jma.go.jp"
            },
            "subject": {
              "value": "{office}/{bulletin_id}",
              "type": "uritemplate"
            }
          },
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "topic_name": "weather/jp/jma/jma-japan/{office}/{bulletin_id}/bulletin",
            "qos": 1,
            "retain": false
          }
        }
      }
    },
    "jp.go.jma.WeatherBulletins.amqp": {
      "description": "AMQP 1.0 companion message group for jp.go.jma.WeatherBulletins.",
      "messages": {
        "jp.go.jma.WeatherBulletins.amqp.WeatherBulletin": {
          "name": "WeatherBulletin",
          "basemessageurl": "/messagegroups/jp.go.jma.WeatherBulletins/messages/jp.go.jma.WeatherBulletin",
          "envelopemetadata": {
            "type": {
              "value": "jp.go.jma.WeatherBulletin"
            },
            "source": {
              "value": "https://www.data.jma.go.jp"
            },
            "subject": {
              "value": "{office}/{bulletin_id}",
              "type": "uritemplate"
            }
          },
          "protocol": "AMQP/1.0",
          "protocoloptions": {
            "properties": {
              "subject": {
                "type": "uritemplate",
                "value": "{office}/{bulletin_id}",
                "description": "AMQP subject matching the CloudEvents subject for this transport variant."
              }
            },
            "application-properties": {}
          }
        }
      }
    }
  },
  "schemagroups": {
    "jp.go.jma.jstruct": {
      "schemas": {
        "jp.go.jma.WeatherBulletin": {
          "name": "WeatherBulletin",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/extended/v0/#",
                "type": "object",
                "required": [
                  "bulletin_id",
                  "title",
                  "updated"
                ],
                "name": "WeatherBulletin",
                "properties": {
                  "bulletin_id": {
                    "type": "string",
                    "description": "Unique identifier for the bulletin, derived from the Atom entry ID (typically a URL to the full XML document)."
                  },
                  "title": {
                    "type": "string",
                    "description": "Title of the weather bulletin in Japanese, e.g. '気象特別警報・警報・注意報' (Special weather warnings/advisories)."
                  },
                  "author": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Issuing authority name in Japanese, e.g. '気象庁' (JMA) or a regional observatory name like '松江地方気象台'."
                  },
                  "updated": {
                    "type": "datetime",
                    "description": "UTC timestamp when the bulletin was last updated."
                  },
                  "link": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "URL to the full XML document for this bulletin on the JMA data server."
                  },
                  "content": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Brief text summary of the bulletin content in Japanese."
                  },
                  "feed_type": {
                    "type": "string",
                    "description": "Which JMA Atom feed this bulletin originated from.",
                    "enum": [
                      "regular",
                      "extra"
                    ],
                    "descriptions": {
                      "regular": "Provider value `regular` for this coded alert field.",
                      "extra": "Provider value `extra` for this coded alert field."
                    }
                  },
                  "office": {
                    "type": "string",
                    "description": "Normalized routing field 'office' added for MQTT/AMQP subscriber filtering."
                  }
                },
                "$id": "https://www.data.jma.go.jp/schemas/jp/go/jma/WeatherBulletin",
                "description": "An official alert or bulletin from the Japan Meteorological Agency. It carries official bulletin messages for the affected area and validity period published by the upstream source."
              }
            }
          }
        }
      }
    }
  },
  "description": "JMA Japan Bulletins publishes official bulletin messages from the Japan Meteorological Agency for Japanese bulletin feeds. These events help consumers monitor hazards, route notifications, and correlate public-warning updates without polling the upstream source directly.",
  "documentation": {
    "description": "Source documentation for JMA Japan Bulletins, including upstream feed context and bridge deployment notes.",
    "url": "README.md"
  }
}
