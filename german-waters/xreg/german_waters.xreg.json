{
  "endpoints": {
    "DE.Waters.Hydrology.Kafka": {
      "usage": [
        "producer"
      ],
      "protocol": "KAFKA",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "structured",
        "format": "application/cloudevents+json"
      },
      "protocoloptions": {
        "deployed": false,
        "options": {
          "topic": "german-waters",
          "key": "{station_id}"
        }
      },
      "messagegroups": [
        "#/messagegroups/DE.Waters.Hydrology"
      ]
    },
    "DE.Waters.Hydrology.Mqtt": {
      "usage": [
        "producer"
      ],
      "protocol": "MQTT/5.0",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "binary"
      },
      "protocoloptions": {
        "deployed": false,
        "endpoints": [
          {
            "uri": "mqtt://localhost:1883"
          }
        ]
      },
      "messagegroups": [
        "#/messagegroups/DE.Waters.Hydrology.mqtt"
      ]
    }
  },
  "messagegroups": {
    "DE.Waters.Hydrology": {
      "messages": {
        "DE.Waters.Hydrology.Station": {
          "name": "Station",
          "envelope": "CloudEvents/1.0",
          "envelopemetadata": {
            "type": {
              "value": "DE.Waters.Hydrology.Station"
            },
            "source": {
              "value": "https://github.com/clemensv/real-time-sources/german-waters"
            },
            "subject": {
              "value": "{station_id}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/DE.Waters.Hydrology.jstruct/schemas/DE.Waters.Hydrology.Station"
        },
        "DE.Waters.Hydrology.WaterLevelObservation": {
          "name": "WaterLevelObservation",
          "envelope": "CloudEvents/1.0",
          "envelopemetadata": {
            "type": {
              "value": "DE.Waters.Hydrology.WaterLevelObservation"
            },
            "source": {
              "value": "https://github.com/clemensv/real-time-sources/german-waters"
            },
            "subject": {
              "value": "{station_id}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/DE.Waters.Hydrology.jstruct/schemas/DE.Waters.Hydrology.WaterLevelObservation"
        }
      }
    },
    "DE.Waters.Hydrology.mqtt": {
      "description": "MQTT/5.0 transport variants of the German Waters Hydrology CloudEvents, mapping each message to a retained, QoS-1 Unified Namespace topic under hydro/de/wsv/german-waters/{water_body}/{station_id}/... The {water_body} placeholder is sourced from the per-provider station catalog (Station.water_body field, e.g. 'Rhein', 'Donau', 'Elbe') and normalized by the bridge to lowercase kebab-case before publishing so subscribers can wildcard whole rivers (e.g. hydro/de/wsv/german-waters/rhein/+/water-level).",
      "messages": {
        "DE.Waters.Hydrology.mqtt.Station": {
          "name": "Station",
          "basemessageurl": "/messagegroups/DE.Waters.Hydrology/messages/DE.Waters.Hydrology.Station",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "topic_name": "hydro/de/wsv/german-waters/{water_body}/{station_id}/info",
            "qos": 1,
            "retain": true
          }
        },
        "DE.Waters.Hydrology.mqtt.WaterLevelObservation": {
          "name": "WaterLevelObservation",
          "basemessageurl": "/messagegroups/DE.Waters.Hydrology/messages/DE.Waters.Hydrology.WaterLevelObservation",
          "protocol": "MQTT/5.0",
          "protocoloptions": {
            "topic_name": "hydro/de/wsv/german-waters/{water_body}/{station_id}/water-level",
            "qos": 1,
            "retain": true
          }
        }
      }
    }
  },
  "schemagroups": {
    "DE.Waters.Hydrology.jstruct": {
      "schemas": {
        "DE.Waters.Hydrology.Station": {
          "name": "Station",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/extended/v0/#",
                "type": "object",
                "required": [
                  "station_id",
                  "station_name",
                  "water_body",
                  "provider"
                ],
                "name": "Station",
                "properties": {
                  "station_id": {
                    "type": "string"
                  },
                  "station_name": {
                    "type": "string"
                  },
                  "water_body": {
                    "type": "string",
                    "altnames": {
                      "lang:de": "Gewaesser"
                    }
                  },
                  "state": {
                    "type": "string"
                  },
                  "region": {
                    "type": "string"
                  },
                  "provider": {
                    "type": "string"
                  },
                  "latitude": {
                    "type": "double"
                  },
                  "longitude": {
                    "type": "double"
                  },
                  "river_km": {
                    "type": "double"
                  },
                  "altitude": {
                    "type": "double",
                    "altnames": {
                      "lang:de": "Hoehe"
                    }
                  },
                  "station_type": {
                    "type": "string"
                  },
                  "warn_level_cm": {
                    "type": "double"
                  },
                  "alarm_level_cm": {
                    "type": "double"
                  },
                  "warn_level_m3s": {
                    "type": "double"
                  },
                  "alarm_level_m3s": {
                    "type": "double"
                  }
                },
                "$id": "https://example.com/schemas/DE/Waters/Hydrology/Station",
                "description": "Station"
              }
            }
          }
        },
        "DE.Waters.Hydrology.WaterLevelObservation": {
          "name": "WaterLevelObservation",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/extended/v0/#",
                "type": "object",
                "required": [
                  "station_id",
                  "provider",
                  "water_body"
                ],
                "name": "WaterLevelObservation",
                "properties": {
                  "station_id": {
                    "type": "string"
                  },
                  "provider": {
                    "type": "string"
                  },
                  "water_body": {
                    "type": "string",
                    "description": "Name of the water body the station observes (e.g. 'Rhein', 'Donau', 'Elbe'). Sourced by the bridge from the per-provider station catalog (Station.water_body field) and propagated onto every observation so subscribers do not need an out-of-band catalog join to route by river. Used as the {water_body} segment of the MQTT/UNS topic and normalized to lowercase kebab-case before publishing."
                  },
                  "water_level": {
                    "type": "double"
                  },
                  "water_level_unit": {
                    "type": "string"
                  },
                  "water_level_timestamp": {
                    "type": "datetime"
                  },
                  "discharge": {
                    "type": "double"
                  },
                  "discharge_unit": {
                    "type": "string"
                  },
                  "discharge_timestamp": {
                    "type": "datetime"
                  },
                  "trend": {
                    "type": "int32"
                  },
                  "situation": {
                    "type": "int32"
                  }
                },
                "$id": "https://example.com/schemas/DE/Waters/Hydrology/WaterLevelObservation",
                "description": "WaterLevelObservation"
              }
            }
          }
        }
      }
    },
