                    "versions": {
                        "1": {
                            "format": "JsonSchema/draft-07",
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "mmsi": { "type": "integer", "description": "Maritime Mobile Service Identity (9 digits)" },
                                    "navigation_status": { "type": "integer", "description": "Navigation status (0=under way using engine, 1=at anchor, 5=moored, etc.)" },
                                    "rate_of_turn": { "type": "number", "description": "Rate of turn in degrees/min. -128 = not available" },
                                    "speed_over_ground": { "type": "number", "description": "Speed over ground in knots (0.1 resolution). 102.3 = not available" },
                                    "position_accuracy": { "type": "integer", "description": "Position accuracy (1=high, 0=low)" },
                                    "longitude": { "type": "number", "description": "Longitude in decimal degrees. 181 = not available" },
                                    "latitude": { "type": "number", "description": "Latitude in decimal degrees. 91 = not available" },
                                    "course_over_ground": { "type": "number", "description": "Course over ground in degrees (0.1 resolution). 360 = not available" },
                                    "true_heading": { "type": "integer", "description": "True heading in degrees. 511 = not available" },
                                    "timestamp": { "type": "string", "description": "ISO 8601 timestamp derived from NMEA tag block" },
                                    "station_id": { "type": "string", "description": "Receiving AIS station ID from NMEA tag block" },
                                    "msg_type": { "type": "integer", "description": "AIS message type (1, 2, or 3)" }
                                },
                                "required": ["mmsi", "longitude", "latitude", "timestamp"]
                            }
                        }
                    }
