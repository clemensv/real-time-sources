                  "mmsi",
                  "flag",
                  "ship_type",
                  "geohash5",
                  "msg_type",
                  "aid_type",
                  "latitude",
                  "longitude",
                  "ais_msg_type"
                ],
                "properties": {
                  "mmsi": {
                    "type": "string",
                    "pattern": "^[0-9]{9}$",
                    "description": "Source MMSI as a 9-digit ASCII string (padded with leading zeros). Used as the UNS topic '{mmsi}' placeholder and as the CloudEvents subject."
                  },
                  "flag": {
                    "type": "string",
                    "pattern": "^[a-z]{2}$|^xx$",
                    "description": "ISO-3166-1 alpha-2 country code (lower-case) derived from the first three digits of the MMSI via the ITU MID (Maritime Identification Digit) registry. 'xx' is used for MIDs that do not map to a country."
                  },
                  "ship_type": {
                    "type": "string",
                    "description": "Kebab-case ship-type bucket derived from the ITU-R M.1371 ShipType code. For static reports it is derived from the broadcast Type-5/24 ShipType field; for position reports it is looked up from an in-process ship-type cache keyed by MMSI. 'unknown' if no static report has been observed yet."
                  },
                  "geohash5": {
                    "type": "string",
                    "pattern": "^[0-9b-hjkmnp-z]{5}$",
                    "description": "5-character geohash of the reported (latitude, longitude). Approx. 4.9 km x 4.9 km cells at the equator. For messages without a position, filled from the most recently observed position for the MMSI, falling back to '00000'."
                  },
                  "msg_type": {
                    "type": "string",
                    "enum": [
                      "position-report",
                      "static",
                      "aid-to-navigation"
                    ],
                    "description": "Kebab-case event family used as the trailing UNS topic segment. Always equals the segment baked into the message's MQTT topic template."
                  },
                  "name": {
                    "type": "string",
                    "description": "Aid-to-Navigation name as broadcast."
                  },
                  "aid_type": {
                    "type": "int32",
                    "description": "AtoN type code (0..31) per ITU-R M.1371."
                  },
                  "latitude": {
                    "type": "double",
                    "description": "Reported latitude in WGS-84 decimal degrees."
                  },
                  "longitude": {
                    "type": "double",
                    "description": "Reported longitude in WGS-84 decimal degrees."
                  },
                  "position_accuracy": {
                    "type": "int32",
                    "description": "1 if high-accuracy (DGPS), else 0."
                  },
                  "timestamp": {
                    "type": "string",
                    "description": "ISO-8601 receive time as supplied by the upstream NMEA tag."
                  },
                  "station_id": {
                    "type": "string",
                    "description": "Kystverket base-station identifier."
                  },
                  "ais_msg_type": {
                    "type": "int32",
                    "description": "Original ITU-R M.1371 message ID (21)."
                  }
                },
                "$id": "https://schemas.real-time-sources.dev/kystverket-ais/mqtt/AidToNavigation"
              }
            }
          }
        }
      }
    }
  }
}
