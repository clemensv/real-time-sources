  {"column": "___id", "path": "$.id"},
  {"column": "___time", "path": "$.time"},
  {"column": "___subject", "path": "$.subject"},
  {"column": "station_number", "path": "$.data.station_number"},
  {"column": "formula", "path": "$.data.formula"},
