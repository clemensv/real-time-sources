                    "description": "Downlink Format value."
                  },
                  "tc": {
                    "type": "int32",
                    "description": "Type Code (ADS-B only)."
                  },
                  "bcode": {
                    "type": "string",
                    "description": "BDS code (Comm-B only)."
                  },
                  "alt": {
                    "type": "int32",
                    "description": "Barometric altitude (ft)."
                  },
                  "cs": {
                    "type": "string",
                    "description": "Aircraft callsign."
                  },
                  "sq": {
                    "type": "string",
                    "description": "Squawk code."
                  },
                  "lat": {
                    "type": "double",
                    "description": "Latitude (deg)."
                  },
                  "lon": {
                    "type": "double",
                    "description": "Longitude (deg)."
                  },
                  "spd": {
                    "type": "float",
                    "description": "Speed (kn)."
                  },
                  "ang": {
                    "type": "float",
                    "description": "Heading angle (deg)."
                  },
                  "vr": {
                    "type": "int32",
                    "description": "Vertical rate (ft/min)."
                  },
                  "rssi": {
                    "type": "float",
                    "description": "RSSI (dBFS)."
                  }
                },
                "required": [
                  "icao24",
                  "receiver_id",
                  "msg_type",
                  "ts",
                  "df"
                ],
                "namespace": "Mode_S"
              }
