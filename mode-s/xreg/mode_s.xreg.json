                  "icao24": {
                    "type": "string",
                    "description": "ICAO 24-bit address (lowercase hex)."
                  },
                  "receiver_id": {
                    "type": "string",
                    "description": "Stable identifier of the receiver/station that decoded this message."
                  },
                  "msg_type": {
                    "type": "string",
                    "description": "Kebab-case Mode-S downlink-format family literal (df17-adsb, df4-altitude, df5-identity, df11-acquisition, df20-comm-b, df21-comm-b)."
