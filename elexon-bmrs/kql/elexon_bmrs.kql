.alter table ['UK.Co.Elexon.BMRS.GenerationMix'] policy update
```
[{
  "IsEnabled": true,
  "Source": "_cloudevents_dispatch",
  "Query": "_cloudevents_dispatch | where (specversion == '1.0' and type == 'UK.Co.Elexon.BMRS.GenerationMix') | project['settlement_period'] = toint(data.['settlement_period']),['start_time'] = todatetime(data.['start_time']),['biomass_mw'] = toreal(data.['biomass_mw']),['ccgt_mw'] = toreal(data.['ccgt_mw']),['coal_mw'] = toreal(data.['coal_mw']),['nuclear_mw'] = toreal(data.['nuclear_mw']),['wind_mw'] = toreal(data.['wind_mw']),['ocgt_mw'] = toreal(data.['ocgt_mw']),['oil_mw'] = toreal(data.['oil_mw']),['npshyd_mw'] = toreal(data.['npshyd_mw']),['ps_mw'] = toreal(data.['ps_mw']),['intfr_mw'] = toreal(data.['intfr_mw']),['intned_mw'] = toreal(data.['intned_mw']),['intnem_mw'] = toreal(data.['intnem_mw']),['intelec_mw'] = toreal(data.['intelec_mw']),['intifa2_mw'] = toreal(data.['intifa2_mw']),['intnsl_mw'] = toreal(data.['intnsl_mw']),['intvkl_mw'] = toreal(data.['intvkl_mw']),['other_mw'] = toreal(data.['other_mw']),___type = type,___source = source,___id = ['id'],___time = ['time'],___subject = subject",
  "IsTransactional": false,
  "PropagateIngestionProperties": true,
}]
```

.create-merge table ['UK.Co.Elexon.BMRS.DemandOutturn'] (
   [settlement_period]: int,
   [settlement_date]: string,
   [start_time]: datetime,
   [publish_time]: datetime,
   [initial_demand_outturn_mw]: real,
   [initial_transmission_system_demand_outturn_mw]: real,
   [___type]: string,
   [___source]: string,
   [___id]: string,
   [___time]: datetime,
   [___subject]: string
);

.alter table ['UK.Co.Elexon.BMRS.DemandOutturn'] docstring "{\"description\": \"Half-hourly demand outturn for the GB electricity transmission system from the Elexon BMRS API. Each record represents one settlement period and contains the initial national demand outturn (INDO) and initial transmission system demand outturn (ITSDO) in megawatts (MW). Sourced from the BMRS /demand/outturn endpoint. Published under CC-BY 4.0 licence by Elexon.\"}";

.alter table ['UK.Co.Elexon.BMRS.DemandOutturn'] column-docstrings (
   [settlement_period]: "{\"description\": \"GB electricity settlement period number (1-50). Each settlement period is 30 minutes long, starting at midnight UTC.\"}",
   [settlement_date]: "{\"description\": \"Settlement date in ISO 8601 format (YYYY-MM-DD) as reported by the BMRS demand outturn endpoint.\"}",
   [start_time]: "{\"description\": \"UTC start time of the settlement period as reported by the BMRS demand outturn endpoint.\"}",
   [publish_time]: "{\"description\": \"UTC timestamp when the demand outturn data was published by Elexon.\"}",
   [initial_demand_outturn_mw]: "{\"description\": \"Initial national demand outturn (INDO) in megawatts (MW). This is the metered generation output less station transformer, unit transformer, and pumped storage demand, measured at the Grid Supply Point (GSP).\"}",
   [initial_transmission_system_demand_outturn_mw]: "{\"description\": \"Initial transmission system demand outturn (ITSDO) in megawatts (MW). This represents the national demand plus station demand, pumping, and interconnector exports.\"}",
   [___type] : 'Event type',
   [___source]: 'Context origin/source of the event',
   [___id]: 'Event identifier',
   [___time]: 'Event generation time',
   [___subject]: 'Context subject of the event'
);

