      "usage": [
        "producer"
      ],
      "protocol": "KAFKA",
      "envelope": "CloudEvents/1.0",
      "envelopeoptions": {
        "mode": "structured",
        "format": "application/cloudevents+json"
      },
      "protocoloptions": {
        "deployed": false,
        "options": {
          "topic": "fmi-finland-airquality",
          "key": "{fmisid}"
        }
      },
      "messagegroups": [
        "#/messagegroups/fi.fmi.opendata.airquality"
      ]
    }
  },
  "messagegroups": {
    "fi.fmi.opendata.airquality": {
      "messages": {
        "fi.fmi.opendata.airquality.Station": {
          "name": "Station",
          "envelope": "CloudEvents/1.0",
          "description": "Reference data for a Finnish Meteorological Institute air quality monitoring station.",
          "envelopemetadata": {
            "type": {
              "value": "fi.fmi.opendata.airquality.Station"
            },
            "source": {
              "value": "https://opendata.fmi.fi/wfs?service=WFS&version=2.0.0&request=getFeature&storedquery_id=fmi::ef::stations",
              "type": "uritemplate"
            },
            "subject": {
              "value": "{fmisid}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/fi.fmi.opendata.airquality.jstruct/schemas/fi.fmi.opendata.airquality.Station"
        },
        "fi.fmi.opendata.airquality.Observation": {
          "name": "Observation",
          "envelope": "CloudEvents/1.0",
          "description": "Hourly air quality observation aggregated per station and timestamp from FMI OGC WFS simple query results.",
          "envelopemetadata": {
            "type": {
              "value": "fi.fmi.opendata.airquality.Observation"
            },
            "source": {
              "value": "https://opendata.fmi.fi/wfs?service=WFS&version=2.0.0&request=getFeature&storedquery_id=urban::observations::airquality::hourly::simple",
              "type": "uritemplate"
            },
            "subject": {
              "value": "{fmisid}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/fi.fmi.opendata.airquality.jstruct/schemas/fi.fmi.opendata.airquality.Observation"
        }
      }
    }
  },
  "schemagroups": {
    "fi.fmi.opendata.airquality.jstruct": {
      "schemas": {
        "fi.fmi.opendata.airquality.Station": {
          "name": "Station",
          "format": "JsonStructure/draft-02",
          "defaultversionid": "1",
          "versions": {
            "1": {
              "format": "JsonStructure/draft-02",
              "schema": {
                "$schema": "https://json-structure.org/meta/extended/v0/#",
                "$id": "https://opendata.fmi.fi/schemas/fi/fmi/opendata/airquality/Station",
                "name": "Station",
                "$root": "#/definitions/fi/fmi/opendata/airquality/Station",
                "definitions": {
                  "fi": {
                    "fmi": {
                      "opendata": {
                        "airquality": {
                          "Station": {
                            "name": "Station",
                            "type": "object",
                            "description": "Reference data for an FMI air quality monitoring station. The station identifier is the FMI station identifier (fmisid). Municipality is taken from the WFS station metadata region name, and coordinates are the representative point published by FMI.",
                            "properties": {
                              "fmisid": {
                                "type": "string",
                                "description": "Stable FMI station identifier (fmisid) used as the Kafka key and CloudEvents subject.",
                                "pattern": "^[0-9]+$"
                              },
                              "station_name": {
                                "type": "string",
                                "description": "Air quality station name from the FMI station metadata, for example 'Helsinki Kallio 2'."
                              },
                              "latitude": {
                                "type": "double",
                                "description": "WGS84 latitude of the station representative point in decimal degrees.",
                                "unit": "degree",
                                "symbol": "°"
                              },
                              "longitude": {
                                "type": "double",
                                "description": "WGS84 longitude of the station representative point in decimal degrees.",
                                "unit": "degree",
                                "symbol": "°"
                              },
                              "municipality": {
                                "type": [
                                  "string",
                                  "null"
                                ],
                                "description": "Municipality or region name from the station metadata if FMI publishes it. Null when it is not available in the station record."
                              }
                            },
                            "required": [
                              "fmisid",
                              "station_name",
                              "latitude",
                              "longitude",
                              "municipality"
                            ]
                          },
                          "Observation": {
                            "name": "Observation",
                            "type": "object",
                            "description": "Hourly FMI air quality observation aggregated per station and observation timestamp from the urban::observations::airquality::hourly::simple stored query. Each event combines all supported pollutant and index parameters published for the station and hour.",
                            "properties": {
                              "fmisid": {
                                "type": "string",
                                "description": "Stable FMI station identifier (fmisid) for the observing station.",
                                "pattern": "^[0-9]+$"
                              },
                              "station_name": {
                                "type": "string",
                                "description": "Station name resolved from station metadata or, if metadata lookup fails, the station identifier string."
                              },
                              "observation_time": {
                                "type": "string",
                                "description": "Observation timestamp in UTC, formatted as an ISO-8601 instant such as 2024-01-15T13:00:00Z.",
                                "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
                              },
                              "aqindex": {
                                "type": [
                                  "double",
                                  "null"
                                ],
                                "description": "Finnish Air Quality Index 1-hour average from the AQINDEX_PT1H_avg parameter. Null when FMI reports the parameter as missing or not available.",
                                "altnames": {
                                  "json": "AQINDEX_PT1H_avg"
                                }
                              },
                              "pm10_ug_m3": {
                                "type": [
                                  "double",
                                  "null"
                                ],
                                "description": "PM10 particulate matter concentration 1-hour average in micrograms per cubic meter from the PM10_PT1H_avg parameter. Null when the value is missing.",
                                "unit": "µg/m³",
                                "altnames": {
                                  "json": "PM10_PT1H_avg"
                                }
                              },
                              "pm2_5_ug_m3": {
                                "type": [
                                  "double",
                                  "null"
                                ],
                                "description": "PM2.5 particulate matter concentration 1-hour average in micrograms per cubic meter from the PM25_PT1H_avg parameter. Null when the value is missing.",
                                "unit": "µg/m³",
                                "altnames": {
                                  "json": "PM25_PT1H_avg"
                                }
                              },
                              "no2_ug_m3": {
                                "type": [
                                  "double",
                                  "null"
                                ],
                                "description": "Nitrogen dioxide concentration 1-hour average in micrograms per cubic meter from the NO2_PT1H_avg parameter. Null when the value is missing.",
                                "unit": "µg/m³",
                                "altnames": {
                                  "json": "NO2_PT1H_avg"
                                }
                              },
                              "o3_ug_m3": {
                                "type": [
                                  "double",
                                  "null"
                                ],
                                "description": "Ozone concentration 1-hour average in micrograms per cubic meter from the O3_PT1H_avg parameter. Null when the value is missing.",
                                "unit": "µg/m³",
                                "altnames": {
                                  "json": "O3_PT1H_avg"
                                }
                              },
                              "so2_ug_m3": {
                                "type": [
                                  "double",
                                  "null"
                                ],
                                "description": "Sulfur dioxide concentration 1-hour average in micrograms per cubic meter from the SO2_PT1H_avg parameter. Null when the value is missing.",
                                "unit": "µg/m³",
                                "altnames": {
                                  "json": "SO2_PT1H_avg"
                                }
                              },
                              "co_mg_m3": {
                                "type": [
                                  "double",
                                  "null"
                                ],
                                "description": "Carbon monoxide concentration 1-hour average in milligrams per cubic meter from the CO_PT1H_avg parameter. Null when the value is missing.",
                                "unit": "mg/m³",
                                "altnames": {
                                  "json": "CO_PT1H_avg"
                                }
                              }
                            },
                            "required": [
                              "fmisid",
                              "station_name",
                              "observation_time",
                              "aqindex",
                              "pm10_ug_m3",
                              "pm2_5_ug_m3",
                              "no2_ug_m3",
                              "o3_ug_m3",
                              "so2_ug_m3",
                              "co_mg_m3"
                            ]
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
