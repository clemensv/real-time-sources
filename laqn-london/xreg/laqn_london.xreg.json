        "uk.kcl.laqn.Site": {
          "name": "Site",
          "envelope": "CloudEvents/1.0",
          "description": "LAQN monitoring site reference data, including stable site identity, operator information, and WGS84 coordinates.",
          "envelopemetadata": {
            "type": {
              "value": "uk.kcl.laqn.Site"
            },
            "source": {
              "value": "http://api.erg.ic.ac.uk/AirQuality/Information/MonitoringSites/GroupName=All/Json"
            },
            "subject": {
              "value": "{site_code}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/uk.kcl.laqn.jstruct/schemas/uk.kcl.laqn.Site"
        },
        "uk.kcl.laqn.Measurement": {
          "name": "Measurement",
          "envelope": "CloudEvents/1.0",
          "description": "LAQN hourly pollutant measurement for a site and species at a GMT timestamp.",
          "envelopemetadata": {
            "type": {
              "value": "uk.kcl.laqn.Measurement"
            },
            "source": {
              "value": "http://api.erg.ic.ac.uk/AirQuality/Data/Site"
            },
            "subject": {
              "value": "{site_code}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/uk.kcl.laqn.jstruct/schemas/uk.kcl.laqn.Measurement"
        },
        "uk.kcl.laqn.DailyIndex": {
          "name": "DailyIndex",
          "envelope": "CloudEvents/1.0",
          "description": "LAQN Daily Air Quality Index (DAQI) for a site and pollutant, published as the latest London-wide bulletin.",
          "envelopemetadata": {
            "type": {
              "value": "uk.kcl.laqn.DailyIndex"
            },
            "source": {
              "value": "http://api.erg.ic.ac.uk/AirQuality/Daily/MonitoringIndex/Latest/GroupName=London/Json"
            },
            "subject": {
              "value": "{site_code}",
              "type": "uritemplate"
            }
          },
          "dataschemaformat": "JsonStructure/draft-02",
          "dataschemauri": "#/schemagroups/uk.kcl.laqn.jstruct/schemas/uk.kcl.laqn.DailyIndex"
        }
