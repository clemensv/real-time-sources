  {"column": "local_authority_name", "path": "$.local_authority_name"},
  {"column": "latitude", "path": "$.latitude"},
  {"column": "longitude", "path": "$.longitude"},
  {"column": "date_opened", "path": "$.date_opened"},
  {"column": "date_closed", "path": "$.date_closed"},
  {"column": "data_owner", "path": "$.data_owner"},
  {"column": "data_manager", "path": "$.data_manager"},
]
```

